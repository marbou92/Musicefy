@echo off
REM build-portable.bat
REM Builds a self-contained, portable Windows build of Musicefy that runs
REM on a bare Windows 7 SP1 install with no extra dependencies.
REM
REM Steps:
REM   1. Configure + build the project in Release.
REM   2. Run windeployqt to copy the required Qt DLLs + plugins next
REM      to musicefy.exe.
REM   3. Run bundle-ucrt.bat to add the UCRT runtime (for Win 7).
REM   4. Copy the SQL migrations next to the exe.
REM
REM Usage: scripts\build-portable.bat [Qt-bin-dir]
REM   Qt-bin-dir defaults to C:\Qt\5.15.2\msvc2019_64\bin
REM
REM After this script completes, the portable tree is at
REM build\bin\Release\ and is ready to be zipped + shipped.

setlocal EnableDelayedExpansion

set "SRC_DIR=%~dp0.."
pushd "%SRC_DIR%"

REM ?????? Locate Qt ??????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????
set "QT_BIN=%~1"
if "%QT_BIN%"=="" set "QT_BIN=C:\Qt\5.15.2\msvc2019_64\bin"
if not exist "%QT_BIN%\windeployqt.exe" (
    echo ERROR: windeployqt.exe not found at:
    echo   %QT_BIN%\windeployqt.exe
    echo Pass the Qt bin dir as the first arg, e.g.:
    echo   scripts\build-portable.bat C:\Qt\5.15.2\msvc2019_64\bin
    popd
    exit /b 1
)

REM ?????? Configure + build ???????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????
if not exist build\CMakeCache.txt (
    echo Configuring...
    call scripts\configure-msvc.bat
    if errorlevel 1 (
        popd
        exit /b 1
    )
)

echo.
echo Building Release...
cmake --build build --config Release --parallel
if errorlevel 1 (
    echo Build FAILED.
    popd
    exit /b 1
)

REM ?????? windeployqt ????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????
set "OUT_DIR=%SRC_DIR%\build\bin\Release"
if not exist "%OUT_DIR%\musicefy.exe" (
    echo ERROR: musicefy.exe not found in %OUT_DIR%.
    popd
    exit /b 1
)

echo.
echo Running windeployqt...
"%QT_BIN%\windeployqt.exe" ^
    --release ^
    --no-translations ^
    --no-system-d3d-compiler ^
    --no-opengl-sw ^
    --verbose 1 ^
    "%OUT_DIR%\musicefy.exe"
if errorlevel 1 (
    echo windeployqt FAILED.
    popd
    exit /b 1
)

REM ?????? Bundle the UCRT for Win 7 ???????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????
echo.
echo Bundling UCRT for Win 7 SP1...
call scripts\bundle-ucrt.bat Release
if errorlevel 1 (
    echo UCRT bundling FAILED.
    popd
    exit /b 1
)


REM --- SQL driver plugins (windeployqt may miss them)
echo.
echo Ensuring SQL driver plugins...
set "QT_PLUGINS_SRC=%QT_DIR%\..\plugins\sqldrivers"
set "QT_PLUGINS_DST=%OUT_DIR%\sqldrivers"
if not exist "%%QT_PLUGINS_DST%%" mkdir "%%QT_PLUGINS_DST%%"
if exist "%%QT_PLUGINS_SRC%%\qsqlite.dll" copy /Y "%%QT_PLUGINS_SRC%%\qsqlite.dll" "%%QT_PLUGINS_DST%%" >nul 2>&1

REM ?????? Copy migrations ?????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????
echo.
echo Copying database migrations...
if not exist "%OUT_DIR%\migrations" mkdir "%OUT_DIR%\migrations"
copy /Y "%SRC_DIR%\src\core\database\migrations\*" "%OUT_DIR%\migrations\" >nul
if errorlevel 1 (
    echo Migration copy FAILED.
    popd
    exit /b 1
)

echo.
echo ????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????

REM --- Optional: Code signing
if defined SIGN_CERT_FILE (
    echo.
    echo Signing release binary...
    call "%%~dp0sign-release.bat"
    if errorlevel 1 (
        echo WARNING: Code signing failed. Continuing without signing.
    )
)

echo   Portable build complete: %OUT_DIR%
echo ????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????
echo.
echo The directory contains musicefy.exe plus every Qt, UCRT, and
echo plugin DLL it needs. It runs on a clean Windows 7 SP1 install
echo with no additional setup.
echo.
echo To ship: zip the contents of %OUT_DIR%.

popd
endlocal
exit /b 0
