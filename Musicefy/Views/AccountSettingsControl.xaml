<UserControl x:Class="Musicefy.Views.AccountSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="10,0,10,10">
        <!-- ═══ MAIN VIEW ═══ -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Visibility="{Binding IsMainView, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Vertical">

                <TextBlock Text="Account" FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource OnSurfaceBrush}" Margin="4,0,0,4"/>
                <TextBlock Text="YouTube Music, Discord, and Last.fm."
                           FontSize="12" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           Margin="4,0,0,20"/>

                <!-- YOUTUBE MUSIC -->
                <TextBlock Text="YOUTUBE MUSIC" Style="{StaticResource M3SectionHeader}"/>
                <Border Style="{StaticResource M3SettingsGroup}">
                    <StackPanel>
                        <CheckBox Style="{StaticResource M3SwitchRow}" IsChecked="{Binding YouTubeEnabled}">
                            <CheckBox.Tag>
                                <Path Data="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
                                      Width="20" Height="20" Stretch="Uniform" Fill="{DynamicResource PrimaryBrush}"/>
                            </CheckBox.Tag>
                            <StackPanel>
                                <TextBlock Text="Enable YouTube Music" Style="{StaticResource M3TitleText}"/>
                                <TextBlock Text="Stream music from YouTube Music." Style="{StaticResource M3DescriptionText}"/>
                            </StackPanel>
                        </CheckBox>
                        <Border Style="{StaticResource M3SettingsItem}">
                            <StackPanel Margin="56,0,0,0">
                                <TextBlock Text="API Key (optional)" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,0,0,4"/>
                                <Border Background="{DynamicResource SurfaceContainerLowBrush}" CornerRadius="8"
                                        BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1" Padding="8,4">
                                    <TextBox Background="Transparent" BorderThickness="0"
                                             Foreground="{DynamicResource OnSurfaceBrush}" FontSize="12"
                                             Text="{Binding YouTubeApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </Border>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource M3SettingsItemLast}">
                            <StackPanel Margin="56,0,0,0">
                                <TextBlock Text="Cookie (optional — for login)" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,0,0,4"/>
                                <Border Background="{DynamicResource SurfaceContainerLowBrush}" CornerRadius="8"
                                        BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1" Padding="8,4">
                                    <TextBox Background="Transparent" BorderThickness="0"
                                             Foreground="{DynamicResource OnSurfaceBrush}" FontSize="12"
                                             Text="{Binding YouTubeCookie, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </Border>
                                <TextBlock Text="Format: SID=...; HSID=...; SAPISID=..."
                                           FontSize="10" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- INTEGRATIONS -->
                <TextBlock Text="INTEGRATIONS" Style="{StaticResource M3SectionHeader}"/>
                <Border Style="{StaticResource M3SettingsGroup}">
                    <StackPanel>
                        <!-- Discord — tapable row -->
                        <Border Style="{StaticResource M3SettingsItem}" Cursor="Hand"
                                MouseLeftButtonUp="DiscordRow_Click">
                            <DockPanel>
                                <Border DockPanel.Dock="Left" Style="{StaticResource M3IconBox}">
                                    <Path Data="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"
                                          Width="20" Height="20" Stretch="Uniform" Fill="{DynamicResource PrimaryBrush}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Discord" Style="{StaticResource M3TitleText}"/>
                                    <TextBlock Text="Rich Presence integration." Style="{StaticResource M3DescriptionText}"/>
                                </StackPanel>
                                <TextBlock DockPanel.Dock="Right" Text="›" FontSize="20"
                                           Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                           VerticalAlignment="Center"/>
                            </DockPanel>
                        </Border>
                        <!-- Last.fm — tapable row -->
                        <Border Style="{StaticResource M3SettingsItemLast}" Cursor="Hand"
                                MouseLeftButtonUp="LastFmRow_Click">
                            <DockPanel>
                                <Border DockPanel.Dock="Left" Style="{StaticResource M3IconBox}">
                                    <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"
                                          Width="20" Height="20" Stretch="Uniform" Fill="{DynamicResource PrimaryBrush}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Last.fm" Style="{StaticResource M3TitleText}"/>
                                    <TextBlock Text="Scrobble tracks to your profile." Style="{StaticResource M3DescriptionText}"/>
                                </StackPanel>
                                <TextBlock DockPanel.Dock="Right" Text="›" FontSize="20"
                                           Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                           VerticalAlignment="Center"/>
                            </DockPanel>
                        </Border>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══ DISCORD VIEW ═══ -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Visibility="{Binding IsDiscordView, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Vertical">
                <StackPanel Orientation="Horizontal" Margin="4,0,0,16">
                    <Button Content="← Back" Padding="8,4" Cursor="Hand"
                            Command="{Binding NavigateBackCommand}" Margin="0,0,12,0"/>
                    <TextBlock Text="Discord" FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource OnSurfaceBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Text="RICH PRESENCE" Style="{StaticResource M3SectionHeader}"/>
                <Border Style="{StaticResource M3SettingsGroup}">
                    <StackPanel>
                        <CheckBox Style="{StaticResource M3SwitchRow}" IsChecked="{Binding DiscordRpcEnabled}">
                            <CheckBox.Tag>
                                <Path Data="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"
                                      Width="20" Height="20" Stretch="Uniform" Fill="{DynamicResource PrimaryBrush}"/>
                            </CheckBox.Tag>
                            <StackPanel>
                                <TextBlock Text="Enable Discord RPC" Style="{StaticResource M3TitleText}"/>
                                <TextBlock Text="Show what you're listening to on Discord." Style="{StaticResource M3DescriptionText}"/>
                            </StackPanel>
                        </CheckBox>
                        <Border Style="{StaticResource M3SettingsItemLast}">
                            <StackPanel Margin="56,0,0,0">
                                <TextBlock Text="Application Client ID" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,0,0,4"/>
                                <Border Background="{DynamicResource SurfaceContainerLowBrush}" CornerRadius="8"
                                        BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1" Padding="8,4">
                                    <TextBox Background="Transparent" BorderThickness="0"
                                             Foreground="{DynamicResource OnSurfaceBrush}" FontSize="12"
                                             Text="{Binding DiscordClientId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </Border>
                                <TextBlock Text="Create an app at discord.com/developers/applications"
                                           FontSize="10" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- ═══ LAST.FM VIEW ═══ -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Visibility="{Binding IsLastFmView, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Vertical">
                <StackPanel Orientation="Horizontal" Margin="4,0,0,16">
                    <Button Content="← Back" Padding="8,4" Cursor="Hand"
                            Command="{Binding NavigateBackCommand}" Margin="0,0,12,0"/>
                    <TextBlock Text="Last.fm" FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource OnSurfaceBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Text="SCROBBLING" Style="{StaticResource M3SectionHeader}"/>
                <Border Style="{StaticResource M3SettingsGroup}">
                    <StackPanel>
                        <CheckBox Style="{StaticResource M3SwitchRow}" IsChecked="{Binding LastFmEnabled}">
                            <CheckBox.Tag>
                                <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"
                                      Width="20" Height="20" Stretch="Uniform" Fill="{DynamicResource PrimaryBrush}"/>
                            </CheckBox.Tag>
                            <StackPanel>
                                <TextBlock Text="Enable scrobbling" Style="{StaticResource M3TitleText}"/>
                                <TextBlock Text="Automatically scrobble tracks as you play them." Style="{StaticResource M3DescriptionText}"/>
                            </StackPanel>
                        </CheckBox>
                        <Border Style="{StaticResource M3SettingsItemLast}">
                            <StackPanel Margin="56,0,0,0">
                                <TextBlock Text="Username" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,0,0,4"/>
                                <Border Background="{DynamicResource SurfaceContainerLowBrush}" CornerRadius="8"
                                        BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1" Padding="8,4">
                                    <TextBox Background="Transparent" BorderThickness="0"
                                             Foreground="{DynamicResource OnSurfaceBrush}" FontSize="12"
                                             Text="{Binding LastFmUsername, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </Border>
                                <TextBlock Text="Password" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,8,0,4"/>
                                <Border Background="{DynamicResource SurfaceContainerLowBrush}" CornerRadius="8"
                                        BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1" Padding="8,4">
                                    <PasswordBox x:Name="LastFmPasswordBox" Background="Transparent" BorderThickness="0"
                                                 Foreground="{DynamicResource OnSurfaceBrush}" FontSize="12"
                                                 PasswordChanged="LastFmPasswordBox_PasswordChanged"/>
                                </Border>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Button Content="Connect" Padding="12,4" Margin="0,0,8,0"
                                            Command="{Binding LastFmLoginCommand}" Cursor="Hand"/>
                                    <Button Content="Disconnect" Padding="12,4"
                                            Command="{Binding LastFmLogoutCommand}" Cursor="Hand"
                                            Foreground="{DynamicResource ErrorBrush}"/>
                                </StackPanel>
                                <TextBlock Text="✓ Connected" FontSize="11" Foreground="#4CAF50"
                                           Visibility="{Binding LastFmAuthenticated, Converter={StaticResource BoolToVis}}"
                                           Margin="0,8,0,0"/>
                                <TextBlock Text="{Binding StatusText}" FontSize="11"
                                           Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
