<UserControl x:Class="Musicefy.Views.PlayerAudioSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="10,0,10,10">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Vertical">

                <TextBlock Text="Player &amp; Audio" FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource OnSurfaceBrush}" Margin="4,0,0,4"/>
                <TextBlock Text="Playback, crossfade, and SponsorBlock."
                           FontSize="12" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           Margin="4,0,0,20"/>

                <!-- PLAYBACK -->
                <TextBlock Text="PLAYBACK" Style="{StaticResource M3SectionHeader}"/>
                <Border Style="{StaticResource M3SettingsGroup}">
                    <StackPanel>
                        <CheckBox Style="{StaticResource M3SwitchRow}" IsChecked="{Binding SkipSilenceEnabled}">
                            <CheckBox.Tag>
                                <Path Data="M7 11v9h2v-9H7zm6-7v16h2V4h-2z" Width="20" Height="20" Stretch="Uniform" Fill="{DynamicResource PrimaryBrush}"/>
                            </CheckBox.Tag>
                            <StackPanel>
                                <TextBlock Text="Skip silence" Style="{StaticResource M3TitleText}"/>
                                <TextBlock Text="Automatically skip silent sections." Style="{StaticResource M3DescriptionText}"/>
                            </StackPanel>
                        </CheckBox>

                        <!-- Threshold slider (visible when Skip Silence is on) -->
                        <Border Style="{StaticResource M3SettingsItem}"
                                Visibility="{Binding SkipSilenceEnabled, Converter={StaticResource BoolToVis}}">
                            <StackPanel Margin="56,8,16,8">
                                <DockPanel>
                                    <TextBlock Text="Threshold" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource OnSurfaceVariantBrush}" VerticalAlignment="Center"/>
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="{Binding SkipSilenceThresholdDb, StringFormat='{}{0} dB'}"
                                               FontSize="12" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center"/>
                                </DockPanel>
                                <Slider Style="{StaticResource M3Slider}" Minimum="-80" Maximum="-20"
                                        Value="{Binding SkipSilenceThresholdDb}" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <CheckBox Style="{StaticResource M3SwitchRow}" IsChecked="{Binding CrossfadeEnabled}">
                            <CheckBox.Tag>
                                <Path Data="M15 6H3v2h12V6zm0 4H3v2h12v-2zm-4 4H3v2h8v-2z" Width="20" Height="20" Stretch="Uniform" Fill="{DynamicResource PrimaryBrush}"/>
                            </CheckBox.Tag>
                            <StackPanel>
                                <TextBlock Text="Crossfade" Style="{StaticResource M3TitleText}"/>
                                <TextBlock Text="Fade between tracks." Style="{StaticResource M3DescriptionText}"/>
                            </StackPanel>
                        </CheckBox>

                        <!-- Crossfade duration slider -->
                        <Border Style="{StaticResource M3SettingsItemLast}"
                                Visibility="{Binding CrossfadeEnabled, Converter={StaticResource BoolToVis}}">
                            <StackPanel Margin="56,8,16,8">
                                <DockPanel>
                                    <TextBlock Text="Duration" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource OnSurfaceVariantBrush}" VerticalAlignment="Center"/>
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="{Binding CrossfadeDurationSeconds, StringFormat='{}{0:F1}s'}"
                                               FontSize="12" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center"/>
                                </DockPanel>
                                <Slider Style="{StaticResource M3Slider}" Minimum="1" Maximum="12"
                                        Value="{Binding CrossfadeDurationSeconds}" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- SPONSORBLOCK -->
                <TextBlock Text="SPONSORBLOCK" Style="{StaticResource M3SectionHeader}"/>
                <Border Style="{StaticResource M3SettingsGroup}">
                    <StackPanel>
                        <CheckBox Style="{StaticResource M3SwitchRow}" IsChecked="{Binding SponsorBlockEnabled}"
                                  Command="{Binding ToggleSponsorBlockExpandedCommand}">
                            <CheckBox.Tag>
                                <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" Width="20" Height="20" Stretch="Uniform" Fill="{DynamicResource PrimaryBrush}"/>
                            </CheckBox.Tag>
                            <StackPanel>
                                <TextBlock Text="Enable SponsorBlock" Style="{StaticResource M3TitleText}"/>
                                <TextBlock Text="Skip sponsor segments in YouTube videos." Style="{StaticResource M3DescriptionText}"/>
                            </StackPanel>
                        </CheckBox>

                        <!-- Expandable categories -->
                        <StackPanel Visibility="{Binding SponsorBlockExpanded, Converter={StaticResource BoolToVis}}">
                            <CheckBox Style="{StaticResource M3SwitchRow}" IsChecked="{Binding SponsorBlockSkipSponsor}" Margin="56,0,0,0">
                                <StackPanel><TextBlock Text="Skip sponsor segments" Style="{StaticResource M3TitleText}"/></StackPanel>
                            </CheckBox>
                            <CheckBox Style="{StaticResource M3SwitchRow}" IsChecked="{Binding SponsorBlockSkipIntro}" Margin="56,0,0,0">
                                <StackPanel><TextBlock Text="Skip intros" Style="{StaticResource M3TitleText}"/></StackPanel>
                            </CheckBox>
                            <CheckBox Style="{StaticResource M3SwitchRow}" IsChecked="{Binding SponsorBlockSkipOutro}" Margin="56,0,0,0">
                                <StackPanel><TextBlock Text="Skip outros" Style="{StaticResource M3TitleText}"/></StackPanel>
                            </CheckBox>
                            <CheckBox Style="{StaticResource M3SwitchRow}" IsChecked="{Binding SponsorBlockSkipSelfPromo}" Margin="56,0,0,0">
                                <StackPanel><TextBlock Text="Skip self-promotion" Style="{StaticResource M3TitleText}"/></StackPanel>
                            </CheckBox>
                            <CheckBox Style="{StaticResource M3SwitchRow}" IsChecked="{Binding SponsorBlockSkipInteraction}" Margin="56,0,0,0">
                                <StackPanel><TextBlock Text="Skip interaction reminders" Style="{StaticResource M3TitleText}"/></StackPanel>
                            </CheckBox>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
