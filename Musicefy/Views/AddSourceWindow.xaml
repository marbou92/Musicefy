<Window x:Class="Musicefy.Views.AddSourceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Streaming Source" Height="400" Width="500"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource ForegroundBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Border Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Grid.Row="0" Text="Add Streaming Source" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

            <!-- Info Text -->
            <TextBlock Grid.Row="1" Text="Connect to a streaming service like Squidify to access music." TextWrapping="Wrap" Foreground="#AAAAAA" Margin="0,0,0,15"/>

            <!-- Source Type -->
            <StackPanel Grid.Row="2" Margin="0,0,0,15">
                <TextBlock Text="Source Type" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox x:Name="SourceTypeCombo" Background="{StaticResource SecondaryBackgroundBrush}" Foreground="{StaticResource ForegroundBrush}" Padding="10" Height="35">
                    <ComboBoxItem Content="Subsonic (Squidify, etc.)" IsSelected="True"/>
                </ComboBox>
            </StackPanel>

            <!-- Source Name -->
            <StackPanel Grid.Row="3" Margin="0,0,0,15">
                <TextBlock Text="Name" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="NameTextBox" Background="{StaticResource SecondaryBackgroundBrush}" Foreground="{StaticResource ForegroundBrush}" Padding="10" Height="35" Text="Squidify"/>
            </StackPanel>

            <!-- Server URL -->
            <StackPanel Grid.Row="4" Margin="0,0,0,15">
                <TextBlock Text="Server URL" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="UrlTextBox" Background="{StaticResource SecondaryBackgroundBrush}" Foreground="{StaticResource ForegroundBrush}" Padding="10" Height="35" Text="https://www.squidify.org"/>
            </StackPanel>

            <!-- Username -->
            <StackPanel Grid.Row="5" Margin="0,0,0,15">
                <TextBlock Text="Username" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="UsernameTextBox" Background="{StaticResource SecondaryBackgroundBrush}" Foreground="{StaticResource ForegroundBrush}" Padding="10" Height="35"/>
            </StackPanel>

            <!-- Password -->
            <StackPanel Grid.Row="6" Margin="0,0,0,15">
                <TextBlock Text="Password" FontWeight="Bold" Margin="0,0,0,5"/>
                <PasswordBox x:Name="PasswordBox" Background="{StaticResource SecondaryBackgroundBrush}" Foreground="{StaticResource ForegroundBrush}" Padding="10" Height="35"/>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelButton" Content="Cancel" Background="{StaticResource BorderBrush}" Foreground="{StaticResource ForegroundBrush}" Padding="20,10" Width="100" Click="CancelButton_Click" Margin="0,0,10,0"/>
                <Button x:Name="TestButton" Content="Test" Background="{StaticResource AccentBrush}" Foreground="{StaticResource BackgroundBrush}" Padding="20,10" Width="100" Click="TestButton_Click" FontWeight="Bold" Margin="0,0,10,0"/>
                <Button x:Name="AddButton" Content="Add Source" Background="{StaticResource AccentBrush}" Foreground="{StaticResource BackgroundBrush}" Padding="20,10" Width="120" Click="AddButton_Click" FontWeight="Bold"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
