<UserControl x:Class="Musicefy.Views.IntegrationsSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="10,0,10,10">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Vertical">

                <!-- Header -->
                <TextBlock Text="Integrations" FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource OnSurfaceBrush}" Margin="4,0,0,4"/>
                <TextBlock Text="AI translation, Last.fm, and Discord."
                           FontSize="12" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           Margin="4,0,0,20"/>

                <!-- ═══ AI Lyrics Translation ═══ -->
                <TextBlock Text="AI Lyrics Translation" FontWeight="Bold" FontSize="15"
                           Foreground="{DynamicResource OnSurfaceBrush}" Margin="4,0,0,4"/>
                <TextBlock Text="Translate synced lyrics into your language using AI."
                           FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           Margin="4,0,0,12" TextWrapping="Wrap"/>

                <Border Background="{DynamicResource SurfaceVariantBrush}" CornerRadius="14"
                        Padding="16,12" Margin="0,0,0,20">
                    <StackPanel>
                        <CheckBox IsChecked="{Binding AiTranslationEnabled}">
                            <StackPanel>
                                <TextBlock Text="Enable AI translation" FontWeight="Bold" FontSize="14"
                                           Foreground="{DynamicResource OnSurfaceBrush}"/>
                                <TextBlock Text="Translates lyrics after they're fetched from LrcLib."
                                           FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </CheckBox>

                        <TextBlock Text="Provider" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,12,0,4"/>
                        <ComboBox x:Name="AiProviderCombo" Padding="8,4" FontSize="12"
                                  SelectedItem="{Binding AiTranslationProvider, Mode=TwoWay}">
                            <ComboBoxItem Content="OpenRouter"/>
                            <ComboBoxItem Content="OpenAI"/>
                            <ComboBoxItem Content="Gemini"/>
                            <ComboBoxItem Content="Groq"/>
                            <ComboBoxItem Content="Mistral"/>
                            <ComboBoxItem Content="xAI"/>
                            <ComboBoxItem Content="Perplexity"/>
                            <ComboBoxItem Content="Nvidia"/>
                        </ComboBox>

                        <TextBlock Text="API Key" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,12,0,4"/>
                        <Border Background="{DynamicResource SurfaceContainerHighBrush}" CornerRadius="8"
                                BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1" Padding="8,4">
                            <TextBox Background="Transparent" BorderThickness="0"
                                     Foreground="{DynamicResource OnSurfaceBrush}" FontSize="12"
                                     Text="{Binding AiTranslationApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Border>

                        <TextBlock Text="Model" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,12,0,4"/>
                        <Border Background="{DynamicResource SurfaceContainerHighBrush}" CornerRadius="8"
                                BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1" Padding="8,4">
                            <TextBox Background="Transparent" BorderThickness="0"
                                     Foreground="{DynamicResource OnSurfaceBrush}" FontSize="12"
                                     Text="{Binding AiTranslationModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Border>

                        <TextBlock Text="Target language (e.g. en, fr, ja, es)" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,12,0,4"/>
                        <Border Background="{DynamicResource SurfaceContainerHighBrush}" CornerRadius="8"
                                BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1" Padding="8,4">
                            <TextBox Background="Transparent" BorderThickness="0"
                                     Foreground="{DynamicResource OnSurfaceBrush}" FontSize="12"
                                     Text="{Binding AiTranslationTargetLang, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ═══ Last.fm ═══ -->
                <TextBlock Text="Last.fm Scrobbling" FontWeight="Bold" FontSize="15"
                           Foreground="{DynamicResource OnSurfaceBrush}" Margin="4,0,0,4"/>
                <TextBlock Text="Scrobble tracks to your Last.fm profile."
                           FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           Margin="4,0,0,12" TextWrapping="Wrap"/>

                <Border Background="{DynamicResource SurfaceVariantBrush}" CornerRadius="14"
                        Padding="16,12" Margin="0,0,0,20">
                    <StackPanel>
                        <CheckBox IsChecked="{Binding LastFmEnabled}">
                            <StackPanel>
                                <TextBlock Text="Enable Last.fm scrobbling" FontWeight="Bold" FontSize="14"
                                           Foreground="{DynamicResource OnSurfaceBrush}"/>
                                <TextBlock Text="Automatically scrobble tracks as you play them."
                                           FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </CheckBox>

                        <TextBlock Text="Username" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,12,0,4"/>
                        <Border Background="{DynamicResource SurfaceContainerHighBrush}" CornerRadius="8"
                                BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1" Padding="8,4">
                            <TextBox Background="Transparent" BorderThickness="0"
                                     Foreground="{DynamicResource OnSurfaceBrush}" FontSize="12"
                                     Text="{Binding LastFmUsername, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Border>

                        <TextBlock Text="Password" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,12,0,4"/>
                        <Border Background="{DynamicResource SurfaceContainerHighBrush}" CornerRadius="8"
                                BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1" Padding="8,4">
                            <PasswordBox x:Name="LastFmPasswordBox" Background="Transparent" BorderThickness="0"
                                         Foreground="{DynamicResource OnSurfaceBrush}" FontSize="12"
                                         PasswordChanged="LastFmPasswordBox_PasswordChanged"/>
                        </Border>

                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Button Content="Connect" Padding="14,6" Margin="0,0,8,0"
                                    Command="{Binding LastFmLoginCommand}" Cursor="Hand"/>
                            <Button Content="Disconnect" Padding="14,6"
                                    Command="{Binding LastFmLogoutCommand}" Cursor="Hand"
                                    Foreground="{DynamicResource ErrorBrush}"/>
                        </StackPanel>

                        <TextBlock Text="✓ Connected" FontSize="11" Foreground="#4CAF50"
                                   Visibility="{Binding LastFmAuthenticated, Converter={StaticResource BoolToVis}}"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- ═══ Discord RPC ═══ -->
                <TextBlock Text="Discord Rich Presence" FontWeight="Bold" FontSize="15"
                           Foreground="{DynamicResource OnSurfaceBrush}" Margin="4,0,0,4"/>
                <TextBlock Text="Show what you're listening to on your Discord profile."
                           FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           Margin="4,0,0,12" TextWrapping="Wrap"/>

                <Border Background="{DynamicResource SurfaceVariantBrush}" CornerRadius="14"
                        Padding="16,12" Margin="0,0,0,20">
                    <StackPanel>
                        <CheckBox IsChecked="{Binding DiscordRpcEnabled}">
                            <StackPanel>
                                <TextBlock Text="Enable Discord RPC" FontWeight="Bold" FontSize="14"
                                           Foreground="{DynamicResource OnSurfaceBrush}"/>
                                <TextBlock Text="Shows 'Playing X by Y' on Discord."
                                           FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </CheckBox>

                        <TextBlock Text="Discord Application Client ID" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,12,0,4"/>
                        <Border Background="{DynamicResource SurfaceContainerHighBrush}" CornerRadius="8"
                                BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1" Padding="8,4">
                            <TextBox Background="Transparent" BorderThickness="0"
                                     Foreground="{DynamicResource OnSurfaceBrush}" FontSize="12"
                                     Text="{Binding DiscordClientId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Border>
                        <TextBlock Text="Create an app at discord.com/developers/applications to get a Client ID."
                                   FontSize="10" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                   Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Save button -->
                <Button Content="Save Integrations" Padding="16,8" HorizontalAlignment="Left"
                        Command="{Binding SaveCommand}" Cursor="Hand" FontWeight="SemiBold"/>

                <!-- Status -->
                <TextBlock Text="{Binding StatusText}" FontSize="11"
                           Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
