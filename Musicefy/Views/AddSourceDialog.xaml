<Window x:Class="Musicefy.Views.AddSourceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Source" Width="500" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource SurfaceBrush}"
        Foreground="{DynamicResource OnSurfaceBrush}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Step Indicator -->
        <TextBlock Grid.Row="0" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource OnSurfaceBrush}" Margin="0,0,0,16">
            <Run Text="Step "/>
            <Run x:Name="StepNumber" Text="1"/>
            <Run Text=" of 2"/>
            <Run Text=" — "/>
            <Run x:Name="StepDescription" Text="Select Source Type"/>
        </TextBlock>

        <!-- Step 1: Select Source Type -->
        <StackPanel Grid.Row="1" x:Name="Step1Panel">
            <TextBlock Text="Choose a source type to add:" FontSize="12" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,0,0,12"/>

            <ItemsControl x:Name="ProviderList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{DynamicResource OutlineVariantBrush}" BorderThickness="1" CornerRadius="8"
                                Background="{DynamicResource SurfaceContainerHighBrush}" Margin="0,4" Padding="12"
                                Cursor="Hand" MouseLeftButtonUp="ProviderItem_Click"
                                Tag="{Binding}">
                            <StackPanel Orientation="Horizontal">
                                <!-- FIX: Replaced TextBlock emoji with Path+IconGlyphConverter
                                     so icons render as proper SVG vectors -->
                                <Border Width="36" Height="36" CornerRadius="18"
                                        Background="{DynamicResource PrimaryContainerBrush}" Margin="0,0,12,0"
                                        VerticalAlignment="Center">
                                    <Path Data="{Binding SourceType, Converter={StaticResource IconGlyphConverter}}"
                                          Width="18" Height="18" Stretch="Uniform"
                                          Fill="{DynamicResource PrimaryBrush}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource OnSurfaceBrush}"/>
                                    <TextBlock Text="{Binding Description}" FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                               TextWrapping="Wrap" MaxWidth="350"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <!-- Step 2: Configure Source -->
        <StackPanel Grid.Row="2" x:Name="Step2Panel" Visibility="Collapsed">
            <!-- Source Name -->
            <TextBlock Text="Source Name" FontSize="12" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,0,0,4"/>
            <TextBox x:Name="SourceNameBox" Padding="8,6" Margin="0,0,0,16"
                     FontSize="13" Background="{DynamicResource SurfaceContainerHighBrush}" Foreground="{DynamicResource OnSurfaceBrush}"
                     BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1"/>

            <!-- Dynamic Configuration Fields -->
            <ItemsControl x:Name="ConfigFieldsPanel">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock FontSize="12" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,0,0,4">
                                <Run Text="{Binding Label, Mode=OneWay}"/>
                                <InlineUIContainer>
                                    <TextBlock Text=" *" Foreground="{DynamicResource ErrorBrush}" FontSize="12"
                                               Visibility="{Binding IsRequired, Converter={StaticResource BoolToVis}}"/>
                                </InlineUIContainer>
                            </TextBlock>
                            <PasswordBox Padding="8,6" FontSize="13"
                                         Background="{DynamicResource SurfaceContainerHighBrush}" Foreground="{DynamicResource OnSurfaceBrush}"
                                         BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1"
                                         Tag="{Binding Key}"
                                         Visibility="{Binding IsPassword, Converter={StaticResource BoolToVis}}"
                                         x:Name="PasswordField"/>
                            <TextBox Padding="8,6" FontSize="13"
                                     Background="{DynamicResource SurfaceContainerHighBrush}" Foreground="{DynamicResource OnSurfaceBrush}"
                                     BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1"
                                     Tag="{Binding Key}"
                                     Visibility="{Binding IsNotPassword, Converter={StaticResource BoolToVis}}"
                                     x:Name="ValueField"/>
                            <TextBlock Text="{Binding Description}" FontSize="10" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                       TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Test Connection Result -->
            <StackPanel x:Name="TestResultPanel" Visibility="Collapsed" Margin="0,8,0,0">
                <Border CornerRadius="8" Padding="10,8"
                        Background="{DynamicResource SurfaceContainerHighBrush}"
                        x:Name="TestResultBorder">
                    <TextBlock x:Name="TestResultText" FontSize="12" TextWrapping="Wrap"/>
                </Border>
            </StackPanel>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Back" Padding="16,8" Margin="0,0,8,0"
                    FontSize="12" Click="BackButton_Click"
                    x:Name="BackButton" Visibility="Collapsed"/>
            <Button Content="Cancel" Padding="16,8" Margin="0,0,8,0"
                    FontSize="12" Click="CancelButton_Click"/>
            <Button Content="Test Connection" Padding="16,8" Margin="0,0,8,0"
                    FontSize="12" Click="TestConnectionButton_Click"
                    x:Name="TestConnectionButton" Visibility="Collapsed"/>
            <Button Content="Save" Padding="16,8"
                    FontSize="12" Click="SaveButton_Click"
                    x:Name="SaveButton" Visibility="Collapsed"
                    FontWeight="SemiBold"/>
        </StackPanel>

        <!-- Loading indicator -->
        <StackPanel Grid.Row="4" x:Name="LoadingPanel" Visibility="Collapsed"
                    Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
            <TextBlock Text="Testing connection..." FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
        </StackPanel>
    </Grid>
</Window>
