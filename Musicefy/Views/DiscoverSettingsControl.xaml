<UserControl x:Class="Musicefy.Views.DiscoverSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid Margin="10,0,10,10">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Vertical">

                <TextBlock Text="Discover" FontSize="22" FontWeight="Bold" Margin="4,0,0,4" Foreground="{DynamicResource ForegroundBrush}"/>
                <TextBlock Text="Choose which sources appear on your home screen." Foreground="{DynamicResource MutedTextBrush}" Margin="4,0,0,20" FontSize="12"/>

                <ItemsControl ItemsSource="{Binding Sources}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Style="{DynamicResource ModernSettingRowStyle}"
                                      IsChecked="{Binding IsEnabled}">
                                <StackPanel>
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource ForegroundBrush}"/>
                                    <TextBlock Text="{Binding Description}" FontSize="11" Foreground="{DynamicResource MutedTextBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <CheckBox.Tag>
                                    <Path Data="{Binding SourceType, Converter={StaticResource IconGlyphConverter}}"
                                          Width="20" Height="20" Stretch="Uniform"
                                          Fill="{DynamicResource AccentBrush}"/>
                                </CheckBox.Tag>
                            </CheckBox>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="Tip: Changes apply when you navigate back to the home view."
                           FontSize="11" Foreground="{DynamicResource MutedTextBrush}"
                           HorizontalAlignment="Center" Margin="0,20,0,10"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
