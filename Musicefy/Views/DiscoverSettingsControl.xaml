<UserControl x:Class="Musicefy.Views.DiscoverSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <Style TargetType="TextBlock" x:Key="SectionHeader">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        </Style>

        <Style x:Key="ToggleStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10,0,10,10">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Vertical">

                <TextBlock Text="Discover" FontSize="22" FontWeight="Bold" Margin="4,0,0,4" Foreground="{DynamicResource ForegroundBrush}"/>
                <TextBlock Text="Choose what content appears on your home screen." Foreground="{DynamicResource MutedTextBrush}" Margin="4,0,0,20" FontSize="12"/>

                <Border Background="{DynamicResource SecondaryBackgroundBrush}" CornerRadius="12" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Sources" Style="{StaticResource SectionHeader}"/>

                        <Border Style="{StaticResource ToggleStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18"
                                        Background="{DynamicResource AccentBrush}" Margin="0,0,12,0">
                                    <Path Data="M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z"
                                          Width="18" Height="18" Stretch="Uniform" Fill="White"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Local Library" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource ForegroundBrush}"/>
                                    <TextBlock Text="Recently played, favourites, and random tracks" FontSize="11" Foreground="{DynamicResource MutedTextBrush}"/>
                                </StackPanel>

                                <CheckBox Grid.Column="2" IsChecked="{Binding ShowLibrary}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource ToggleStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18"
                                        Background="#FF0000" Margin="0,0,12,0">
                                    <Path Data="M17 7h-4v2h4c1.65 0 3 1.35 3 3s-1.35 3-3 3h-4v2h4c2.76 0 5-2.24 5-5s-2.24-5-5-5zm-6 8H7c-1.65 0-3-1.35-3-3s1.35-3 3-3h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-2zm-3-4h8v2H8v-2z"
                                          Width="18" Height="18" Stretch="Uniform" Fill="White"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="YouTube Music" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource ForegroundBrush}"/>
                                    <TextBlock Text="Trending music videos and search results" FontSize="11" Foreground="{DynamicResource MutedTextBrush}"/>
                                </StackPanel>

                                <CheckBox Grid.Column="2" IsChecked="{Binding ShowYouTube}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource ToggleStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18"
                                        Background="#1DB954" Margin="0,0,12,0">
                                    <Path Data="M6 18c0 1.1-.9 2-2 2s-2-.9-2-2 .9-2 2-2 2 .9 2 2zm-2-8v4h4c0-2.21-1.79-4-4-4zm0-6v4c5.52 0 10 4.48 10 10h4c0-7.73-6.27-14-14-14z"
                                          Width="18" Height="18" Stretch="Uniform" Fill="White"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Subsonic / Navidrome" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource ForegroundBrush}"/>
                                    <TextBlock Text="Random songs from your personal server" FontSize="11" Foreground="{DynamicResource MutedTextBrush}"/>
                                </StackPanel>

                                <CheckBox Grid.Column="2" IsChecked="{Binding ShowSubsonic}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <TextBlock Text="Tip: Changes apply after navigating back to the home view."
                           FontSize="11" Foreground="{DynamicResource MutedTextBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,10"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
