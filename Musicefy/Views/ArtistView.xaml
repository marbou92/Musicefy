<UserControl x:Class="Musicefy.Views.ArtistView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Musicefy.Converters"
             Background="Transparent">

    <UserControl.Resources>
        <converters:PathToImageConverter x:Key="PathToImageConverter"/>
    </UserControl.Resources>

    <Grid ClipToBounds="True">
        <!-- Layer 1: Dynamic gradient background -->
        <Rectangle x:Name="BgGradient" Fill="{Binding BackgroundGradient}"/>

        <!-- Layer 2: Scrollable content -->
        <ScrollViewer VerticalScrollBarVisibility="Hidden"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="24,0">

                <!-- Section A: Top navigation bar -->
                <Grid Height="56">
                    <Button x:Name="BtnBack" Click="BtnBack_Click"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Width="40" Height="40"
                            HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Path Data="M20,11H7.83l5.59-5.59L12,4l-8,8 8,8 1.41-1.41L7.83,13H20v-2z"
                              Fill="White" Width="24" Height="24" Stretch="Uniform"/>
                    </Button>
                </Grid>

                <!-- Section B: Artist photo and identity block -->
                <StackPanel HorizontalAlignment="Center" Margin="0,16,0,24">
                    <Border Width="220" Height="220" CornerRadius="110"
                            ClipToBounds="True"
                            Background="{DynamicResource SurfaceVariantBrush}">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="40" ShadowDepth="0"
                                              Opacity="0.5" Color="Black"/>
                        </Border.Effect>
                        <Grid>
                            <Image Source="{Binding CoverPath, Converter={StaticResource PathToImageConverter}}"
                                   Stretch="UniformToFill"/>
                        </Grid>
                    </Border>
                    <TextBlock Text="{Binding ArtistName}" FontSize="32" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center"
                               Margin="0,16,0,0" TextTrimming="CharacterEllipsis"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding SongsCountText}" FontSize="20" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Songs" FontSize="12" Foreground="#AAFFFFFF"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Width="1" Height="32" Background="White" Opacity="0.3"
                                Margin="24,0"/>
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding AlbumsCountText}" FontSize="20" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Albums" FontSize="12" Foreground="#AAFFFFFF"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Section C: Action buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,28">
                    <Border CornerRadius="24" Height="40" Padding="20,0"
                            Background="#33000000" BorderBrush="#55FFFFFF" BorderThickness="1"
                            Margin="0,0,12,0" Cursor="Hand">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding SubscribeCommand}"/>
                        </Border.InputBindings>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="+" FontSize="16" Foreground="White"
                                       FontWeight="Bold" Margin="0,0,6,0"/>
                            <TextBlock Text="Subscribe" FontSize="13" Foreground="White"/>
                        </StackPanel>
                    </Border>
                    <Border CornerRadius="24" Height="40" Padding="20,0"
                            Background="#55FFFFFF" Margin="0,0,12,0" Cursor="Hand">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding ShufflePlayCommand}"/>
                        </Border.InputBindings>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Data="M14.83,13.41L13.42,14.82L16.55,17.95L14.5,20H20V14.5L17.96,16.54L14.83,13.41M14.5,4L16.54,6.04L4,18.58L5.41,20L17.96,7.46L20,9.5V4H14.5M10.59,9.17L5.41,4L4,5.41L9.17,10.58L10.59,9.17Z"
                                  Fill="#333333" Width="16" Height="16" Stretch="Uniform" Margin="0,0,6,0"/>
                            <TextBlock Text="Shuffle" FontSize="13" Foreground="#333333"/>
                        </StackPanel>
                    </Border>
                    <Border CornerRadius="24" Height="40" Padding="20,0"
                            Background="#33000000" BorderBrush="#55FFFFFF" BorderThickness="1"
                            Cursor="Hand">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding RadioCommand}"/>
                        </Border.InputBindings>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Data="M12,1C7.03,1 3,5.03 3,10V17C3,18.66 4.34,20 6,20H9V12H5V10C5,6.13 8.13,3 12,3C15.87,3 19,6.13 19,10V12H15V20H18C19.66,20 21,18.66 21,17V10C21,5.03 16.97,1 12,1Z"
                                  Fill="White" Width="16" Height="16" Stretch="Uniform" Margin="0,0,6,0"/>
                            <TextBlock Text="Radio" FontSize="13" Foreground="White"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Section D: Top Songs header -->
                <Grid Margin="0,0,0,16">
                    <TextBlock Text="Top songs" FontSize="20" FontWeight="Bold"
                               Foreground="White" VerticalAlignment="Center"/>
                    <Button Content="→" Command="{Binding SwitchToTracksCommand}"
                            HorizontalAlignment="Right" Background="Transparent"
                            BorderThickness="0" Foreground="White" FontSize="18"
                            Cursor="Hand" Width="40" Height="40"/>
                </Grid>

                <!-- Section E: Top songs track list -->
                <ItemsControl ItemsSource="{Binding Tracks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="14" Padding="8,6" Margin="0,0,0,4"
                                    Background="Transparent" Cursor="Hand">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#22FFFFFF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.PlayTrackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding}"/>
                                </Border.InputBindings>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="52" Height="52"
                                            CornerRadius="10" ClipToBounds="True"
                                            Background="{DynamicResource SurfaceVariantBrush}">
                                        <Image Source="{Binding CoverPath, Converter={StaticResource PathToImageConverter}}"
                                               Stretch="UniformToFill"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="Medium"
                                                   Foreground="White" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Artist}" FontSize="12"
                                                   Foreground="#AAFFFFFF" TextTrimming="CharacterEllipsis"
                                                   Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="2" Width="40" Height="40"
                                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                                            Command="{Binding DataContext.TrackMoreCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <Path Data="M12,8C13.1,8 14,7.1 14,6C14,4.9 13.1,4 12,4C10.9,4 10,4.9 10,6C10,7.1 10.9,8 12,8M12,10C10.9,10 10,10.9 10,12C10,13.1 10.9,14 12,14C13.1,14 14,13.1 14,12C14,10.9 13.1,10 12,10M12,16C10.9,16 10,16.9 10,18C10,19.1 10.9,20 12,20C13.1,20 14,19.1 14,18C14,16.9 13.1,16 12,16Z"
                                              Fill="White" Opacity="0.7" Width="20" Height="20" Stretch="Uniform"/>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Section F: Bottom spacer -->
                <Border Height="80"/>

            </StackPanel>
        </ScrollViewer>

        <!-- Loading overlay -->
        <Grid Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
              HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="Loading..." FontSize="14" Foreground="White" Opacity="0.7"/>
        </Grid>
    </Grid>
</UserControl>
