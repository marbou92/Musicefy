<UserControl x:Class="Musicefy.Views.SearchControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="20">
        <!-- Removed PlaceholderText (UWP-only). Added watermark style -->
        <TextBox x:Name="SearchBox" Width="400" Height="32" Text="Search..."
                 Foreground="Gray"
                 GotFocus="SearchBox_GotFocus"
                 LostFocus="SearchBox_LostFocus"
                 TextChanged="SearchBox_TextChanged"/>
        <ListBox x:Name="SearchResults" Margin="0,12,0,0"/>
    </StackPanel>
</UserControl>
