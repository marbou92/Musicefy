<UserControl x:Class="Musicefy.Views.SearchControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:Musicefy.Core.Models;assembly=Musicefy.Core"
             xmlns:vm="clr-namespace:Musicefy.ViewModels"
             xmlns:conv="clr-namespace:Musicefy.Converters"
             Background="Transparent"
             VerticalAlignment="Stretch" HorizontalAlignment="Stretch">

    <Grid>
        <!-- Search Bar (always visible) -->
        <Grid x:Name="SearchBar" VerticalAlignment="Top" Margin="24,16,24,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Search TextBox -->
            <Border Grid.Column="0" Background="{DynamicResource SurfaceVariantBrush}"
                    CornerRadius="24" Padding="8,0" Height="44">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Search Icon -->
                    <Path Grid.Column="0" Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z"
                          Fill="{DynamicResource OnSurfaceVariantBrush}" Width="18" Height="18"
                          Stretch="Uniform" VerticalAlignment="Center" Margin="8,0,8,0"/>

                    <!-- Input -->
                    <TextBox x:Name="SearchTextBox" Grid.Column="1"
                             Text="{Binding Query, UpdateSourceTrigger=PropertyChanged, Delay=0}"
                             Background="Transparent" BorderThickness="0"
                             Foreground="{DynamicResource OnSurfaceBrush}"
                             FontSize="14" VerticalAlignment="Center"
                             VerticalContentAlignment="Center"
                             CaretBrush="{DynamicResource PrimaryBrush}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding SearchCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <!-- Clear Button -->
                    <Button Grid.Column="2" Width="32" Height="32"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Command="{Binding ClearQueryCommand}"
                            Visibility="{Binding HasQuery, Converter={StaticResource BooleanToVisibilityConverter}}"
                            VerticalAlignment="Center">
                        <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"
                              Fill="{DynamicResource OnSurfaceVariantBrush}" Width="16" Height="16"
                              Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>

                    <!-- Source Toggle Icon (secondary indicator inside search box) -->
                    <Button Grid.Column="3" Width="32" Height="32" Margin="4,0,4,0"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Command="{Binding ToggleSourceModeCommand}"
                            ToolTip="{Binding SourceMode}"
                            VerticalAlignment="Center">
                        <Path Data="{Binding SourceMode, Converter={StaticResource SearchModeIconConverter}}"
                              Fill="{DynamicResource PrimaryBrush}" Width="18" Height="18"
                              Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </Grid>
            </Border>

            <!-- ═══ Session 4: Online / Library Toggle Pill ════════════════ -->
            <!-- Two-segment pill below the search bar, always visible when there's a query -->
            <Border Grid.Row="1" Grid.Column="0" HorizontalAlignment="Left"
                    Background="{DynamicResource SurfaceVariantBrush}"
                    CornerRadius="20" Padding="2" Margin="0,10,0,0"
                    Visibility="{Binding HasQuery, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <!-- Online segment -->
                    <RadioButton x:Name="OnlinePill" GroupName="SourcePill"
                                 Content="Online" Padding="20,7"
                                 FontSize="12" FontWeight="SemiBold"
                                 Cursor="Hand" IsChecked="True"
                                 Command="{Binding SetOnlineModeCommand}">
                        <RadioButton.Style>
                            <Style TargetType="RadioButton">
                                <Setter Property="Foreground" Value="{DynamicResource OnSurfaceVariantBrush}"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Border x:Name="PillBorder" Background="{TemplateBinding Background}"
                                                    CornerRadius="18" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="PillBorder" Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource OnPrimaryBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="PillBorder" Property="Opacity" Value="0.85"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </RadioButton.Style>
                    </RadioButton>
                    <!-- Library segment -->
                    <RadioButton x:Name="LibraryPill" GroupName="SourcePill"
                                 Content="Library" Padding="20,7"
                                 FontSize="12" FontWeight="SemiBold"
                                 Cursor="Hand"
                                 Command="{Binding SetLocalModeCommand}">
                        <RadioButton.Style>
                            <Style TargetType="RadioButton">
                                <Setter Property="Foreground" Value="{DynamicResource OnSurfaceVariantBrush}"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Border x:Name="PillBorder" Background="{TemplateBinding Background}"
                                                    CornerRadius="18" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="PillBorder" Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource OnPrimaryBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="PillBorder" Property="Opacity" Value="0.85"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </RadioButton.Style>
                    </RadioButton>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Content Area (below search bar + toggle pill) -->
        <Grid Margin="24,110,24,0">

            <!-- ═══ Idle State: Search History ═══════════════════════════ -->
            <ScrollViewer x:Name="IdlePanel"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Visibility="{Binding IsIdle, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <!-- History header -->
                    <Grid Margin="0,0,0,16">
                        <TextBlock Text="Recent Searches" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource OnSurfaceBrush}" VerticalAlignment="Center"/>
                        <Button Content="Clear" HorizontalAlignment="Right"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{DynamicResource PrimaryBrush}"
                                FontSize="12" FontWeight="SemiBold" Cursor="Hand"
                                Command="{Binding ClearHistoryCommand}"
                                Visibility="{Binding RecentSearches.Count, Converter={StaticResource NonZeroToVisibilityConverter}}"/>
                    </Grid>

                    <!-- History list -->
                    <ItemsControl ItemsSource="{Binding RecentSearches}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:SearchHistory}">
                                <Button Background="Transparent" BorderThickness="0"
                                        HorizontalContentAlignment="Left" Padding="12,10"
                                        Cursor="Hand"
                                        Command="{Binding DataContext.HistoryItemSelectedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="M13.5,8H12V13L16.28,15.54L17,14.33L13.5,12.25V8M12,3A9,9 0 0,0 3,12A9,9 0 0,0 12,21A9,9 0 0,0 21,12A9,9 0 0,0 12,3M12,19C7.59,19 4,15.41 4,11C4,6.59 7.59,3 12,3C16.41,3 20,6.59 20,11C20,15.41 16.41,19 12,19Z"
                                              Fill="{DynamicResource OnSurfaceVariantBrush}" Width="16" Height="16"
                                              Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <TextBlock Text="{Binding Query}" FontSize="14"
                                                   Foreground="{DynamicResource OnSurfaceBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Empty history message -->
                    <TextBlock Text="No recent searches" FontSize="14"
                               Foreground="{DynamicResource OnSurfaceVariantBrush}"
                               HorizontalAlignment="Center" Margin="0,40,0,0"
                               Visibility="{Binding RecentSearches.Count, Converter={StaticResource ZeroToVisibilityConverter}}"/>
                </StackPanel>
            </ScrollViewer>

            <!-- ═══ Suggestions State ═══════════════════════════════════ -->
            <ScrollViewer x:Name="SuggestionsPanel"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Visibility="{Binding IsShowingSuggestions, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="Suggestions" FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource OnSurfaceBrush}" Margin="0,0,0,12"/>
                    <ItemsControl ItemsSource="{Binding Suggestions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Background="Transparent" BorderThickness="0"
                                        HorizontalContentAlignment="Left" Padding="12,10"
                                        Cursor="Hand"
                                        Command="{Binding DataContext.SuggestionSelectedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z"
                                              Fill="{DynamicResource OnSurfaceVariantBrush}" Width="16" Height="16"
                                              Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,12,0" Opacity="0.6"/>
                                        <TextBlock Text="{Binding}" FontSize="14"
                                                   Foreground="{DynamicResource OnSurfaceBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <!-- ═══ Searching State (Loading) ═══════════════════════════ -->
            <StackPanel x:Name="LoadingPanel"
                        Visibility="{Binding IsSearching, Converter={StaticResource BooleanToVisibilityConverter}}"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4"
                             Foreground="{DynamicResource PrimaryBrush}"
                             Background="{DynamicResource SurfaceVariantBrush}"/>
                <TextBlock Text="Searching..." FontSize="14"
                           Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           HorizontalAlignment="Center" Margin="0,12,0,0"/>
            </StackPanel>

            <!-- ═══ Results State ═══════════════════════════════════════ -->
            <Grid x:Name="ResultsPanel"
                  Visibility="{Binding HasResults, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ═══ Session 4: Top Result Featured Card ═══════════════ -->
                <!-- Shown when the "Top result" category exists in ResultGroups -->
                <Border Grid.Row="0" x:Name="TopResultCard"
                        Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="12" Padding="16" Margin="0,0,0,16"
                        Cursor="Hand"
                        MouseLeftButtonUp="TopResultCard_Click"
                        Visibility="{Binding HasTopResult, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Large thumbnail -->
                        <Border Grid.Column="0" Width="120" Height="120"
                                CornerRadius="12" ClipToBounds="True" Margin="0,0,16,0"
                                Background="{DynamicResource SurfaceVariantBrush}">
                            <Grid>
                                <!-- Placeholder -->
                                <Path Data="M12,3V12.26C11.5,12.09 11,12 10.5,12C8,12 6,14 6,16.5C6,19 8,21 10.5,21C13,21 15,19 15,16.5V6H19V3H12Z"
                                      Fill="{DynamicResource OnSurfaceVariantBrush}" Width="36" Height="36"
                                      Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.3"/>
                                <!-- Cover image -->
                                <Image Source="{Binding TopResult.CoverPath, Converter={StaticResource PathToImageConverter}, ConverterParameter=hero}"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       Stretch="UniformToFill"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       conv:CoverFadeBehavior.IsEnabled="True"/>
                            </Grid>
                        </Border>

                        <!-- Title, artist, type badge -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding TopResultTitle}" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource OnSurfaceBrush}"
                                       TextTrimming="CharacterEllipsis" MaxHeight="28"/>
                            <TextBlock Text="{Binding TopResultSubtitle}" FontSize="14"
                                       Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                       TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                            <!-- Type badge (Song / Artist / Album) -->
                            <Border Background="{DynamicResource PrimaryBrush}"
                                    CornerRadius="10" Padding="10,3" Margin="0,8,0,0"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="{Binding TopResultType}" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource OnPrimaryBrush}"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Filter Tabs — wired via SelectedFilterCommand -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
                    <RadioButton Content="All" GroupName="SearchFilter"
                                 IsChecked="True"
                                 Margin="0,0,12,0" Padding="16,8" FontSize="12" FontWeight="SemiBold"
                                 Cursor="Hand"
                                 Command="{Binding SelectedFilterCommand}"
                                 CommandParameter="All"/>
                    <RadioButton Content="Songs" GroupName="SearchFilter"
                                 Margin="0,0,12,0" Padding="16,8" FontSize="12" FontWeight="SemiBold"
                                 Cursor="Hand"
                                 Command="{Binding SelectedFilterCommand}"
                                 CommandParameter="Songs"/>
                    <RadioButton Content="Albums" GroupName="SearchFilter"
                                 Margin="0,0,12,0" Padding="16,8" FontSize="12" FontWeight="SemiBold"
                                 Cursor="Hand"
                                 Command="{Binding SelectedFilterCommand}"
                                 CommandParameter="Albums"/>
                    <RadioButton Content="Artists" GroupName="SearchFilter"
                                 Margin="0,0,12,0" Padding="16,8" FontSize="12" FontWeight="SemiBold"
                                 Cursor="Hand"
                                 Command="{Binding SelectedFilterCommand}"
                                 CommandParameter="Artists"/>
                    <RadioButton Content="Playlists" GroupName="SearchFilter"
                                 Margin="0,0,12,0" Padding="16,8" FontSize="12" FontWeight="SemiBold"
                                 Cursor="Hand"
                                 Command="{Binding SelectedFilterCommand}"
                                 CommandParameter="Playlists"/>
                </StackPanel>

                <!-- ═══ Grouped Results (visible when filter = All) ═══ -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="{Binding IsAllFilter, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ItemsControl ItemsSource="{Binding ResultGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:SearchResultGroup}">
                                <StackPanel Margin="0,0,0,20">
                                    <!-- Category Header -->
                                    <TextBlock Text="{Binding Category}" FontSize="16" FontWeight="SemiBold"
                                               Foreground="{DynamicResource OnSurfaceBrush}"
                                               Margin="0,0,0,12"/>
                                    <!-- Items in this category -->
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource SurfaceBrush}"
                                                        CornerRadius="8" Margin="0,0,0,4" Padding="12,10"
                                                        Cursor="Hand"
                                                        MouseLeftButtonUp="ResultItem_Click">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="48"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Cover Art with type-aware corner radius -->
                                                        <Border Grid.Column="0" Width="40" Height="40"
                                                                CornerRadius="{Binding ., Converter={StaticResource ItemTypeToCornerRadiusConverter}}"
                                                                Background="{DynamicResource SurfaceVariantBrush}"
                                                                ClipToBounds="True">
                                                            <Grid>
                                                                <!-- Placeholder icon -->
                                                                <Path Data="M12,3V12.26C11.5,12.09 11,12 10.5,12C8,12 6,14 6,16.5C6,19 8,21 10.5,21C13,21 15,19 15,16.5V6H19V3H12Z"
                                                                      Fill="{DynamicResource OnSurfaceVariantBrush}"
                                                                      Width="20" Height="20" Stretch="Uniform"
                                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                <!-- Cover image -->
                                                                <Image Source="{Binding CoverPath, Converter={StaticResource PathToImageConverter}, ConverterParameter=list}"
                                                                       RenderOptions.BitmapScalingMode="HighQuality"
                                                                       Stretch="UniformToFill"
                                                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                                                       conv:CoverFadeBehavior.IsEnabled="True"/>
                                                            </Grid>
                                                        </Border>

                                                        <!-- Title / Subtitle -->
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                                            <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="Medium"
                                                                       Foreground="{DynamicResource OnSurfaceBrush}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       MaxHeight="20"/>
                                                            <TextBlock FontSize="12"
                                                                       Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       MaxHeight="18">
                                                                <TextBlock.Text>
                                                                    <MultiBinding StringFormat="{}{0} - {1}">
                                                                        <Binding Path="Artist" />
                                                                        <Binding Path="Album" />
                                                                    </MultiBinding>
                                                                </TextBlock.Text>
                                                            </TextBlock>
                                                        </StackPanel>

                                                        <!-- Source indicator -->
                                                        <TextBlock Grid.Column="2" Text="{Binding SourceType}"
                                                                   FontSize="10"
                                                                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- ═══ Flat Filtered Results (visible when specific filter selected) ═══ -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="{Binding IsAllFilter, Converter={StaticResource InverseBoolToVisConverter}}">
                    <ItemsControl ItemsSource="{Binding FlatResults}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource SurfaceBrush}"
                                        CornerRadius="8" Margin="0,0,0,4" Padding="12,10"
                                        Cursor="Hand"
                                        MouseLeftButtonUp="ResultItem_Click">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="48"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Cover Art with type-aware corner radius -->
                                        <Border Grid.Column="0" Width="40" Height="40"
                                                CornerRadius="{Binding ., Converter={StaticResource ItemTypeToCornerRadiusConverter}}"
                                                Background="{DynamicResource SurfaceVariantBrush}"
                                                ClipToBounds="True">
                                            <Grid>
                                                <!-- Placeholder icon -->
                                                <Path Data="M12,3V12.26C11.5,12.09 11,12 10.5,12C8,12 6,14 6,16.5C6,19 8,21 10.5,21C13,21 15,19 15,16.5V6H19V3H12Z"
                                                      Fill="{DynamicResource OnSurfaceVariantBrush}"
                                                      Width="20" Height="20" Stretch="Uniform"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                <!-- Cover image -->
                                                <Image Source="{Binding CoverPath, Converter={StaticResource PathToImageConverter}, ConverterParameter=list}"
                                                       RenderOptions.BitmapScalingMode="HighQuality"
                                                       Stretch="UniformToFill"
                                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                                       conv:CoverFadeBehavior.IsEnabled="True"/>
                                            </Grid>
                                        </Border>

                                        <!-- Title / Subtitle -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                            <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="Medium"
                                                       Foreground="{DynamicResource OnSurfaceBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxHeight="20"/>
                                            <TextBlock FontSize="12"
                                                       Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxHeight="18">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0} - {1}">
                                                        <Binding Path="Artist" />
                                                        <Binding Path="Album" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Source indicator -->
                                        <TextBlock Grid.Column="2" Text="{Binding SourceType}"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- ═══ Empty Results State ═══════════════════════════════════ -->
            <StackPanel x:Name="EmptyResultsPanel"
                        Visibility="{Binding IsEmptyResults, Converter={StaticResource BooleanToVisibilityConverter}}"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                <!-- Search icon in circle -->
                <Border Width="96" Height="96" CornerRadius="48"
                        Background="{DynamicResource SurfaceVariantBrush}"
                        HorizontalAlignment="Center" Margin="0,0,0,20">
                    <Path Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z"
                          Fill="{DynamicResource OnSurfaceVariantBrush}" Width="36" Height="36"
                          Stretch="Uniform" HorizontalAlignment="Center"
                          VerticalAlignment="Center" Opacity="0.5"/>
                </Border>
                <!-- Dynamic "No results" message -->
                <TextBlock FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource OnSurfaceBrush}"
                           HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="400">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}No results for &quot;{0}&quot;">
                            <Binding Path="Query"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
                <TextBlock Text="Try a different spelling, check your spelling, or switch to a different search source."
                           FontSize="14" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           Margin="0,8,0,0" HorizontalAlignment="Center" TextWrapping="Wrap"
                           MaxWidth="400"/>
                <!-- Source mode toggle button -->
                <Button Margin="0,20,0,0" Padding="24,10"
                        FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                        Background="{DynamicResource SurfaceVariantBrush}"
                        Foreground="{DynamicResource OnSurfaceBrush}"
                        BorderThickness="0" HorizontalAlignment="Center"
                        Command="{Binding ToggleSourceModeCommand}">
                    <TextBlock>
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}Switch to {0}">
                                <Binding Path="SourceMode"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </Button>
            </StackPanel>

            <!-- ═══ Error State ═════════════════════════════════════════ -->
            <StackPanel x:Name="ErrorPanel"
                        Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Search failed" FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource OnSurfaceBrush}" HorizontalAlignment="Center"/>
                <TextBlock x:Name="ErrorText" Text="{Binding ErrorMessage}" FontSize="14"
                           Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           HorizontalAlignment="Center" Margin="0,8,0,0" TextWrapping="Wrap"
                           MaxWidth="400"/>
                <Button Content="Try Again" Margin="0,20,0,0" Padding="24,10"
                        FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                        Background="{DynamicResource PrimaryBrush}"
                        Foreground="{DynamicResource OnPrimaryBrush}"
                        BorderThickness="0" HorizontalAlignment="Center"
                        Command="{Binding SearchCommand}"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
