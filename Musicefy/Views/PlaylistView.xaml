<UserControl x:Class="Musicefy.Views.PlaylistView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Musicefy.Converters"
             Background="Transparent">

    <UserControl.Resources>
        <converters:PathToImageConverter x:Key="PathToImageConverter"/>
    </UserControl.Resources>

    <Grid>
        <!-- Layer 1: Dynamic gradient background -->
        <Rectangle x:Name="BgGradient" Fill="{Binding BackgroundGradient}"/>

        <!-- Layer 2: Scrollable content -->
        <ScrollViewer VerticalScrollBarVisibility="Hidden"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="24,0">

                <!-- Navigation bar -->
                <Grid Height="56">
                    <Button x:Name="BtnBack" Click="BtnBack_Click"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Width="40" Height="40"
                            HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Path Data="M20,11H7.83l5.59-5.59L12,4l-8,8 8,8 1.41-1.41L7.83,13H20v-2z"
                              Fill="{DynamicResource OnSurfaceBrush}" Width="24" Height="24" Stretch="Uniform"/>
                    </Button>
                </Grid>

                <!-- Playlist art block -->
                <StackPanel HorizontalAlignment="Center" Margin="0,8,0,0">
                    <Border Width="280" Height="280" CornerRadius="16"
                            ClipToBounds="True"
                            Background="{DynamicResource SurfaceVariantBrush}">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="36" ShadowDepth="8"
                                              Opacity="0.45" Color="Black"/>
                        </Border.Effect>
                        <Grid>
                            <Path Data="M12,2C6.48,2 2,6.48 2,12S6.48,22 12,22 22,17.52 22,12 17.52,2 12,2M12,16.5L7,11.5H10V6H14V11.5H17L12,16.5Z"
                                  Fill="{DynamicResource OnSurfaceBrush}" Opacity="0.3"
                                  Width="64" Height="64" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Image Source="{Binding CoverPath, Converter={StaticResource PathToImageConverter}}"
                                   Stretch="UniformToFill"/>
                        </Grid>
                    </Border>
                    <TextBlock Text="{Binding PlaylistName}" FontSize="28" FontWeight="Bold"
                               Foreground="{DynamicResource OnSurfaceBrush}" HorizontalAlignment="Center"
                               TextWrapping="Wrap" MaxWidth="480" Margin="0,20,0,0"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding CreatedAtText}" FontSize="13"
                               Foreground="{DynamicResource OnSurfaceVariantBrush}" HorizontalAlignment="Center"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Metadata chips row -->
                <WrapPanel HorizontalAlignment="Center" Margin="0,16,0,0">
                    <Border CornerRadius="20" Padding="10,6" Margin="0,0,8,8"
                            Background="{DynamicResource SurfaceContainerHighBrush}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M12,2C6.48,2 2,6.48 2,12S6.48,22 12,22 22,17.52 22,12 17.52,2 12,2M12,16.5L7,11.5H10V6H14V11.5H17L12,16.5Z"
                                  Width="14" Height="14" Stretch="Uniform" Fill="{DynamicResource OnSurfaceVariantBrush}" Opacity="0.8"
                                  VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding SongsCountText}" Margin="6,0,0,0" FontSize="13"
                                       Foreground="{DynamicResource OnSurfaceBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border CornerRadius="20" Padding="10,6" Margin="0,0,8,8"
                            Background="{DynamicResource SurfaceContainerHighBrush}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M15,12H16.5V16.25L19.36,17.94L18.61,19.16L15,17V12M12,2C17.52,2 22,6.48 22,12S17.52,22 12,22 2,17.52 2,12 6.48,2 12,2M12,4C7.58,4 4,7.58 4,12S7.58,20 12,20 20,16.42 20,12 16.42,4 12,4Z"
                                  Width="14" Height="14" Stretch="Uniform" Fill="{DynamicResource OnSurfaceVariantBrush}" Opacity="0.8"
                                  VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding TotalDurationText}" Margin="6,0,0,0" FontSize="13"
                                       Foreground="{DynamicResource OnSurfaceBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <!-- Action buttons row -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <!-- Rename button -->
                    <Button Width="40" Height="40" Background="Transparent"
                            BorderThickness="0" Cursor="Hand" Margin="0,0,16,0"
                            Command="{Binding RenamePlaylistCommand}" ToolTip="Rename playlist">
                        <Path Data="M3,17.25V21H6.75L17.81,9.94L14.06,6.19L3,17.25M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.13,5.12L18.88,8.87L20.71,7.04Z"
                              Fill="{DynamicResource OnSurfaceVariantBrush}" Opacity="0.7" Width="20" Height="20" Stretch="Uniform"/>
                    </Button>
                    <!-- Play button -->
                    <Button Height="44" Padding="24,0"
                            Background="{DynamicResource PrimaryBrush}" Foreground="{DynamicResource OnPrimaryBrush}"
                            BorderThickness="0" Cursor="Hand" Margin="0,0,16,0"
                            Command="{Binding PlayAllCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="22" Padding="{TemplateBinding Padding}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="M8,5V19L19,12L8,5Z" Fill="{DynamicResource OnPrimaryBrush}"
                                              Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0"/>
                                        <TextBlock Text="Play" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource OnPrimaryBrush}"/>
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- Shuffle button -->
                    <Button Height="44" Padding="24,0"
                            Background="{DynamicResource PrimaryBrush}" Foreground="{DynamicResource OnPrimaryBrush}"
                            BorderThickness="0" Cursor="Hand" Margin="0,0,16,0"
                            Command="{Binding ShuffleCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="22" Padding="{TemplateBinding Padding}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="M14.83,13.41L13.42,14.82L16.55,17.95L14.5,20H20V14.5L17.96,16.54L14.83,13.41M14.5,4L16.54,6.04L4,18.58L5.41,20L17.96,7.46L20,9.5V4H14.5M10.59,9.17L5.41,4L4,5.41L9.17,10.58L10.59,9.17Z"
                                              Fill="{DynamicResource OnPrimaryBrush}" Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0"/>
                                        <TextBlock Text="Shuffle" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource OnPrimaryBrush}"/>
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- Delete button -->
                    <Button Width="40" Height="40" Background="Transparent"
                            BorderThickness="0" Cursor="Hand" Margin="0,0,16,0"
                            Command="{Binding DeletePlaylistCommand}" ToolTip="Delete playlist">
                        <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"
                              Fill="{DynamicResource OnSurfaceVariantBrush}" Opacity="0.7" Width="20" Height="20" Stretch="Uniform"/>
                    </Button>
                    <!-- More options -->
                    <Button Width="40" Height="40" Background="Transparent"
                            BorderThickness="0" Cursor="Hand">
                        <Path Data="M12,8C13.1,8 14,7.1 14,6C14,4.9 13.1,4 12,4C10.9,4 10,4.9 10,6C10,7.1 10.9,8 12,8M12,10C10.9,10 10,10.9 10,12C10,13.1 10.9,14 12,14C13.1,14 14,13.1 14,12C14,10.9 13.1,10 12,10M12,16C10.9,16 10,16.9 10,18C10,19.1 10.9,20 12,20C13.1,20 14,19.1 14,18C14,16.9 13.1,16 12,16Z"
                              Fill="{DynamicResource OnSurfaceVariantBrush}" Opacity="0.7" Width="22" Height="22" Stretch="Uniform"/>
                    </Button>
                </StackPanel>

                <!-- Songs header -->
                <TextBlock Text="Songs" FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource OnSurfaceBrush}" Margin="0,24,0,12"/>

                <!-- Track list -->
                <ListView ItemsSource="{Binding Tracks}"
                          Background="Transparent" BorderThickness="0"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          VirtualizingPanel.IsVirtualizing="True">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border CornerRadius="12" Padding="8,10" Margin="0,0,0,4"
                                                Background="Transparent">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <ContentPresenter/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="52">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding TrackNumber}"
                                           FontSize="14" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                    <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="Medium"
                                               Foreground="{DynamicResource OnSurfaceBrush}" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Artist}" FontSize="12"
                                               Foreground="{DynamicResource OnSurfaceVariantBrush}" TextTrimming="CharacterEllipsis"
                                               Margin="0,3,0,0"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Duration, StringFormat='{}{0:mm\\:ss}'}"
                                           FontSize="13" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <!-- Remove from playlist button -->
                                <Button Grid.Column="3" Width="40" Height="40"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                                        Command="{Binding DataContext.RemoveTrackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}" ToolTip="Remove from playlist">
                                    <Path Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z"
                                          Fill="{DynamicResource OnSurfaceVariantBrush}" Opacity="0.5" Width="18" Height="18" Stretch="Uniform"/>
                                </Button>
                                <!-- More options button -->
                                <Button Grid.Column="4" Width="40" Height="40"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                                        Command="{Binding DataContext.MoreCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                    <Path Data="M12,8C13.1,8 14,7.1 14,6C14,4.9 13.1,4 12,4C10.9,4 10,4.9 10,6C10,7.1 10.9,8 12,8M12,10C10.9,10 10,10.9 10,12C10,13.1 10.9,14 12,14C13.1,14 14,13.1 14,12C14,10.9 13.1,10 12,10M12,16C10.9,16 10,16.9 10,18C10,19.1 10.9,20 12,20C13.1,20 14,19.1 14,18C14,16.9 13.1,16 12,16Z"
                                          Fill="{DynamicResource OnSurfaceVariantBrush}" Opacity="0.7" Width="20" Height="20" Stretch="Uniform"/>
                                </Button>
                                <Grid.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.PlayTrackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding}"/>
                                </Grid.InputBindings>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Bottom spacer -->
                <Border Height="80"/>

            </StackPanel>
        </ScrollViewer>

        <!-- Loading overlay -->
        <Grid Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
              HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="Loading..." FontSize="14" Foreground="{DynamicResource OnSurfaceVariantBrush}" Opacity="0.7"/>
        </Grid>
    </Grid>
</UserControl>
