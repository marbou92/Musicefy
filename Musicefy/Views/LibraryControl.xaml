<UserControl x:Class="Musicefy.Views.LibraryControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Musicefy.Controls"
             Background="Transparent">
    <Grid Margin="40,20,40,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,30">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Button x:Name="BtnBack" 
                        Content="←" 
                        FontSize="20" 
                        FontWeight="Bold"
                        Background="Transparent" 
                        BorderThickness="0" 
                        Foreground="{DynamicResource TextBrush}"
                        Margin="0,0,15,0"
                        Cursor="Hand"
                        Visibility="Collapsed"
                        Click="BtnBack_Click"/>
                
                <TextBlock x:Name="TxtHeaderTitle"
                           Text="Saved" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="{DynamicResource TextBrush}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Width="35" Height="35" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0">
                    <Path Data="M9,3L5,7H8V14H10V7H13L9,3M19,17H16V10H14V17H11L15,21L19,17Z" 
                          Fill="{DynamicResource MutedTextBrush}" Stretch="Uniform" Width="18"/>
                </Button>
                <Button Width="35" Height="35" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnAddPlaylist_Click">
                    <Path Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" 
                          Fill="{DynamicResource TextBrush}" Stretch="Uniform" Width="18"/>
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <ScrollViewer x:Name="LibraryCardsScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Visibility="Visible">
                <ItemsControl x:Name="LibraryItemsControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" Margin="0,0,-20,0"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Background="Transparent" BorderThickness="0" Margin="0,0,20,25" Cursor="Hand" Click="LibraryCard_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <StackPanel Width="140">
                                            <Border Background="{DynamicResource SecondaryBackgroundBrush}" 
                                                    Height="140" 
                                                    CornerRadius="12" 
                                                    Margin="0,0,0,10"
                                                    SnapsToDevicePixels="True">
                                                <Path Data="{Binding IconData}" 
                                                      Fill="{DynamicResource TextBrush}" 
                                                      Stretch="Uniform" 
                                                      Width="32" Height="32" 
                                                      HorizontalAlignment="Center" 
                                                      VerticalAlignment="Center"/>
                                            </Border>
                                            
                                            <TextBlock Text="{Binding Title}" 
                                                       FontWeight="SemiBold" 
                                                       FontSize="14" 
                                                       Foreground="{DynamicResource TextBrush}" 
                                                       Margin="2,0,0,2"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Subtitle}" 
                                                       FontSize="12" 
                                                       Foreground="{DynamicResource MutedTextBrush}" 
                                                       Margin="2,0,0,0"/>
                                        </StackPanel>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <controls:FolderLibraryControl x:Name="TrackListDisplayPanel" Visibility="Collapsed"/>
        </Grid>
    </Grid>
</UserControl>
