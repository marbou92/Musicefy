<UserControl x:Class="Musicefy.Views.LibraryControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Musicefy.Controls"
             xmlns:converters="clr-namespace:Musicefy.Converters"
             Background="Transparent"
             VerticalAlignment="Stretch"
             HorizontalAlignment="Stretch">

    <UserControl.Resources>
        <converters:PathToImageConverter x:Key="PathToImageConverter"/>

        <!-- Root library card (Favourites / Downloads / History / Folder) -->
        <Style x:Key="LibraryCardStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,0,24,28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CardContainer" Background="Transparent"
                                CornerRadius="16" Padding="8" SnapsToDevicePixels="True">
                            <StackPanel Width="140">
                                <Border x:Name="CoverArtContainer"
                                        Background="{DynamicResource SurfaceVariantBrush}"
                                        Height="140" CornerRadius="12" Margin="0,0,0,12"
                                        SnapsToDevicePixels="True"
                                        RenderTransformOrigin="0.5,0.5">
                                    <Border.RenderTransform>
                                        <TranslateTransform x:Name="CardLift" Y="0"/>
                                    </Border.RenderTransform>
                                    <Path Data="{Binding IconData}"
                                          Fill="{DynamicResource OnSurfaceBrush}" Opacity="0.85"
                                          Stretch="Uniform" Width="36" Height="36"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                           FontSize="14" Foreground="{DynamicResource OnSurfaceBrush}"
                                           Margin="4,0,4,2" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding Subtitle}" FontSize="12"
                                           Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                           Margin="4,0,4,4" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardContainer" Property="Background" Value="{DynamicResource SurfaceContainerHighBrush}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="CardLift"
                                                             Storyboard.TargetProperty="Y"
                                                             To="-4" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="CardLift"
                                                             Storyboard.TargetProperty="Y"
                                                             To="0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CardContainer" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small icon-only pill button -->
        <Style x:Key="IconPillButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Pill" Background="Transparent" CornerRadius="20">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Pill" Property="Background" Value="{DynamicResource SurfaceVariantBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Pill" Property="Background" Value="{DynamicResource OutlineBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Track row favourite-heart inline button -->
        <Style x:Key="HeartButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Track list row container -->
        <Style x:Key="TrackRowStyle" TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="RowBorder" CornerRadius="14"
                                Background="{TemplateBinding Background}"
                                Padding="12,8" SnapsToDevicePixels="True">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RowBorder" Property="Background" Value="{DynamicResource SurfaceVariantBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="RowBorder" Property="Background" Value="{DynamicResource OutlineBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="40,24,40,24" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header bar ────────────────────────────────────────────────── -->
        <Grid Grid.Row="0" Margin="4,0,4,24">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Button x:Name="BtnBack" Style="{StaticResource IconPillButtonStyle}"
                        Margin="0,0,12,0"
                        Visibility="{Binding IsBackVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Command="{Binding BackCommand}">
                    <Path Data="M20,11H7.83l5.59-5.59L12,4l-8,8l8,8l1.41-1.41L7.83,13H20V11z"
                          Fill="{DynamicResource OnSurfaceBrush}" Stretch="Uniform" Width="20" Height="20"/>
                </Button>

                <TextBlock x:Name="TxtHeaderTitle" Text="{Binding HeaderTitle}"
                           FontSize="28" FontWeight="SemiBold"
                           Foreground="{DynamicResource OnSurfaceBrush}" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <!-- Only visible when viewing a special playlist — refreshes the list -->
                <Button x:Name="BtnRefreshSpecial" Style="{StaticResource IconPillButtonStyle}"
                        Margin="0,0,8,0"
                        Visibility="{Binding IsRefreshVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Command="{Binding RefreshCommand}" ToolTip="Refresh">
                    <Path Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z"
                          Fill="{DynamicResource OnSurfaceVariantBrush}" Stretch="Uniform" Width="18" Height="18"/>
                </Button>

                <Button x:Name="BtnAddPlaylist" Style="{StaticResource IconPillButtonStyle}"
                        Command="{Binding AddPlaylistCommand}" ToolTip="New Playlist">
                    <Path Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z"
                          Fill="{DynamicResource OnSurfaceBrush}" Stretch="Uniform" Width="20" Height="20"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ── Content area ──────────────────────────────────────────────── -->
        <Grid Grid.Row="1" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">

            <!-- Panel A: Root cards (Favourites / Downloads / History / Folder) -->
            <ScrollViewer x:Name="LibraryCardsScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Visibility="{Binding CardsPanelVisibility}" VerticalAlignment="Stretch">
                <ItemsControl x:Name="LibraryItemsControl"
                              ItemsSource="{Binding RootCards}"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" Margin="0,0,-24,0"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource LibraryCardStyle}"
                                    Command="{Binding DataContext.CardClickCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Panel B: Special collection track list (Fav / History / Downloads) -->
            <Grid x:Name="SpecialCollectionPanel" Visibility="Collapsed"
                  VerticalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Track count + empty state -->
                <StackPanel Grid.Row="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="4,0,0,16">
                    <TextBlock x:Name="TxtTrackCount"
                               Text="{Binding TrackCountText}" FontSize="13"
                               Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
                    <TextBlock x:Name="TxtEmptyHint"
                               Text=" · Add songs by scanning a folder in the Folder section."
                               FontSize="13" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                               Visibility="{Binding IsEmptyHintVisible}"/>
                </StackPanel>

                <!-- Track list -->
                <ListView x:Name="SpecialListView" Grid.Row="1"
                          Background="Transparent" BorderThickness="0"
                          Foreground="{DynamicResource OnSurfaceBrush}"
                          ItemsSource="{Binding SpecialTracks}"
                          SelectedItem="{Binding SelectedTrack}"
                          VerticalAlignment="Stretch"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          ItemContainerStyle="{StaticResource TrackRowStyle}"
                          Padding="0,4">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="52">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="64"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>

                                <!-- Cover + Title + Artist -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="44" Height="44" CornerRadius="12"
                                            ClipToBounds="True" Margin="0,0,14,0"
                                            Background="{DynamicResource SurfaceVariantBrush}"
                                            SnapsToDevicePixels="True">
                                        <Image Source="{Binding CoverPath, Converter={StaticResource PathToImageConverter}}"
                                               RenderOptions.BitmapScalingMode="HighQuality" Stretch="UniformToFill"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center" MaxWidth="280">
                                        <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="Medium"
                                                   Foreground="{DynamicResource OnSurfaceBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Artist}" FontSize="12"
                                                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                                   TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Album -->
                                <TextBlock Grid.Column="1" Text="{Binding Album}" FontSize="13"
                                           Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>

                                <!-- Duration -->
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Duration, StringFormat='{}{0:mm\\:ss}'}"
                                           FontSize="13" FontWeight="Medium"
                                           Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                <!-- Favourite toggle heart -->
                                <Button Grid.Column="3"
                                        Style="{StaticResource HeartButtonStyle}"
                                        Command="{Binding DataContext.ToggleFavouriteCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="Toggle Favourite"
                                        VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Path x:Name="HeartIcon"
                                          Data="M12,21.35L10.55,20.03C5.4,15.36 2,12.27 2,8.5C2,5.41 4.42,3 7.5,3C9.24,3 10.91,3.81 12,5.08C13.09,3.81 14.76,3 16.5,3C19.58,3 22,5.41 22,8.5C22,12.27 18.6,15.36 13.45,20.03L12,21.35Z"
                                          Width="18" Height="18" Stretch="Uniform"
                                          Fill="{DynamicResource OnSurfaceVariantBrush}"/>
                                </Button>
                            </Grid>

                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsFavourite}" Value="True">
                                    <Setter TargetName="HeartIcon" Property="Fill"
                                            Value="{DynamicResource PrimaryBrush}"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListView.ItemTemplate>

                    <!-- Right-click context menu on each track -->
                    <ListView.ContextMenu>
                          <ContextMenu>
                              <MenuItem Header="▶  Play"
                                        Command="{Binding DataContext.PlaySelectedTrackCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding PlacementTarget.SelectedItem.DataContext,
                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                              <MenuItem Header="+ Play Next"
                                        Command="{Binding DataContext.ContextQueueNextCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding PlacementTarget.SelectedItem.DataContext,
                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                              <Separator/>
                              <MenuItem Header="♡  Toggle Favourite"
                                        Command="{Binding DataContext.ContextToggleFavouriteCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding PlacementTarget.SelectedItem.DataContext,
                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                              <Separator/>
                              <MenuItem Header="📂  Show in Explorer"
                                        Command="{Binding DataContext.ContextShowInExplorerCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding PlacementTarget.SelectedItem.DataContext,
                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                          </ContextMenu>
                      </ListView.ContextMenu>
                  </ListView>
              </Grid>

            <!-- Panel C: Folder browser (FolderLibraryControl) -->
            <controls:FolderLibraryControl x:Name="TrackListDisplayPanel"
                                           Visibility="{Binding FolderPanelVisibility}"
                                           VerticalAlignment="Stretch"/>
        </Grid>
    </Grid>
</UserControl>
