<UserControl x:Class="Musicefy.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             VerticalAlignment="Stretch"
             HorizontalAlignment="Stretch">

    <UserControl.Resources>
        <!-- M3 Settings Sidebar Tab -->
        <Style x:Key="SidebarTabStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource OnSurfaceVariantBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="TabBorder" Background="{TemplateBinding Background}" CornerRadius="8" Margin="8,2" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource OnSurfaceBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource SurfaceContainerHighBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sub-sidebar -->
        <Border Grid.Column="0" 
                Background="{DynamicResource SurfaceContainerLowBrush}" 
                BorderBrush="Transparent"
                BorderThickness="0">
            <StackPanel Margin="10,20,10,10">
                <TextBlock Text="Settings" FontSize="22" FontWeight="Bold" 
                           Margin="20,0,0,25" 
                           Foreground="{DynamicResource OnSurfaceBrush}"/>

                <RadioButton x:Name="AppearanceButton" Style="{StaticResource SidebarTabStyle}" 
                             GroupName="SettingsTabs" IsChecked="True"
                             Checked="AppearanceButton_Checked">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M12 2C6.49 2 2 6.49 2 12s4.49 10 10 10c.55 0 1-.45 1-1 0-.28-.11-.53-.29-.71-.18-.18-.29-.43-.29-.71 0-.55.45-1 1-1H16c3.31 0 6-2.69 6-6 0-4.96-4.49-9-10-9zm-5.5 8.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5S8 8.17 8 9s-.67 1.5-1.5 1.5zm3.5-2.5c-.83 0-1.5-.67-1.5-1.5S9.17 5 10 5s1.5.67 1.5 1.5S10.83 8 10 8zm5 0c-.83 0-1.5-.67-1.5-1.5S14.17 5 15 5s1.5.67 1.5 1.5S15.83 8 15 8zm1.5 4.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"
                              Width="18" Height="18" Stretch="Uniform"
                              Fill="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"
                              Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <StackPanel>
                            <TextBlock Text="Appearance" FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock Text="Theme &amp; palettes" FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </RadioButton>

                <RadioButton x:Name="DownloadsButton" Style="{StaticResource SidebarTabStyle}" 
                             GroupName="SettingsTabs"
                             Checked="DownloadsButton_Checked">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"
                              Width="18" Height="18" Stretch="Uniform"
                              Fill="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"
                              Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <StackPanel>
                            <TextBlock Text="Downloads" FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock Text="Cache &amp; limits" FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </RadioButton>

                <RadioButton x:Name="SourcesButton" Style="{StaticResource SidebarTabStyle}" 
                             GroupName="SettingsTabs"
                             Checked="SourcesButton_Checked">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M17 7h-4v2h4c1.65 0 3 1.35 3 3s-1.35 3-3 3h-4v2h4c2.76 0 5-2.24 5-5s-2.24-5-5-5zm-6 8H7c-1.65 0-3-1.35-3-3s1.35-3 3-3h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-2zm-3-4h8v2H8v-2z"
                              Width="18" Height="18" Stretch="Uniform"
                              Fill="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"
                              Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <StackPanel>
                            <TextBlock Text="Sources" FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock Text="Music sources &amp; home screen" FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </RadioButton>
            </StackPanel>
        </Border>

        <!-- Content area -->
        <Grid Grid.Column="1" Margin="40,30,40,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" x:Name="SectionTitle" 
                       Text="Appearance Settings" 
                       FontSize="24" FontWeight="Bold" 
                       Margin="0,0,0,25" 
                       Foreground="{DynamicResource OnSurfaceBrush}"/>

            <ContentControl x:Name="SettingsContent" 
                            Grid.Row="1"
                            VerticalAlignment="Stretch"
                            HorizontalAlignment="Stretch"/>
        </Grid>
    </Grid>
</UserControl>
