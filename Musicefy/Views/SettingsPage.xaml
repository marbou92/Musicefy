<UserControl x:Class="Musicefy.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             VerticalAlignment="Stretch"
             HorizontalAlignment="Stretch">

    <UserControl.Resources>
        <!-- M3 Settings Sidebar Tab -->
        <Style x:Key="SidebarTabStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource OnSurfaceVariantBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="TabBorder" Background="{TemplateBinding Background}" CornerRadius="8" Margin="8,2" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource OnSurfaceBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource SurfaceContainerHighBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sub-sidebar -->
        <Border Grid.Column="0"
                Background="{DynamicResource SurfaceContainerLowBrush}"
                BorderBrush="Transparent"
                BorderThickness="0">
            <StackPanel Margin="10,20,10,10">
                <TextBlock Text="Settings" FontSize="22" FontWeight="Bold"
                           Margin="20,0,0,25"
                           Foreground="{DynamicResource OnSurfaceBrush}"/>

                <!-- Sprint 4: Settings Search Bar -->
                <Border Background="{DynamicResource SurfaceContainerHighBrush}"
                        CornerRadius="8" Margin="8,0,8,12" Padding="8,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Path Grid.Column="0" Data="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"
                              Width="16" Height="16" Stretch="Uniform"
                              Fill="{DynamicResource OnSurfaceVariantBrush}"
                              Margin="4,0,8,0" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="SearchBox"
                                 Text="{Binding SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="{DynamicResource OnSurfaceBrush}"
                                 CaretBrush="{DynamicResource OnSurfaceBrush}"
                                 FontSize="12" VerticalContentAlignment="Center"
                                 ToolTip="Search settings…"/>
                    </Grid>
                </Border>

                <!-- Search Results Panel (visible when searching) -->
                <ItemsControl x:Name="SearchResultsPanel"
                              ItemsSource="{Binding SearchResults}"
                              Visibility="Collapsed" Margin="4,0,4,8">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource SurfaceContainerHighBrush}"
                                    CornerRadius="6" Margin="0,2" Padding="10,8"
                                    Cursor="Hand" MouseLeftButtonUp="SearchResult_Click"
                                    Tag="{Binding}">
                                <StackPanel>
                                    <TextBlock Text="{Binding Label}" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource OnSurfaceBrush}"/>
                                    <TextBlock Text="{Binding Category}" FontSize="10"
                                               Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Tabs (hidden when searching) -->
                <StackPanel x:Name="TabsPanel">
                    <RadioButton x:Name="AppearanceButton" Style="{StaticResource SidebarTabStyle}"
                                 GroupName="SettingsTabs" IsChecked="True"
                                 Checked="AppearanceButton_Checked">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M12 2C6.49 2 2 6.49 2 12s4.49 10 10 10c.55 0 1-.45 1-1 0-.28-.11-.53-.29-.71-.18-.18-.29-.43-.29-.71 0-.55.45-1 1-1H16c3.31 0 6-2.69 6-6 0-4.96-4.49-9-10-9zm-5.5 8.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5S8 8.17 8 9s-.67 1.5-1.5 1.5zm3.5-2.5c-.83 0-1.5-.67-1.5-1.5S9.17 5 10 5s1.5.67 1.5 1.5S10.83 8 10 8zm5 0c-.83 0-1.5-.67-1.5-1.5S14.17 5 15 5s1.5.67 1.5 1.5S15.83 8 15 8zm1.5 4.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"
                                  Width="18" Height="18" Stretch="Uniform"
                                  Fill="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"
                                  Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="Appearance" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Text="Theme &amp; palettes" FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="DownloadsButton" Style="{StaticResource SidebarTabStyle}"
                                 GroupName="SettingsTabs"
                                 Checked="DownloadsButton_Checked">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"
                                  Width="18" Height="18" Stretch="Uniform"
                                  Fill="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"
                                  Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="Storage &amp; Sources" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Text="Local folders, YouTube, downloads" FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </RadioButton>

                    <!-- Sprint 5: History tab -->
                    <RadioButton x:Name="HistoryButton" Style="{StaticResource SidebarTabStyle}"
                                 GroupName="SettingsTabs"
                                 Checked="HistoryButton_Checked">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M13 3a9 9 0 0 0-9 9H1l3.89 3.89.07.14L9 12H6c0-3.87 3.13-7 7-7s7 3.13 7 7-3.13 7-7 7c-1.93 0-3.68-.79-4.94-2.06l-1.42 1.42A8.954 8.954 0 0 0 13 21a9 9 0 0 0 0-18zm-1 5v5l4.28 2.54.72-1.21-3.5-2.08V8H12z"
                                  Width="18" Height="18" Stretch="Uniform"
                                  Fill="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"
                                  Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="History" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Text="Recently played" FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </RadioButton>

                    <!-- Sprint 5: Stats tab -->
                    <RadioButton x:Name="StatsButton" Style="{StaticResource SidebarTabStyle}"
                                 GroupName="SettingsTabs"
                                 Checked="StatsButton_Checked">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M5 9.2h3V19H5zM10.6 5h2.8v14h-2.8zm5.6 8H19v6h-2.8z"
                                  Width="18" Height="18" Stretch="Uniform"
                                  Fill="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"
                                  Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="Stats" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Text="Listening activity" FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </RadioButton>

                    <!-- Sprint 6: Backup & Restore tab -->
                    <RadioButton x:Name="BackupButton" Style="{StaticResource SidebarTabStyle}"
                                 GroupName="SettingsTabs"
                                 Checked="BackupButton_Checked">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M19 12v7H5v-7H3v7c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2v-7h-2zm-6 .67l2.59-2.58L17 11.5l-5 5-5-5 1.41-1.41L11 12.67V3h2z"
                                  Width="18" Height="18" Stretch="Uniform"
                                  Fill="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"
                                  Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="Backup" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Text="Export &amp; restore" FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Content area -->
        <Grid Grid.Column="1" Margin="40,30,40,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" x:Name="SectionTitle"
                       Text="Appearance Settings"
                       FontSize="24" FontWeight="Bold"
                       Margin="0,0,0,25"
                       Foreground="{DynamicResource OnSurfaceBrush}"/>

            <ContentControl x:Name="SettingsContent"
                            Grid.Row="1"
                            VerticalAlignment="Stretch"
                            HorizontalAlignment="Stretch"/>
        </Grid>
    </Grid>
</UserControl>
