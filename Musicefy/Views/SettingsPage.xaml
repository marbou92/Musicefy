<UserControl x:Class="Musicefy.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             VerticalAlignment="Stretch"
             HorizontalAlignment="Stretch">

    <UserControl.Resources>
        <!-- M3 Settings Sidebar Tab -->
        <Style x:Key="SidebarTabStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource OnSurfaceVariantBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="TabBorder" Background="{TemplateBinding Background}" CornerRadius="8" Margin="8,2" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource OnSurfaceBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource SurfaceContainerHighBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sub-sidebar -->
        <Border Grid.Column="0"
                Background="{DynamicResource SurfaceContainerLowBrush}"
                BorderBrush="Transparent"
                BorderThickness="0">
            <StackPanel Margin="10,20,10,10">
                <TextBlock Text="Settings" FontSize="22" FontWeight="Bold"
                           Margin="20,0,0,25"
                           Foreground="{DynamicResource OnSurfaceBrush}"/>

                <!-- Sprint 4: Settings Search Bar -->
                <Border Background="{DynamicResource SurfaceContainerHighBrush}"
                        CornerRadius="8" Margin="8,0,8,12" Padding="8,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Path Grid.Column="0" Data="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"
                              Width="16" Height="16" Stretch="Uniform"
                              Fill="{DynamicResource OnSurfaceVariantBrush}"
                              Margin="4,0,8,0" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="SearchBox"
                                 Text="{Binding SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="{DynamicResource OnSurfaceBrush}"
                                 CaretBrush="{DynamicResource OnSurfaceBrush}"
                                 FontSize="12" VerticalContentAlignment="Center"
                                 ToolTip="Search settings…"/>
                    </Grid>
                </Border>

                <!-- Search Results Panel (visible when searching) -->
                <ItemsControl x:Name="SearchResultsPanel"
                              ItemsSource="{Binding SearchResults}"
                              Visibility="Collapsed" Margin="4,0,4,8">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource SurfaceContainerHighBrush}"
                                    CornerRadius="6" Margin="0,2" Padding="10,8"
                                    Cursor="Hand" MouseLeftButtonUp="SearchResult_Click"
                                    Tag="{Binding}">
                                <StackPanel>
                                    <TextBlock Text="{Binding Label}" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource OnSurfaceBrush}"/>
                                    <TextBlock Text="{Binding Category}" FontSize="10"
                                               Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Tabs (hidden when searching) -->
                <StackPanel x:Name="TabsPanel">
                    <!-- Account -->
                    <RadioButton x:Name="AccountButton" Style="{StaticResource SidebarTabStyle}"
                                 GroupName="SettingsTabs" IsChecked="True"
                                 Checked="AccountButton_Checked">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"
                                  Width="18" Height="18" Stretch="Uniform"
                                  Fill="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"
                                  Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="Account" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Text="YouTube login" FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </RadioButton>

                    <!-- Appearance -->
                    <RadioButton x:Name="AppearanceButton" Style="{StaticResource SidebarTabStyle}"
                                 GroupName="SettingsTabs"
                                 Checked="AppearanceButton_Checked">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M12 2C6.49 2 2 6.49 2 12s4.49 10 10 10c.55 0 1-.45 1-1 0-.28-.11-.53-.29-.71-.18-.18-.29-.43-.29-.71 0-.55.45-1 1-1H16c3.31 0 6-2.69 6-6 0-4.96-4.49-9-10-9zm-5.5 8.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5S8 8.17 8 9s-.67 1.5-1.5 1.5zm3.5-2.5c-.83 0-1.5-.67-1.5-1.5S9.17 5 10 5s1.5.67 1.5 1.5S10.83 8 10 8zm5 0c-.83 0-1.5-.67-1.5-1.5S14.17 5 15 5s1.5.67 1.5 1.5S15.83 8 15 8zm1.5 4.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"
                                  Width="18" Height="18" Stretch="Uniform"
                                  Fill="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"
                                  Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="Appearance" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Text="Theme &amp; palettes" FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </RadioButton>

                    <!-- Player & Audio -->
                    <RadioButton x:Name="PlayerAudioButton" Style="{StaticResource SidebarTabStyle}"
                                 GroupName="SettingsTabs"
                                 Checked="PlayerAudioButton_Checked">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M12 3v9.28c-.47-.17-.97-.28-1.5-.28C8.01 12 6 14.01 6 16.5S8.01 21 10.5 21c2.31 0 4.2-1.75 4.45-4H15V6h4V3h-7z"
                                  Width="18" Height="18" Stretch="Uniform"
                                  Fill="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"
                                  Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="Player &amp; Audio" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Text="Playback &amp; SponsorBlock" FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </RadioButton>

                    <!-- Content -->
                    <RadioButton x:Name="ContentButton" Style="{StaticResource SidebarTabStyle}"
                                 GroupName="SettingsTabs"
                                 Checked="ContentButton_Checked">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M20 6h-8l-2-2H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm0 12H4V8h16v10z"
                                  Width="18" Height="18" Stretch="Uniform"
                                  Fill="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"
                                  Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="Content" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Text="Lyrics &amp; home screen" FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </RadioButton>

                    <!-- Storage -->
                    <RadioButton x:Name="DownloadsButton" Style="{StaticResource SidebarTabStyle}"
                                 GroupName="SettingsTabs"
                                 Checked="DownloadsButton_Checked">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"
                                  Width="18" Height="18" Stretch="Uniform"
                                  Fill="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"
                                  Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="Storage" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Text="Downloads &amp; folders" FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </RadioButton>

                    <!-- Backup -->
                    <RadioButton x:Name="BackupButton" Style="{StaticResource SidebarTabStyle}"
                                 GroupName="SettingsTabs"
                                 Checked="BackupButton_Checked">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M19 12v7H5v-7H3v7c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2v-7h-2zm-6 .67l2.59-2.58L17 11.5l-5 5-5-5 1.41-1.41L11 12.67V3h2z"
                                  Width="18" Height="18" Stretch="Uniform"
                                  Fill="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"
                                  Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="Backup" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Text="Export &amp; restore" FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </RadioButton>

                    <!-- About -->
                    <RadioButton x:Name="AboutButton" Style="{StaticResource SidebarTabStyle}"
                                 GroupName="SettingsTabs"
                                 Checked="AboutButton_Checked">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M11 17h2v-6h-2v6zm1-15C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"
                                  Width="18" Height="18" Stretch="Uniform"
                                  Fill="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"
                                  Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="About" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Text="App info" FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Content area -->
        <Grid Grid.Column="1" Margin="40,30,40,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" x:Name="SectionTitle"
                       Text="Appearance Settings"
                       FontSize="24" FontWeight="Bold"
                       Margin="0,0,0,25"
                       Foreground="{DynamicResource OnSurfaceBrush}"/>

            <ContentControl x:Name="SettingsContent"
                            Grid.Row="1"
                            VerticalAlignment="Stretch"
                            HorizontalAlignment="Stretch"/>
        </Grid>
    </Grid>
</UserControl>
