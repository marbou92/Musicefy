<UserControl x:Class="Musicefy.Views.RepositoriesSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:Musicefy.Core.Models;assembly=Musicefy.Core"
             Background="Transparent">

    <UserControl.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource OnSurfaceBrush}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource OnSurfaceBrush}"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Foreground" Value="{DynamicResource OnSurfaceBrush}"/>
        </Style>

        <Style x:Key="SectionSubtitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource OnSurfaceVariantBrush}"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="PrimaryActionButton" TargetType="Button" BasedOn="{StaticResource TonalButtonStyle}">
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="InstallButtonStyle" TargetType="Button" BasedOn="{StaticResource TonalButtonStyle}">
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="RemoveRepoButtonStyle" TargetType="Button" BasedOn="{StaticResource TonalButtonStyle}">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- Converter: returns "Install" if not installed, "Installed" otherwise.
             We do this via DataTrigger inside the Button itself rather than a converter. -->
    </UserControl.Resources>

    <Grid Margin="10,0,10,10">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Vertical">

                <!-- Header -->
                <Grid Margin="4,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Extension Repositories" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource OnSurfaceBrush}"/>
                        <TextBlock Text="Add community repositories and install their extensions. Anyone can host a repo — see the Developer Guide below."
                                   Foreground="{DynamicResource OnSurfaceVariantBrush}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                    <Button Grid.Column="1" Command="{Binding OpenDeveloperGuideCommand}"
                            Style="{StaticResource PrimaryActionButton}"
                            VerticalAlignment="Center"
                            ToolTip="Open the Musicefy-Extensions repo on GitHub — docs, samples, and the official repo.json">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Data="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"
                                  Width="14" Height="14" Stretch="Uniform"
                                  Fill="{DynamicResource OnPrimaryBrush}" Margin="0,0,6,0"/>
                            <TextBlock Text="Developer Guide"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Add Repository -->
                <Border Background="{DynamicResource SurfaceVariantBrush}" CornerRadius="12" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Add Repository" Style="{StaticResource SectionHeaderStyle}"/>
                        <TextBlock Text="Paste the URL of a repository manifest (repo.json). The official Musicefy repository is added by default."
                                   Style="{StaticResource SectionSubtitleStyle}"/>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{DynamicResource SurfaceVariantBrush}" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1" CornerRadius="10" Height="38" Margin="0,0,8,0">
                                <TextBox Text="{Binding RepoUrlInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Paste a repo manifest URL (e.g. https://example.com/repo.json)" VerticalAlignment="Center"/>
                            </Border>
                            <Button Grid.Column="1" Content="Add" Command="{Binding AddRepoCommand}"
                                    Style="{StaticResource PrimaryActionButton}" Width="80"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Repositories list -->
                <ItemsControl ItemsSource="{Binding Repos}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:ExtensionRepoManifest}">
                            <Border Background="{DynamicResource SurfaceVariantBrush}" CornerRadius="12" Padding="16" Margin="0,0,0,12">
                                <StackPanel>
                                    <!-- Repo header -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Repo icon -->
                                        <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20"
                                                Background="{DynamicResource PrimaryContainerBrush}" Margin="0,0,12,0">
                                            <Path Data="M4,6H20V8H4V6M4,11H20V13H4V11M4,16H20V18H4V16Z"
                                                  Width="20" Height="20" Stretch="Uniform"
                                                  Fill="{DynamicResource PrimaryBrush}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="15" Foreground="{DynamicResource OnSurfaceBrush}" VerticalAlignment="Center"/>
                                                <!-- "Official" badge -->
                                                <Border Background="{DynamicResource PrimaryContainerBrush}" CornerRadius="4" Padding="8,2" VerticalAlignment="Center" Margin="8,0,0,0">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Url}" Value="https://raw.githubusercontent.com/marbou92/Musicefy-Extensions/main/repo.json">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="Official" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource OnPrimaryContainerBrush}"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Description}" FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Url}" FontSize="9" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,2,0,0" MaxWidth="500" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <!-- Extension count badge -->
                                        <Border Grid.Column="2" Background="{DynamicResource SurfaceContainerHighBrush}" CornerRadius="6" Padding="10,4" VerticalAlignment="Center" Margin="0,0,8,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Extensions.Count}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource OnSurfaceBrush}"/>
                                                <TextBlock Text=" extensions" FontSize="10" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Remove repo button (hidden for official repo) -->
                                        <Button Grid.Column="3" Content="Remove"
                                                Command="{Binding DataContext.RemoveRepoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" VerticalAlignment="Center">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource RemoveRepoButtonStyle}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Url}" Value="https://raw.githubusercontent.com/marbou92/Musicefy-Extensions/main/repo.json">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>

                                    <!-- Extensions in this repo -->
                                    <ItemsControl ItemsSource="{Binding Extensions}" Margin="0,12,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type models:ExtensionManifest}">
                                                <Border Background="{DynamicResource SurfaceContainerLowBrush}" CornerRadius="8" Padding="12,10" Margin="0,3">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Extension icon -->
                                                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18"
                                                                Background="{DynamicResource PrimaryBrush}" Margin="0,0,12,0">
                                                            <Path Data="{Binding SourceType, Converter={StaticResource IconGlyphConverter}}"
                                                                  Width="18" Height="18" Stretch="Uniform"
                                                                  Fill="{DynamicResource OnPrimaryBrush}"
                                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>

                                                        <!-- Extension info -->
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource OnSurfaceBrush}" VerticalAlignment="Center"/>
                                                                <TextBlock Text="{Binding Version, StringFormat=' v{0}'}" FontSize="10" Foreground="{DynamicResource OnSurfaceVariantBrush}" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                                                <TextBlock Text="{Binding Author, StringFormat='  ·  by {0}'}" FontSize="10" Foreground="{DynamicResource OnSurfaceVariantBrush}" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                                            </StackPanel>
                                                            <TextBlock Text="{Binding Description}" FontSize="10" Foreground="{DynamicResource OnSurfaceVariantBrush}" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                                        </StackPanel>

                                                        <!-- Install / Installed badge -->
                                                        <!-- We don't have a per-item VM, so we rely on the parent VM
                                                             IsExtensionInstalled. For binding simplicity we always show
                                                             the Install button; the VM's InstallAsync checks for
                                                             already-installed state and shows a message. -->
                                                        <Button Grid.Column="2" Content="Install"
                                                                Style="{StaticResource InstallButtonStyle}"
                                                                Command="{Binding DataContext.InstallCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Margin="8,0,0,0" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty state when no repos loaded -->
                <Border Background="{DynamicResource SurfaceVariantBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,12">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Repos.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="No repositories loaded" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource OnSurfaceVariantBrush}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock Text="Click Refresh or add a repository URL above."
                                   FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Tip footer -->
                <TextBlock Text="Installed extensions appear in the Extensions tab. The Local source provider is always installed and cannot be removed."
                           FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           HorizontalAlignment="Center" Margin="0,4,0,10" TextWrapping="Wrap" TextAlignment="Center"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
