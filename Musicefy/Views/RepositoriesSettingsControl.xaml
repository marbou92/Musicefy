<UserControl x:Class="Musicefy.Views.RepositoriesSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10,0,10,10">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Vertical">

                <TextBlock Text="Extension Repositories" FontSize="22" FontWeight="Bold" Margin="4,0,0,4" Foreground="{DynamicResource ForegroundBrush}"/>
                <TextBlock Text="Add and manage extension repositories from the community." Foreground="{DynamicResource MutedTextBrush}" Margin="4,0,0,20" FontSize="12"/>

                <Border Background="{DynamicResource SecondaryBackgroundBrush}" CornerRadius="12" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Add Repository" FontWeight="Bold" FontSize="13" Margin="0,0,0,10" Foreground="{DynamicResource ForegroundBrush}"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{DynamicResource SecondaryBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10" Height="38" Margin="0,0,8,0">
                                <TextBox Text="{Binding RepoUrlInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Paste a repo manifest URL" VerticalAlignment="Center"/>
                            </Border>
                            <Button Grid.Column="1" Content="Add" Command="{Binding AddRepoCommand}" Width="80"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <ItemsControl ItemsSource="{Binding Repos}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource SecondaryBackgroundBrush}" CornerRadius="12" Padding="16" Margin="0,0,0,12">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="15" Foreground="{DynamicResource ForegroundBrush}"/>
                                            <TextBlock Text="{Binding Description}" FontSize="11" Foreground="{DynamicResource MutedTextBrush}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" Background="#2c3e50" CornerRadius="4" Padding="8,2" VerticalAlignment="Center" Margin="0,0,8,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Url}" Value="https://raw.githubusercontent.com/marbou92/Musicefy-Extensions/main/repo.json">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="Official" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                        </Border>
                                        <TextBlock Grid.Column="2" Text="{Binding Url}" FontSize="9" Foreground="{DynamicResource MutedTextBrush}" VerticalAlignment="Center" MaxWidth="200" TextTrimming="CharacterEllipsis"/>
                                    </Grid>

                                    <ItemsControl ItemsSource="{Binding Extensions}" Margin="0,8,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource BackgroundBrush}" CornerRadius="8" Padding="10,8" Margin="0,2">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <Border Grid.Column="0" Width="28" Height="28" CornerRadius="14"
                                                                Background="{DynamicResource AccentBrush}" Margin="0,0,10,0">
                                                            <Path Data="{Binding SourceType, Converter={StaticResource IconGlyphConverter}}"
                                                                  Width="14" Height="14" Stretch="Uniform"
                                                                  Fill="White"
                                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>

                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource ForegroundBrush}"/>
                                                                <TextBlock Text="{Binding Version, StringFormat=' v{0}'}" FontSize="10" Foreground="{DynamicResource MutedTextBrush}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                                            </StackPanel>
                                                            <TextBlock Text="{Binding Description}" FontSize="10" Foreground="{DynamicResource MutedTextBrush}" TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>

                                                        <TextBlock Grid.Column="2" Text="Browse" FontSize="11" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Button Content="Remove Repo" HorizontalAlignment="Right" Margin="0,6,0,0"
                                            Command="{Binding DataContext.RemoveRepoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Foreground="#e74c3c" Background="Transparent" FontSize="11" Padding="10,4">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Url}" Value="https://raw.githubusercontent.com/marbou92/Musicefy-Extensions/main/repo.json">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="Tip: Installed extensions appear in the Extensions tab."
                           FontSize="11" Foreground="{DynamicResource MutedTextBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,10"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
