<Window x:Class="Musicefy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Musicefy"
        Height="720" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}">

    <DockPanel LastChildFill="True">

        <!-- Sidebar -->
        <StackPanel DockPanel.Dock="Left" Width="80" Background="{DynamicResource SecondaryBackgroundBrush}">
            <Button Content="🏠" ToolTip="Home" Style="{StaticResource SidebarButtonStyle}"/>
            <Button Content="🔍" ToolTip="Search" Style="{StaticResource SidebarButtonStyle}"/>
            <Button Content="🎵" ToolTip="Library" Style="{StaticResource SidebarButtonStyle}"/>
            <Button Content="⚙" ToolTip="Settings" Style="{StaticResource SidebarButtonStyle}" Click="OpenSettings_Click"/>
        </StackPanel>

        <!-- Main Content -->
        <TabControl x:Name="MainTabControl" Margin="12">
            <!-- Favourites -->
            <TabItem Header="Favourites">
                <StackPanel Margin="20">
                    <TextBlock Text="Favourites" FontSize="20" FontWeight="Bold"/>
                    <ListBox x:Name="FavouritesList"/>
                    <TextBlock x:Name="FavouritesEmpty" Text="No Songs" Foreground="Gray" Visibility="Collapsed"/>
                </StackPanel>
            </TabItem>

            <!-- Downloads -->
            <TabItem Header="Downloads">
                <StackPanel Margin="20">
                    <TextBlock Text="Downloads" FontSize="20" FontWeight="Bold"/>
                    <ListBox x:Name="DownloadsList"/>
                    <TextBlock x:Name="DownloadsEmpty" Text="No Songs" Foreground="Gray" Visibility="Collapsed"/>
                </StackPanel>
            </TabItem>

            <!-- History -->
            <TabItem Header="History">
                <StackPanel Margin="20">
                    <TextBlock Text="History" FontSize="20" FontWeight="Bold"/>
                    <ListBox x:Name="HistoryList"/>
                    <TextBlock x:Name="HistoryEmpty" Text="No Songs" Foreground="Gray" Visibility="Collapsed"/>
                </StackPanel>
            </TabItem>

            <!-- Now Playing -->
            <TabItem Header="Now Playing">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Album Art -->
                    <Image x:Name="NowPlayingCover" Width="240" Height="240" 
                           HorizontalAlignment="Center" Margin="0,0,0,20"/>

                    <!-- Song Info -->
                    <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,12,0,12">
                        <TextBlock x:Name="NowPlayingTitle" FontSize="20" FontWeight="Bold"/>
                        <TextBlock x:Name="NowPlayingArtist" Foreground="Gray" FontSize="16"/>
                        <TextBlock x:Name="NowPlayingMeta" Foreground="Gray" FontSize="12"/>
                    </StackPanel>

                    <!-- Lyrics -->
                    <ListBox x:Name="LyricsList" Grid.Row="2" Margin="0,12,0,12" FontSize="14"/>

                    <!-- Playback Controls -->
                    <StackPanel Grid.Row="3" Orientation="Vertical" Margin="0,12,0,0">
                        <Slider x:Name="PlaybackSlider" Minimum="0" Maximum="100" Value="0" Height="20"
                                PreviewMouseUp="PlaybackSlider_MouseUp"/>
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" x:Name="ElapsedText" Text="0:00" FontSize="12" Foreground="Gray"/>
                            <TextBlock Grid.Column="2" x:Name="RemainingText" Text="0:00" FontSize="12" Foreground="Gray" HorizontalAlignment="Right"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                            <Button x:Name="PreviousButton" Content="⏮" Width="48" Height="40" Margin="4" Click="PreviousButton_Click"/>
                            <Button x:Name="PlayButton" Content="▶" Width="64" Height="40" Margin="4" Click="PlayButton_Click"/>
                            <Button x:Name="PauseButton" Content="⏸" Width="64" Height="40" Margin="4" Click="PauseButton_Click"/>
                            <Button x:Name="NextButton" Content="⏭" Width="48" Height="40" Margin="4" Click="NextButton_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
