<Window x:Class="Musicefy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Musicefy.Converters"
        Title="Musicefy" Height="760" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}" 
        Foreground="{DynamicResource TextBrush}"
        TextElement.FontFamily="Segoe UI"
        Style="{StaticResource EchoCustomWindowStyle}">

    <Window.Resources>
        <converters:PathToImageConverter x:Key="PathToImageConverter"/>

        <!-- M3 Navigation Rail Item -->
        <Style x:Key="SidebarIconButtonStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Grid x:Name="Root" Background="Transparent" Cursor="Hand">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <!-- Pill active indicator -->
                                <Border x:Name="Pill" Background="Transparent" CornerRadius="16"
                                        Width="56" Height="32" HorizontalAlignment="Center"/>
                                <!-- Icon -->
                                <Path x:Name="IconPath" 
                                      Data="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                      Fill="{DynamicResource OnSurfaceVariantBrush}" 
                                      Width="24" Height="24" Stretch="Uniform" 
                                      HorizontalAlignment="Center"/>
                                <!-- Label -->
                                <TextBlock Text="{Binding ToolTip, RelativeSource={RelativeSource TemplatedParent}}"
                                           FontSize="11" FontWeight="Medium" 
                                           Foreground="{TemplateBinding Foreground}"
                                           HorizontalAlignment="Center" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Pill" Property="Background" Value="{DynamicResource HoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Pill" Property="Background" Value="{DynamicResource SurfaceContainerHighBrush}"/>
                                <Setter TargetName="IconPath" Property="Fill" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TransportPathButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ControlBg" Background="{TemplateBinding Background}" CornerRadius="19">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ControlBg" Property="Background" Value="{DynamicResource SurfaceVariantBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <DockPanel LastChildFill="True">
            <Border DockPanel.Dock="Left" Width="80" 
                    Background="{DynamicResource SurfaceContainerLowBrush}" 
                    BorderBrush="{DynamicResource OutlineBrush}" 
                    BorderThickness="0,0,1,0">
                <ListBox x:Name="SidebarList" Background="Transparent" BorderThickness="0"
                         ItemContainerStyle="{StaticResource SidebarIconButtonStyle}"
                         SelectionChanged="Sidebar_SelectionChanged">
                    <ListBoxItem ToolTip="Home" Tag="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
                    <ListBoxItem ToolTip="Search" Tag="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
                    <ListBoxItem ToolTip="Library" Tag="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/>
                    <ListBoxItem x:Name="SettingsItem" ToolTip="Settings" Tag="M19.14 12.94c0.04-0.3 0.06-0.61 0.06-0.94c0-0.32-0.02-0.64-0.07-0.94l2.03-1.58c0.18-0.14 0.23-0.41 0.12-0.61l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39 0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4 2.81c-0.04-0.24-0.24-0.41-0.48-0.41h-3.84c-0.24 0-0.43 0.17-0.47 0.41l-0.36 2.54c-0.59 0.24-1.13 0.57-1.62 0.94L5.24 5.33c-0.22-0.07-0.47 0-0.59 0.22L2.74 8.87C2.62 9.08 2.67 9.34 2.85 9.48l2.03 1.58C4.84 11.36 4.81 11.69 4.81 12.01s0.02 0.64 0.07 0.94l-2.03 1.58c-0.18 0.14-0.23 0.41-0.12 0.61l1.92 3.32c0.12 0.22 0.37 0.29 0.59 0.22l2.39-0.96c0.5 0.38 1.03 0.7 1.62 0.94l0.36 2.54c0.05 0.24 0.24 0.41 0.48 0.41h3.84c0.24 0 0.44-0.17 0.47-0.41l0.36-2.54c0.59-0.24 1.13-0.56 1.62-0.94l2.39 0.96c0.22 0.07 0.47 0 0.59-0.22l1.92-3.32c0.12-0.22 0.07-0.47-0.12-0.61L19.14 12.94zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6s3.6 1.62 3.6 3.6S13.98 15.6 12 15.6z"/>
                </ListBox>
            </Border>

            <Grid VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                <ContentControl x:Name="MainContent"
                                  Content="{Binding CurrentPage}"
                VerticalAlignment="Stretch" HorizontalAlignment="Stretch"/>
            </Grid>
        </DockPanel>

        <Grid VerticalAlignment="Bottom" HorizontalAlignment="Stretch">
            
            <Border x:Name="MiniPlayerBar"
                    Height="64" 
                    Width="520"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,24"
                    Background="{DynamicResource SecondaryBackgroundBrush}" 
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="32"
                    Cursor="Hand"
                    Visibility="Collapsed"
                    MouseLeftButtonDown="MiniPlayerBar_MouseLeftButtonDown"
                    MouseMove="MiniPlayerBar_MouseMove"
                    MouseLeftButtonUp="MiniPlayerBar_MouseLeftButtonUp">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="3" Opacity="0.2" Color="Black"/>
                </Border.Effect>
                
                <Border.RenderTransform>
                    <TranslateTransform x:Name="MiniPlayerTransform"/>
                </Border.RenderTransform>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
            
                    <Border Grid.Column="0" Width="44" Height="44" CornerRadius="22" Background="#0A0A0A" VerticalAlignment="Center" Margin="10,0,0,0">
                        <Image Source="{Binding NowPlaying.CoverPath, Converter={StaticResource PathToImageConverter}}" Stretch="UniformToFill">
                            <Image.Clip>
                                <EllipseGeometry Center="22,22" RadiusX="22" RadiusY="22"/>
                            </Image.Clip>
                        </Image>
                    </Border>
            
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,14,0">
                        <TextBlock Text="{Binding NowPlaying.Title, FallbackValue='Not Playing'}" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource TextBrush}" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding NowPlaying.Artist, FallbackValue='Unknown Artist'}" FontSize="11" Foreground="{DynamicResource MutedTextBrush}" Margin="0,1,0,0" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
            
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                        <Button Width="34" Height="34" Style="{StaticResource TransportPathButtonStyle}"
                                Command="{Binding MiniPreviousCommand}">
                            <Path Data="M6,18V6H8V18H6M9.5,12L18,6V18L9.5,12Z"
                                  Fill="{DynamicResource TextBrush}" Width="10" Height="10" Stretch="Uniform"/>
                        </Button>
                        
                        <Button x:Name="BtnMiniPlay" Content="{Binding MiniPlayContent}"
                                Width="42" Height="42" Margin="2,0,2,0"
                                Command="{Binding MiniPlayCommand}">
                            <!-- Keep the exact same Template from the original -->
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid Background="Transparent">
                                        <Ellipse x:Name="Circle" Fill="{DynamicResource TextBrush}" Opacity="0.1"/>
                                        <Path x:Name="MiniPlayIcon" Data="M8,5V19L19,12L8,5Z" Fill="{DynamicResource TextBrush}" Width="12" Height="12" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2,0,0,0"/>
                                        <Path x:Name="MiniPauseIcon" Data="M14,19H18V5H14M6,19H10V5H6Z" Fill="{DynamicResource TextBrush}" Width="10" Height="10" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="Content" Value="⏸">
                                            <Setter TargetName="MiniPlayIcon" Property="Visibility" Value="Collapsed"/>
                                            <Setter TargetName="MiniPauseIcon" Property="Visibility" Value="Visible"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Circle" Property="Opacity" Value="0.2"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        
                        <Button Width="34" Height="34" Style="{StaticResource TransportPathButtonStyle}"
                                Command="{Binding MiniNextCommand}">
                            <Path Data="M16,18H18V6H16M6,18L14.5,12L6,6V18Z"
                                  Fill="{DynamicResource TextBrush}" Width="10" Height="10" Stretch="Uniform"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

                <Grid x:Name="FullNowPlayingContainer" 
                  Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Window}}" 
                  VerticalAlignment="Bottom" 
                  Visibility="Collapsed"
                  Opacity="0">
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="FullPanelTransform"/>
                </Grid.RenderTransform>
                <ContentControl x:Name="NowPlayingPresenter"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
