<Window x:Class="Musicefy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Musicefy"
        Height="760" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="#0A0A0A"
        Foreground="White"
        TextElement.FontFamily="Segoe UI Semibold">

    <Window.Resources>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#0A0A0A"/>
        <SolidColorBrush x:Key="SecondaryBackgroundBrush" Color="#161616"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="GlassBrush" Color="#CC1DB954"/> <SolidColorBrush x:Key="MutedTextBrush" Color="#909090"/>

        <Style x:Key="SidebarIconButtonStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Margin" Value="0,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Grid x:Name="Root" Background="Transparent" Cursor="Hand">
                            <Border x:Name="Indicator" Background="White" Width="4" Height="20" 
                                    HorizontalAlignment="Left" CornerRadius="0,2,2,0" Visibility="Collapsed"/>
                            <Path x:Name="IconPath" Data="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" 
                                  Fill="#707070" Width="22" Height="22" Stretch="Uniform" Margin="20,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="IconPath" Property="Fill" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Indicator" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="IconPath" Property="Fill" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Left" Width="70" Background="#050505" BorderBrush="#1A1A1A" BorderThickness="0,0,1,0">
            <StackPanel VerticalAlignment="Center">
                <ListBox x:Name="SidebarList" Background="Transparent" BorderThickness="0"
                         ItemContainerStyle="{StaticResource SidebarIconButtonStyle}"
                         SelectionChanged="Sidebar_SelectionChanged">
                    <ListBoxItem IsSelected="True" ToolTip="Home" Tag="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
                    <ListBoxItem ToolTip="Search" Tag="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
                    <ListBoxItem ToolTip="Library" Tag="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/>
                    <ListBoxItem x:Name="SettingsItem" ToolTip="Settings" Tag="M19.14,12.94c0.04..."/>
                </ListBox>
            </StackPanel>
        </Border>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="20,10">
                <TextBlock Text="Musicefy" FontSize="18" FontWeight="ExtraBold" Margin="10,10,0,15"/>
                <ListBox x:Name="CategoriesList" ItemsSource="{Binding HeaderCategories}" 
                         Background="Transparent" BorderThickness="0">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Pill" Background="#1A1A1A" CornerRadius="15" Padding="15,6" Margin="5,0">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Pill" Property="Background" Value="White"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" FontSize="13"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>

            <ContentControl x:Name="MainContent" Grid.Row="1"/>
        </Grid>
    </DockPanel>
</Window>
