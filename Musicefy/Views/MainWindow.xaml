<Window x:Class="Musicefy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Musicefy.Views"
        Title="Musicefy"
        Height="720" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}">

    <DockPanel LastChildFill="True">

        <!-- Sidebar -->
        <StackPanel DockPanel.Dock="Left" Width="80" Background="{DynamicResource SecondaryBackgroundBrush}">
            <Button Content="🏠" ToolTip="Home" Click="Home_Click"/>
            <Button Content="🔍" ToolTip="Search" Click="Search_Click"/>
            <Button Content="🎵" ToolTip="Library" Click="Library_Click"/>
            <Button Content="▶" ToolTip="Now Playing" Click="NowPlaying_Click"/>
            <Button Content="⚙" ToolTip="Settings" Click="OpenSettings_Click"/>
        </StackPanel>

        <!-- Main Content -->
        <DockPanel>
            <ContentControl x:Name="MainContent" DockPanel.Dock="Top"/>

            <!-- Mini Player Bar -->
            <Border DockPanel.Dock="Bottom" Background="{DynamicResource SecondaryBackgroundBrush}" Padding="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Cover -->
                    <Image x:Name="MiniCover" Width="48" Height="48" Margin="0,0,12,0"/>

                    <!-- Info + Progress -->
                    <StackPanel Grid.Column="1">
                        <TextBlock x:Name="MiniTitle" FontWeight="Bold"/>
                        <TextBlock x:Name="MiniArtist" Foreground="Gray" FontSize="12"/>
                        <Slider x:Name="MiniProgress" Minimum="0" Maximum="100" Height="16" Margin="0,4,0,0"
                                PreviewMouseUp="MiniProgress_MouseUp"/>
                    </StackPanel>

                    <!-- Controls -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Content="⏮" Width="32" Height="32" Margin="2" Click="PreviousButton_Click"/>
                        <Button Content="▶" Width="32" Height="32" Margin="2" Click="PlayButton_Click"/>
                        <Button Content="⏸" Width="32" Height="32" Margin="2" Click="PauseButton_Click"/>
                        <Button Content="⏭" Width="32" Height="32" Margin="2" Click="NextButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DockPanel>
    </DockPanel>
</Window>
