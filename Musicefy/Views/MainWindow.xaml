<Window x:Class="Musicefy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Musicefy.Converters"
        Title="Musicefy" Height="760" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource SurfaceBrush}" 
        Foreground="{DynamicResource OnSurfaceBrush}"
        TextElement.FontFamily="Segoe UI"
        Style="{StaticResource EchoCustomWindowStyle}">

    <Window.Resources>
        <converters:PathToImageConverter x:Key="PathToImageConverter"/>

        <!-- M3 Navigation Rail Item -->
        <Style x:Key="SidebarIconButtonStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Grid x:Name="Root" Background="Transparent" Cursor="Hand"
                              RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <ScaleTransform x:Name="ItemScale" ScaleX="0.88" ScaleY="0.88"/>
                            </Grid.RenderTransform>
                             <!-- Pill active indicator (behind content) -->
                             <Border x:Name="Pill" Background="Transparent" CornerRadius="16"
                                     Width="56" Height="32" HorizontalAlignment="Center" VerticalAlignment="Center"
                                     RenderTransformOrigin="0.5,0.5">
                                 <Border.RenderTransform>
                                     <ScaleTransform x:Name="PillScale" ScaleX="0" ScaleY="1"/>
                                 </Border.RenderTransform>
                             </Border>
                            <!-- Content: icon + label stacked -->
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Path x:Name="IconPath" 
                                      Data="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                      Fill="{DynamicResource OnSurfaceVariantBrush}" 
                                      Width="24" Height="24" Stretch="Uniform" 
                                      HorizontalAlignment="Center"/>
                                <TextBlock x:Name="LabelText" Text="{Binding ToolTip, RelativeSource={RelativeSource TemplatedParent}}"
                                           FontSize="11" FontWeight="Medium" 
                                           Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                           HorizontalAlignment="Center" Margin="0,3,0,0" Opacity="0.6"/>
                            </StackPanel>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Pill" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ItemScale" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="ItemScale" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="LabelText" Storyboard.TargetProperty="Opacity" To="0.9" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ItemScale" Storyboard.TargetProperty="ScaleX" To="0.88" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="ItemScale" Storyboard.TargetProperty="ScaleY" To="0.88" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="LabelText" Storyboard.TargetProperty="Opacity" To="0.6" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                             <Trigger Property="IsSelected" Value="True">
                                 <Setter TargetName="Pill" Property="Background" Value="{DynamicResource DynamicPrimaryBrush}"/>
                                 <Setter TargetName="Pill" Property="Opacity" Value="0.15"/>
                                 <Setter TargetName="IconPath" Property="Fill" Value="{DynamicResource DynamicPrimaryBrush}"/>
                                 <Setter TargetName="LabelText" Property="Foreground" Value="{DynamicResource DynamicPrimaryBrush}"/>
                                 <Setter TargetName="LabelText" Property="Opacity" Value="1.0"/>
                                 <Trigger.EnterActions>
                                     <BeginStoryboard>
                                         <Storyboard>
                                             <DoubleAnimation Storyboard.TargetName="ItemScale" Storyboard.TargetProperty="ScaleX" To="1.08" Duration="0:0:0.2">
                                                 <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                             </DoubleAnimation>
                                             <DoubleAnimation Storyboard.TargetName="ItemScale" Storyboard.TargetProperty="ScaleY" To="1.08" Duration="0:0:0.2">
                                                 <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                             </DoubleAnimation>
                                             <DoubleAnimation Storyboard.TargetName="PillScale" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.2">
                                                 <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                             </DoubleAnimation>
                                         </Storyboard>
                                     </BeginStoryboard>
                                 </Trigger.EnterActions>
                                 <Trigger.ExitActions>
                                     <BeginStoryboard>
                                         <Storyboard>
                                             <DoubleAnimation Storyboard.TargetName="ItemScale" Storyboard.TargetProperty="ScaleX" To="0.88" Duration="0:0:0.2">
                                                 <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                             </DoubleAnimation>
                                             <DoubleAnimation Storyboard.TargetName="ItemScale" Storyboard.TargetProperty="ScaleY" To="0.88" Duration="0:0:0.2">
                                                 <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                             </DoubleAnimation>
                                             <DoubleAnimation Storyboard.TargetName="PillScale" Storyboard.TargetProperty="ScaleX" To="0.0" Duration="0:0:0.2">
                                                 <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                             </DoubleAnimation>
                                         </Storyboard>
                                     </BeginStoryboard>
                                 </Trigger.ExitActions>
                             </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <DockPanel LastChildFill="True">
            <Border x:Name="SidebarBorder" DockPanel.Dock="Left" Width="80" 
                    Background="{DynamicResource SurfaceContainerLowBrush}" 
                    BorderBrush="{DynamicResource OutlineBrush}" 
                    BorderThickness="0,0,1,0"
                    Padding="0,12,0,12"
                    RenderTransformOrigin="0.5,0.5"
                    MouseEnter="SidebarBorder_MouseEnter"
                    MouseLeave="SidebarBorder_MouseLeave">
                <Border.RenderTransform>
                    <ScaleTransform x:Name="SidebarScale" ScaleX="1" ScaleY="1"/>
                </Border.RenderTransform>
                <ListBox x:Name="SidebarList" Background="Transparent" BorderThickness="0"
                         VerticalAlignment="Center"
                         ItemContainerStyle="{StaticResource SidebarIconButtonStyle}"
                         SelectionChanged="Sidebar_SelectionChanged">
                    <ListBoxItem ToolTip="Home" Tag="M12 3c-.46 0-.93.18-1.28.53L3.53 10.72c-.7.7-.2 1.9.78 1.9H5v5c0 1.1.9 2 2 2h2c.55 0 1-.45 1-1v-4h4v4c0 .55.45 1 1 1h2c1.1 0 2-.9 2-2v-5h.69c.98 0 1.48-1.2.78-1.9l-7.19-7.19C12.93 3.18 12.46 3 12 3z"/>
                    <ListBoxItem ToolTip="Search" Tag="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
                    <ListBoxItem ToolTip="Library" Tag="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/>
                    <ListBoxItem x:Name="SettingsItem" ToolTip="Settings" Tag="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94L14.4 2.81c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94L5.24 5.33c-.22-.07-.47 0-.59.22L2.74 8.87C2.62 9.08 2.67 9.34 2.85 9.48l2.03 1.58C4.84 11.36 4.81 11.69 4.81 12.01s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.07.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"/>
                </ListBox>
            </Border>

            <Grid VerticalAlignment="Stretch" HorizontalAlignment="Stretch" ClipToBounds="True">
                <ContentControl x:Name="MainContent"
                                Content="{Binding CurrentPage}"
                                VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                                RenderTransformOrigin="0.5,0.5">
                    <ContentControl.RenderTransform>
                        <TranslateTransform x:Name="PageSlideTransform"/>
                    </ContentControl.RenderTransform>
                </ContentControl>
            </Grid>
        </DockPanel>

        <Grid VerticalAlignment="Bottom" HorizontalAlignment="Stretch">
            
            <Border x:Name="MiniPlayerBar"
                    Height="64" 
                    Width="520"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,24"
                    Background="{DynamicResource SurfaceVariantBrush}" 
                    BorderBrush="{DynamicResource OutlineBrush}"
                    BorderThickness="1"
                    CornerRadius="32"
                    Cursor="Hand"
                    Visibility="Collapsed"
                    MouseLeftButtonDown="MiniPlayerBar_MouseLeftButtonDown"
                    MouseMove="MiniPlayerBar_MouseMove"
                    MouseLeftButtonUp="MiniPlayerBar_MouseLeftButtonUp">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="3" Opacity="0.2" Color="Black"/>
                </Border.Effect>
                
                <Border.RenderTransform>
                    <TranslateTransform x:Name="MiniPlayerTransform"/>
                </Border.RenderTransform>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
            
                    <Border Grid.Column="0" Width="44" Height="44" CornerRadius="22" Background="{DynamicResource SurfaceVariantBrush}" VerticalAlignment="Center" Margin="10,0,0,0">
                        <Image Source="{Binding NowPlaying.CoverPath, Converter={StaticResource PathToImageConverter}}" Stretch="UniformToFill">
                            <Image.Clip>
                                <EllipseGeometry Center="22,22" RadiusX="22" RadiusY="22"/>
                            </Image.Clip>
                        </Image>
                    </Border>
            
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,14,0">
                        <TextBlock Text="{Binding NowPlaying.Title, FallbackValue='Not Playing'}" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource OnSurfaceBrush}" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding NowPlaying.Artist, FallbackValue='Unknown Artist'}" FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,1,0,0" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
            
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                        <Button Width="34" Height="34" Style="{StaticResource TransportPathButtonStyle}"
                                Command="{Binding MiniPreviousCommand}">
                            <Path Data="M6,18V6H8V18H6M9.5,12L18,6V18L9.5,12Z"
                                  Fill="{DynamicResource OnSurfaceBrush}" Width="10" Height="10" Stretch="Uniform"/>
                        </Button>
                        
                        <Button x:Name="BtnMiniPlay" Content="{Binding MiniPlayContent}"
                                Width="42" Height="42" Margin="2,0,2,0"
                                Command="{Binding MiniPlayCommand}">
                            <!-- Keep the exact same Template from the original -->
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid Background="Transparent">
                                        <Ellipse x:Name="Circle" Fill="{DynamicResource OnSurfaceBrush}" Opacity="0.1"/>
                                        <Path x:Name="MiniPlayIcon" Data="M8,5V19L19,12L8,5Z" Fill="{DynamicResource OnSurfaceBrush}" Width="12" Height="12" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2,0,0,0"/>
                                        <Path x:Name="MiniPauseIcon" Data="M14,19H18V5H14M6,19H10V5H6Z" Fill="{DynamicResource OnSurfaceBrush}" Width="10" Height="10" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="Content" Value="⏸">
                                            <Setter TargetName="MiniPlayIcon" Property="Visibility" Value="Collapsed"/>
                                            <Setter TargetName="MiniPauseIcon" Property="Visibility" Value="Visible"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Circle" Property="Opacity" Value="0.2"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        
                        <Button Width="34" Height="34" Style="{StaticResource TransportPathButtonStyle}"
                                Command="{Binding MiniNextCommand}">
                            <Path Data="M16,18H18V6H16M6,18L14.5,12L6,6V18Z"
                                  Fill="{DynamicResource OnSurfaceBrush}" Width="10" Height="10" Stretch="Uniform"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
            </Border>

                <Grid x:Name="FullNowPlayingContainer" 
                  Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Window}}" 
                  VerticalAlignment="Bottom" 
                  Visibility="Collapsed"
                  Opacity="0">
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="FullPanelTransform"/>
                </Grid.RenderTransform>
                <ContentControl x:Name="NowPlayingPresenter"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
