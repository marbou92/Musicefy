<Window x:Class="Musicefy.Views.AppearanceSettingsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Musicefy.ViewModels"
        Title="Appearance Settings" Height="600" Width="400"
        Background="{DynamicResource BackgroundBrush}">
    <Window.DataContext>
        <vm:AppearanceSettingsViewModel/>
    </Window.DataContext>

    <StackPanel Margin="20" Orientation="Vertical" Spacing="15">

        <!-- Theme Tabs -->
        <TabControl SelectedIndex="{Binding SelectedThemeIndex}">
            <TabItem Header="System"/>
            <TabItem Header="Light"/>
            <TabItem Header="Dark"/>
        </TabControl>

        <!-- Theme Previews -->
        <ItemsControl ItemsSource="{Binding ThemePreviews}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="{Binding AccentBrush}" Padding="10" Margin="5" CornerRadius="6">
                        <StackPanel>
                            <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="White"/>
                            <Rectangle Height="40" Fill="{Binding AccentBrush}" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Toggles -->
        <CheckBox Content="Pure black dark mode" IsChecked="{Binding PureBlackMode}"/>
        <CheckBox Content="Relative timestamps" IsChecked="{Binding RelativeTimestamps}"/>
        <CheckBox Content="Render images in manga descriptions" IsChecked="{Binding RenderImages}"/>
        <CheckBox Content="Show updates in the nav" IsChecked="{Binding ShowUpdates}"/>

        <!-- Date Format -->
        <ComboBox ItemsSource="{Binding DateFormats}" SelectedItem="{Binding SelectedDateFormat}"/>
    </StackPanel>
</Window>
