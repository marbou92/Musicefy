<UserControl x:Class="Musicefy.Views.NowPlayingControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Musicefy.Converters"
             Background="Transparent"
             RenderOptions.BitmapScalingMode="HighQuality"
             RenderOptions.ClearTypeHint="Enabled">
    
    <UserControl.Resources>
        <converters:PathToImageConverter x:Key="PathToImageConverter"/>
        <converters:LyricsToLinesConverter x:Key="LyricsToLinesConverter"/>
        <converters:IsEqualConverter x:Key="IsEqualConverter"/>

        <Style x:Key="NowPlayingIconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="Transparent" CornerRadius="20" Width="44" Height="44">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value><ScaleTransform ScaleX="0.9" ScaleY="0.9"/></Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NowPlayingPlayButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="30" Width="64" Height="64">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.35" Color="Black"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Bg" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.08" Duration="0:0:0.15"><DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="Bg" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.08" Duration="0:0:0.15"><DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Bg" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="Bg" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform"><Setter.Value><ScaleTransform ScaleX="0.92" ScaleY="0.92"/></Setter.Value></Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform"><Setter.Value><ScaleTransform ScaleX="1" ScaleY="1"/></Setter.Value></Setter>
        </Style>
        
        <Style x:Key="TransportIconStyle" TargetType="Button" BasedOn="{StaticResource NowPlayingIconButton}"/>

    </UserControl.Resources>

    <Grid x:Name="RootGrid" CacheMode="BitmapCache">

        <!-- Layer 1: Full-screen album art background -->
        <Grid x:Name="CoverArtContainer" ClipToBounds="True">
            <Image x:Name="BgCoverImage" 
                   Source="{Binding NowPlaying.CoverPath, Converter={StaticResource PathToImageConverter}}"
                   Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>

        <!-- Layer 2: Vibrant color gradient (dynamic from album art) -->
        <Border Opacity="0.25">
            <Border.Background>
                <SolidColorBrush Color="{Binding VibrantColor, FallbackValue=Transparent}"/>
            </Border.Background>
        </Border>

        <!-- Layer 3: Dark gradient overlay -->
        <Border Background="{DynamicResource BackgroundBrush}" Opacity="0.45"/>
        <Border VerticalAlignment="Bottom" Height="75">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="Transparent" Offset="0"/>
                    <GradientStop Color="#CC000000" Offset="0.5"/>
                    <GradientStop Color="#F2000000" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>
        <Border VerticalAlignment="Top" Height="120">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#AA000000" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- Layer 3: Content overlay -->
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Top bar: collapse + title -->
            <Grid Grid.Row="0" Margin="20,16,20,0">
                <Button x:Name="BtnCollapse" HorizontalAlignment="Left" VerticalAlignment="Center"
                        Style="{StaticResource NowPlayingIconButton}" Command="{Binding CollapseCommand}">
                    <Path Data="M7.41,8.58L12,13.17L16.59,8.58L18,10L12,16L6,10L7.41,8.58Z" 
                          Fill="White" Width="24" Height="24" Stretch="Uniform"/>
                </Button>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Now Playing" FontSize="13" FontWeight="SemiBold" Foreground="White" Opacity="0.7" HorizontalAlignment="Center"/>
                </StackPanel>

                <Button x:Name="BtnMenu" HorizontalAlignment="Right" VerticalAlignment="Center"
                        Style="{StaticResource NowPlayingIconButton}">
                    <Path Data="M12,8C13.1,8 14,7.1 14,6C14,4.9 13.1,4 12,4C10.9,4 10,4.9 10,6C10,7.1 10.9,8 12,8M12,10C10.9,10 10,10.9 10,12C10,13.1 10.9,14 12,14C13.1,14 14,13.1 14,12C14,10.9 13.1,10 12,10M12,16C10.9,16 10,16.9 10,18C10,19.1 10.9,20 12,20C13.1,20 14,19.1 14,18C14,16.9 13.1,16 12,16Z" 
                          Fill="White" Width="20" Height="20" Stretch="Uniform"/>
                </Button>
            </Grid>

            <!-- Middle spacer -->
            <Grid Grid.Row="1"/>

            <!-- Bottom: track info + controls -->
            <Grid Grid.Row="2" Margin="28,0,28,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Track info -->
                <StackPanel Grid.Row="0" Margin="0,0,0,20" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding NowPlaying.Title, FallbackValue='Not Playing'}" 
                               FontSize="24" FontWeight="Bold" Foreground="White"
                               TextTrimming="CharacterEllipsis" HorizontalAlignment="Center" MaxWidth="500"/>
                    <TextBlock Text="{Binding NowPlaying.Artist, FallbackValue='Unknown Artist'}" 
                               FontSize="14" Foreground="White" Opacity="0.65"
                               TextTrimming="CharacterEllipsis" HorizontalAlignment="Center" Margin="0,4,0,0" MaxWidth="400"/>
                </StackPanel>

                <!-- Progress bar -->
                <Grid Grid.Row="1" Margin="0,0,0,4">
                    <Slider x:Name="ProgressSlider" Minimum="0" Maximum="100" 
                            Value="{Binding ProgressValue}" Height="20"
                            Thumb.DragStarted="Slider_DragStarted" Thumb.DragCompleted="Slider_DragCompleted"/>
                </Grid>
                <Grid Grid.Row="2" Margin="4,0,4,16">
                    <TextBlock Text="{Binding CurrentTimeText}" FontSize="12" Foreground="White" Opacity="0.6" FontWeight="Medium"/>
                    <TextBlock Text="{Binding TotalTimeText}" FontSize="12" Foreground="White" Opacity="0.6" FontWeight="Medium" HorizontalAlignment="Right"/>
                </Grid>

                <!-- Transport controls -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                    <Button x:Name="BtnShuffle" Command="{Binding ShuffleCommand}" Margin="0,0,12,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource TransportIconStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsShuffleEnabled}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource DynamicPrimaryBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Path Data="M14.83,13.41L13.42,14.82L16.55,17.95L14.5,20H20V14.5L17.96,16.54L14.83,13.41M14.5,4L16.54,6.04L4,18.58L5.41,20L17.96,7.46L20,9.5V4H14.5M10.59,9.17L5.41,4L4,5.41L9.17,10.58L10.59,9.17Z" 
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="20" Height="20" Stretch="Uniform"/>
                    </Button>

                    <Button Style="{StaticResource TransportIconStyle}" Command="{Binding PreviousCommand}" Margin="0,0,8,0">
                        <Path Data="M6,18V6H8V18H6M9.5,12L18,6V18L9.5,12Z" 
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="28" Height="28" Stretch="Uniform"/>
                    </Button>

                    <Button x:Name="BtnMainPlay" Content="{Binding PlayPauseContent}" 
                            Style="{StaticResource NowPlayingPlayButton}" Command="{Binding PlayPauseCommand}" Margin="8,0,8,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" Background="White" CornerRadius="30" Width="64" Height="64" RenderTransformOrigin="0.5,0.5">
                                    <Border.RenderTransform><ScaleTransform ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.35" Color="Black"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Path x:Name="PlayIcon" Data="M8,5V19L19,12L8,5Z" Fill="Black" Width="28" Height="28" Stretch="Uniform" Margin="4,0,0,0"/>
                                        <Path x:Name="PauseIcon" Data="M14,19H18V5H14M6,19H10V5H6Z" Fill="Black" Width="24" Height="24" Stretch="Uniform" Visibility="Collapsed"/>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="Content" Value="&#x23F8;">
                                        <Setter TargetName="PlayIcon" Property="Visibility" Value="Collapsed"/>
                                        <Setter TargetName="PauseIcon" Property="Visibility" Value="Visible"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="Bg" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.08" Duration="0:0:0.15"><DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                                                    <DoubleAnimation Storyboard.TargetName="Bg" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.08" Duration="0:0:0.15"><DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                        <Trigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="Bg" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.15"/>
                                                    <DoubleAnimation Storyboard.TargetName="Bg" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.15"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.ExitActions>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="RenderTransform"><Setter.Value><ScaleTransform ScaleX="0.92" ScaleY="0.92"/></Setter.Value></Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Style="{StaticResource TransportIconStyle}" Command="{Binding NextCommand}" Margin="8,0,0,0">
                        <Path Data="M16,18H18V6H16M6,18L14.5,12L6,6V18Z" 
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="28" Height="28" Stretch="Uniform"/>
                    </Button>

                    <Button x:Name="BtnRepeat" Command="{Binding RepeatCommand}" Margin="12,0,0,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource TransportIconStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRepeatEnabled}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource DynamicPrimaryBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Path Data="M17,17H7V14L3,18L7,22V19H19V13H17V17M7,7H17V10L21,6L17,2V5H5V11H7V7Z" 
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="20" Height="20" Stretch="Uniform"/>
                    </Button>
                </StackPanel>

                <!-- Bottom bar: favorite + queue + lyrics -->
                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="BtnFavorite" Command="{Binding FavoriteCommand}" Margin="0,0,16,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NowPlayingIconButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFavoriteTrack}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Grid Width="22" Height="22">
                            <Path Data="M12.1,18.55L12,18.65L11.89,18.55C7.14,14.24 4,11.39 4,8.5C4,6.5 5.5,5 7.5,5C9.04,5 10.54,6 11.07,7.36H12.93C13.46,6 14.96,5 16.5,5C18.5,5 20,6.5 20,8.5C20,11.39 16.86,14.24 12.1,18.55M16.5,3C14.76,3 13.09,3.81 12,5.08C10.91,3.81 9.24,3 7.5,3C4.42,3 2,5.41 2,8.5C2,12.27 5.4,15.36 10.55,20.03L12,21.35L13.45,20.03C18.6,15.36 22,12.27 22,8.5C22,5.41 19.58,3 16.5,3Z" 
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform">
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFavoriteTrack}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Path.Style>
                            </Path>
                            <Path Data="M12,21.35L10.55,20.03C5.4,15.36 2,12.28 2,8.5C2,5.42 4.42,3 7.5,3C9.24,3 10.91,3.81 12,5.09C13.09,3.81 14.76,3 16.5,3C19.58,3 22,5.42 22,8.5C22,12.28 18.6,15.36 13.45,20.03L12,21.35Z" 
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform">
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFavoriteTrack}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Path.Style>
                            </Path>
                        </Grid>
                    </Button>

                    <Button x:Name="BtnToggleQueue" Command="{Binding ToggleQueueCommand}" Margin="0,0,16,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NowPlayingIconButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsQueuePanelVisible}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource DynamicPrimaryBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Path Data="M4,16H14V14H4V16ZM4,11H18V9H4V11ZM4,4V6H18V4H4Z" 
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="20" Height="20" Stretch="Uniform"/>
                    </Button>

                    <Button x:Name="BtnToggleLyrics" Command="{Binding ToggleLyricsCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NowPlayingIconButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLyricsPanelVisible}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource DynamicPrimaryBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Path Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M9,17H7V10H9V17ZM13,17H11V7H13V17ZM17,17H15V12H17V17Z" 
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="20" Height="20" Stretch="Uniform"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Layer 4: Lyrics overlay (bottom sheet) -->
        <Grid x:Name="LyricsOverlay" Visibility="Collapsed" VerticalAlignment="Bottom" Height="55%" 
              Margin="28,0,28,0" Opacity="0">
            <Grid.RenderTransform>
                <TranslateTransform Y="100"/>
            </Grid.RenderTransform>
            <Border Background="#F01A1A1A" CornerRadius="20,20,0,0" Padding="24,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Lyrics" FontSize="16" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,16" HorizontalAlignment="Center"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" PanningMode="VerticalOnly">
                        <ItemsControl ItemsSource="{Binding NowPlaying.Lyrics, Converter={StaticResource LyricsToLinesConverter}}"
                                      VirtualizingStackPanel.IsVirtualizing="True">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontSize="22" FontWeight="Bold" Foreground="White" Opacity="0.25"
                                               TextWrapping="Wrap" Margin="0,10,0,10" Cursor="Hand">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Opacity" Value="1.0"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Layer 5: Queue overlay (bottom sheet) -->
        <Grid x:Name="QueueOverlay" Visibility="Collapsed" VerticalAlignment="Bottom" Height="55%"
              Margin="28,0,28,0" Opacity="0">
            <Grid.RenderTransform>
                <TranslateTransform Y="100"/>
            </Grid.RenderTransform>
            <Border Background="#F01A1A1A" CornerRadius="20,20,0,0" Padding="24,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Up Next" FontSize="16" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,16" HorizontalAlignment="Center"/>
                    <ScrollViewer x:Name="QueueScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" PanningMode="VerticalOnly"
                                  MouseEnter="QueueScrollViewer_MouseEnter" MouseLeave="QueueScrollViewer_MouseLeave">
                        <ItemsControl x:Name="QueueItemsControl" ItemsSource="{Binding QueueItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12" CornerRadius="12" Margin="0,0,0,6" Cursor="Hand"
                                            Background="#22FFFFFF">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick" Command="{Binding DataContext.QueueItemClickCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                        </Border.InputBindings>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Image Grid.Column="0" Source="{Binding CoverPath, Converter={StaticResource PathToImageConverter}}" 
                                                   Width="40" Height="40" Stretch="UniformToFill" Margin="0,0,12,0">
                                                <Image.Clip><RectangleGeometry Rect="0,0,40,40" RadiusX="6" RadiusY="6"/></Image.Clip>
                                            </Image>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Artist}" FontSize="12" Foreground="White" Opacity="0.5" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>
