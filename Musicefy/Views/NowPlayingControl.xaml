<UserControl x:Class="Musicefy.Views.NowPlayingControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#050505">
    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Button Content="✕" HorizontalAlignment="Right" Click="BackButton_Click" 
                Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"
                Foreground="White" FontSize="20"/>

        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border CornerRadius="30" Width="300" Height="300" ClipToBounds="True" Background="#1A1A1A">
                <Image Source="{Binding NowPlaying.CoverPath, FallbackValue='pack://application:,,,/Assets/default_cover.png'}" 
                       Stretch="UniformToFill"/>
            </Border>
            
            <TextBlock Text="{Binding NowPlaying.Title, FallbackValue='Not Playing'}" 
                       FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,30,0,5"/>
            <TextBlock Text="{Binding NowPlaying.Artist, FallbackValue='Unknown Artist'}" 
                       FontSize="18" Foreground="Gray" HorizontalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,40">
            <Slider x:Name="ProgressSlider" Minimum="0" Maximum="100" Margin="0,20"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="⏮" FontSize="24" Click="Previous_Click" Width="60" Height="60" Background="Transparent"/>
                
                <Button Content="▶" FontSize="32" Click="Play_Click" 
                        Width="80" Height="80" Margin="20,0"
                        Style="{StaticResource RoundPlayButtonStyle}"/>
                
                <Button Content="⏭" FontSize="24" Click="Next_Click" Width="60" Height="60" Background="Transparent"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
