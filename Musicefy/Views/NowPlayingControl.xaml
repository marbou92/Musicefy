<UserControl x:Class="Musicefy.Views.NowPlayingControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#050505">
    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Button Content="✕" HorizontalAlignment="Right" Click="BackButton_Click" 
                Background="Transparent" Foreground="White" BorderThickness="0" FontSize="20"/>

        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border CornerRadius="30" Width="300" Height="300" ClipToBounds="True">
                <Image Source="{Binding NowPlaying.CoverPath, FallbackValue='pack://application:,,,/Assets/default_cover.png'}" Stretch="UniformToFill"/>
            </Border>
            
            <TextBlock Text="{Binding NowPlaying.Title}" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,30,0,5"/>
            <TextBlock Text="{Binding NowPlaying.Artist}" FontSize="18" Foreground="Gray" HorizontalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,40">
            <Slider Minimum="0" Maximum="100" Margin="0,20" Foreground="White"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="⏮" FontSize="24" Background="Transparent" Foreground="White" BorderThickness="0" Margin="20,0"/>
                <Button Content="▶" FontSize="40" Background="White" Foreground="Black" Width="70" Height="70" CornerRadius="35" Margin="20,0"/>
                <Button Content="⏭" FontSize="24" Background="Transparent" Foreground="White" BorderThickness="0" Margin="20,0"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
