<UserControl x:Class="Musicefy.Views.NowPlayingControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#050505"
             MouseDown="OnMouseDown"
             MouseMove="OnMouseMove"
             MouseUp="OnMouseUp"
             TouchDown="OnTouchDown"
             TouchMove="OnTouchMove"
             TouchUp="OnTouchUp">
    
    <UserControl.Resources>
        <Style x:Key="DismissButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" Width="44" Height="44" CornerRadius="22">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#151515"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="40,24,40,40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Border Width="40" Height="4" CornerRadius="2" Background="#303030" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <Button Content="✕" HorizontalAlignment="Right" Style="{StaticResource DismissButtonStyle}" FontSize="18" Click="BackButton_Click"/>
        </Grid>

        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border CornerRadius="24" Width="340" Height="340" ClipToBounds="True" Background="#101010">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="40" ShadowDepth="8" Opacity="0.6" Color="Black"/>
                </Border.Effect>
                <Image Source="{Binding NowPlaying.CoverPath, FallbackValue='pack://application:,,,/Assets/default_cover.png'}" Stretch="UniformToFill"/>
            </Border>
            
            <TextBlock Text="{Binding NowPlaying.Title, FallbackValue='Not Playing'}" FontSize="28" FontWeight="Bold" Foreground="#FFFFFF" HorizontalAlignment="Center" Margin="0,36,0,6" TextTrimming="CharacterEllipsis" MaxWidth="400"/>
            <TextBlock Text="{Binding NowPlaying.Artist, FallbackValue='Unknown Artist'}" FontSize="16" Foreground="{DynamicResource MutedTextBrush}" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="400"/>
        </StackPanel>

        <StackPanel Grid.Row="2" MaxWidth="500" HorizontalAlignment="Stretch" Margin="0,0,0,20">
            <Slider x:Name="ProgressSlider" Minimum="0" Maximum="100" Style="{StaticResource {x:Type Slider}}" Thumb.DragStarted="Slider_DragStarted" Thumb.DragCompleted="Slider_DragCompleted"/>
            
            <Grid Margin="4,8,4,30">
                <TextBlock x:Name="TxtCurrentTime" Text="0:00" FontSize="11" Foreground="{DynamicResource MutedTextBrush}" HorizontalAlignment="Left"/>
                <TextBlock x:Name="TxtTotalTime" Text="0:00" FontSize="11" Foreground="{DynamicResource MutedTextBrush}" HorizontalAlignment="Right"/>
            </Grid>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button Content="⏮" FontSize="26" Width="64" Height="64" Background="Transparent" BorderThickness="0" Foreground="#FFFFFF" Cursor="Hand" Click="Previous_Click"/>
                
                <Button x:Name="BtnMainPlay" Content="▶" FontSize="36" Width="84" Height="84" Margin="32,0" Cursor="Hand" Click="Play_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Ellipse x:Name="Circle" Fill="#FFFFFF"/>
                                <ContentPresenter x:Name="Content" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4,0,0,0">
                                    <ContentPresenter.Resources>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#000000"/>
                                        </Style>
                                    </ContentPresenter.Resources>
                                </ContentPresenter>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="Content" Value="⏸">
                                    <Setter TargetName="Content" Property="Margin" Value="0,0,0,0"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Circle" Property="Opacity" Value="0.9"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                
                <Button Content="⏭" FontSize="26" Width="64" Height="64" Background="Transparent" BorderThickness="0" Foreground="#FFFFFF" Cursor="Hand" Click="Next_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
