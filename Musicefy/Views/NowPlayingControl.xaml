<UserControl x:Class="Musicefy.Views.NowPlayingControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Musicefy.Converters"
             Background="Transparent"
             RenderOptions.BitmapScalingMode="HighQuality"
             RenderOptions.ClearTypeHint="Enabled">
    
    <UserControl.Resources>
        <converters:PathToImageConverter x:Key="PathToImageConverter"/>
        <converters:LyricsToLinesConverter x:Key="LyricsToLinesConverter"/>
        <converters:IsEqualConverter x:Key="IsEqualConverter"/>

        <Style x:Key="NowPlayingIconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="Transparent" CornerRadius="20" Width="44" Height="44">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value><ScaleTransform ScaleX="0.9" ScaleY="0.9"/></Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TransportCircleButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform"><Setter.Value><ScaleTransform ScaleX="1" ScaleY="1"/></Setter.Value></Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="30" Width="60" Height="60">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.3" Color="Black"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Bg" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.06" Duration="0:0:0.15"><DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="Bg" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.06" Duration="0:0:0.15"><DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Bg" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="Bg" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform"><Setter.Value><ScaleTransform ScaleX="0.93" ScaleY="0.93"/></Setter.Value></Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CenterPlayButton" TargetType="Button" BasedOn="{StaticResource TransportCircleButton}">
            <Setter Property="Width" Value="76"/>
            <Setter Property="Height" Value="76"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="White" CornerRadius="38" Width="76" Height="76" RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform><ScaleTransform ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.35" Color="Black"/>
                            </Border.Effect>
                            <Grid>
                                <Path x:Name="PlayIcon" Data="M8,5V19L19,12L8,5Z" Fill="Black" Width="28" Height="28" Stretch="Uniform" Margin="4,0,0,0"/>
                                <Path x:Name="PauseIcon" Data="M14,19H18V5H14M6,19H10V5H6Z" Fill="Black" Width="24" Height="24" Stretch="Uniform" Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Content" Value="&#x23F8;">
                                <Setter TargetName="PlayIcon" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="PauseIcon" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Bg" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.06" Duration="0:0:0.15"><DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="Bg" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.06" Duration="0:0:0.15"><DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Bg" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="Bg" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform"><Setter.Value><ScaleTransform ScaleX="0.92" ScaleY="0.92"/></Setter.Value></Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="RootGrid" CacheMode="BitmapCache">
        <!-- Root Grid rows -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Background layers (span all rows) -->
        <Grid Grid.RowSpan="3" ClipToBounds="True" IsHitTestVisible="False">
            <Image x:Name="BgCoverImage"
                   Source="{Binding NowPlaying.CoverPath, Converter={StaticResource PathToImageConverter}}"
                   Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"
                   HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image.RenderTransform>
                    <ScaleTransform ScaleX="1.2" ScaleY="1.2"/>
                </Image.RenderTransform>
                <Image.Effect>
                    <BlurEffect Radius="50"/>
                </Image.Effect>
            </Image>
            <Border Opacity="0.18">
                <Border.Background>
                    <SolidColorBrush Color="{Binding VibrantColor, FallbackValue=Transparent}"/>
                </Border.Background>
            </Border>
            <Border Background="#CC000000"/>
            <Border VerticalAlignment="Top" Height="160">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#BB000000" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <Border VerticalAlignment="Bottom" Height="220">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="Transparent" Offset="0"/>
                        <GradientStop Color="#EE000000" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
        </Grid>

        <!-- Row 0: Top bar -->
        <Grid Grid.Row="0" Margin="20,16,20,0" Height="52" ZIndex="1">
            <Button x:Name="BtnCollapse" HorizontalAlignment="Left" VerticalAlignment="Center"
                    Style="{StaticResource NowPlayingIconButton}" Command="{Binding CollapseCommand}">
                <Path Data="M7.41,8.58L12,13.17L16.59,8.58L18,10L12,16L6,10L7.41,8.58Z"
                      Fill="White" Width="24" Height="24" Stretch="Uniform"/>
            </Button>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Now Playing" FontSize="13" FontWeight="SemiBold"
                           Foreground="White" Opacity="0.75" HorizontalAlignment="Center"/>
            </StackPanel>
            <Button x:Name="BtnMenu" HorizontalAlignment="Right" VerticalAlignment="Center"
                    Style="{StaticResource NowPlayingIconButton}">
                <Path Data="M12,8C13.1,8 14,7.1 14,6C14,4.9 13.1,4 12,4C10.9,4 10,4.9 10,6C10,7.1 10.9,8 12,8M12,10C10.9,10 10,10.9 10,12C10,13.1 10.9,14 12,14C13.1,14 14,13.1 14,12C14,10.9 13.1,10 12,10M12,16C10.9,16 10,16.9 10,18C10,19.1 10.9,20 12,20C13.1,20 14,19.1 14,18C14,16.9 13.1,16 12,16Z"
                      Fill="White" Width="20" Height="20" Stretch="Uniform"/>
            </Button>
        </Grid>

        <!-- Row 1: Center content -->
        <Grid Grid.Row="1" ZIndex="1">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Width="340" Height="340" CornerRadius="20" ClipToBounds="True"
                        Background="{DynamicResource SurfaceVariantBrush}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="48" ShadowDepth="16" Opacity="0.6" Color="Black"/>
                    </Border.Effect>
                    <Image Source="{Binding NowPlaying.CoverPath, Converter={StaticResource PathToImageConverter}}"
                           Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                </Border>
                <TextBlock Text="{Binding NowPlaying.Title, FallbackValue='Not Playing'}"
                           FontSize="24" FontWeight="Bold" Foreground="White"
                           TextTrimming="CharacterEllipsis" HorizontalAlignment="Center"
                           MaxWidth="380" Margin="0,24,0,0"/>
                <Grid Width="380" Margin="0,8,0,0">
                    <TextBlock Text="{Binding NowPlaying.Artist, FallbackValue='Unknown Artist'}"
                               FontSize="15" Foreground="White" Opacity="0.70"
                               TextTrimming="CharacterEllipsis" HorizontalAlignment="Center"
                               Cursor="Hand" MouseLeftButtonUp="ArtistText_MouseLeftButtonUp">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.9"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="BtnShare" Style="{StaticResource NowPlayingIconButton}"
                                Command="{Binding ShareCommand}" ToolTip="Share">
                            <Path Data="M18,16.08C17.24,16.08 16.56,16.38 16.04,16.85L8.91,12.7C8.96,12.47 9,12.24 9,12S8.96,11.53 8.91,11.3L15.96,7.19C16.5,7.69 17.21,8 18,8C19.66,8 21,6.66 21,5S19.66,2 18,2 15,3.34 15,5C15,5.24 15.04,5.47 15.09,5.7L8.04,9.81C7.5,9.31 6.79,9 6,9C4.34,9 3,10.34 3,12S4.34,15 6,15C6.79,15 7.5,14.69 8.04,14.19L15.16,18.35C15.11,18.56 15.08,18.78 15.08,19C15.08,20.61 16.39,21.92 18,21.92S20.92,20.61 20.92,19 19.61,16.08 18,16.08Z"
                                  Fill="White" Width="20" Height="20" Stretch="Uniform"/>
                        </Button>
                        <Button x:Name="BtnFavorite" Style="{StaticResource NowPlayingIconButton}"
                                Command="{Binding FavoriteCommand}" ToolTip="Favorite" Margin="8,0,0,0">
                            <Grid Width="22" Height="22">
                                <Path Data="M12.1,18.55L12,18.65L11.89,18.55C7.14,14.24 4,11.39 4,8.5C4,6.5 5.5,5 7.5,5C9.04,5 10.54,6 11.07,7.36H12.93C13.46,6 14.96,5 16.5,5C18.5,5 20,6.5 20,8.5C20,11.39 16.86,14.24 12.1,18.55M16.5,3C14.76,3 13.09,3.81 12,5.08C10.91,3.81 9.24,3 7.5,3C4.42,3 2,5.41 2,8.5C2,12.27 5.4,15.36 10.55,20.03L12,21.35L13.45,20.03C18.6,15.36 22,12.27 22,8.5C22,5.41 19.58,3 16.5,3Z"
                                      Fill="White" Stretch="Uniform">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsFavoriteTrack}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                                <Path Data="M12,21.35L10.55,20.03C5.4,15.36 2,12.28 2,8.5C2,5.42 4.42,3 7.5,3C9.24,3 10.91,3.81 12,5.09C13.09,3.81 14.76,3 16.5,3C19.58,3 22,5.42 22,8.5C22,12.28 18.6,15.36 13.45,20.03L12,21.35Z"
                                      Fill="{DynamicResource ErrorBrush}" Stretch="Uniform">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsFavoriteTrack}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                            </Grid>
                        </Button>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Grid>

        <!-- Row 2: Controls -->
        <Grid Grid.Row="2" ZIndex="1" Margin="28,0,28,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Progress bar -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Slider x:Name="ProgressSlider" Minimum="0" Maximum="100"
                        Value="{Binding ProgressValue}" Height="20"
                        Thumb.DragStarted="Slider_DragStarted" Thumb.DragCompleted="Slider_DragCompleted"/>
            </Grid>
            <Grid Grid.Row="1" Margin="0,6,0,0">
                <TextBlock Text="{Binding CurrentTimeText}" FontSize="12"
                           Foreground="White" Opacity="0.65" FontWeight="Medium"/>
                <TextBlock Text="{Binding TotalTimeText}" FontSize="12"
                           Foreground="White" Opacity="0.65" FontWeight="Medium"
                           HorizontalAlignment="Right"/>
            </Grid>

            <!-- Large playback buttons -->
            <Grid Grid.Row="2" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Style="{StaticResource TransportCircleButton}"
                        Command="{Binding PreviousCommand}" Margin="0,0,16,0">
                    <Path Data="M6,18V6H8V18H6M9.5,12L18,6V18L9.5,12Z"
                          Fill="Black" Width="24" Height="24" Stretch="Uniform"/>
                </Button>
                <Button Grid.Column="1" x:Name="BtnMainPlay" Content="{Binding PlayPauseContent}"
                        Style="{StaticResource CenterPlayButton}" Command="{Binding PlayPauseCommand}"
                        Margin="16,0,16,0"/>
                <Button Grid.Column="2" Style="{StaticResource TransportCircleButton}"
                        Command="{Binding NextCommand}" Margin="16,0,0,0">
                    <Path Data="M16,18H18V6H16M6,18L14.5,12L6,6V18Z"
                          Fill="Black" Width="24" Height="24" Stretch="Uniform"/>
                </Button>
            </Grid>

            <!-- Audio format info -->
            <TextBlock Grid.Row="3" Text="{Binding AudioFormatText}"
                       HorizontalAlignment="Center" Margin="0,14,0,0"
                       FontSize="11" Foreground="White" Opacity="0.45">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding AudioFormatText}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding AudioFormatText}" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Utility buttons row -->
            <StackPanel Grid.Row="4" Orientation="Horizontal"
                        HorizontalAlignment="Center" Margin="0,18,0,0">
                <Button x:Name="BtnToggleQueue" Style="{StaticResource NowPlayingIconButton}"
                        Command="{Binding ToggleQueueCommand}" Margin="0,0,20,0" ToolTip="Queue">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource NowPlayingIconButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsQueuePanelVisible}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource DynamicPrimaryBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Path Data="M4,16H14V14H4V16ZM4,11H18V9H4V11ZM4,4V6H18V4H4Z"
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          Width="20" Height="20" Stretch="Uniform"/>
                </Button>
                <Button x:Name="BtnSleepTimer" Style="{StaticResource NowPlayingIconButton}"
                        Command="{Binding SleepTimerCommand}" Margin="0,0,20,0" ToolTip="Sleep Timer">
                    <Path Data="M12,3c0.132 0 0.263 0.007 0.393 0.021a8.4 8.4 0 0 0-0.143 1.579c0 4.639 3.76 8.4 8.4 8.4 0.542 0 1.062-0.051 1.564-0.149A8.4 8.4 0 1 1 12 3z"
                          Fill="White" Width="20" Height="20" Stretch="Uniform"/>
                </Button>
                <Button x:Name="BtnToggleLyrics" Style="{StaticResource NowPlayingIconButton}"
                        Command="{Binding ToggleLyricsCommand}" Margin="0,0,20,0" ToolTip="Lyrics">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource NowPlayingIconButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLyricsPanelVisible}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource DynamicPrimaryBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Path Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M9,17H7V10H9V17ZM13,17H11V7H13V17ZM17,17H15V12H17V17Z"
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          Width="20" Height="20" Stretch="Uniform"/>
                </Button>
                <Button x:Name="BtnRepeat" Style="{StaticResource NowPlayingIconButton}"
                        Command="{Binding RepeatCommand}" Margin="0,0,20,0" ToolTip="Repeat">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource NowPlayingIconButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRepeatEnabled}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource DynamicPrimaryBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Path Data="M17,17H7V14L3,18L7,22V19H19V13H17V17M7,7H7V10L21,6L17,2V5H5V11H7V7Z"
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          Width="20" Height="20" Stretch="Uniform"/>
                </Button>
                <Button x:Name="BtnShuffle" Style="{StaticResource NowPlayingIconButton}"
                        Command="{Binding ShuffleCommand}" ToolTip="Shuffle">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource NowPlayingIconButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsShuffleEnabled}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource DynamicPrimaryBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Path Data="M14.83,13.41L13.42,14.82L16.55,17.95L14.5,20H20V14.5L17.96,16.54L14.83,13.41M14.5,4L16.54,6.04L4,18.58L5.41,20L17.96,7.46L20,9.5V4H14.5M10.59,9.17L5.41,4L4,5.41L9.17,10.58L10.59,9.17Z"
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          Width="20" Height="20" Stretch="Uniform"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Layer: Lyrics overlay (bottom sheet) -->
        <Grid x:Name="LyricsOverlay" Visibility="Collapsed" VerticalAlignment="Bottom" MaxHeight="440"
              Margin="28,0,28,0" Opacity="0">
            <Grid.RenderTransform>
                <TranslateTransform Y="100"/>
            </Grid.RenderTransform>
            <Border Background="#F01A1A1A" CornerRadius="20,20,0,0" Padding="24,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Lyrics" FontSize="16" FontWeight="SemiBold"
                               Foreground="White" Margin="0,0,0,16" HorizontalAlignment="Center"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" PanningMode="VerticalOnly">
                        <ItemsControl ItemsSource="{Binding NowPlaying.Lyrics, Converter={StaticResource LyricsToLinesConverter}}"
                                      VirtualizingStackPanel.IsVirtualizing="True">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontSize="22" FontWeight="Bold"
                                               Foreground="White" Opacity="0.25"
                                               TextWrapping="Wrap" Margin="0,10,0,10" Cursor="Hand">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Opacity" Value="1.0"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Layer: Queue overlay (bottom sheet) -->
        <Grid x:Name="QueueOverlay" Visibility="Collapsed" VerticalAlignment="Bottom" MaxHeight="440"
              Margin="28,0,28,0" Opacity="0">
            <Grid.RenderTransform>
                <TranslateTransform Y="100"/>
            </Grid.RenderTransform>
            <Border Background="#F01A1A1A" CornerRadius="20,20,0,0" Padding="24,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Up Next" FontSize="16" FontWeight="SemiBold"
                               Foreground="White" Margin="0,0,0,16" HorizontalAlignment="Center"/>
                    <ScrollViewer x:Name="QueueScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" PanningMode="VerticalOnly"
                                  MouseEnter="QueueScrollViewer_MouseEnter" MouseLeave="QueueScrollViewer_MouseLeave">
                        <ItemsControl x:Name="QueueItemsControl" ItemsSource="{Binding QueueItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12" CornerRadius="12" Margin="0,0,0,6" Cursor="Hand"
                                            Background="#22FFFFFF">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick" Command="{Binding DataContext.QueueItemClickCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                        </Border.InputBindings>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Image Grid.Column="0" Source="{Binding CoverPath, Converter={StaticResource PathToImageConverter}}"
                                                   Width="40" Height="40" Stretch="UniformToFill" Margin="0,0,12,0">
                                                <Image.Clip><RectangleGeometry Rect="0,0,40,40" RadiusX="6" RadiusY="6"/></Image.Clip>
                                            </Image>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Artist}" FontSize="12" Foreground="White" Opacity="0.5" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
