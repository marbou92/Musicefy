<UserControl x:Class="Musicefy.Views.NowPlayingControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Musicefy.Converters"
             Background="{DynamicResource BackgroundBrush}"
             MouseDown="OnMouseDown"
             MouseMove="OnMouseMove"
             MouseUp="OnMouseUp"
             TouchDown="OnTouchDown"
             TouchMove="OnTouchMove"
             TouchUp="OnTouchUp">
    
    <UserControl.Resources>
        <converters:PathToImageConverter x:Key="PathToImageConverter"/>
        <converters:LyricsToLinesConverter x:Key="LyricsToLinesConverter"/>

        <Style x:Key="DismissButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" Width="44" Height="44" CornerRadius="22">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TransportPathButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="52"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="26">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border Background="{DynamicResource BorderBrush}" Opacity="0.1" VerticalAlignment="Bottom" Height="400"/>

        <Grid Margin="50,30,50,40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Path Data="M7.41,8.58L12,13.17L16.59,8.58L18,10L12,16L6,10L7.41,8.58Z" Fill="{DynamicResource MutedTextBrush}" Width="24" Height="24" Stretch="Uniform" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                <Button Content="✕" HorizontalAlignment="Right" Style="{StaticResource DismissButtonStyle}" FontSize="18" Click="BackButton_Click"/>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4.5*"/>
                    <ColumnDefinition Width="5.5*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0,0,40,0" VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" CornerRadius="16" Width="380" Height="380" HorizontalAlignment="Left" ClipToBounds="True" Background="{DynamicResource SecondaryBackgroundBrush}">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="45" ShadowDepth="10" Opacity="0.4" Color="Black"/>
                        </Border.Effect>
                        <Image Source="{Binding NowPlaying.CoverPath, Converter={StaticResource PathToImageConverter}}" Stretch="UniformToFill"/>
                    </Border>

                    <Grid Grid.Row="1" Margin="4,24,4,0" Width="380" HorizontalAlignment="Left">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding NowPlaying.Title, FallbackValue='Not Playing'}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding NowPlaying.Artist, FallbackValue='Unknown Artist'}" FontSize="15" Foreground="{DynamicResource MutedTextBrush}" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <Button Grid.Column="1" x:Name="BtnToggleLyrics" Width="44" Height="44" Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center" Click="BtnToggleLyrics_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="PillBg" Background="{DynamicResource SecondaryBackgroundBrush}" CornerRadius="22">
                                        <Path x:Name="BubbleIcon" Data="M9,22A1,1 0 0,1 8,21V18H4A2,2 0 0,1 2,16V4C2,2.89 2.9,2 4,2H20A2,2 0 0,1 22,4V16A2,2 0 0,1 20,12H12L9,22M12,14H17V12H12V14M7,14H10V12H7V14M14,10H17V8H14V10M7,10H12V8H7V10Z" 
                                              Fill="{DynamicResource MutedTextBrush}" Width="20" Height="20" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="BubbleIcon" Property="Fill" Value="{DynamicResource TextBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <Grid Grid.Row="2" Margin="4,24,4,0" MaxWidth="380" HorizontalAlignment="Left">
                        <StackPanel Width="380">
                            <Slider x:Name="ProgressSlider" Minimum="0" Maximum="100" Style="{StaticResource {x:Type Slider}}" Thumb.DragStarted="Slider_DragStarted" Thumb.DragCompleted="Slider_DragCompleted"/>
                            <Grid Margin="2,6,2,0">
                                <TextBlock x:Name="TxtCurrentTime" Text="0:00" FontSize="11" Foreground="{DynamicResource MutedTextBrush}" HorizontalAlignment="Left"/>
                                <TextBlock x:Name="TxtTotalTime" Text="0:00" FontSize="11" Foreground="{DynamicResource MutedTextBrush}" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,30,0,0" Width="380">
                        <Grid Width="380">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Button Style="{StaticResource TransportPathButtonStyle}" Click="Previous_Click" Margin="0,0,24,0">
                                    <Path Data="M6,18V6H8V18H6M9.5,12L18,6V18L9.5,12Z" Fill="{DynamicResource TextBrush}" Width="18" Height="18" Stretch="Uniform"/>
                                </Button>

                                <Button x:Name="BtnMainPlay" Content="▶" Width="68" Height="68" Cursor="Hand" Click="Play_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Grid>
                                                <Ellipse x:Name="Circle" Fill="White"/>
                                                <Path x:Name="PlayIcon" Data="M8,5V19L19,12L8,5Z" Fill="Black" Width="20" Height="20" Stretch="Uniform" Margin="3,0,0,0"/>
                                                <Path x:Name="PauseIcon" Data="M14,19H18V5H14M6,19H10V5H6Z" Fill="Black" Width="18" Height="18" Stretch="Uniform" Visibility="Collapsed"/>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="Content" Value="⏸">
                                                    <Setter TargetName="PlayIcon" Property="Visibility" Value="Collapsed"/>
                                                    <Setter TargetName="PauseIcon" Property="Visibility" Value="Visible"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Circle" Property="Opacity" Value="0.9"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <Button Style="{StaticResource TransportPathButtonStyle}" Click="Next_Click" Margin="24,0,0,0">
                                    <Path Data="M16,18H18V6H16M6,18L14.5,12L6,6V18Z" Fill="{DynamicResource TextBrush}" Width="18" Height="18" Stretch="Uniform"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Grid>

                <Grid Grid.Column="1" Margin="20,10,0,10">
                    
                    <Grid x:Name="QueuePanelContainer" Visibility="Visible">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Path Data="M12,3V10.55C11.41,10.21 10.73,10 10,10A4,4 0 0,0 6,14A4,4 0 0,0 10,18A4,4 0 0,0 14,14V7H18V3H12Z" 
                                  Fill="{DynamicResource BorderBrush}" Width="48" Height="48" Stretch="Uniform" Margin="0,0,0,16"/>
                            <TextBlock Text="Up Next Queue Active" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource MutedTextBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Click the icon button to switch on live lyrics feed." FontSize="13" Foreground="{DynamicResource BorderBrush}" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <Grid x:Name="LyricsPanelContainer" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding NowPlaying.Lyrics, Converter={StaticResource LyricsToLinesConverter}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" 
                                                   FontSize="22" 
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource TextBrush}" 
                                                   Opacity="0.45" 
                                                   TextAlignment="Center" 
                                                   TextWrapping="Wrap" 
                                                   Margin="0,10,0,10"
                                                   Cursor="Hand">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Opacity" Value="1.0"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                    
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
