<UserControl x:Class="Musicefy.Views.NowPlayingControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Musicefy.Converters">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Back Button -->
        <Button x:Name="BackButton" Content="⬇ Collapse" HorizontalAlignment="Left" Width="100" Height="32"
                Click="BackButton_Click"/>

        <!-- Album Art -->
        <Image Width="240" Height="240" HorizontalAlignment="Center" Grid.Row="0" Margin="0,40,0,0"
               Source="{Binding NowPlaying.CoverPath, 
                                Converter={StaticResource PathToImageConverter}, 
                                FallbackValue='pack://application:,,,/Assets/default_cover.png'}"/>

        <!-- Song Info -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,12,0,12">
            <TextBlock Text="{Binding NowPlaying.Title, FallbackValue='Untitled Track'}" FontSize="20" FontWeight="Bold"/>
            <TextBlock Text="{Binding NowPlaying.Artist, FallbackValue='Unknown'}" Foreground="Gray" FontSize="16"/>
            <TextBlock Text="{Binding NowPlaying.Album, FallbackValue='Unknown Album'}" Foreground="Gray" FontSize="12"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,0">
                <Button Command="{Binding ToggleFavouriteCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <TextBlock Text="❤" FontSize="18"
                               Foreground="{Binding NowPlaying.IsFavourite, Converter={StaticResource BoolToBrushConverter}}"
                               Margin="6,0"/>
                </Button>
                <TextBlock Text="{Binding NowPlaying.PlayCount, StringFormat='Played {0} times'}"
                           Foreground="Gray" FontSize="12" Margin="6,0"/>
            </StackPanel>
        </StackPanel>

        <!-- Lyrics -->
        <ListBox Grid.Row="2" Margin="0,12,0,12"
                 ItemsSource="{Binding NowPlaying.Lyrics, Converter={StaticResource LyricsToLinesConverter}}"/>

        <!-- Playback Controls + Progress -->
        <StackPanel Grid.Row="3" Orientation="Vertical" HorizontalAlignment="Center" Margin="0,12,0,0">
            <Slider x:Name="ProgressSlider" Minimum="0" Maximum="100" Height="20" Width="400" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="⏮" Width="48" Height="40" Click="Previous_Click"/>
                <Button Content="▶" Width="64" Height="40" Click="Play_Click"/>
                <Button Content="⏸" Width="64" Height="40" Click="Pause_Click"/>
                <Button Content="⏭" Width="48" Height="40" Click="Next_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
