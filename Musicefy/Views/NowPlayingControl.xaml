<UserControl x:Class="Musicefy.Views.NowPlayingControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Musicefy.Converters"
             Background="{DynamicResource BackgroundBrush}"
             MouseDown="OnMouseDown"
             MouseMove="OnMouseMove"
             MouseUp="OnMouseUp"
             TouchDown="OnTouchDown"
             TouchMove="OnTouchMove"
             TouchUp="OnTouchUp">
    
    <UserControl.Resources>
        <converters:PathToImageConverter x:Key="PathToImageConverter"/>
        <converters:LyricsToLinesConverter x:Key="LyricsToLinesConverter"/>

        <Style x:Key="DismissButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" Width="44" Height="44" CornerRadius="22">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TransportPathButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="52"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="26">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MetaTogglePillStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="PillBg" Background="{DynamicResource SecondaryBackgroundBrush}" CornerRadius="21">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PillBg" Property="Background" Value="{DynamicResource BorderBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border Background="{DynamicResource BorderBrush}" Opacity="0.08" VerticalAlignment="Bottom" Height="450"/>

        <Grid Margin="60,30,60,40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Path Data="M7.41,8.58L12,13.17L16.59,8.58L18,10L12,16L6,10L7.41,8.58Z" Fill="{DynamicResource MutedTextBrush}" Width="24" Height="24" Stretch="Uniform" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                <Button Content="✕" HorizontalAlignment="Right" Style="{StaticResource DismissButtonStyle}" FontSize="18" Click="BackButton_Click"/>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="LeftPlayerColumn" Width="*"/>
                    <ColumnDefinition x:Name="RightPanelColumn" Width="0"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" x:Name="PlayerDeckRoot" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel Width="420">
                        
                        <Border CornerRadius="20" Width="420" Height="420" ClipToBounds="True" Background="#0D0D0D">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="50" ShadowDepth="12" Opacity="0.45" Color="Black"/>
                            </Border.Effect>
                            <Image Source="{Binding NowPlaying.CoverPath, Converter={StaticResource PathToImageConverter}}" Stretch="UniformToFill"/>
                        </Border>

                        <Grid Margin="4,28,4,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                <TextBlock Text="{Binding NowPlaying.Title, FallbackValue='Not Playing'}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding NowPlaying.Artist, FallbackValue='Unknown Artist'}" FontSize="15" Foreground="{DynamicResource MutedTextBrush}" Margin="0,5,0,0" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button x:Name="BtnToggleQueue" Style="{StaticResource MetaTogglePillStyle}" Click="BtnToggleQueue_Click" Margin="0,0,10,0">
                                    <Path x:Name="QueueIcon" Data="M19,15H3V17H19V15M19,11H3V13H19V11M3,7H19V9H3V7Z" Fill="{DynamicResource MutedTextBrush}" Width="18" Height="18" Stretch="Uniform"/>
                                </Button>
                                <Button x:Name="BtnToggleLyrics" Style="{StaticResource MetaTogglePillStyle}" Click="BtnToggleLyrics_Click">
                                    <Path x:Name="LyricsIcon" Data="M9,22A1,1 0 0,1 8,21V18H4A2,2 0 0,1 2,16V4C2,2.89 2.9,2 4,2H20A2,2 0 0,1 22,4V16A2,2 0 0,1 20,12H12L9,22M12,14H17V12H12V14M7,14H10V12H7V14M14,10H17V8H14V10M7,10H12V8H7V10Z" Fill="{DynamicResource MutedTextBrush}" Width="16" Height="16" Stretch="Uniform"/>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <StackPanel Margin="4,24,4,0">
                            <Slider x:Name="ProgressSlider" Minimum="0" Maximum="100" Style="{StaticResource {x:Type Slider}}" Thumb.DragStarted="Slider_DragStarted" Thumb.DragCompleted="Slider_DragCompleted"/>
                            <Grid Margin="2,6,2,0">
                                <TextBlock x:Name="TxtCurrentTime" Text="0:00" FontSize="11" Foreground="{DynamicResource MutedTextBrush}"/>
                                <TextBlock x:Name="TxtTotalTime" Text="0:00" FontSize="11" Foreground="{DynamicResource MutedTextBrush}" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,28,0,0">
                            <Button Style="{StaticResource TransportPathButtonStyle}" Click="Previous_Click" Margin="0,0,24,0">
                                <Path Data="M6,18V6H8V18H6M9.5,12L18,6V18L9.5,12Z" Fill="{DynamicResource TextBrush}" Width="18" Height="18" Stretch="Uniform"/>
                            </Button>

                            <Button x:Name="BtnMainPlay" Content="▶" Width="72" Height="72" Cursor="Hand" Click="Play_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Grid>
                                            <Ellipse x:Name="Circle" Fill="White"/>
                                            <Path x:Name="PlayIcon" Data="M8,5V19L19,12L8,5Z" Fill="Black" Width="22" Height="22" Stretch="Uniform" Margin="4,0,0,0"/>
                                            <Path x:Name="PauseIcon" Data="M14,19H18V5H14M6,19H10V5H6Z" Fill="Black" Width="20" Height="20" Stretch="Uniform" Visibility="Collapsed"/>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="Content" Value="⏸">
                                                <Setter TargetName="PlayIcon" Property="Visibility" Value="Collapsed"/>
                                                <Setter TargetName="PauseIcon" Property="Visibility" Value="Visible"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Circle" Property="Opacity" Value="0.92"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button Style="{StaticResource TransportPathButtonStyle}" Click="Next_Click" Margin="24,0,0,0">
                                <Path Data="M16,18H18V6H16M6,18L14.5,12L6,6V18Z" Fill="{DynamicResource TextBrush}" Width="18" Height="18" Stretch="Uniform"/>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <Grid Grid.Column="1" x:Name="RightPanelRoot" Margin="40,20,0,20" Visibility="Collapsed">
                    
                    <Grid x:Name="LyricsPanelContainer" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding NowPlaying.Lyrics, Converter={StaticResource LyricsToLinesConverter}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Opacity="0.4" TextAlignment="Left" TextWrapping="Wrap" Margin="0,12,0,12" Cursor="Hand">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Opacity" Value="1.0"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>

                    <Grid x:Name="QueuePanelContainer" Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Text="Up Next Queue" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,20"/>
                            
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                                <StackPanel>
                                    <Border Background="{DynamicResource SecondaryBackgroundBrush}" Padding="16" CornerRadius="12" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Path Grid.Column="0" Data="M12,3V10.55C11.41,10.21 10.73,10 10,10A4,4 0 0,0 6,14A4,4 0 0,0 10,18A4,4 0 0,0 14,14V7H18V3H12Z" Fill="{DynamicResource AccentBrush}" Width="18" Height="18" Stretch="Uniform" Margin="0,0,14,0"/>
                                            <TextBlock Grid.Column="1" Text="Next Tracks Scheduled In Stream Queue" FontSize="14" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                    
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
