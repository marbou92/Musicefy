<UserControl x:Class="Musicefy.Views.NowPlayingControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Musicefy.Converters"
             Background="{DynamicResource BackgroundBrush}"
             RenderOptions.BitmapScalingMode="HighQuality"
             RenderOptions.ClearTypeHint="Enabled">
    
    <UserControl.Resources>
        <converters:PathToImageConverter x:Key="PathToImageConverter"/>
        <converters:LyricsToLinesConverter x:Key="LyricsToLinesConverter"/>
        <converters:IsEqualConverter x:Key="IsEqualConverter"/>

        <Style x:Key="BaseControlButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MaterialSecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseControlButtonStyle}">
            <Setter Property="Foreground" Value="{DynamicResource OnSurfaceBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BgBorder" Background="{TemplateBinding Background}" CornerRadius="20" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BgBorder" Property="Background" Value="{DynamicResource HoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.94" ScaleY="0.94"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MaterialPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseControlButtonStyle}">
            <Setter Property="Foreground" Value="{DynamicResource OnPrimaryBrush}"/>
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BgBorder" Background="{TemplateBinding Background}" CornerRadius="28" Width="80" Height="80">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.3" Color="Black"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="BgBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.05" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="BgBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.05" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="BgBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="BgBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.92" ScaleY="0.92"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="TransportIconStyle" TargetType="Button" BasedOn="{StaticResource BaseControlButtonStyle}">
            <Setter Property="Foreground" Value="{DynamicResource OnSurfaceBrush}"/>
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.85" ScaleY="0.85"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid CacheMode="BitmapCache">
        <Border Background="{DynamicResource BorderBrush}" Opacity="0.015" VerticalAlignment="Bottom" Height="500"/>

        <Grid Margin="44,24,44,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Button x:Name="BtnCollapse" Style="{StaticResource MaterialSecondaryButtonStyle}" Width="40" HorizontalAlignment="Left" Command="{Binding CollapseCommand}" Background="Transparent">
                    <Path Data="M7.41,8.58L12,13.17L16.59,8.58L18,10L12,16L6,10L7.41,8.58Z" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="24" Height="24" Stretch="Uniform"/>
                </Button>
                
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Now Playing" FontSize="14" Foreground="{DynamicResource OnSurfaceBrush}" FontWeight="Medium" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="LeftPlayerColumn" Width="*"/>
                    <ColumnDefinition x:Name="RightPanelColumn" Width="0"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" x:Name="PlayerDeckRoot" MaxWidth="460" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <Grid Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,24">
                        <Grid.Effect>
                            <DropShadowEffect BlurRadius="40" ShadowDepth="10" Opacity="0.4" Color="Black"/>
                        </Grid.Effect>
                        <Border x:Name="CoverArtBorder" CornerRadius="32" ClipToBounds="True" Background="#030303" MaxHeight="390" Width="{Binding ActualHeight, RelativeSource={RelativeSource Self}}">
                            <Image Source="{Binding NowPlaying.CoverPath, Converter={StaticResource PathToImageConverter}}" Stretch="UniformToFill"/>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1" Margin="4,0,4,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,0,10,0">
                            <TextBlock Text="{Binding NowPlaying.Title, FallbackValue='Not Playing'}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource OnSurfaceBrush}" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding NowPlaying.Artist, FallbackValue='Unknown Artist'}" FontSize="16" Foreground="{DynamicResource OnSurfaceVariantBrush}" TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="BtnShare" Style="{StaticResource MaterialSecondaryButtonStyle}" Command="{Binding ShareCommand}" Margin="0,0,8,0">
                                <Path Data="M18,16.08C17.24,16.08 16.56,16.38 16.04,16.85L8.91,12.7C8.96,12.47 9,12.24 9,12C9,11.76 8.96,11.53 8.91,11.3L15.96,7.19C16.5,7.69 17.21,8 18,8A3,3 0 0,0 21,5A3,3 0 0,0 18,2A3,3 0 0,0 15,5C15,5.24 15.04,5.47 15.09,5.7L8.04,9.81C7.5,9.31 6.79,9 6,9A3,3 0 0,0 3,12A3,3 0 0,0 6,15C6.79,15 7.5,14.69 8.04,14.19L15.16,18.34C15.11,18.55 15.08,18.77 15.08,19C15.08,20.61 16.39,21.92 18,21.92C19.61,21.92 20.92,20.61 20.92,19C20.92,17.39 19.61,16.08 18,16.08Z" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="18" Height="18" Stretch="Uniform"/>
                            </Button>
                            
                            <Button x:Name="BtnFavorite" Command="{Binding FavoriteCommand}" Margin="0,0,8,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource MaterialSecondaryButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFavoriteTrack}" Value="True">
                                                <Setter Property="Foreground" Value="Crimson"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsFavoriteTrack}" Value="False">
                                                <Setter Property="Foreground" Value="{DynamicResource OnSurfaceBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Grid Width="22" Height="22">
                                    <Path x:Name="HeartOutline" Data="M12.1,18.55L12,18.65L11.89,18.55C7.14,14.24 4,11.39 4,8.5C4,6.5 5.5,5 7.5,5C9.04,5 10.54,6 11.07,7.36H12.93C13.46,6 14.96,5 16.5,5C18.5,5 20,6.5 20,8.5C20,11.39 16.86,14.24 12.1,18.55M16.5,3C14.76,3 13.09,3.81 12,5.08C10.91,3.81 9.24,3 7.5,3C4.42,3 2,5.41 2,8.5C2,12.27 5.4,15.36 10.55,20.03L12,21.35L13.45,20.03C18.6,15.36 22,12.27 22,8.5C22,5.41 19.58,3 16.5,3Z" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform">
                                        <Path.Style>
                                            <Style TargetType="Path">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsFavoriteTrack}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Path.Style>
                                    </Path>
                                    <Path x:Name="HeartFilled" Data="M12,21.35L10.55,20.03C5.4,15.36 2,12.28 2,8.5C2,5.42 4.42,3 7.5,3C9.24,3 10.91,3.81 12,5.09C13.09,3.81 14.76,3 16.5,3C19.58,3 22,5.42 22,8.5C22,12.28 18.6,15.36 13.45,20.03L12,21.35Z" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform">
                                        <Path.Style>
                                            <Style TargetType="Path">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsFavoriteTrack}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Path.Style>
                                    </Path>
                                </Grid>
                            </Button>

                            <Button x:Name="BtnShowInExplorer" Style="{StaticResource MaterialSecondaryButtonStyle}" Command="{Binding ShowInExplorerCommand}">
                                <Path Data="M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="20" Height="20" Stretch="Uniform"/>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="2" Margin="4,0,4,20">
                        <Slider x:Name="ProgressSlider" Minimum="0" Maximum="100" Value="{Binding ProgressValue}" Style="{StaticResource {x:Type Slider}}" Height="24" Thumb.DragStarted="Slider_DragStarted" Thumb.DragCompleted="Slider_DragCompleted"/>
                        <Grid Margin="4,2,4,0">
                            <TextBlock Text="{Binding CurrentTimeText}" FontSize="12" Foreground="{DynamicResource OnSurfaceVariantBrush}" FontWeight="Medium"/>
                            <TextBlock Text="{Binding TotalTimeText}" FontSize="12" Foreground="{DynamicResource OnSurfaceVariantBrush}" HorizontalAlignment="Right" FontWeight="Medium"/>
                        </Grid>
                    </StackPanel>

                    <Grid Grid.Row="3" Margin="0,0,0,24">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                             <Button x:Name="BtnShuffle" Command="{Binding ShuffleCommand}" Margin="0,0,16,0">
                                 <Button.Style>
                                     <Style TargetType="Button" BasedOn="{StaticResource TransportIconStyle}">
                                         <Style.Triggers>
                                             <DataTrigger Binding="{Binding IsShuffleEnabled}" Value="True">
                                                 <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                             </DataTrigger>
                                             <DataTrigger Binding="{Binding IsShuffleEnabled}" Value="False">
                                                 <Setter Property="Foreground" Value="{DynamicResource OnSurfaceBrush}"/>
                                             </DataTrigger>
                                         </Style.Triggers>
                                     </Style>
                                 </Button.Style>
                                 <Path x:Name="ShuffleIcon" Data="M14.83,13.41L13.42,14.82L16.55,17.95L14.5,20H20V14.5L17.96,16.54L14.83,13.41M14.5,4L16.54,6.04L4,18.58L5.41,20L17.96,7.46L20,9.5V4H14.5M10.59,9.17L5.41,4L4,5.41L9.17,10.58L10.59,9.17Z" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="20" Height="20" Stretch="Uniform"/>
                             </Button>
                            
                            <Button Style="{StaticResource TransportIconStyle}" Command="{Binding PreviousCommand}" Margin="0,0,20,0">
                                <Path Data="M6,18V6H8V18H6M9.5,12L18,6V18L9.5,12Z" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="22" Height="22" Stretch="Uniform"/>
                            </Button>

                             <Button x:Name="BtnMainPlay" Content="{Binding PlayPauseContent}" Style="{StaticResource MaterialPrimaryButtonStyle}" Command="{Binding PlayPauseCommand}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="32" Width="80" Height="80">
                                            <Grid>
                                                <Path x:Name="PlayIcon" Data="M8,5V19L19,12L8,5Z" Fill="{TemplateBinding Foreground}" Width="32" Height="32" Stretch="Uniform" Margin="4,0,0,0"/>
                                                <Path x:Name="PauseIcon" Data="M14,19H18V5H14M6,19H10V5H6Z" Fill="{TemplateBinding Foreground}" Width="28" Height="28" Stretch="Uniform" Visibility="Collapsed"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="Content" Value="⏸">
                                                <Setter TargetName="PlayIcon" Property="Visibility" Value="Collapsed"/>
                                                <Setter TargetName="PauseIcon" Property="Visibility" Value="Visible"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter Property="RenderTransform">
                                                    <Setter.Value>
                                                        <ScaleTransform ScaleX="0.94" ScaleY="0.94"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button Style="{StaticResource TransportIconStyle}" Command="{Binding NextCommand}" Margin="20,0,16,0">
                                <Path Data="M16,18H18V6H16M6,18L14.5,12L6,6V18Z" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="22" Height="22" Stretch="Uniform"/>
                            </Button>

                             <Button x:Name="BtnRepeat" Command="{Binding RepeatCommand}">
                                 <Button.Style>
                                     <Style TargetType="Button" BasedOn="{StaticResource TransportIconStyle}">
                                         <Style.Triggers>
                                             <DataTrigger Binding="{Binding IsRepeatEnabled}" Value="True">
                                                 <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                             </DataTrigger>
                                             <DataTrigger Binding="{Binding IsRepeatEnabled}" Value="False">
                                                 <Setter Property="Foreground" Value="{DynamicResource OnSurfaceBrush}"/>
                                             </DataTrigger>
                                         </Style.Triggers>
                                     </Style>
                                 </Button.Style>
                                 <Path x:Name="RepeatIcon" Data="M17,17H7V14L3,18L7,22V19H19V13H17V17M7,7H17V10L21,6L17,2V5H5V11H7V7Z" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="20" Height="20" Stretch="Uniform"/>
                             </Button>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="4" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" x:Name="BtnToggleQueue" Style="{StaticResource MaterialSecondaryButtonStyle}" Command="{Binding ToggleQueueCommand}" HorizontalAlignment="Right" Margin="0,0,16,0" Padding="16,8">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M4,16H14V14H4V16ZM4,11H18V9H4V11ZM4,4V6H18V4H4ZM16,14V20L21,17L16,14Z" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="18" Height="18" Stretch="Uniform" Margin="0,0,8,0"/>
                                <TextBlock Text="Queue" FontWeight="Medium" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                            <Button Grid.Column="1" x:Name="BtnSleepTimer" Style="{StaticResource MaterialSecondaryButtonStyle}" Padding="12,8" HorizontalAlignment="Center">
                            <Path Data="M12,2A7,7 0 0,0 5,9C5,11.38 6.19,13.47 8.06,14.74C8.36,10.15 12.28,6.5 17,6.5C17.65,6.5 18.28,6.57 18.88,6.72C17.34,3.95 14.88,2 12,2M12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22Z" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="20" Height="20" Stretch="Uniform"/>
                        </Button>

                        <Button Grid.Column="2" x:Name="BtnToggleLyrics" Style="{StaticResource MaterialSecondaryButtonStyle}" Command="{Binding ToggleLyricsCommand}" HorizontalAlignment="Left" Margin="16,0,0,0" Padding="16,8">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M9,17H7V10H9V17ZM13,17H11V7H13V17ZM17,17H15V12H17V17Z" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="18" Height="18" Stretch="Uniform" Margin="0,0,8,0"/>
                                <TextBlock Text="Lyrics" FontWeight="Medium" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>

                <Grid Grid.Column="1" x:Name="RightPanelRoot" Margin="44,10,0,10" Opacity="0" Visibility="Collapsed" RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <TranslateTransform X="30" Y="0"/>
                    </Grid.RenderTransform>

                    <Grid x:Name="LyricsPanelContainer" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled" PanningMode="VerticalOnly">
                            <ItemsControl ItemsSource="{Binding NowPlaying.Lyrics, Converter={StaticResource LyricsToLinesConverter}}" 
                                          VirtualizingStackPanel.IsVirtualizing="True"
                                          VirtualizingStackPanel.VirtualizationMode="Recycling">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource OnSurfaceBrush}" Opacity="0.3" TextAlignment="Left" TextWrapping="Wrap" Margin="0,14,0,14" Cursor="Hand">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Opacity" Value="1.0"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>

                    <Grid x:Name="QueuePanelContainer" Visibility="Collapsed">
                      <Grid>
                          <Grid.RowDefinitions>
                              <RowDefinition Height="Auto"/>
                              <RowDefinition Height="*"/>
                          </Grid.RowDefinitions>
                          
                          <TextBlock Grid.Row="0" Text="Up Next" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource OnSurfaceBrush}" Margin="0,4,0,20"/>
                          
                          <ScrollViewer x:Name="QueueScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" PanningMode="VerticalOnly" MouseEnter="QueueScrollViewer_MouseEnter" MouseLeave="QueueScrollViewer_MouseLeave">
                               <ItemsControl x:Name="QueueItemsControl" ItemsSource="{Binding QueueItems}">
                                  <ItemsControl.ItemTemplate>
                                      <DataTemplate>
                                          <Border Padding="14" CornerRadius="14" Margin="0,0,0,8" Cursor="Hand" ClipToBounds="False">
                                              <Border.InputBindings>
                                                  <MouseBinding MouseAction="LeftClick" Command="{Binding DataContext.QueueItemClickCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                              </Border.InputBindings>
                                              <Border.Style>
                                                  <Style TargetType="Border">
                                                      <Setter Property="Background" Value="{DynamicResource SurfaceVariantBrush}"/>
                                                      <Setter Property="BorderThickness" Value="0"/>
                                                      <Style.Triggers>
                                                          <Trigger Property="IsMouseOver" Value="True">
                                                              <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
                                                          </Trigger>
                                                          <DataTrigger Value="True">
                                                              <DataTrigger.Binding>
                                                                  <MultiBinding Converter="{StaticResource IsEqualConverter}">
                                                                      <Binding Path="."/>
                                                                      <Binding Path="DataContext.NowPlaying" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                                  </MultiBinding>
                                                              </DataTrigger.Binding>
                                                              <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
                                                              <Setter Property="BorderThickness" Value="3,0,0,0"/>
                                                              <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                                          </DataTrigger>
                                                      </Style.Triggers>
                                                  </Style>
                                              </Border.Style>
                                              <Grid RenderTransformOrigin="0.5,0.5">
                                                  <Grid.RenderTransform>
                                                      <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                  </Grid.RenderTransform>
                                                  <Grid.Style>
                                                      <Style TargetType="Grid">
                                                          <Style.Triggers>
                                                              <DataTrigger Value="True">
                                                                  <DataTrigger.Binding>
                                                                      <MultiBinding Converter="{StaticResource IsEqualConverter}">
                                                                          <Binding Path="."/>
                                                                          <Binding Path="DataContext.NowPlaying" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                                      </MultiBinding>
                                                                  </DataTrigger.Binding>
                                                                  <DataTrigger.EnterActions>
                                                                      <BeginStoryboard>
                                                                          <Storyboard>
                                                                              <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.04" Duration="0:0:0.2">
                                                                                  <DoubleAnimation.EasingFunction>
                                                                                      <QuadraticEase EasingMode="EaseOut"/>
                                                                                  </DoubleAnimation.EasingFunction>
                                                                              </DoubleAnimation>
                                                                              <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.04" Duration="0:0:0.2">
                                                                                  <DoubleAnimation.EasingFunction>
                                                                                      <QuadraticEase EasingMode="EaseOut"/>
                                                                                  </DoubleAnimation.EasingFunction>
                                                                              </DoubleAnimation>
                                                                          </Storyboard>
                                                                      </BeginStoryboard>
                                                                  </DataTrigger.EnterActions>
                                                                  <DataTrigger.ExitActions>
                                                                      <BeginStoryboard>
                                                                          <Storyboard>
                                                                              <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.0" Duration="0:0:0.2"/>
                                                                              <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.0" Duration="0:0:0.2"/>
                                                                          </Storyboard>
                                                                      </BeginStoryboard>
                                                                  </DataTrigger.ExitActions>
                                                              </DataTrigger>
                                                          </Style.Triggers>
                                                      </Style>
                                                  </Grid.Style>
                                                  <Grid.ColumnDefinitions>
                                                      <ColumnDefinition Width="Auto"/>
                                                      <ColumnDefinition Width="*"/>
                                                  </Grid.ColumnDefinitions>
                                                  <Image Grid.Column="0" Source="{Binding CoverPath, Converter={StaticResource PathToImageConverter}, ConverterParameter=list}" Width="40" Height="40" Stretch="UniformToFill" Margin="0,0,12,0">
                                                      <Image.Clip>
                                                          <RectangleGeometry Rect="0,0,40,40" RadiusX="6" RadiusY="6"/>
                                                      </Image.Clip>
                                                  </Image>
                                                  <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                      <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource OnSurfaceBrush}" TextTrimming="CharacterEllipsis"/>
                                                      <TextBlock Text="{Binding Artist}" FontSize="12" Foreground="{DynamicResource OnSurfaceVariantBrush}" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                                  </StackPanel>
                                              </Grid>
                                          </Border>
                                      </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                              </ItemsControl>
                          </ScrollViewer>
                      </Grid>
                  </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
