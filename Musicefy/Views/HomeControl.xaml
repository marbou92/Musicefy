<UserControl x:Class="Musicefy.Views.HomeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}"
             Foreground="{DynamicResource ForegroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <!-- Random Albums -->
            <TextBlock Text="Random Albums" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>
            <ItemsControl x:Name="AlbumsList" Margin="0,0,0,20" MouseDoubleClick="AlbumsList_DoubleClick">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="8">
                            <Image Source="{Binding Cover}" Width="160" Height="160" Stretch="UniformToFill"/>
                            <TextBlock Text="{Binding Album}" FontSize="14" FontWeight="SemiBold" Margin="0,6,0,0"/>
                            <TextBlock Text="{Binding Artist}" FontSize="12" Foreground="Gray"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Album Tracks -->
            <Border Background="{DynamicResource SecondaryBackgroundBrush}" Padding="12" CornerRadius="6" Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock Text="Album Tracks" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <ListBox x:Name="AlbumTracksList" Height="300"/>
                    <TextBlock x:Name="AlbumTracksEmpty" Text="No tracks loaded" Foreground="Gray" Visibility="Collapsed"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
