<UserControl x:Class="Musicefy.Views.HomeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:views="clr-namespace:Musicefy.Views"
             xmlns:vms="clr-namespace:Musicefy.ViewModels"
             mc:Ignorable="d" 
             Background="{DynamicResource BackgroundBrush}"
             Foreground="{DynamicResource ForegroundBrush}"
             d:DataContext="{d:DesignInstance Type=vms:MainViewModel, IsDesignTimeCreatable=True}">

    <!-- Re-using brushes defined in MainWindow.xaml, in case this control is hosted there. -->
    <UserControl.Resources>
        <!-- Style for horizontal section headers from image -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        </Style>

        <!-- Style for horizontally scrollable ListBox used for cards -->
        <Style x:Key="HorizontalListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="Margin" Value="0,0,0,30"/>
            <Setter Property="ItemsPanel">
                <Setter.Value>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataTemplate for the Chart Card from image (large image, title, subtitle) -->
        <DataTemplate x:Key="ChartCardTemplate">
            <Border Background="{DynamicResource SecondaryBackgroundBrush}" Padding="0" CornerRadius="8" Margin="8,0">
                <StackPanel Width="150" Height="220">
                    <Border CornerRadius="8,8,0,0" Width="150" Height="150" Margin="0" >
                        <Image Source="{Binding Cover}" Stretch="UniformToFill" Margin="10" />
                    </Border>
                    <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14" Margin="10,10,10,3" TextWrapping="Wrap" TextAlignment="Center"/>
                    <TextBlock Text="{Binding Subtitle}" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12" Margin="10,0" TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- DataTemplate for the Track Card from image (small image, track, artist) -->
        <DataTemplate x:Key="TrackCardTemplate">
            <Border Background="{DynamicResource SecondaryBackgroundBrush}" Padding="8" CornerRadius="8" Margin="8,0">
                <StackPanel Width="180">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border CornerRadius="6" Width="40" Height="40" Margin="0,0,10,0">
                            <Image Source="{Binding Cover}" Stretch="UniformToFill"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock Text="{Binding Artist}" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- DataTemplate for the Video Card from image (small image, title, channel) -->
        <DataTemplate x:Key="VideoCardTemplate">
            <Border Background="{DynamicResource SecondaryBackgroundBrush}" Padding="8" CornerRadius="8" Margin="8,0">
                <StackPanel Width="180">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border CornerRadius="6" Width="40" Height="40" Margin="0,0,10,0">
                            <Image Source="{Binding Cover}" Stretch="UniformToFill"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock Text="{Binding Channel}" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Style for the action buttons from image (Play all, More) -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,5"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#33FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10,0,10,30">

            <!-- Browse Charts section -->
            <TextBlock Text="Browse Charts" Style="{StaticResource SectionHeaderStyle}" />
            <ListBox x:Name="ChartsList"
                     Style="{StaticResource HorizontalListBoxStyle}"
                     ItemTemplate="{StaticResource ChartCardTemplate}" />

            <!-- Quick picks section -->
            <DockPanel Margin="0,0,0,15">
                <TextBlock Text="Quick picks" Style="{StaticResource SectionHeaderStyle}" VerticalAlignment="Center" />
                <Button Content="Play all" HorizontalAlignment="Right" VerticalAlignment="Center" Style="{StaticResource ActionButtonStyle}"
                        Click="PlayAllQuickPicks_Click"/>
            </DockPanel>
            <ListBox x:Name="QuickPicksList"
                     Style="{StaticResource HorizontalListBoxStyle}"
                     ItemTemplate="{StaticResource TrackCardTemplate}"
                     MouseDoubleClick="QuickPicksList_DoubleClick" />

            <!-- Top music videos section -->
            <DockPanel Margin="0,0,0,15">
                <TextBlock Text="Top music videos" Style="{StaticResource SectionHeaderStyle}" VerticalAlignment="Center" />
                <Button Content="More" HorizontalAlignment="Right" VerticalAlignment="Center" Style="{StaticResource ActionButtonStyle}"
                        Click="MoreVideos_Click"/>
            </DockPanel>
            <ListBox x:Name="VideosList"
                     Style="{StaticResource HorizontalScrollBarVisibility=Auto}"
                     ItemTemplate="{StaticResource VideoCardTemplate}" />

        </StackPanel>
    </ScrollViewer>
</UserControl>
