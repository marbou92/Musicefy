<UserControl x:Class="Musicefy.Views.HomeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Musicefy.Controls"
             xmlns:vm="clr-namespace:Musicefy.ViewModels"
             xmlns:models="clr-namespace:Musicefy.Core.Models;assembly=Musicefy.Core"
             Background="Transparent"
             VerticalAlignment="Stretch" HorizontalAlignment="Stretch">

    <Grid>
        <!-- Loading State (Skeleton) -->
        <Grid x:Name="LoadingSkeleton" Visibility="Collapsed" VerticalAlignment="Stretch">
            <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="24,0,24,20">
                    <!-- Greeting skeleton -->
                    <Border Background="{DynamicResource SurfaceVariantBrush}" Width="280" Height="32"
                            CornerRadius="8" Margin="0,0,0,32" Opacity="0.5"/>
                    <!-- Section skeleton -->
                    <Border Background="{DynamicResource SurfaceVariantBrush}" Width="200" Height="20"
                            CornerRadius="6" Margin="0,0,0,16" Opacity="0.4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,32">
                        <Border Background="{DynamicResource SurfaceVariantBrush}" Width="160" Height="200"
                                CornerRadius="12" Margin="0,0,16,0" Opacity="0.3"/>
                        <Border Background="{DynamicResource SurfaceVariantBrush}" Width="160" Height="200"
                                CornerRadius="12" Margin="0,0,16,0" Opacity="0.25"/>
                        <Border Background="{DynamicResource SurfaceVariantBrush}" Width="160" Height="200"
                                CornerRadius="12" Margin="0,0,16,0" Opacity="0.2"/>
                        <Border Background="{DynamicResource SurfaceVariantBrush}" Width="160" Height="200"
                                CornerRadius="12" Margin="0,0,16,0" Opacity="0.15"/>
                    </StackPanel>
                    <!-- Another section skeleton -->
                    <Border Background="{DynamicResource SurfaceVariantBrush}" Width="220" Height="20"
                            CornerRadius="6" Margin="0,0,0,16" Opacity="0.4"/>
                    <StackPanel Orientation="Horizontal">
                        <Border Background="{DynamicResource SurfaceVariantBrush}" Width="160" Height="200"
                                CornerRadius="12" Margin="0,0,16,0" Opacity="0.3"/>
                        <Border Background="{DynamicResource SurfaceVariantBrush}" Width="160" Height="200"
                                CornerRadius="12" Margin="0,0,16,0" Opacity="0.25"/>
                        <Border Background="{DynamicResource SurfaceVariantBrush}" Width="160" Height="200"
                                CornerRadius="12" Margin="0,0,16,0" Opacity="0.2"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Error State -->
        <Grid x:Name="ErrorPanel" Visibility="Collapsed"
              VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,40">
            <StackPanel HorizontalAlignment="Center">
                <Border Width="96" Height="96" CornerRadius="48"
                        Background="{DynamicResource SurfaceVariantBrush}"
                        HorizontalAlignment="Center" Margin="0,0,0,20">
                    <Path Data="M12,2C17.53,2 22,6.47 22,12C22,17.53 17.53,22 12,22C6.47,22 2,17.53 2,12C2,6.47 6.47,2 12,2M15.59,7L12,10.59L8.41,7L7,8.41L10.59,12L7,15.59L8.41,17L12,13.41L15.59,17L17,15.59L13.41,12L17,8.41L15.59,7Z"
                          Fill="{DynamicResource ErrorBrush}" Width="32" Height="32"
                          Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="Something went wrong" FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource OnSurfaceBrush}" HorizontalAlignment="Center"/>
                <TextBlock x:Name="ErrorText" Text="" FontSize="14"
                           Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           Margin="0,8,0,0" HorizontalAlignment="Center" TextWrapping="Wrap"
                           MaxWidth="400"/>
                <Button Content="Try Again" Margin="0,20,0,0" Padding="24,10"
                        FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                        Background="{DynamicResource PrimaryBrush}"
                        Foreground="{DynamicResource OnPrimaryBrush}"
                        BorderThickness="0" HorizontalAlignment="Center"
                        Click="RetryButton_Click"/>
            </StackPanel>
        </Grid>

        <!-- Empty State -->
        <Grid x:Name="EmptyPanel" Visibility="Collapsed"
              VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,40">
            <StackPanel HorizontalAlignment="Center">
                <Border Width="96" Height="96" CornerRadius="48"
                        Background="{DynamicResource SurfaceVariantBrush}"
                        HorizontalAlignment="Center" Margin="0,0,0,20">
                    <Path Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,9A3,3 0 0,1 15,12A3,3 0 0,1 12,15A3,3 0 0,1 9,12A3,3 0 0,1 12,9Z"
                          Fill="{DynamicResource OnSurfaceVariantBrush}" Width="32" Height="32"
                          Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5"/>
                </Border>
                <TextBlock Text="Welcome to Musicefy" FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource OnSurfaceBrush}" HorizontalAlignment="Center"/>
                <TextBlock Text="Add some music sources to get started with personalized recommendations."
                           FontSize="14" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           Margin="0,8,0,0" HorizontalAlignment="Center" TextWrapping="Wrap"
                           MaxWidth="400"/>
            </StackPanel>
        </Grid>

        <!-- Main Content -->
        <ScrollViewer x:Name="MainScrollViewer" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled" Visibility="Collapsed">
            <StackPanel Margin="24,0,24,20">
                <!-- Greeting / Header -->
                <Grid Margin="0,0,0,28">
                    <StackPanel>
                        <TextBlock x:Name="GreetingText" FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource OnSurfaceBrush}" Margin="0,0,0,4"/>
                        <TextBlock x:Name="SubGreetingText" FontSize="14"
                                   Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
                    </StackPanel>
                    <!-- Refresh button -->
                    <Button x:Name="RefreshButton" HorizontalAlignment="Right" VerticalAlignment="Top"
                            Width="40" Height="40" Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Click="RefreshButton_Click"
                            ToolTip="Refresh">
                        <Path Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z"
                              Fill="{DynamicResource OnSurfaceVariantBrush}" Width="18" Height="18"
                              Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </Grid>

                <!-- Chip Bar (YouTube Home Feed filters) -->
                <ScrollViewer x:Name="ChipBar" VerticalScrollBarVisibility="Disabled"
                              HorizontalScrollBarVisibility="Auto" Margin="0,0,0,20"
                              Visibility="Collapsed">
                    <ItemsControl ItemsSource="{Binding AvailableChips}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <RadioButton Content="{Binding Title}"
                                             GroupName="HomeChips"
                                             IsChecked="{Binding IsSelected}"
                                             Margin="0,0,8,0" Padding="16,8"
                                             FontSize="12" FontWeight="SemiBold"
                                             Cursor="Hand"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Home Sections -->
                <ItemsControl ItemsSource="{Binding Sections}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:HomeSection}">
                            <controls:HomeSectionControl DataContext="{Binding}"
                                                         Margin="0,0,0,8"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
