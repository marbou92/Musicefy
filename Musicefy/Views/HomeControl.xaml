<UserControl x:Class="Musicefy.Views.HomeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <Style x:Key="CleanListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#161616"/>
            <Setter Property="Foreground" Value="#909090"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#222222"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="ChartCardTemplate">
            <Border x:Name="CardBorder" Background="#111111" BorderBrush="#1A1A1A" BorderThickness="1" CornerRadius="20" Margin="0,0,16,0" Width="165" Height="240" Cursor="Hand">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.3" Color="Black"/>
                </Border.Effect>
                <StackPanel>
                    <Border CornerRadius="14" Margin="12" Height="140" ClipToBounds="True">
                        <Image Source="{Binding Cover}" Stretch="UniformToFill"/>
                    </Border>
                    <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="13" Margin="12,2,12,0" TextAlignment="Center" Foreground="White" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding Subtitle}" Foreground="#707070" FontSize="11" TextAlignment="Center" Margin="12,2" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Border>
            <DataTemplate.Triggers>
                <Trigger Property="IsMouseOver" SourceName="CardBorder" Value="True">
                    <Setter TargetName="CardBorder" Property="Background" Value="#161616"/>
                    <Setter TargetName="CardBorder" Property="BorderBrush" Value="#303030"/>
                </Trigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate x:Key="TrackCardTemplate">
            <Border x:Name="CardBorder" Background="#111111" BorderBrush="#141414" BorderThickness="1" CornerRadius="14" Margin="6" Padding="10" Width="280" Cursor="Hand">
                <DockPanel>
                    <Border CornerRadius="8" Width="44" Height="44" ClipToBounds="True" DockPanel.Dock="Left">
                        <Image Source="{Binding Cover}" Stretch="UniformToFill"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Margin="12,0,0,0">
                        <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="13" Foreground="White" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding Artist}" Foreground="#808080" FontSize="11" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </DockPanel>
            </Border>
            <DataTemplate.Triggers>
                <Trigger Property="IsMouseOver" SourceName="CardBorder" Value="True">
                    <Setter TargetName="CardBorder" Property="Background" Value="#1A1A1A"/>
                    <Setter TargetName="CardBorder" Property="BorderBrush" Value="#252525"/>
                </Trigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate x:Key="VideoCardTemplate">
            <Border x:Name="CardBorder" Background="#111111" BorderBrush="#1A1A1A" BorderThickness="1" CornerRadius="16" Margin="0,0,16,0" Width="240" Height="175" Cursor="Hand">
                <StackPanel>
                    <Border CornerRadius="10" Margin="10" Height="115" ClipToBounds="True">
                        <Image Source="{Binding Cover}" Stretch="UniformToFill"/>
                    </Border>
                    <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="13" Margin="12,0" Foreground="White" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding Channel}" Foreground="#707070" FontSize="11" Margin="12,2" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Border>
            <DataTemplate.Triggers>
                <Trigger Property="IsMouseOver" SourceName="CardBorder" Value="True">
                    <Setter TargetName="CardBorder" Property="Background" Value="#161616"/>
                    <Setter TargetName="CardBorder" Property="BorderBrush" Value="#303030"/>
                </Trigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="25,10,25,25">
            
            <Grid Margin="6,0,0,15">
                <TextBlock Text="Charts for you" FontSize="20" FontWeight="ExtraBold" Foreground="White" VerticalAlignment="Center"/>
            </Grid>
            <ListBox x:Name="ChartsList" 
                     ItemsSource="{Binding BrowseCharts}" 
                     ItemTemplate="{StaticResource ChartCardTemplate}" 
                     ItemContainerStyle="{StaticResource CleanListBoxItemStyle}"
                     Background="Transparent" BorderThickness="0" Margin="0,0,0,30">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>

            <Grid Margin="6,0,6,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Quick Picks" FontSize="20" FontWeight="ExtraBold" Foreground="White" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="PLAY ALL" Style="{StaticResource HeaderActionButtonStyle}" Click="PlayAllQuickPicks_Click"/>
            </Grid>
            
            <ListBox x:Name="QuickPicksList" 
                     ItemsSource="{Binding QuickPicks}" 
                     ItemTemplate="{StaticResource TrackCardTemplate}" 
                     ItemContainerStyle="{StaticResource CleanListBoxItemStyle}"
                     Background="Transparent" BorderThickness="0" Margin="0,0,0,30"
                     MouseDoubleClick="QuickPicksList_DoubleClick">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>

            <Grid Margin="6,0,6,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Top Music Videos" FontSize="20" FontWeight="ExtraBold" Foreground="White" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="SEE MORE" Style="{StaticResource HeaderActionButtonStyle}" Click="MoreVideos_Click"/>
            </Grid>
            <ListBox x:Name="VideosList" 
                     ItemsSource="{Binding TopMusicVideos}" 
                     ItemTemplate="{StaticResource VideoCardTemplate}"
                     ItemContainerStyle="{StaticResource CleanListBoxItemStyle}"
                     Background="Transparent" BorderThickness="0">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>
            
        </StackPanel>
    </ScrollViewer>
</UserControl>
