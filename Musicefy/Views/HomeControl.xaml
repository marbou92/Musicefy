<UserControl x:Class="Musicefy.Views.HomeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}"
             Foreground="{DynamicResource ForegroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <!-- Random Albums -->
            <TextBlock Text="Featured Albums" FontSize="22" FontWeight="Bold" Margin="0,0,0,12"/>
            <ItemsControl x:Name="AlbumsList" Margin="0,0,0,20" SelectionChanged="AlbumsList_SelectionChanged">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource SecondaryBackgroundBrush}" Padding="8" CornerRadius="6" Margin="8">
                            <StackPanel Width="180">
                                <Image Source="{Binding Cover}" Width="160" Height="160" Stretch="UniformToFill"/>
                                <TextBlock Text="{Binding Album}" FontSize="14" FontWeight="SemiBold" Margin="0,6,0,0"/>
                                <TextBlock Text="{Binding Artist}" FontSize="12" Foreground="Gray"/>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <Button Content="▶ Play" Padding="6,2" Margin="0,0,6,0"
                                            Click="PlayAlbum_Click"/>
                                    <Button Content="🔀 Shuffle" Padding="6,2"
                                            Click="ShuffleAlbum_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Album Tracks -->
            <Border Background="{DynamicResource SecondaryBackgroundBrush}" Padding="12" CornerRadius="6" Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock x:Name="AlbumTitle" Text="Select an album to view tracks" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <ListBox x:Name="AlbumTracksList" Height="300" MouseDoubleClick="AlbumTracksList_DoubleClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="4">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Width="250"/>
                                    <TextBlock Text="{Binding Artist}" Foreground="Gray" Width="200"/>
                                    <TextBlock Text="{Binding Duration}" Foreground="Gray" Width="80"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock x:Name="AlbumTracksEmpty" Text="No tracks loaded" Foreground="Gray" Visibility="Collapsed"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
