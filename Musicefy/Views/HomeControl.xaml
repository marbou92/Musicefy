<UserControl x:Class="Musicefy.Views.HomeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <DataTemplate x:Key="ChartCardTemplate">
            <Border Background="#121212" CornerRadius="20" Margin="10,0" Width="160" Height="230">
                <StackPanel>
                    <Border CornerRadius="20" Margin="10" Height="140" ClipToBounds="True">
                        <Image Source="{Binding Cover}" Stretch="UniformToFill"/>
                    </Border>
                    <TextBlock Text="{Binding Title}" FontWeight="Bold" Margin="15,5,15,0" TextAlignment="Center"/>
                    <TextBlock Text="{Binding Subtitle}" Foreground="Gray" FontSize="11" TextAlignment="Center" Margin="15,2"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="TrackCardTemplate">
            <Border Background="#121212" CornerRadius="12" Margin="0,5" Padding="10" Width="280">
                <DockPanel>
                    <Border CornerRadius="8" Width="45" Height="45" ClipToBounds="True" DockPanel.Dock="Left">
                        <Image Source="{Binding Cover}" Stretch="UniformToFill"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Margin="12,0">
                        <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14"/>
                        <TextBlock Text="{Binding Artist}" Foreground="Gray" FontSize="12"/>
                    </StackPanel>
                </DockPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Hidden">
        <StackPanel Margin="20">
            <TextBlock Text="Charts for you" FontSize="22" FontWeight="Bold" Margin="10,0,0,20"/>
            <ListBox ItemsSource="{Binding BrowseCharts}" ItemTemplate="{StaticResource ChartCardTemplate}" 
                     Background="Transparent" BorderThickness="0">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>

            <TextBlock Text="Quick Picks" FontSize="22" FontWeight="Bold" Margin="10,30,0,20"/>
            <ListBox ItemsSource="{Binding QuickPicks}" ItemTemplate="{StaticResource TrackCardTemplate}" 
                     Background="Transparent" BorderThickness="0">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>
        </StackPanel>
    </ScrollViewer>
</UserControl>
