<UserControl x:Class="Musicefy.Views.HomeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <Style x:Key="CleanListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ChipBorder" Background="{TemplateBinding Background}" CornerRadius="20" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ChipBorder" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource BackgroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="ChartCardTemplate">
            <Border x:Name="CardBorder" Background="{DynamicResource SecondaryBackgroundBrush}" CornerRadius="28" Margin="0,0,18,0" Width="170" Height="250" Cursor="Hand" SnapsToDevicePixels="True">
                <Grid>
                    <StackPanel>
                        <Border CornerRadius="20" Margin="12,12,12,10" Height="146" ClipToBounds="True">
                            <Image Source="{Binding Cover}" Stretch="UniformToFill"/>
                        </Border>
                        <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14" Margin="14,2,14,0" Foreground="{DynamicResource TextBrush}" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding Subtitle}" Foreground="{DynamicResource MutedTextBrush}" FontSize="12" Margin="14,4,14,0" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <Border x:Name="HoverOverlay" CornerRadius="28" Background="{DynamicResource AccentBrush}" Opacity="0.0"/>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <Trigger Property="IsMouseOver" SourceName="CardBorder" Value="True">
                    <Setter TargetName="HoverOverlay" Property="Opacity" Value="0.08"/>
                </Trigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate x:Key="TrackCardTemplate">
            <Border x:Name="CardBorder" Background="{DynamicResource SecondaryBackgroundBrush}" CornerRadius="16" Margin="6" Padding="12" Width="290" Cursor="Hand" SnapsToDevicePixels="True">
                <Grid>
                    <DockPanel>
                        <Border CornerRadius="12" Width="48" Height="48" ClipToBounds="True" DockPanel.Dock="Left">
                            <Image Source="{Binding Cover}" Stretch="UniformToFill"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center" Margin="14,0,0,0">
                            <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource TextBrush}" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding Artist}" Foreground="{DynamicResource MutedTextBrush}" FontSize="12" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </DockPanel>
                    <Border x:Name="HoverOverlay" CornerRadius="16" Background="{DynamicResource AccentBrush}" Opacity="0.0"/>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <Trigger Property="IsMouseOver" SourceName="CardBorder" Value="True">
                    <Setter TargetName="HoverOverlay" Property="Opacity" Value="0.08"/>
                </Trigger>
            </DataTemplate.Triggers>
        </DataTemplate>

    </UserControl.Resources>

    <Grid>
        <!-- Empty state -->
        <Border x:Name="EmptyState" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="40">
                <TextBlock Text="&#x1F3B5;" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                <TextBlock Text="Welcome to Musicefy" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding EmptyMessage}" FontSize="14" Foreground="{DynamicResource MutedTextBrush}" HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="400" TextAlignment="Center" Margin="0,12,0,20"/>
                <Button Content="Open Settings" Width="160" Height="38" Click="OpenSources_Click"
                        Background="{DynamicResource AccentBrush}" Foreground="White"
                        FontWeight="SemiBold" FontSize="13" Cursor="Hand"
                        HorizontalAlignment="Center" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" CornerRadius="19" Padding="18,8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="BtnBorder" Property="Opacity" Value="0.85"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <TextBlock Text="or add a local music folder to get started" FontSize="11" Foreground="{DynamicResource MutedTextBrush}" HorizontalAlignment="Center" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <!-- Content area -->
        <ScrollViewer x:Name="ContentArea" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="30,20,30,30">
                
                <Grid Margin="6,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Charts for you" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextBrush}"/>
                        <TextBlock Text="Curated tunes from your connected sources" FontSize="12" Foreground="{DynamicResource MutedTextBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
                <ListBox x:Name="ChartsList" 
                         ItemsSource="{Binding BrowseCharts}" 
                         ItemTemplate="{StaticResource ChartCardTemplate}" 
                         ItemContainerStyle="{StaticResource CleanListBoxItemStyle}"
                         Background="Transparent" BorderThickness="0" Margin="0,0,0,32">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>

                <ListBox x:Name="QuickPicksList" 
                         ItemsSource="{Binding QuickPicks}" 
                         ItemTemplate="{StaticResource TrackCardTemplate}" 
                         ItemContainerStyle="{StaticResource CleanListBoxItemStyle}"
                         Background="Transparent" BorderThickness="0" Margin="0,0,0,32"
                         MouseDoubleClick="QuickPicksList_DoubleClick">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.Template>
                        <ControlTemplate TargetType="ListBox">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="6,0,6,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Quick Picks" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextBrush}"/>
                                        <TextBlock Text="Recently played and favourites" FontSize="12" Foreground="{DynamicResource MutedTextBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Play All" Style="{StaticResource HeaderActionButtonStyle}" Click="PlayAllQuickPicks_Click" VerticalAlignment="Center"/>
                                </Grid>
                                <ItemsPresenter Grid.Row="1"/>
                            </Grid>
                        </ControlTemplate>
                    </ListBox.Template>
                </ListBox>

                <Grid Margin="6,0,6,16">
                    <StackPanel>
                        <TextBlock Text="Top Music Videos" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextBrush}"/>
                        <TextBlock Text="Streaming suggestions from your sources" FontSize="12" Foreground="{DynamicResource MutedTextBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
                
                <ListBox x:Name="VideosList" 
                         ItemsSource="{Binding TopMusicVideos}" 
                         ItemTemplate="{StaticResource TrackCardTemplate}"
                         ItemContainerStyle="{StaticResource CleanListBoxItemStyle}"
                         Background="Transparent" BorderThickness="0">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>
                
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
