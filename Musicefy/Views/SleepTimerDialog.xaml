<Window x:Class="Musicefy.Views.SleepTimerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sleep Timer" Height="260" Width="300"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceBrush}"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Set sleep timer" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource OnSurfaceBrush}" Margin="0,0,0,16"/>

        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            <RadioButton x:Name="Rb15" Content="15 minutes" FontSize="14"
                         Foreground="{DynamicResource OnSurfaceBrush}" Margin="0,6" IsChecked="True"/>
            <RadioButton x:Name="Rb30" Content="30 minutes" FontSize="14"
                         Foreground="{DynamicResource OnSurfaceBrush}" Margin="0,6"/>
            <RadioButton x:Name="Rb60" Content="60 minutes" FontSize="14"
                         Foreground="{DynamicResource OnSurfaceBrush}" Margin="0,6"/>
            <RadioButton x:Name="Rb90" Content="90 minutes" FontSize="14"
                         Foreground="{DynamicResource OnSurfaceBrush}" Margin="0,6"/>
            <RadioButton x:Name="Rb120" Content="120 minutes" FontSize="14"
                         Foreground="{DynamicResource OnSurfaceBrush}" Margin="0,6"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Width="80" Height="32" Margin="0,0,12,0"
                    Click="BtnCancel_Click"
                    Background="{DynamicResource SurfaceContainerHighBrush}"
                    Foreground="{DynamicResource OnSurfaceBrush}"/>
            <Button Content="Start" Width="80" Height="32"
                    Click="BtnStart_Click"
                    Background="{DynamicResource PrimaryBrush}"
                    Foreground="{DynamicResource OnPrimaryBrush}"/>
        </StackPanel>
    </Grid>
</Window>
