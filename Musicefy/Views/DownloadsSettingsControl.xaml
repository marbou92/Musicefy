<UserControl x:Class="Musicefy.Views.DownloadsSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid Margin="10,0,10,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Vertical">

                <!-- ════════════════════════════════════════════════════════════ -->
                <!-- SECTION 1: LOCAL MUSIC FOLDERS (Sprint 4)                    -->
                <!-- ════════════════════════════════════════════════════════════ -->
                <TextBlock Text="Local Music Folders" FontWeight="Bold" FontSize="15"
                           Foreground="{DynamicResource OnSurfaceBrush}" Margin="4,0,0,4"/>
                <TextBlock Text="Folders on your disk that Musicefy scans for music files."
                           FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           Margin="4,0,0,12" TextWrapping="Wrap"/>

                <Border Background="{DynamicResource SurfaceVariantBrush}" CornerRadius="14"
                        Padding="16,12" Margin="0,0,0,20">
                    <StackPanel>
                        <ItemsControl x:Name="FoldersList" Margin="0,0,0,8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource SurfaceContainerHighBrush}"
                                            CornerRadius="8" Padding="10,8" Margin="0,3">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Path Grid.Column="0" Data="M20 6h-8l-2-2H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm0 12H4V8h16v10z"
                                                  Width="18" Height="18" Stretch="Uniform"
                                                  Fill="{DynamicResource OnSurfaceVariantBrush}"
                                                  Margin="0,0,10,0" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding}"
                                                       FontSize="12" Foreground="{DynamicResource OnSurfaceBrush}"
                                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            <Button Grid.Column="2" Content="✕" Padding="6,2" Margin="8,0,0,0"
                                                    FontSize="11" Cursor="Hand"
                                                    Foreground="{DynamicResource ErrorBrush}"
                                                    Click="RemoveFolder_Click" Tag="{Binding}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock x:Name="NoFoldersText" Text="No folders added yet. Click below to add your music folder."
                                   FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                   Margin="0,4,0,8" Visibility="Collapsed"/>

                        <Button Content="+ Add Folder" Padding="14,6" Width="120" HorizontalAlignment="Left"
                                Click="AddFolder_Click"/>
                    </StackPanel>
                </Border>

                <!-- ════════════════════════════════════════════════════════════ -->
                <!-- SECTION 2: YOUTUBE MUSIC (Sprint 4 — always-on)              -->
                <!-- ════════════════════════════════════════════════════════════ -->
                <TextBlock Text="YouTube Music" FontWeight="Bold" FontSize="15"
                           Foreground="{DynamicResource OnSurfaceBrush}" Margin="4,0,0,4"/>
                <TextBlock Text="YouTube is always available. Optional: add an API key or cookie for enhanced access."
                           FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           Margin="4,0,0,12" TextWrapping="Wrap"/>

                <Border Background="{DynamicResource SurfaceVariantBrush}" CornerRadius="14"
                        Padding="16,12" Margin="0,0,0,20">
                    <StackPanel>
                        <CheckBox x:Name="YouTubeEnabledBox" Style="{StaticResource ModernSettingRowStyle}"
                                  IsChecked="{Binding YouTubeEnabled}">
                            <StackPanel>
                                <TextBlock Text="Enable YouTube Music" FontWeight="Bold" FontSize="14"
                                           Foreground="{DynamicResource OnSurfaceBrush}"/>
                                <TextBlock Text="When disabled, YouTube search and streaming are turned off."
                                           FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </CheckBox>

                        <TextBlock Text="API Key (optional)" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,8,0,4"/>
                        <Border Background="{DynamicResource SurfaceContainerHighBrush}" CornerRadius="8"
                                BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1" Padding="8,4">
                            <TextBox x:Name="YouTubeApiKeyBox" Background="Transparent" BorderThickness="0"
                                     Foreground="{DynamicResource OnSurfaceBrush}" FontSize="12"
                                     Text="{Binding YouTubeApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Google API key for higher search quotas. Leave empty for anonymous mode."/>
                        </Border>

                        <TextBlock Text="Cookie (optional — for login)" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,8,0,4"/>
                        <Border Background="{DynamicResource SurfaceContainerHighBrush}" CornerRadius="8"
                                BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1" Padding="8,4">
                            <TextBox x:Name="YouTubeCookieBox" Background="Transparent" BorderThickness="0"
                                     Foreground="{DynamicResource OnSurfaceBrush}" FontSize="12"
                                     Text="{Binding YouTubeCookie, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Login cookie for authenticated access (SID=...; HSID=...; SAPISID=...)"/>
                        </Border>

                        <TextBlock Text="Audio Quality" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,8,0,4"/>
                        <ComboBox x:Name="AudioQualityCombo" Padding="8,4" FontSize="12"
                                  SelectedIndex="{Binding YouTubeAudioQualityIndex, Mode=TwoWay}">
                            <ComboBoxItem Content="Opus (default, better quality at lower bitrates)"/>
                            <ComboBoxItem Content="AAC (wider compatibility)"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- ════════════════════════════════════════════════════════════ -->
                <!-- SECTION 3: SPONSORBLOCK (Sprint 4)                           -->
                <!-- ════════════════════════════════════════════════════════════ -->
                <TextBlock Text="SponsorBlock" FontWeight="Bold" FontSize="15"
                           Foreground="{DynamicResource OnSurfaceBrush}" Margin="4,0,0,4"/>
                <TextBlock Text="Skip sponsored segments, intros, and outros in YouTube videos."
                           FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           Margin="4,0,0,12" TextWrapping="Wrap"/>

                <Border Background="{DynamicResource SurfaceVariantBrush}" CornerRadius="14"
                        Padding="16,12" Margin="0,0,0,20">
                    <StackPanel>
                        <CheckBox x:Name="SponsorBlockEnabledBox" Style="{StaticResource ModernSettingRowStyle}"
                                  IsChecked="{Binding SponsorBlockEnabled}">
                            <StackPanel>
                                <TextBlock Text="Enable SponsorBlock" FontWeight="Bold" FontSize="14"
                                           Foreground="{DynamicResource OnSurfaceBrush}"/>
                                <TextBlock Text="Uses the free sponsor.ajay.app API. No key required."
                                           FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </CheckBox>

                        <CheckBox IsChecked="{Binding SponsorBlockSkipSponsor}" Margin="16,4,0,0">
                            <TextBlock Text="Skip sponsor segments" FontSize="12" Foreground="{DynamicResource OnSurfaceBrush}"/>
                        </CheckBox>
                        <CheckBox IsChecked="{Binding SponsorBlockSkipIntro}" Margin="16,4,0,0">
                            <TextBlock Text="Skip intros" FontSize="12" Foreground="{DynamicResource OnSurfaceBrush}"/>
                        </CheckBox>
                        <CheckBox IsChecked="{Binding SponsorBlockSkipOutro}" Margin="16,4,0,0">
                            <TextBlock Text="Skip outros" FontSize="12" Foreground="{DynamicResource OnSurfaceBrush}"/>
                        </CheckBox>
                        <CheckBox IsChecked="{Binding SponsorBlockSkipSelfPromo}" Margin="16,4,0,0">
                            <TextBlock Text="Skip self-promotion" FontSize="12" Foreground="{DynamicResource OnSurfaceBrush}"/>
                        </CheckBox>
                        <CheckBox IsChecked="{Binding SponsorBlockSkipInteraction}" Margin="16,4,0,0">
                            <TextBlock Text="Skip interaction reminders (subscribe/like)" FontSize="12" Foreground="{DynamicResource OnSurfaceBrush}"/>
                        </CheckBox>
                    </StackPanel>
                </Border>

                <!-- ════════════════════════════════════════════════════════════ -->
                <!-- SECTION 4: LYRICS (Sprint 4 — LrcLib)                        -->
                <!-- ════════════════════════════════════════════════════════════ -->
                <TextBlock Text="Lyrics" FontWeight="Bold" FontSize="15"
                           Foreground="{DynamicResource OnSurfaceBrush}" Margin="4,0,0,4"/>
                <TextBlock Text="Fetch synced lyrics from LrcLib — free, no API key required."
                           FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           Margin="4,0,0,12" TextWrapping="Wrap"/>

                <Border Background="{DynamicResource SurfaceVariantBrush}" CornerRadius="14"
                        Padding="16,12" Margin="0,0,0,20">
                    <StackPanel>
                        <CheckBox x:Name="LyricsEnabledBox" Style="{StaticResource ModernSettingRowStyle}"
                                  IsChecked="{Binding LyricsEnabled}">
                            <StackPanel>
                                <TextBlock Text="Enable lyrics" FontWeight="Bold" FontSize="14"
                                           Foreground="{DynamicResource OnSurfaceBrush}"/>
                                <TextBlock Text="Fetch synced lyrics from LrcLib (lrclib.net)."
                                           FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </CheckBox>
                    </StackPanel>
                </Border>

                <!-- ════════════════════════════════════════════════════════════ -->
                <!-- SECTION 5: HOME SCREEN VISIBILITY (absorbed from Discover)   -->
                <!-- ════════════════════════════════════════════════════════════ -->
                <TextBlock Text="Home Screen" FontWeight="Bold" FontSize="15"
                           Foreground="{DynamicResource OnSurfaceBrush}" Margin="4,0,0,4"/>
                <TextBlock Text="Choose which sources appear on the Home screen."
                           FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           Margin="4,0,0,12" TextWrapping="Wrap"/>

                <Border Background="{DynamicResource SurfaceVariantBrush}" CornerRadius="14"
                        Padding="16,12" Margin="0,0,0,20">
                    <StackPanel>
                        <CheckBox IsChecked="{Binding ShowLocalOnHome}">
                            <StackPanel>
                                <TextBlock Text="Show local music on Home" FontWeight="Bold" FontSize="13"
                                           Foreground="{DynamicResource OnSurfaceBrush}"/>
                                <TextBlock Text="Display local albums and recently played on the Home screen."
                                           FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </CheckBox>
                        <CheckBox IsChecked="{Binding ShowYouTubeOnHome}" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="Show YouTube on Home" FontWeight="Bold" FontSize="13"
                                           Foreground="{DynamicResource OnSurfaceBrush}"/>
                                <TextBlock Text="Display YouTube recommendations and trending on the Home screen."
                                           FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </CheckBox>
                    </StackPanel>
                </Border>

                <!-- ════════════════════════════════════════════════════════════ -->
                <!-- SECTION 6: STORAGE DIRECTORY (existing)                      -->
                <!-- ════════════════════════════════════════════════════════════ -->
                <TextBlock Text="Storage Directory" FontWeight="Bold" FontSize="15"
                           Foreground="{DynamicResource OnSurfaceBrush}" Margin="4,0,0,12"/>
                <Border Background="{DynamicResource SurfaceVariantBrush}" BorderBrush="{DynamicResource OutlineBrush}"
                        BorderThickness="1" CornerRadius="14" Padding="16,14" Margin="0,0,0,20">
                    <DockPanel>
                        <Button Content="Browse..." DockPanel.Dock="Right" Padding="16,6" Width="100"
                                Click="Browse_Click" VerticalAlignment="Center"/>
                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Text="Target Download Path" FontWeight="Bold" FontSize="14"
                                       Foreground="{DynamicResource OnSurfaceBrush}"/>
                            <TextBox x:Name="DownloadPathBox" IsReadOnly="True" BorderThickness="0"
                                     Background="Transparent" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                     FontSize="12" Margin="0,4,0,0" TextWrapping="NoWrap" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- ════════════════════════════════════════════════════════════ -->
                <!-- SECTION 7: CACHING & BANDWIDTH (existing)                    -->
                <!-- ════════════════════════════════════════════════════════════ -->
                <TextBlock Text="Caching &amp; Bandwidth Policies" FontWeight="Bold" FontSize="15"
                           Foreground="{DynamicResource OnSurfaceBrush}" Margin="4,0,0,12"/>

                <CheckBox x:Name="AutoClearCacheBox" Style="{StaticResource ModernSettingRowStyle}">
                    <StackPanel>
                        <TextBlock Text="Auto-Clear Cache on Exit" FontWeight="Bold" FontSize="14"
                                   Foreground="{DynamicResource OnSurfaceBrush}"/>
                        <TextBlock Text="Flushes temporary stream directories immediately upon application shutdown"
                                   FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox.Tag>
                        <Path Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"
                              Fill="{DynamicResource OnSurfaceVariantBrush}" Width="18" Height="18" Stretch="Uniform"/>
                    </CheckBox.Tag>
                </CheckBox>

                <CheckBox x:Name="LimitDownloadSizeBox" Style="{StaticResource ModernSettingRowStyle}">
                    <StackPanel>
                        <TextBlock Text="Limit Download Size to 500 MB" FontWeight="Bold" FontSize="14"
                                   Foreground="{DynamicResource OnSurfaceBrush}"/>
                        <TextBlock Text="Restricts maximum track file sizes to conserve your local storage footprint"
                                   FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox.Tag>
                        <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"
                              Fill="{DynamicResource OnSurfaceVariantBrush}" Width="18" Height="18" Stretch="Uniform"/>
                    </CheckBox.Tag>
                </CheckBox>

                <!-- ════════════════════════════════════════════════════════════ -->
                <!-- SECTION 8: LIVE STORAGE MONITOR (existing)                   -->
                <!-- ════════════════════════════════════════════════════════════ -->
                <TextBlock Text="Live Storage Monitor" FontWeight="Bold" FontSize="15"
                           Foreground="{DynamicResource OnSurfaceBrush}" Margin="4,8,0,12"/>
                <Border CornerRadius="14" BorderThickness="1" BorderBrush="{DynamicResource OutlineBrush}"
                        Padding="16" Background="{DynamicResource SurfaceVariantBrush}">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,10">
                            <TextBlock x:Name="DownloadStatusLabel" Text="Idle" DockPanel.Dock="Right"
                                       FontWeight="Bold" Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
                            <TextBlock x:Name="CacheStatusLabel" Text="Cache size: 0.00 MB"
                                       FontWeight="Bold" Foreground="{DynamicResource OnSurfaceBrush}"/>
                        </DockPanel>

                        <ProgressBar x:Name="CacheProgressBar" Height="8" Maximum="100" Value="0"
                                     BorderThickness="0" Background="{DynamicResource OutlineBrush}" Margin="0,0,0,16"/>

                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <Button x:Name="ClearNowButton" Content="Clear Cache" Padding="14,6" Margin="0,0,8,0" Click="ClearNow_Click"/>
                            <Button x:Name="TestDownloadButton" Content="Test Download" Padding="14,6" Margin="0,0,8,0" Click="TestDownload_Click"/>
                            <Button x:Name="PauseDownloadButton" Content="Pause" Padding="14,6" Margin="0,0,8,0" Click="PauseDownload_Click" IsEnabled="False"/>
                            <Button x:Name="ResumeDownloadButton" Content="Resume" Padding="14,6" Margin="0,0,8,0" Click="ResumeDownload_Click" IsEnabled="False"/>
                            <Button x:Name="CancelDownloadButton" Content="Cancel" Padding="14,6" Click="CancelDownload_Click" IsEnabled="False"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
