<UserControl x:Class="Musicefy.Views.DownloadsSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}"
             Foreground="{DynamicResource ForegroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Downloads Settings"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Orientation="Vertical">

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,20">
                    <TextBlock Text="Download path:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox x:Name="DownloadPathBox" Width="400" IsReadOnly="True"/>
                    <Button Content="Browse..." Margin="10,0,0,0" Click="Browse_Click"/>
                </StackPanel>

                <CheckBox x:Name="AutoClearCacheBox"
                          Content="Auto-clear cache on exit"
                          Style="{StaticResource ToggleSettingStyle}"
                          Margin="0,0,0,20"/>
                <CheckBox x:Name="LimitDownloadSizeBox"
                          Content="Limit download size to 500 MB"
                          Style="{StaticResource ToggleSettingStyle}"
                          Margin="0,0,0,20"/>

                <Border CornerRadius="6" Padding="10"
                        Background="{DynamicResource SecondaryBackgroundBrush}"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock x:Name="CacheStatusLabel"
                                   Text="Cache size: 0 MB"
                                   FontStyle="Italic"
                                   Margin="0,0,0,5"/>
                        <ProgressBar x:Name="CacheProgressBar"
                                     Height="20"
                                     Maximum="100"
                                     Value="0"
                                     ToolTip="Cache size"/>
                        <TextBlock x:Name="DownloadStatusLabel"
                                   Text="Idle"
                                   Margin="0,5,0,0"
                                   Foreground="{DynamicResource ForegroundBrush}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Button x:Name="ClearNowButton"
                                    Content="Clear Now"
                                    Width="120"
                                    Margin="0,0,10,0"
                                    Click="ClearNow_Click"/>
                            <Button x:Name="TestDownloadButton"
                                    Content="Test Download"
                                    Width="140"
                                    Margin="0,0,10,0"
                                    Click="TestDownload_Click"/>
                            <Button x:Name="PauseDownloadButton"
                                    Content="Pause Download"
                                    Width="140"
                                    Margin="0,0,10,0"
                                    Click="PauseDownload_Click"
                                    IsEnabled="False"/>
                            <Button x:Name="ResumeDownloadButton"
                                    Content="Resume Download"
                                    Width="140"
                                    Margin="0,0,10,0"
                                    Click="ResumeDownload_Click"
                                    IsEnabled="False"/>
                            <Button x:Name="CancelDownloadButton"
                                    Content="Cancel Download"
                                    Width="140"
                                    Click="CancelDownload_Click"
                                    IsEnabled="False"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Cancel" Width="100" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button Content="Save" Width="100" Background="{DynamicResource AccentBrush}" Foreground="White" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
