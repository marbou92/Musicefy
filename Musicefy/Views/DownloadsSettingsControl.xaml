<UserControl x:Class="Musicefy.Views.DownloadsSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="10,0,10,10">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Vertical">

                <!-- Header -->
                <TextBlock Text="Storage" FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource OnSurfaceBrush}" Margin="4,0,0,4"/>
                <TextBlock Text="Download path, cache, and local music folders."
                           FontSize="12" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           Margin="4,0,0,20"/>

                <!-- ═══ LOCAL MUSIC FOLDERS section ═══ -->
                <TextBlock Text="LOCAL MUSIC FOLDERS" Style="{StaticResource M3SectionHeader}"/>
                <Border Style="{StaticResource M3SettingsGroup}">
                    <StackPanel>
                        <Border Style="{StaticResource M3SettingsItemLast}">
                            <StackPanel>
                                <DockPanel>
                                    <Border DockPanel.Dock="Left" Style="{StaticResource M3IconBox}">
                                        <Path Data="M20 6h-8l-2-2H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm0 12H4V8h16v10z"
                                              Width="20" Height="20" Stretch="Uniform"
                                              Fill="{DynamicResource PrimaryBrush}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Music Folders" Style="{StaticResource M3TitleText}"/>
                                        <TextBlock Text="Folders on your disk that Musicefy scans."
                                                   Style="{StaticResource M3DescriptionText}"/>
                                    </StackPanel>
                                    <Button DockPanel.Dock="Right" Content="+ Add" Padding="10,4"
                                            Style="{StaticResource TonalButtonStyle}"
                                            Click="AddFolder_Click" Cursor="Hand" VerticalAlignment="Center"/>
                                </DockPanel>

                                <ItemsControl x:Name="FoldersList" Margin="56,8,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource SurfaceContainerLowBrush}"
                                                    CornerRadius="8" Padding="10,6" Margin="0,2">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding}"
                                                               FontSize="11" Foreground="{DynamicResource OnSurfaceBrush}"
                                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                    <Button Grid.Column="1" Content="✕" Padding="6,2" Margin="8,0,0,0"
                                                            FontSize="11" Cursor="Hand"
                                                            Foreground="{DynamicResource ErrorBrush}"
                                                            Click="RemoveFolder_Click" Tag="{Binding}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock x:Name="NoFoldersText" Text="No folders added yet."
                                           FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                           Margin="56,4,0,0" Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ═══ DOWNLOAD PATH section ═══ -->
                <TextBlock Text="DOWNLOAD PATH" Style="{StaticResource M3SectionHeader}"/>
                <Border Style="{StaticResource M3SettingsGroup}">
                    <StackPanel>
                        <Border Style="{StaticResource M3SettingsItemLast}">
                            <DockPanel>
                                <Border DockPanel.Dock="Left" Style="{StaticResource M3IconBox}">
                                    <Path Data="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"
                                          Width="20" Height="20" Stretch="Uniform"
                                          Fill="{DynamicResource PrimaryBrush}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                                    <TextBlock Text="Target Download Path" Style="{StaticResource M3TitleText}"/>
                                    <TextBox x:Name="DownloadPathBox" IsReadOnly="True" BorderThickness="0"
                                             Background="Transparent" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                             FontSize="11" Margin="0,2,0,0" TextWrapping="NoWrap"/>
                                </StackPanel>
                                <Button DockPanel.Dock="Right" Content="Browse" Padding="10,4"
                                        Style="{StaticResource TonalButtonStyle}"
                                        Click="Browse_Click" Cursor="Hand" VerticalAlignment="Center"/>
                            </DockPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ═══ CACHE section ═══ -->
                <TextBlock Text="CACHE" Style="{StaticResource M3SectionHeader}"/>
                <Border Style="{StaticResource M3SettingsGroup}">
                    <StackPanel>
                        <CheckBox Style="{StaticResource M3SwitchRow}" x:Name="AutoClearCacheBox">
                            <CheckBox.Tag>
                                <Path Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"
                                      Width="20" Height="20" Stretch="Uniform"
                                      Fill="{DynamicResource PrimaryBrush}"/>
                            </CheckBox.Tag>
                            <StackPanel>
                                <TextBlock Text="Auto-clear cache on exit" Style="{StaticResource M3TitleText}"/>
                                <TextBlock Text="Flushes temporary stream directories on shutdown."
                                           Style="{StaticResource M3DescriptionText}"/>
                            </StackPanel>
                        </CheckBox>

                        <CheckBox Style="{StaticResource M3SwitchRow}" x:Name="LimitDownloadSizeBox">
                            <CheckBox.Tag>
                                <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"
                                      Width="20" Height="20" Stretch="Uniform"
                                      Fill="{DynamicResource PrimaryBrush}"/>
                            </CheckBox.Tag>
                            <StackPanel>
                                <TextBlock Text="Limit download size to 500 MB" Style="{StaticResource M3TitleText}"/>
                                <TextBlock Text="Restricts maximum track file sizes."
                                           Style="{StaticResource M3DescriptionText}"/>
                            </StackPanel>
                        </CheckBox>

                        <Border Style="{StaticResource M3SettingsItemLast}">
                            <StackPanel>
                                <DockPanel>
                                    <Border DockPanel.Dock="Left" Style="{StaticResource M3IconBox}">
                                        <Path Data="M3 13h2v-2H3v2zm0 4h2v-2H3v2zm0-8h2V7H3v2zm4 4h14v-2H7v2zm0 4h14v-2H7v2zM7 7v2h14V7H7z"
                                              Width="20" Height="20" Stretch="Uniform"
                                              Fill="{DynamicResource PrimaryBrush}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Cache size" Style="{StaticResource M3TitleText}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="CacheStatusLabel" Text="0 MB"
                                               DockPanel.Dock="Right" Style="{StaticResource M3TrailingValue}"/>
                                </DockPanel>
                                <ProgressBar x:Name="CacheProgressBar" Height="6" Maximum="100" Value="0"
                                             BorderThickness="0" Background="{DynamicResource OutlineBrush}"
                                             Margin="56,8,0,0"/>
                                <Button Content="Clear Cache" Padding="10,4" HorizontalAlignment="Left"
                                        Style="{StaticResource TonalButtonStyle}"
                                        Click="ClearNow_Click" Cursor="Hand" Margin="56,8,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
