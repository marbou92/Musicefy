<UserControl x:Class="Musicefy.Views.DownloadsSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid Margin="10,0,10,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Vertical">

                <TextBlock Text="Storage Directory" FontWeight="Bold" FontSize="15" Foreground="{DynamicResource ForegroundBrush}" Margin="4,0,0,12"/>
                <Border Background="{DynamicResource SecondaryBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="16,14" Margin="0,0,0,20">
                    <DockPanel>
                        <Button Content="Browse..." DockPanel.Dock="Right" Padding="16,6" Width="100" Click="Browse_Click" VerticalAlignment="Center"/>
                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Text="Target Download Path" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource ForegroundBrush}"/>
                            <TextBox x:Name="DownloadPathBox" IsReadOnly="True" BorderThickness="0" Background="Transparent" Foreground="{DynamicResource MutedTextBrush}" FontSize="12" Margin="0,4,0,0" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <TextBlock Text="Caching &amp; Bandwidth Policies" FontWeight="Bold" FontSize="15" Foreground="{DynamicResource ForegroundBrush}" Margin="4,0,0,12"/>

                <CheckBox x:Name="AutoClearCacheBox" Style="{StaticResource ModernSettingRowStyle}">
                    <StackPanel>
                        <TextBlock Text="Auto-Clear Cache on Exit" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource ForegroundBrush}"/>
                        <TextBlock Text="Flushes temporary stream directories immediately upon application shutdown" FontSize="11" Foreground="{DynamicResource MutedTextBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox.Tag>
                        <Path Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z" 
                              Fill="{DynamicResource MutedTextBrush}" Width="18" Height="18" Stretch="Uniform"/>
                    </CheckBox.Tag>
                </CheckBox>

                <CheckBox x:Name="LimitDownloadSizeBox" Style="{StaticResource ModernSettingRowStyle}">
                    <StackPanel>
                        <TextBlock Text="Limit Download Size to 500 MB" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource ForegroundBrush}"/>
                        <TextBlock Text="Restricts maximum track file sizes to conserve your local storage footprint" FontSize="11" Foreground="{DynamicResource MutedTextBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox.Tag>
                        <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z" 
                              Fill="{DynamicResource MutedTextBrush}" Width="18" Height="18" Stretch="Uniform"/>
                    </CheckBox.Tag>
                </CheckBox>

                <TextBlock Text="Live Storage Monitor" FontWeight="Bold" FontSize="15" Foreground="{DynamicResource ForegroundBrush}" Margin="4,8,0,12"/>
                <Border CornerRadius="14" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" Padding="16" Background="{DynamicResource SecondaryBackgroundBrush}">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,10">
                            <TextBlock x:Name="DownloadStatusLabel" Text="Idle" DockPanel.Dock="Right" FontWeight="Bold" Foreground="{DynamicResource MutedTextBrush}"/>
                            <TextBlock x:Name="CacheStatusLabel" Text="Cache size: 0.00 MB" FontWeight="Bold" Foreground="{DynamicResource ForegroundBrush}"/>
                        </DockPanel>
                        
                        <ProgressBar x:Name="CacheProgressBar" Height="8" Maximum="100" Value="0" CornerRadius="4" BorderThickness="0" Background="#202020" Margin="0,0,0,16"/>
                        
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <Button x:Name="ClearNowButton" Content="Clear Cache" Padding="14,6" Margin="0,0,8,0" Click="ClearNow_Click"/>
                            <Button x:Name="TestDownloadButton" Content="Test Download" Padding="14,6" Margin="0,0,8,0" Click="TestDownload_Click"/>
                            <Button x:Name="PauseDownloadButton" Content="Pause" Padding="14,6" Margin="0,0,8,0" Click="PauseDownload_Click" IsEnabled="False"/>
                            <Button x:Name="ResumeDownloadButton" Content="Resume" Padding="14,6" Margin="0,0,8,0" Click="ResumeDownload_Click" IsEnabled="False"/>
                            <Button x:Name="CancelDownloadButton" Content="Cancel" Padding="14,6" Click="CancelDownload_Click" IsEnabled="False"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
