<UserControl x:Class="Musicefy.Views.DownloadsSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}"
             Foreground="{DynamicResource ForegroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Downloads Settings"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Orientation="Vertical" Spacing="20">

                <!-- Download Path -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Download path:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox x:Name="DownloadPathBox" Width="400" IsReadOnly="True"/>
                    <Button Content="Browse..." Margin="10,0,0,0" Click="Browse_Click"/>
                </StackPanel>

                <!-- Toggles -->
                <CheckBox x:Name="AutoClearCacheBox"
                          Content="Auto-clear cache on exit"
                          Style="{StaticResource ToggleSettingStyle}"/>
                <CheckBox x:Name="LimitDownloadSizeBox"
                          Content="Limit download size to 500 MB"
                          Style="{StaticResource ToggleSettingStyle}"/>

                <!-- Cache status card -->
                <Border CornerRadius="6" Padding="10"
                        Background="{DynamicResource SecondaryBackgroundBrush}">
                    <StackPanel>
                        <TextBlock x:Name="CacheStatusLabel"
                                   Text="Cache size: 0 MB"
                                   FontStyle="Italic"
                                   Margin="0,0,0,5"/>
                        <ProgressBar x:Name="CacheProgressBar"
                                     Height="20"
                                     Maximum="100"
                                     Value="0"
                                     ToolTip="Cache size"/>
                        <TextBlock x:Name="DownloadStatusLabel"
                                   Text="Idle"
                                   Margin="0,5,0,0"
                                   Foreground="{DynamicResource ForegroundBrush}"/>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button Content="Clear Now"
                                    Width="120"
                                    Click="ClearNow_Click"/>
                            <Button Content="Test Download"
                                    Width="140"
                                    Click="TestDownload_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Cancel" Width="100" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button Content="Save" Width="100" Background="{DynamicResource AccentBrush}" Foreground="White" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
