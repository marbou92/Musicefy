<Window x:Class="Musicefy.Views.PlaylistPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add to Playlist" Height="400" Width="360"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceBrush}"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Select a playlist" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource OnSurfaceBrush}" Margin="0,0,0,16"/>

        <ListView x:Name="PlaylistList" Grid.Row="1"
                  Background="Transparent" BorderThickness="0"
                  Foreground="{DynamicResource OnSurfaceBrush}"
                  VirtualizingPanel.IsVirtualizing="True"
                  Padding="0,4">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="0,6">
                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Medium"
                                   Foreground="{DynamicResource OnSurfaceBrush}"/>
                        <TextBlock FontSize="12" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,2,0,0">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0} tracks">
                                    <Binding Path="TrackCount"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Width="80" Height="32" Margin="0,0,12,0"
                    Click="BtnCancel_Click"
                    Background="{DynamicResource SurfaceContainerHighBrush}"
                    Foreground="{DynamicResource OnSurfaceBrush}"/>
            <Button Content="Add" Width="80" Height="32"
                    Click="BtnAdd_Click"
                    Background="{DynamicResource PrimaryBrush}"
                    Foreground="{DynamicResource OnPrimaryBrush}"/>
        </StackPanel>
    </Grid>
</Window>
