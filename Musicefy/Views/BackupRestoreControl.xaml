<UserControl x:Class="Musicefy.Views.BackupRestoreControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="20,16,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Backup &amp; Restore" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource OnSurfaceBrush}"/>
            <TextBlock Text="Export your database, sources, and settings to a .mbackup file."
                       FontSize="12" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Create Backup -->
                <Border Background="{DynamicResource SurfaceVariantBrush}" CornerRadius="14"
                        Padding="20,16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Create Backup" FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource OnSurfaceBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="Save a complete snapshot of your Musicefy data, including:"
                                   FontSize="12" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="  • Music library database (tracks, playlists, play history)&#x0a;  • Configured sources (Local folders, YouTube settings)&#x0a;  • Saved playback queue"
                                   FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,0,0,12"/>
                        <Button Content="📤 Create Backup" Padding="16,8" HorizontalAlignment="Left"
                                Command="{Binding CreateBackupCommand}" Cursor="Hand"/>
                    </StackPanel>
                </Border>

                <!-- Restore Backup -->
                <Border Background="{DynamicResource SurfaceVariantBrush}" CornerRadius="14"
                        Padding="20,16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Restore Backup" FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource OnSurfaceBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="Restore from a previously created .mbackup file."
                                   FontSize="12" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="⚠ This will overwrite your current data. The app will need to restart after restore."
                                   FontSize="11" Foreground="{DynamicResource ErrorBrush}" Margin="0,0,0,12"
                                   TextWrapping="Wrap"/>
                        <Button Content="📥 Restore Backup" Padding="16,8" HorizontalAlignment="Left"
                                Command="{Binding RestoreBackupCommand}" Cursor="Hand"
                                Foreground="{DynamicResource ErrorBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Status -->
                <Border Background="{DynamicResource SurfaceContainerHighBrush}" CornerRadius="10"
                        Padding="16,10" Margin="0,0,0,16"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⏳" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding StatusText}" FontSize="12"
                                   Foreground="{DynamicResource OnSurfaceVariantBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Last backup info -->
                <Border Background="{DynamicResource SurfaceContainerHighBrush}" CornerRadius="10"
                        Padding="16,10" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Last Backup" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding LastBackupPath, TargetNullValue='No backup created yet.'}"
                                   FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Status text -->
                <TextBlock Text="{Binding StatusText}" FontSize="11"
                           Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
