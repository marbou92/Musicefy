<UserControl x:Class="Musicefy.Views.BackupRestoreControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="10,0,10,10">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Vertical">

                <TextBlock Text="Backup &amp; Restore" FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource OnSurfaceBrush}" Margin="4,0,0,4"/>
                <TextBlock Text="Export and restore your data."
                           FontSize="12" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           Margin="4,0,0,20"/>

                <!-- CREATE BACKUP card -->
                <Border Background="{DynamicResource SurfaceVariantBrush}" CornerRadius="16"
                        Padding="20,16" Margin="0,0,0,16" Cursor="Hand"
                        MouseLeftButtonUp="CreateBackup_Click">
                    <DockPanel>
                        <Border DockPanel.Dock="Left" Style="{StaticResource M3IconBox}">
                            <Path Data="M19 12v7H5v-7H3v7c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2v-7h-2zm-6 .67l2.59-2.58L17 11.5l-5 5-5-5 1.41-1.41L11 12.67V3h2z"
                                  Width="24" Height="24" Stretch="Uniform"
                                  Fill="{DynamicResource PrimaryBrush}"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Local Backup" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource OnSurfaceBrush}"/>
                            <TextBlock Text="Create a manual backup of your data"
                                       FontSize="12" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- IMPORT card -->
                <Border Background="{DynamicResource SurfaceVariantBrush}" CornerRadius="16"
                        Padding="20,16" Margin="0,0,0,16" Cursor="Hand"
                        MouseLeftButtonUp="RestoreBackup_Click">
                    <DockPanel>
                        <Border DockPanel.Dock="Left" Style="{StaticResource M3IconBox}">
                            <Path Data="M9 16h6v-6h4l-7-7-7 7h4v6zm-4 2h14v2H5v-2z"
                                  Width="24" Height="24" Stretch="Uniform"
                                  Fill="{DynamicResource PrimaryBrush}"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Import" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource OnSurfaceBrush}"/>
                            <TextBlock Text="Restore data from backups or other sources"
                                       FontSize="12" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Status (loading) -->
                <Border Background="{DynamicResource SurfaceContainerHighBrush}" CornerRadius="12"
                        Padding="16,10" Margin="0,0,0,8"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⏳" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding StatusText}" FontSize="12"
                                   Foreground="{DynamicResource OnSurfaceVariantBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Last backup info -->
                <Border Background="{DynamicResource SurfaceContainerHighBrush}" CornerRadius="12"
                        Padding="16,10" Margin="0,0,0,8"
                        Visibility="{Binding HasLastBackup, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="Last Backup" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding LastBackupPath}"
                                   FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
