<UserControl x:Class="Musicefy.Views.StatsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="20,16,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Stats" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource OnSurfaceBrush}"/>
                <TextBlock Text="Your listening activity" FontSize="12"
                           Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,4,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <ComboBox x:Name="PeriodCombo" Padding="8,4" FontSize="12"
                          SelectedIndex="{Binding SelectedPeriodIndex, Mode=TwoWay}"
                          Margin="0,0,8,0">
                    <ComboBoxItem Content="7 days"/>
                    <ComboBoxItem Content="30 days"/>
                    <ComboBoxItem Content="90 days"/>
                    <ComboBoxItem Content="All time"/>
                </ComboBox>
                <Button Content="🔄 Refresh" Padding="12,6"
                        Command="{Binding RefreshCommand}" Cursor="Hand"/>
            </StackPanel>
        </Grid>

        <!-- Summary cards -->
        <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
            <Border Background="{DynamicResource SurfaceVariantBrush}" CornerRadius="12"
                    Padding="16,12" Margin="0,0,12,8" MinWidth="120">
                <StackPanel>
                    <TextBlock Text="{Binding Summary.TotalPlays}" FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBrush}"/>
                    <TextBlock Text="Total Plays" FontSize="11"
                               Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource SurfaceVariantBrush}" CornerRadius="12"
                    Padding="16,12" Margin="0,0,12,8" MinWidth="120">
                <StackPanel>
                    <TextBlock Text="{Binding Summary.UniqueTracks}" FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBrush}"/>
                    <TextBlock Text="Unique Tracks" FontSize="11"
                               Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource SurfaceVariantBrush}" CornerRadius="12"
                    Padding="16,12" Margin="0,0,12,8" MinWidth="120">
                <StackPanel>
                    <TextBlock Text="{Binding Summary.UniqueArtists}" FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBrush}"/>
                    <TextBlock Text="Unique Artists" FontSize="11"
                               Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource SurfaceVariantBrush}" CornerRadius="12"
                    Padding="16,12" Margin="0,0,0,8" MinWidth="120">
                <StackPanel>
                    <TextBlock Text="{Binding Summary.UniqueAlbums}" FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBrush}"/>
                    <TextBlock Text="Unique Albums" FontSize="11"
                               Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <!-- Stats sections -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Loading -->
                <TextBlock Text="Loading…"
                           FontSize="12" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                           Margin="0,0,0,8"/>

                <!-- Top Tracks -->
                <TextBlock Text="Top Tracks" FontSize="16" FontWeight="Bold"
                           Foreground="{DynamicResource OnSurfaceBrush}" Margin="0,0,0,8"/>
                <ItemsControl ItemsSource="{Binding TopTracks}" Margin="0,0,0,20">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource SurfaceVariantBrush}"
                                    CornerRadius="8" Padding="10,6" Margin="0,2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding PlayCount, StringFormat='{0}×'}"
                                               FontSize="12" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryBrush}"
                                               VerticalAlignment="Center" Margin="0,0,12,0" MinWidth="40"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource OnSurfaceBrush}" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Artist}" FontSize="10"
                                                   Foreground="{DynamicResource OnSurfaceVariantBrush}" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Top Artists -->
                <TextBlock Text="Top Artists" FontSize="16" FontWeight="Bold"
                           Foreground="{DynamicResource OnSurfaceBrush}" Margin="0,0,0,8"/>
                <ItemsControl ItemsSource="{Binding TopArtists}" Margin="0,0,0,20">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource SurfaceVariantBrush}"
                                    CornerRadius="8" Padding="10,6" Margin="0,2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding PlayCount, StringFormat='{0}×'}"
                                               FontSize="12" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryBrush}"
                                               VerticalAlignment="Center" Margin="0,0,12,0" MinWidth="40"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Artist}" FontSize="12"
                                               Foreground="{DynamicResource OnSurfaceBrush}"
                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Top Albums -->
                <TextBlock Text="Top Albums" FontSize="16" FontWeight="Bold"
                           Foreground="{DynamicResource OnSurfaceBrush}" Margin="0,0,0,8"/>
                <ItemsControl ItemsSource="{Binding TopAlbums}" Margin="0,0,0,20">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource SurfaceVariantBrush}"
                                    CornerRadius="8" Padding="10,6" Margin="0,2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding PlayCount, StringFormat='{0}×'}"
                                               FontSize="12" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryBrush}"
                                               VerticalAlignment="Center" Margin="0,0,12,0" MinWidth="40"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Album}" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource OnSurfaceBrush}" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Artist}" FontSize="10"
                                                   Foreground="{DynamicResource OnSurfaceVariantBrush}" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
