<UserControl x:Class="Musicefy.Views.AppearanceSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Musicefy.ViewModels"
             xmlns:controls="clr-namespace:Musicefy.Controls"
             Background="{DynamicResource BackgroundBrush}"
             Foreground="{DynamicResource ForegroundBrush}">

    <UserControl.DataContext>
        <vm:AppearanceSettingsViewModel/>
    </UserControl.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Appearance Settings"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>

        <!-- Appearance content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Orientation="Vertical" Spacing="20">

                <!-- Theme Mode Selector -->
                <TextBlock Text="Theme Mode" FontWeight="Bold" Margin="0,0,0,5"/>
                <controls:ThemeSelectorGroup DataContext="{Binding}" />

                <!-- Pure Dark Mode Toggle -->
                <CheckBox Content="Enable pure black dark mode" 
                          IsChecked="{Binding PureBlackMode}" 
                          Margin="0,10,0,0"/>

                <!-- Date Format -->
                <TextBlock Text="Date Format" FontWeight="Bold" Margin="0,20,0,5"/>
                <ComboBox ItemsSource="{Binding DateFormats}" 
                          SelectedItem="{Binding SelectedDateFormat}" 
                          Width="200"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Cancel" Width="100" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button Content="Save" Width="100" Background="{DynamicResource AccentBrush}" Foreground="White" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
