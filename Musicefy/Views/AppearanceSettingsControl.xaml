<UserControl x:Class="Musicefy.Views.AppearanceSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <Style x:Key="PaletteExpanderStyle" TargetType="Expander">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition x:Name="ContentRow" Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border x:Name="HeaderBorder" Background="Transparent" Padding="4,6,4,6" Cursor="Hand">
                                <StackPanel Orientation="Horizontal">
                                    <Path x:Name="ExpandChevron"
                                          Data="M8,0L16,10L0,10Z"
                                          Fill="{DynamicResource OnSurfaceVariantBrush}"
                                          Width="10" Height="10" Stretch="Uniform"
                                          RenderTransformOrigin="0.5,0.5"
                                          Margin="0,0,8,0">
                                        <Path.RenderTransform>
                                            <RotateTransform Angle="0"/>
                                        </Path.RenderTransform>
                                    </Path>
                                    <TextBlock Text="{TemplateBinding Header}"
                                               FontWeight="SemiBold" FontSize="14"
                                               Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
                                </StackPanel>
                            </Border>

                            <ContentPresenter x:Name="ContentSite"
                                              Grid.Row="1" Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Visible"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ExpandChevron"
                                                             Storyboard.TargetProperty="(Path.RenderTransform).(RotateTransform.Angle)"
                                                             To="180" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ExpandChevron"
                                                             Storyboard.TargetProperty="(Path.RenderTransform).(RotateTransform.Angle)"
                                                             To="0" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10,0,10,10">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Vertical">

                <TextBlock Text="Theme" FontWeight="Bold" FontSize="15" Foreground="{DynamicResource OnSurfaceBrush}" Margin="4,0,0,12"/>
                <Border CornerRadius="22" BorderThickness="1.5" BorderBrush="{DynamicResource OutlineBrush}" ClipToBounds="True" Margin="0,0,0,25" Height="44" Background="Transparent">
                    <UniformGrid Columns="3">
                        <RadioButton Content="System" Style="{StaticResource SegmentedTabStyle}" GroupName="ThemeGroup"
                                     IsChecked="{Binding SelectedThemeIndex, Converter={StaticResource IndexToBoolConverter}, ConverterParameter=0}"/>
                        <RadioButton Content="Light" Style="{StaticResource SegmentedTabStyle}" GroupName="ThemeGroup"
                                     IsChecked="{Binding SelectedThemeIndex, Converter={StaticResource IndexToBoolConverter}, ConverterParameter=1}"/>
                        <RadioButton Content="Dark" Style="{StaticResource SegmentedTabStyle}" GroupName="ThemeGroup"
                                     IsChecked="{Binding SelectedThemeIndex, Converter={StaticResource IndexToBoolConverter}, ConverterParameter=2}"/>
                    </UniformGrid>
                </Border>

                <!-- Block 1: Theme Preview Card -->
                <Border CornerRadius="20" Background="{DynamicResource SurfaceVariantBrush}" Padding="20" Margin="0,0,0,20">
                    <Grid Height="160">
                        <Border Width="56" Height="56" CornerRadius="10"
                                Background="{DynamicResource PrimaryBrush}"
                                HorizontalAlignment="Left" VerticalAlignment="Top"/>
                        <Rectangle Width="100" Height="5" RadiusX="3" RadiusY="3"
                                   Fill="{DynamicResource PrimaryBrush}"
                                   HorizontalAlignment="Left" Margin="0,66,0,0"/>
                        <Border Width="52" Height="52" CornerRadius="26"
                                Background="{DynamicResource PrimaryBrush}"
                                HorizontalAlignment="Right" VerticalAlignment="Top">
                            <Path Data="M8,5V19L19,12L8,5Z" Fill="{DynamicResource OnPrimaryBrush}"
                                  Width="20" Height="20" Stretch="Uniform" Margin="2,0,0,0"/>
                        </Border>
                        <Ellipse Width="52" Height="52" Fill="{DynamicResource PrimaryBrush}"
                                 HorizontalAlignment="Left" Margin="0,0,0,0" VerticalAlignment="Center"/>
                        <Ellipse Width="44" Height="44" Fill="{DynamicResource PrimaryBrush}" Opacity="0.6"
                                 HorizontalAlignment="Left" Margin="28,0,0,0" VerticalAlignment="Center"/>
                        <Ellipse Width="44" Height="44" Fill="{DynamicResource SecondaryBrush}"
                                 HorizontalAlignment="Left" Margin="52,0,0,0" VerticalAlignment="Center"/>
                        <Border CornerRadius="20" Height="32" Width="80"
                                Background="{DynamicResource OutlineBrush}" Opacity="0.5"
                                HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="0,0,0,0"/>
                        <Border CornerRadius="20" Height="32" Width="80"
                                Background="{DynamicResource OutlineBrush}" Opacity="0.5"
                                HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                        <Border CornerRadius="20" Height="32" Width="80"
                                Background="{DynamicResource OutlineBrush}" Opacity="0.5"
                                HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                        <Button Content="Reset Palette"
                                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                Background="{DynamicResource PrimaryBrush}" Foreground="{DynamicResource OnPrimaryBrush}"
                                BorderThickness="0" Padding="12,6" FontSize="11" FontWeight="SemiBold"
                                Cursor="Hand" Margin="0,0,0,36"
                                Click="BtnResetPalette_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="12" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <!-- Block 2: Family group palette scroller -->
                <ItemsControl ItemsSource="{Binding FamilyGroups}" Margin="0,0,0,12">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Expander Header="{Binding FamilyName}" Style="{StaticResource PaletteExpanderStyle}"
                                      IsExpanded="{Binding IsExpanded}">
                                <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" Margin="0,4,0,0">
                                    <ItemsControl ItemsSource="{Binding Previews}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="80" Height="80" CornerRadius="18" Margin="0,0,12,0"
                                                        Cursor="Hand"
                                                        BorderBrush="{Binding BorderBrush}" BorderThickness="2"
                                                        MouseLeftButtonUp="PaletteCard_Click">
                                                    <Grid Width="80" Height="80">
                                                        <Grid.Clip>
                                                            <RectangleGeometry Rect="0,0,80,80" RadiusX="18" RadiusY="18"/>
                                                        </Grid.Clip>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="40"/>
                                                            <RowDefinition Height="40"/>
                                                        </Grid.RowDefinitions>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="40"/>
                                                            <ColumnDefinition Width="40"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Grid.Row="0" Grid.Column="0" Background="{Binding PrimarySeed}"/>
                                                        <Border Grid.Row="0" Grid.Column="1" Background="{Binding SecondarySeed}"/>
                                                        <Border Grid.Row="1" Grid.Column="0" Background="{Binding TertiarySeed}"/>
                                                        <Border Grid.Row="1" Grid.Column="1" Background="{Binding NeutralSeed}"/>

                                                        <Border Grid.RowSpan="2" Grid.ColumnSpan="2"
                                                                Background="#CC000000"
                                                                Visibility="{Binding IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                            <Path Data="M9,16.17L4.83,12L3.41,13.41L9,19L21,7L19.59,5.59L9,16.17Z"
                                                                  Fill="White" Width="24" Height="24" Stretch="Uniform"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Block 3: Action buttons -->
                <StackPanel HorizontalAlignment="Center" Margin="0,8,0,0">
                    <Button Height="48" Padding="24,0"
                            Background="#FFAB9A" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            Command="{Binding CustomThemeCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="24" Padding="{TemplateBinding Padding}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="M12,2C6.48,2 2,6.48 2,12S6.48,22 12,22 22,17.52 22,12 17.52,2 12,2M12,20C7.59,20 4,16.41 4,12S7.59,4 12,4 20,7.59 20,12 16.41,20 12,20M12,6C9.79,6 8,7.79 8,10S9.79,14 12,14 16,12.21 16,10 14.21,6 12,6M12,12C10.9,12 10,11.1 10,10S10.9,8 12,8 14,8.9 14,10 13.1,12 12,12M18,18H6V17.5C6,15.5 10,14.5 12,14.5S18,15.5 18,17.5V18Z"
                                              Fill="White" Width="18" Height="18" Stretch="Uniform" Margin="0,0,10,0"/>
                                        <TextBlock Text="Custom Theme" FontWeight="SemiBold" FontSize="14"
                                                   Foreground="White"/>
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Height="48" Padding="24,0"
                            Background="{DynamicResource SurfaceVariantBrush}"
                            Foreground="{DynamicResource OnSurfaceBrush}"
                            BorderThickness="0" Cursor="Hand" Margin="0,12,0,0"
                            Command="{Binding ImportThemeCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="24" Padding="{TemplateBinding Padding}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="M14,2H6C4.9,2 4,2.9 4,4V20C4,21.1 4.9,22 6,22H18C19.1,22 20,21.1 20,20V8L14,2M18,20H6V4H13V9H18V20M12,19L8,15H10.5V12H13.5V15H16L12,19Z"
                                              Fill="{DynamicResource OnSurfaceBrush}" Width="18" Height="18"
                                              Stretch="Uniform" Margin="0,0,10,0"/>
                                        <TextBlock Text="Import Theme" FontWeight="SemiBold" FontSize="14"
                                                   Foreground="{DynamicResource OnSurfaceBrush}"/>
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <TextBlock Text="Dynamic Colors" FontWeight="Bold" FontSize="15" Foreground="{DynamicResource OnSurfaceBrush}" Margin="4,25,0,12"/>

                <CheckBox Style="{StaticResource ModernSettingRowStyle}" IsChecked="{Binding DynamicColorsEnabled}">
                    <StackPanel>
                        <TextBlock Text="Dynamic Album Colors" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource OnSurfaceBrush}"/>
                        <TextBlock Text="Automatically theme the app using colors extracted from the currently playing album art" FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,2,0,0"/>
                    </StackPanel>

                    <CheckBox.Tag>
                        <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-2-3.5l6-4.5-6-4.5v9z"
                              Fill="{DynamicResource OnSurfaceVariantBrush}" Width="18" Height="18" Stretch="Uniform"/>
                    </CheckBox.Tag>
                </CheckBox>

                <TextBlock Text="Pure Black Settings" FontWeight="Bold" FontSize="15" Foreground="{DynamicResource OnSurfaceBrush}" Margin="4,25,0,12"/>

                <CheckBox Style="{StaticResource ModernSettingRowStyle}" IsChecked="{Binding PureBlackMode}">
                    <StackPanel>
                        <TextBlock Text="Enable Pure Black Dark Mode" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource OnSurfaceBrush}"/>
                        <TextBlock Text="Applies an absolute blackout layout optimization matrix across your views" FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,2,0,0"/>
                    </StackPanel>

                    <CheckBox.Tag>
                        <Path Data="M12 3c0.132 0 0.263 0.007 0.393 0.021a8.4 8.4 0 0 0-0.143 1.579c0 4.639 3.76 8.4 8.4 8.4 0.542 0 1.062-0.051 1.564-0.149A8.4 8.4 0 1 1 12 3z"
                              Fill="{DynamicResource OnSurfaceVariantBrush}" Width="18" Height="18" Stretch="Uniform"/>
                    </CheckBox.Tag>
                </CheckBox>

                <TextBlock Text="Format Configurations" FontWeight="Bold" FontSize="15" Foreground="{DynamicResource OnSurfaceBrush}" Margin="4,15,0,12"/>
                <Border Background="{DynamicResource SurfaceVariantBrush}" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1" CornerRadius="14" Padding="16,12">
                    <DockPanel>
                        <ComboBox DockPanel.Dock="Right" ItemsSource="{Binding DateFormats}" SelectedItem="{Binding SelectedDateFormat}" Width="160" VerticalAlignment="Center"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Application Date Format" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource OnSurfaceBrush}"/>
                            <TextBlock Text="Updates string display values throughout global window listings" FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
