<UserControl x:Class="Musicefy.Views.AppearanceSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Musicefy.ViewModels"
             Background="{DynamicResource BackgroundBrush}"
             Foreground="{DynamicResource ForegroundBrush}">

    <UserControl.DataContext>
        <vm:AppearanceSettingsViewModel/>
    </UserControl.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Appearance Settings"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>

        <!-- Appearance content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Orientation="Vertical">

                <!-- Theme Tabs -->
                <TabControl SelectedIndex="{Binding SelectedThemeIndex}"
                            Margin="0,0,0,15">
                    <TabItem Header="System"/>
                    <TabItem Header="Light"/>
                    <TabItem Header="Dark"/>
                </TabControl>

                <!-- Theme Previews -->
                <ItemsControl ItemsSource="{Binding ThemePreviews}" Margin="0,0,0,15">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Click="PalettePreview_Click"
                                    Padding="0" Margin="5"
                                    Width="140" Height="100"
                                    Background="{Binding AccentBrush}">
                                <Border BorderThickness="1" BorderBrush="White" CornerRadius="4">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" 
                                                   FontWeight="Bold" 
                                                   Foreground="White" 
                                                   HorizontalAlignment="Center"/>
                                        <Grid Height="50" Margin="0,5,0,0">
                                            <Rectangle Fill="{Binding AccentBrush}" RadiusX="4" RadiusY="4"/>
                                            <TextBlock Text="Aa" 
                                                       Foreground="White" 
                                                       FontSize="16" 
                                                       HorizontalAlignment="Center" 
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Pure Dark Mode Toggle -->
                <CheckBox Content="Enable pure black dark mode" 
                          IsChecked="{Binding PureBlackMode}" 
                          Margin="0,0,0,10"/>
                
                <!-- Date Format -->
                <ComboBox ItemsSource="{Binding DateFormats}" 
                          SelectedItem="{Binding SelectedDateFormat}" 
                          Width="200" Margin="0,10,0,0"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Cancel" Width="100" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button Content="Save" Width="100" Background="{DynamicResource AccentBrush}" Foreground="White" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
