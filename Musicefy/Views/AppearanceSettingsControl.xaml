<UserControl x:Class="Musicefy.Views.AppearanceSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    
    <UserControl.Resources>
        <Style x:Key="SleekToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Border" CornerRadius="12" Background="{DynamicResource AppSurfaceHover}" BorderThickness="1.5" BorderBrush="{DynamicResource AppBorder}">
                            <Grid>
                                <Ellipse x:Name="Knob" Fill="{DynamicResource AppSubText}" Width="16" Height="16" HorizontalAlignment="Left" Margin="3,0,0,0"/>
                                <TextBlock x:Name="Cross" Text="×" Foreground="{DynamicResource AppSurface}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="6,-2,0,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Knob" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Knob" Property="Margin" Value="0,0,3,0"/>
                                <Setter TargetName="Knob" Property="Fill" Value="{DynamicResource AppAccent}"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource AppAccent}"/>
                                <Setter TargetName="Cross" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SegmentedTab" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource AppText}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="Transparent" Padding="0,12" BorderThickness="0,0,1,0" BorderBrush="{DynamicResource AppBorder}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppSurfaceHover}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AppAccent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <StackPanel Margin="0,10,0,0">
        
        <Border Background="{DynamicResource AppSurface}" CornerRadius="10" Margin="0,0,0,10" Padding="15">
            <DockPanel>
                <Path DockPanel.Dock="Left" Data="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z" Fill="{DynamicResource AppSubText}" Width="20" Height="20" Stretch="Uniform" Margin="0,0,15,0"/>
                <ToggleButton DockPanel.Dock="Right" Style="{StaticResource SleekToggleStyle}" IsChecked="{Binding HideThumbnail}"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Hide Player Thumbnail" Foreground="{DynamicResource AppText}" FontWeight="Bold" FontSize="14"/>
                    <TextBlock Text="Hide album art in the player" Foreground="{DynamicResource AppSubText}" FontSize="12"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Background="{DynamicResource AppSurface}" CornerRadius="10" Margin="0,0,0,30" Padding="15">
            <DockPanel>
                <Path DockPanel.Dock="Left" Data="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14zm-5.04-6.71l-2.75 3.54-1.96-2.36L6.5 17h11l-3.54-4.71z" Fill="{DynamicResource AppSubText}" Width="20" Height="20" Stretch="Uniform" Margin="0,0,15,0"/>
                <ToggleButton DockPanel.Dock="Right" Style="{StaticResource SleekToggleStyle}" IsChecked="{Binding CropSquare}"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Crop Thumbnail to Square" Foreground="{DynamicResource AppText}" FontWeight="Bold" FontSize="14"/>
                    <TextBlock Text="Crop album art to a square" Foreground="{DynamicResource AppSubText}" FontSize="12"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <TextBlock Text="Theme" Foreground="{DynamicResource AppAccent}" FontSize="14" Margin="0,0,0,10"/>
        
        <Border CornerRadius="20" BorderThickness="1" BorderBrush="{DynamicResource AppBorder}" ClipToBounds="True" Margin="0,0,0,20">
            <UniformGrid Columns="3">
                <RadioButton Content="System" Style="{StaticResource SegmentedTab}" GroupName="ThemeGroup"/>
                <RadioButton Content="Light" Style="{StaticResource SegmentedTab}" GroupName="ThemeGroup" Checked="Theme_Changed"/>
                <RadioButton Content="Dark" Style="{StaticResource SegmentedTab}" GroupName="ThemeGroup" IsChecked="True" Checked="Theme_Changed"/>
            </UniformGrid>
        </Border>

        <TextBlock Text="Palettes" Foreground="{DynamicResource AppText}" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
        
        <ComboBox x:Name="PaletteBox" Background="{DynamicResource AppSurface}" Foreground="{DynamicResource AppText}" SelectionChanged="PaletteBox_SelectionChanged">
            <ComboBoxItem Content="Default" IsSelected="True"/>
            <ComboBoxItem Content="Catppuccin"/>
            <ComboBoxItem Content="Green Apple"/>
            <ComboBoxItem Content="Lavender"/>
            <ComboBoxItem Content="Midnight"/>
        </ComboBox>

    </StackPanel>
</UserControl>
