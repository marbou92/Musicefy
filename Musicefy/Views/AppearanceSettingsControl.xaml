<UserControl x:Class="Musicefy.Views.AppearanceSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Musicefy.ViewModels"
             Background="{DynamicResource BackgroundBrush}"
             Foreground="{DynamicResource ForegroundBrush}">

    <UserControl.DataContext>
        <vm:AppearanceSettingsViewModel/>
    </UserControl.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Appearance Settings"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>

        <!-- Appearance content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Orientation="Vertical">

                <!-- Theme Mode Selector -->
                <TextBlock Text="Theme Mode" FontWeight="Bold" Margin="0,0,0,5"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                    <RadioButton Content="System" IsChecked="{Binding SelectedThemeIndex, Converter={StaticResource IndexToBoolConverter}, ConverterParameter=0}" Margin="0,0,10,0"/>
                    <RadioButton Content="Light" IsChecked="{Binding SelectedThemeIndex, Converter={StaticResource IndexToBoolConverter}, ConverterParameter=1}" Margin="0,0,10,0"/>
                    <RadioButton Content="Dark" IsChecked="{Binding SelectedThemeIndex, Converter={StaticResource IndexToBoolConverter}, ConverterParameter=2}"/>
                </StackPanel>

                <!-- Palette Previews -->
                <TextBlock Text="Palettes" FontWeight="Bold" Margin="0,10,0,5"/>
                <ItemsControl ItemsSource="{Binding ThemePreviews}" Margin="0,0,0,15">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="140" Height="100" Margin="6"
                                    Background="{Binding BackgroundBrush}"
                                    BorderBrush="{Binding HighlightBrush}"
                                    BorderThickness="3"
                                    CornerRadius="8"
                                    Cursor="Hand"
                                    MouseLeftButtonUp="PaletteCard_Click">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Rectangle Width="40" Height="10" Fill="{Binding AccentBrush}" Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding CardName}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Pure Dark Mode Toggle -->
                <CheckBox Content="Enable pure black dark mode" 
                          IsChecked="{Binding PureBlackMode}" 
                          Margin="0,10,0,15"/>

                <!-- Date Format -->
                <TextBlock Text="Date Format" FontWeight="Bold" Margin="0,20,0,5"/>
                <ComboBox ItemsSource="{Binding DateFormats}" 
                          SelectedItem="{Binding SelectedDateFormat}" 
                          Width="200"
                          Margin="0,0,0,15"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Cancel" Width="100" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button Content="Save" Width="100" Background="{DynamicResource AccentBrush}" Foreground="White" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
