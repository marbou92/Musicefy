<UserControl x:Class="Musicefy.Views.AppearanceSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="PaletteCardStyle" TargetType="Border">
            <Setter Property="Width" Value="72"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)" To="1.05" Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction><CircleEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)" To="1.05" Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction><CircleEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.15">
                                    <DoubleAnimation.EasingFunction><CircleEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.15">
                                    <DoubleAnimation.EasingFunction><CircleEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10,0,10,10">

        <!-- ═══ MAIN VIEW ═══ -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      Visibility="{Binding IsMainView, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Vertical">

                <TextBlock Text="Appearance" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource OnSurfaceBrush}" Margin="4,0,0,4"/>
                <TextBlock Text="Theme, player, lyrics, and layout." FontSize="12" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="4,0,0,20"/>

                <!-- ═══ THEME ═══ -->
                <TextBlock Text="THEME" Style="{StaticResource M3SectionHeader}"/>
                <Border Style="{StaticResource M3SettingsGroup}">
                    <Border Style="{StaticResource M3SettingsItemLast}" Padding="16,14" Cursor="Hand"
                            MouseLeftButtonUp="ThemeRow_Click">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Right" Text="›" FontSize="20"
                                       Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                       VerticalAlignment="Center" Margin="0,0,0,0"
                                       HorizontalAlignment="Right"/>
                            <Border DockPanel.Dock="Left" Style="{StaticResource M3IconBox}">
                                <Path Data="M12 2C6.49 2 2 6.49 2 12s4.49 10 10 10c.55 0 1-.45 1-1 0-.28-.11-.53-.29-.71-.18-.18-.29-.43-.29-.71 0-.55.45-1 1-1H16c3.31 0 6-2.69 6-6 0-4.96-4.49-9-10-9zm-5.5 8.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5S8 8.17 8 9s-.67 1.5-1.5 1.5zm3.5-2.5c-.83 0-1.5-.67-1.5-1.5S9.17 5 10 5s1.5.67 1.5 1.5S10.83 8 10 8zm5 0c-.83 0-1.5-.67-1.5-1.5S14.17 5 15 5s1.5.67 1.5 1.5S15.83 8 15 8zm1.5 4.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"
                                      Width="20" Height="20" Stretch="Uniform" Fill="{DynamicResource PrimaryBrush}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Theme" Style="{StaticResource M3TitleText}"/>
                                <TextBlock Text="Theme mode, color palette, dynamic colors." Style="{StaticResource M3DescriptionText}"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </Border>

                <!-- ═══ PLAYER ═══ -->
                <TextBlock Text="PLAYER" Style="{StaticResource M3SectionHeader}"/>
                <Border Style="{StaticResource M3SettingsGroup}">
                    <StackPanel>
                        <!-- Player Background (segmented control — keep as-is, has icon) -->
                        <Border Style="{StaticResource M3SettingsItemLast}" Padding="16,12">
                            <StackPanel>
                                <TextBlock Text="Player Background" Style="{StaticResource M3TitleText}" Margin="0,0,0,8"/>
                                <Border Style="{StaticResource M3SegmentedControl}">
                                    <UniformGrid Columns="3">
                                        <RadioButton Content="Gradient" Style="{StaticResource SegmentedTabStyle}" GroupName="BgStyleGroup" IsChecked="{Binding SelectedPlayerBackgroundIndex, Converter={StaticResource IndexToBoolConverter}, ConverterParameter=0}"/>
                                        <RadioButton Content="Coloring" Style="{StaticResource SegmentedTabStyle}" GroupName="BgStyleGroup" IsChecked="{Binding SelectedPlayerBackgroundIndex, Converter={StaticResource IndexToBoolConverter}, ConverterParameter=1}"/>
                                        <RadioButton Content="Glow" Style="{StaticResource SegmentedTabStyle}" GroupName="BgStyleGroup" IsChecked="{Binding SelectedPlayerBackgroundIndex, Converter={StaticResource IndexToBoolConverter}, ConverterParameter=2}"/>
                                    </UniformGrid>
                                </Border>
                            </StackPanel>
                        </Border>
                        <!-- Player Slider Style — fixed: icon + ComboBox docked right first + no separator -->
                        <Border Style="{StaticResource M3SettingsItemLast}" Padding="16,14">
                            <DockPanel>
                                <ComboBox DockPanel.Dock="Right" SelectedIndex="{Binding PlayerSliderStyleIndex}" Width="120" VerticalAlignment="Center">
                                    <ComboBoxItem Content="Default"/>
                                    <ComboBoxItem Content="Wavy"/>
                                    <ComboBoxItem Content="Squiggly"/>
                                </ComboBox>
                                <Border DockPanel.Dock="Left" Style="{StaticResource M3IconBox}">
                                    <Path Data="M19.5,9.5c-1.03,0 -1.9,0.62 -2.29,1.5h-2.92c-0.39,-0.88 -1.26,-1.5 -2.29,-1.5s-1.9,0.62 -2.29,1.5H6.79c-0.39,-0.88 -1.26,-1.5 -2.29,-1.5C3.12,9.5 2,10.62 2,12s1.12,2.5 2.5,2.5c1.03,0 1.9,-0.62 2.29,-1.5h2.92c0.39,0.88 1.26,1.5 2.29,1.5s1.9,-0.62 2.29,-1.5h2.92c0.39,0.88 1.26,1.5 2.29,1.5c1.38,0 2.5,-1.12 2.5,-2.5S20.88,9.5 19.5,9.5z"
                                          Width="20" Height="20" Stretch="Uniform" Fill="{DynamicResource PrimaryBrush}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Player Slider Style" Style="{StaticResource M3TitleText}"/>
                                    <TextBlock Text="Choose the progress bar animation style." Style="{StaticResource M3DescriptionText}"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                        <CheckBox Style="{StaticResource M3SwitchRow}" IsChecked="{Binding HidePlayerThumbnail}">
                            <CheckBox.Tag><Path Data="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z" Width="20" Height="20" Stretch="Uniform" Fill="{DynamicResource PrimaryBrush}"/></CheckBox.Tag>
                            <StackPanel><TextBlock Text="Hide Player Thumbnail" Style="{StaticResource M3TitleText}"/><TextBlock Text="Replace album art with app logo." Style="{StaticResource M3DescriptionText}"/></StackPanel>
                        </CheckBox>
                        <CheckBox Style="{StaticResource M3SwitchRow}" IsChecked="{Binding CropAlbumArt}">
                            <CheckBox.Tag><Path Data="M3 5v4h2V5h4V3H5c-1.1 0-2 .9-2 2zm2 10H3v4c0 1.1.9 2 2 2h4v-2H5v-4zm14 4h-4v2h4c1.1 0 2-.9 2-2v-4h-2v4zm0-16h-4v2h4v4h2V5c0-1.1-.9-2-2-2z" Width="20" Height="20" Stretch="Uniform" Fill="{DynamicResource PrimaryBrush}"/></CheckBox.Tag>
                            <StackPanel><TextBlock Text="Crop Album Art" Style="{StaticResource M3TitleText}"/><TextBlock Text="Force square aspect ratio." Style="{StaticResource M3DescriptionText}"/></StackPanel>
                        </CheckBox>
                        <CheckBox Style="{StaticResource M3SwitchRow}" IsChecked="{Binding ShowCodecOnPlayer}">
                            <CheckBox.Tag><Path Data="M21 3H3c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h18c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H3V5h18v14zM6 15h2v2H6zm3-4h2v6H9zm3-4h2v10h-2zm3 7h2v3h-2z" Width="20" Height="20" Stretch="Uniform" Fill="{DynamicResource PrimaryBrush}"/></CheckBox.Tag>
                            <StackPanel><TextBlock Text="Show Codec on Player" Style="{StaticResource M3TitleText}"/><TextBlock Text="Display audio codec below timeline." Style="{StaticResource M3DescriptionText}"/></StackPanel>
                        </CheckBox>
                        <!-- Thumbnail Corner Radius — fixed: icon + no separator -->
                        <Border Style="{StaticResource M3SettingsItemLast}" Padding="16,14">
                            <StackPanel>
                                <DockPanel>
                                    <Border DockPanel.Dock="Left" Style="{StaticResource M3IconBox}">
                                        <Path Data="M3 5v4h2V5h4V3H5c-1.1 0-2 .9-2 2zm2 10H3v4c0 1.1.9 2 2 2h4v-2H5v-4zm14 4h-4v2h4c1.1 0 2-.9 2-2v-4h-2v4zm0-16h-4v2h4v4h2V5c0-1.1-.9-2-2-2z"
                                              Width="20" Height="20" Stretch="Uniform" Fill="{DynamicResource PrimaryBrush}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Thumbnail Corner Radius" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource OnSurfaceVariantBrush}" VerticalAlignment="Center"/>
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding ThumbnailCornerRadius, StringFormat='{}{0}dp'}" FontSize="12" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center"/>
                                </DockPanel>
                                <Slider Style="{StaticResource M3Slider}" Minimum="0" Maximum="24" Value="{Binding ThumbnailCornerRadius}" Margin="56,8,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ═══ MINI-PLAYER ═══ -->
                <TextBlock Text="MINI-PLAYER" Style="{StaticResource M3SectionHeader}"/>
                <Border Style="{StaticResource M3SettingsGroup}">
                    <Border Style="{StaticResource M3SettingsItemLast}" Padding="16,14">
                        <DockPanel>
                            <ComboBox DockPanel.Dock="Right" SelectedIndex="{Binding MiniPlayerBackgroundStyleIndex}" Width="120" VerticalAlignment="Center">
                                <ComboBoxItem Content="Follow Theme"/>
                                <ComboBoxItem Content="Solid"/>
                                <ComboBoxItem Content="Gradient"/>
                            </ComboBox>
                            <Border DockPanel.Dock="Left" Style="{StaticResource M3IconBox}">
                                <Path Data="M21 3H3c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h18c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H3V5h18v14zM4 16h4v2H4v-2z"
                                      Width="20" Height="20" Stretch="Uniform" Fill="{DynamicResource PrimaryBrush}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Mini-player Background" Style="{StaticResource M3TitleText}"/>
                                <TextBlock Text="Background style for the mini-player bar." Style="{StaticResource M3DescriptionText}"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </Border>

                <!-- ═══ LYRICS ═══ -->
                <TextBlock Text="LYRICS" Style="{StaticResource M3SectionHeader}"/>
                <Border Style="{StaticResource M3SettingsGroup}">
                    <StackPanel>
                        <!-- Lyrics Text Position — fixed: icon + ComboBox docked right first + no separator -->
                        <Border Style="{StaticResource M3SettingsItemLast}" Padding="16,14">
                            <DockPanel>
                                <ComboBox DockPanel.Dock="Right" SelectedIndex="{Binding LyricsTextPositionIndex}" Width="100" VerticalAlignment="Center">
                                    <ComboBoxItem Content="Left"/>
                                    <ComboBoxItem Content="Center"/>
                                </ComboBox>
                                <Border DockPanel.Dock="Left" Style="{StaticResource M3IconBox}">
                                    <Path Data="M3 3h18v2H3V3zm0 4h12v2H3V7zm0 4h18v2H3v-2zm0 4h12v2H3v-2zm0 4h18v2H3v-2z"
                                          Width="20" Height="20" Stretch="Uniform" Fill="{DynamicResource PrimaryBrush}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Lyrics Text Position" Style="{StaticResource M3TitleText}"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                        <!-- Lyrics Text Size — fixed: icon + no separator -->
                        <Border Style="{StaticResource M3SettingsItemLast}" Padding="16,14">
                            <StackPanel>
                                <DockPanel>
                                    <Border DockPanel.Dock="Left" Style="{StaticResource M3IconBox}">
                                        <Path Data="M9 4v3h5v12h3V7h5V4H9zm-7 0h3v3H2V4z"
                                              Width="20" Height="20" Stretch="Uniform" Fill="{DynamicResource PrimaryBrush}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Lyrics Text Size" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource OnSurfaceVariantBrush}" VerticalAlignment="Center"/>
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding LyricsTextSize, StringFormat='{}{0}sp'}" FontSize="12" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center"/>
                                </DockPanel>
                                <Slider Style="{StaticResource M3Slider}" Minimum="12" Maximum="32" Value="{Binding LyricsTextSize}" Margin="56,8,0,0"/>
                            </StackPanel>
                        </Border>
                        <!-- Lyrics Line Spacing — fixed: icon + no separator -->
                        <Border Style="{StaticResource M3SettingsItemLast}" Padding="16,14">
                            <StackPanel>
                                <DockPanel>
                                    <Border DockPanel.Dock="Left" Style="{StaticResource M3IconBox}">
                                        <Path Data="M6 7h12v2H6V7zm0 4h12v4H6v-4z"
                                              Width="20" Height="20" Stretch="Uniform" Fill="{DynamicResource PrimaryBrush}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Lyrics Line Spacing" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource OnSurfaceVariantBrush}" VerticalAlignment="Center"/>
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding LyricsLineSpacing, StringFormat='{}{0:F1}x'}" FontSize="12" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center"/>
                                </DockPanel>
                                <Slider Style="{StaticResource M3Slider}" Minimum="1" Maximum="2" Value="{Binding LyricsLineSpacing}" Margin="56,8,0,0"/>
                            </StackPanel>
                        </Border>
                        <CheckBox Style="{StaticResource M3SwitchRow}" IsChecked="{Binding GlowingLyricsEffect}">
                            <CheckBox.Tag><Path Data="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" Width="20" Height="20" Stretch="Uniform" Fill="{DynamicResource PrimaryBrush}"/></CheckBox.Tag>
                            <StackPanel><TextBlock Text="Glowing Lyrics Effect" Style="{StaticResource M3TitleText}"/><TextBlock Text="Add glow to active lyrics." Style="{StaticResource M3DescriptionText}"/></StackPanel>
                        </CheckBox>
                        <CheckBox Style="{StaticResource M3SwitchRow}" IsChecked="{Binding LyricsBlurInactive}">
                            <CheckBox.Tag><Path Data="M3 3h18v2H3V3zm0 4h12v2H3V7zm0 4h18v2H3v-2zm0 4h12v2H3v-2zm0 4h18v2H3v-2z" Width="20" Height="20" Stretch="Uniform" Fill="{DynamicResource PrimaryBrush}"/></CheckBox.Tag>
                            <StackPanel><TextBlock Text="Blur Inactive Lyrics" Style="{StaticResource M3TitleText}"/><TextBlock Text="Blur inactive lines for focus." Style="{StaticResource M3DescriptionText}"/></StackPanel>
                        </CheckBox>
                        <CheckBox Style="{StaticResource M3SwitchRow}" IsChecked="{Binding AutoScrollLyrics}">
                            <CheckBox.Tag><Path Data="M16 13h-3V3h-2v10H8l4 4 4-4zM4 19v2h16v-2H4z" Width="20" Height="20" Stretch="Uniform" Fill="{DynamicResource PrimaryBrush}"/></CheckBox.Tag>
                            <StackPanel><TextBlock Text="Auto Scroll Lyrics" Style="{StaticResource M3TitleText}"/><TextBlock Text="Scroll lyrics automatically." Style="{StaticResource M3DescriptionText}"/></StackPanel>
                        </CheckBox>
                    </StackPanel>
                </Border>

                <!-- ═══ MISC ═══ -->
                <TextBlock Text="MISC" Style="{StaticResource M3SectionHeader}"/>
                <Border Style="{StaticResource M3SettingsGroup}">
                    <StackPanel>
                        <!-- Default Open Tab — fixed: icon + ComboBox docked right first + no separator -->
                        <Border Style="{StaticResource M3SettingsItemLast}" Padding="16,14">
                            <DockPanel>
                                <ComboBox DockPanel.Dock="Right" SelectedIndex="{Binding DefaultOpenTabIndex}" Width="100" VerticalAlignment="Center">
                                    <ComboBoxItem Content="Home"/>
                                    <ComboBoxItem Content="Search"/>
                                    <ComboBoxItem Content="Library"/>
                                </ComboBox>
                                <Border DockPanel.Dock="Left" Style="{StaticResource M3IconBox}">
                                    <Path Data="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"
                                          Width="20" Height="20" Stretch="Uniform" Fill="{DynamicResource PrimaryBrush}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Default Open Tab" Style="{StaticResource M3TitleText}"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                        <!-- Grid Cell Size — fixed: icon + ComboBox docked right first + no separator -->
                        <Border Style="{StaticResource M3SettingsItemLast}" Padding="16,14">
                            <DockPanel>
                                <ComboBox DockPanel.Dock="Right" SelectedIndex="{Binding GridCellSizeIndex}" Width="100" VerticalAlignment="Center">
                                    <ComboBoxItem Content="Small"/>
                                    <ComboBoxItem Content="Medium"/>
                                    <ComboBoxItem Content="Large"/>
                                </ComboBox>
                                <Border DockPanel.Dock="Left" Style="{StaticResource M3IconBox}">
                                    <Path Data="M3 3h8v8H3V3zm10 0h8v8h-8V3zM3 13h8v8H3v-8zm10 0h8v8h-8v-8z"
                                          Width="20" Height="20" Stretch="Uniform" Fill="{DynamicResource PrimaryBrush}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Grid Cell Size" Style="{StaticResource M3TitleText}"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                        <CheckBox Style="{StaticResource M3SwitchRow}" IsChecked="{Binding ShowLikedPlaylist}">
                            <CheckBox.Tag><Path Data="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" Width="20" Height="20" Stretch="Uniform" Fill="{DynamicResource PrimaryBrush}"/></CheckBox.Tag>
                            <StackPanel><TextBlock Text="Show Liked Playlist" Style="{StaticResource M3TitleText}"/></StackPanel>
                        </CheckBox>
                        <CheckBox Style="{StaticResource M3SwitchRow}" IsChecked="{Binding ShowDownloadedPlaylist}">
                            <CheckBox.Tag><Path Data="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z" Width="20" Height="20" Stretch="Uniform" Fill="{DynamicResource PrimaryBrush}"/></CheckBox.Tag>
                            <StackPanel><TextBlock Text="Show Downloaded Playlist" Style="{StaticResource M3TitleText}"/></StackPanel>
                        </CheckBox>
                    </StackPanel>
                </Border>

                <!-- ═══ FORMAT ═══ -->
                <TextBlock Text="FORMAT" Style="{StaticResource M3SectionHeader}"/>
                <Border Style="{StaticResource M3SettingsGroup}">
                    <Border Style="{StaticResource M3SettingsItemLast}" Padding="16,14">
                        <DockPanel>
                            <ComboBox DockPanel.Dock="Right" ItemsSource="{Binding DateFormats}" SelectedItem="{Binding SelectedDateFormat}" Width="160" VerticalAlignment="Center"/>
                            <Border DockPanel.Dock="Left" Style="{StaticResource M3IconBox}">
                                <Path Data="M19 3h-1V1h-2v2H8V1H6v2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11z"
                                      Width="20" Height="20" Stretch="Uniform" Fill="{DynamicResource PrimaryBrush}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Application Date Format" Style="{StaticResource M3TitleText}"/>
                                <TextBlock Text="Updates string display throughout listings." Style="{StaticResource M3DescriptionText}"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══ THEME SUB-VIEW ═══ -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      Visibility="{Binding IsThemeView, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Vertical">

                <StackPanel Orientation="Horizontal" Margin="4,0,0,16">
                    <Button Padding="8,4" Cursor="Hand" Background="Transparent" BorderThickness="0"
                            Command="{Binding NavigateBackCommand}" Margin="0,0,12,0">
                        <Path Data="M20,11L7.8,11l5.6,-5.6L12,4l-8,8l8,8l1.4,-1.4L7.8,13L20,13L20,11z"
                              Width="20" Height="20" Stretch="Uniform"
                              Fill="{DynamicResource OnSurfaceBrush}"/>
                    </Button>
                    <TextBlock Text="Theme" FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource OnSurfaceBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Text="THEME MODE" Style="{StaticResource M3SectionHeader}"/>
                <Border Style="{StaticResource M3SettingsGroup}">
                    <Border Style="{StaticResource M3SettingsItemLast}" Padding="16,12">
                        <StackPanel>
                            <Border Style="{StaticResource M3SegmentedControl}">
                                <UniformGrid Columns="4">
                                    <RadioButton Content="System" Style="{StaticResource SegmentedTabStyle}" GroupName="ThemeGroup" IsChecked="{Binding SelectedThemeMode, Converter={StaticResource IndexToBoolConverter}, ConverterParameter=0}"/>
                                    <RadioButton Content="Light" Style="{StaticResource SegmentedTabStyle}" GroupName="ThemeGroup" IsChecked="{Binding SelectedThemeMode, Converter={StaticResource IndexToBoolConverter}, ConverterParameter=1}"/>
                                    <RadioButton Content="Dark" Style="{StaticResource SegmentedTabStyle}" GroupName="ThemeGroup" IsChecked="{Binding SelectedThemeMode, Converter={StaticResource IndexToBoolConverter}, ConverterParameter=2}"/>
                                    <RadioButton Content="AMOLED" Style="{StaticResource SegmentedTabStyle}" GroupName="ThemeGroup" IsChecked="{Binding SelectedThemeMode, Converter={StaticResource IndexToBoolConverter}, ConverterParameter=3}"/>
                                </UniformGrid>
                            </Border>
                        </StackPanel>
                    </Border>
                </Border>

                <TextBlock Text="COLOR PALETTE" Style="{StaticResource M3SectionHeader}"/>
                <Border Style="{StaticResource M3SettingsGroup}">
                    <StackPanel>
                        <Border Style="{StaticResource M3SettingsItem}" Padding="16,12">
                            <Border CornerRadius="20" Background="{DynamicResource SurfaceContainerHighBrush}" Padding="16">
                                <Grid Height="140">
                                    <Border Width="40" CornerRadius="10,0,0,10" Background="{DynamicResource SurfaceContainerLowBrush}" HorizontalAlignment="Left"/>
                                    <Ellipse Width="20" Height="20" Fill="{DynamicResource PrimaryBrush}" HorizontalAlignment="Left" Margin="10,12,0,0" VerticalAlignment="Top"/>
                                    <Border CornerRadius="0,10,10,10" Margin="40,0,0,0" Background="{DynamicResource SurfaceBrush}"/>
                                    <Border Width="80" Height="44" CornerRadius="12" Background="{DynamicResource PrimaryContainerBrush}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="52,10,0,0">
                                        <StackPanel VerticalAlignment="Center" Margin="10,0,0,0">
                                            <Rectangle Width="36" Height="4" RadiusX="2" Fill="{DynamicResource PrimaryBrush}"/>
                                            <Rectangle Width="24" Height="3" RadiusX="1.5" Fill="{DynamicResource OnSurfaceVariantBrush}" Opacity="0.5" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <Ellipse Width="28" Height="28" Fill="{DynamicResource SecondaryBrush}" Opacity="0.8" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,14,14,0"/>
                                    <Ellipse Width="20" Height="20" Fill="{DynamicResource TertiaryBrush}" Opacity="0.8" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,14,48,0"/>
                                    <Border CornerRadius="16" Height="28" Width="60" Background="{DynamicResource PrimaryBrush}" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="52,0,0,8">
                                        <TextBlock Text="Action" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource OnPrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <Button Content="Reset" HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="{DynamicResource PrimaryBrush}" Foreground="{DynamicResource OnPrimaryBrush}" BorderThickness="0" Padding="12,6" FontSize="11" FontWeight="SemiBold" Cursor="Hand" Click="BtnResetPalette_Click">
                                        <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="12" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Button.Template>
                                    </Button>
                                </Grid>
                            </Border>
                        </Border>
                        <Border Style="{StaticResource M3SettingsItem}" Padding="16,8">
                            <ItemsControl ItemsSource="{Binding AppThemePreviews}">
                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource PaletteCardStyle}" BorderBrush="{Binding BorderBrush}" MouseLeftButtonUp="PaletteCard_Click" RenderTransformOrigin="0.5,0.5" Margin="0,0,8,8" ToolTip="{Binding Label}">
                                            <Border.RenderTransform><ScaleTransform ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                                            <StackPanel Width="72">
                                                <Grid Width="48" Height="48" Margin="12,8,12,0" HorizontalAlignment="Center">
                                                    <Grid.Clip><RectangleGeometry Rect="0,0,48,48" RadiusX="24" RadiusY="24"/></Grid.Clip>
                                                    <Ellipse Fill="{Binding SurfaceBrush}" Width="48" Height="48"/>
                                                    <Border Width="28" Height="14" CornerRadius="7" Background="{Binding PrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,6,0,0"/>
                                                    <Ellipse Fill="{Binding SecondaryBrush}" Width="10" Height="10" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,6,6"/>
                                                    <Ellipse Fill="{Binding TertiaryBrush}" Width="10" Height="10" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="6,0,0,6"/>
                                                    <Ellipse Stroke="{Binding BorderBrush}" StrokeThickness="1.5" Fill="Transparent" Width="48" Height="48"/>
                                                    <Border Background="#AA000000" Visibility="{Binding IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <Path Data="M9,16.17L4.83,12L3.41,13.41L9,19L21,7L19.59,5.59L9,16.17Z" Fill="White" Width="18" Height="18" Stretch="Uniform"/>
                                                    </Border>
                                                </Grid>
                                                <TextBlock Text="{Binding Label}" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource OnSurfaceVariantBrush}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" HorizontalAlignment="Center" Margin="4,4,4,6"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                        <CheckBox Style="{StaticResource M3SwitchRow}" IsChecked="{Binding DynamicColorsEnabled}">
                            <CheckBox.Tag><Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-2-3.5l6-4.5-6-4.5v9z" Width="20" Height="20" Stretch="Uniform" Fill="{DynamicResource PrimaryBrush}"/></CheckBox.Tag>
                            <StackPanel>
                                <TextBlock Text="Dynamic Album Colors" Style="{StaticResource M3TitleText}"/>
                                <TextBlock Text="Theme the app using colors from album art." Style="{StaticResource M3DescriptionText}"/>
                            </StackPanel>
                        </CheckBox>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
