<UserControl x:Class="Musicefy.Views.AppearanceSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <!-- ── Expander for family groups ── -->
        <Style x:Key="PaletteExpanderStyle" TargetType="Expander">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition x:Name="ContentRow" Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border x:Name="HeaderBorder" Background="Transparent" Padding="4,6,4,6" Cursor="Hand">
                                <StackPanel Orientation="Horizontal">
                                    <Path x:Name="ExpandChevron"
                                          Data="M8,0L16,10L0,10Z"
                                          Fill="{DynamicResource OnSurfaceVariantBrush}"
                                          Width="10" Height="10" Stretch="Uniform"
                                          RenderTransformOrigin="0.5,0.5"
                                          Margin="0,0,8,0">
                                        <Path.RenderTransform>
                                            <RotateTransform Angle="0"/>
                                        </Path.RenderTransform>
                                    </Path>
                                    <TextBlock Text="{TemplateBinding Header}"
                                               FontWeight="SemiBold" FontSize="14"
                                               Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
                                </StackPanel>
                            </Border>
                            <ContentPresenter x:Name="ContentSite"
                                              Grid.Row="1" Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Visible"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ExpandChevron"
                                                             Storyboard.TargetProperty="(Path.RenderTransform).(RotateTransform.Angle)"
                                                             To="180" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ExpandChevron"
                                                             Storyboard.TargetProperty="(Path.RenderTransform).(RotateTransform.Angle)"
                                                             To="0" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Palette card style (larger cards with name label) ── -->
        <Style x:Key="PaletteCardStyle" TargetType="Border">
            <Setter Property="Width" Value="72"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Background" Value="Transparent"/>
            <!-- RenderTransform and RenderTransformOrigin are set as LOCAL values on the
                 Border element in the DataTemplate, NOT here in the Style. WPF freezes
                 Freezable objects set via Style Setters, making them immutable and
                 un-animateable by Storyboards. Local values are never frozen. -->
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                 To="1.05" Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <CircleEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                 To="1.05" Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <CircleEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                 To="1.0" Duration="0:0:0.15">
                                    <DoubleAnimation.EasingFunction>
                                        <CircleEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                 To="1.0" Duration="0:0:0.15">
                                    <DoubleAnimation.EasingFunction>
                                        <CircleEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- ── Chip-style RadioButton for palette styles / seed roles ── -->
        <Style x:Key="SeedChipButton" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" CornerRadius="20" Padding="12,8" Cursor="Hand"
                                Background="{DynamicResource SurfaceContainerHighBrush}"
                                BorderThickness="0" Margin="0,0,0,0">
                            <TextBlock Text="{TemplateBinding Content}" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource OnSurfaceBrush}" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource OnPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10,0,10,10">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Vertical">

                <!-- ═══════════════════════════════════════ -->
                <!-- MAIN SETTINGS (visible when not in palette subspace) -->
                <!-- ═══════════════════════════════════════ -->
                <StackPanel Visibility="{Binding IsMainSettingsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">

                    <TextBlock Text="Theme" FontWeight="Bold" FontSize="15" Foreground="{DynamicResource OnSurfaceBrush}" Margin="4,0,0,12"/>
                    <Border CornerRadius="22" BorderThickness="1.5" BorderBrush="{DynamicResource OutlineBrush}" ClipToBounds="True" Margin="0,0,0,25" Height="44" Background="Transparent">
                        <UniformGrid Columns="3">
                            <RadioButton Content="System" Style="{StaticResource SegmentedTabStyle}" GroupName="ThemeGroup"
                                         IsChecked="{Binding SelectedThemeIndex, Converter={StaticResource IndexToBoolConverter}, ConverterParameter=0}"/>
                            <RadioButton Content="Light" Style="{StaticResource SegmentedTabStyle}" GroupName="ThemeGroup"
                                         IsChecked="{Binding SelectedThemeIndex, Converter={StaticResource IndexToBoolConverter}, ConverterParameter=1}"/>
                            <RadioButton Content="Dark" Style="{StaticResource SegmentedTabStyle}" GroupName="ThemeGroup"
                                         IsChecked="{Binding SelectedThemeIndex, Converter={StaticResource IndexToBoolConverter}, ConverterParameter=2}"/>
                        </UniformGrid>
                    </Border>

                    <!-- Color Palette navigation button -->
                    <TextBlock Text="Color" FontWeight="Bold" FontSize="15" Foreground="{DynamicResource OnSurfaceBrush}" Margin="4,0,0,12"/>
                    <Border CornerRadius="20" Background="{DynamicResource SurfaceVariantBrush}" Padding="16" Margin="0,0,0,8"
                            Cursor="Hand" MouseLeftButtonUp="ColorPaletteButton_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="44" Height="44" CornerRadius="22" Margin="0,0,12,0">
                                    <Border.Clip>
                                        <RectangleGeometry Rect="0,0,44,44" RadiusX="22" RadiusY="22"/>
                                    </Border.Clip>
                                    <Grid>
                                        <Ellipse Fill="{DynamicResource SurfaceContainerBrush}" Width="44" Height="44"/>
                                        <Border Width="24" Height="12" CornerRadius="6"
                                                Background="{DynamicResource PrimaryBrush}"
                                                HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,7,0,0"/>
                                        <Ellipse Fill="{DynamicResource SecondaryBrush}" Width="10" Height="10"
                                                 HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,7,7"/>
                                        <Ellipse Fill="{DynamicResource TertiaryBrush}" Width="10" Height="10"
                                                 HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="7,0,0,7"/>
                                        <Ellipse Stroke="{DynamicResource OutlineBrush}" StrokeThickness="1.5" Fill="Transparent"
                                                 Width="44" Height="44"/>
                                    </Grid>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Color Palette" FontWeight="Bold" FontSize="14"
                                               Foreground="{DynamicResource OnSurfaceBrush}"/>
                                    <TextBlock Text="Browse presets or create custom themes" FontSize="11"
                                               Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                            <Path Grid.Column="2" Data="M8.59,16.59L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.59Z"
                                  Fill="{DynamicResource OnSurfaceVariantBrush}" Width="20" Height="20" Stretch="Uniform"
                                  VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <TextBlock Text="Dynamic Colors" FontWeight="Bold" FontSize="15" Foreground="{DynamicResource OnSurfaceBrush}" Margin="4,25,0,12"/>
                    <CheckBox Style="{StaticResource ModernSettingRowStyle}" IsChecked="{Binding DynamicColorsEnabled}">
                        <StackPanel>
                            <TextBlock Text="Dynamic Album Colors" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource OnSurfaceBrush}"/>
                            <TextBlock Text="Automatically theme the app using colors extracted from the currently playing album art" FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <CheckBox.Tag>
                            <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-2-3.5l6-4.5-6-4.5v9z"
                                  Fill="{DynamicResource OnSurfaceVariantBrush}" Width="18" Height="18" Stretch="Uniform"/>
                        </CheckBox.Tag>
                    </CheckBox>

                    <TextBlock Text="Pure Black Settings" FontWeight="Bold" FontSize="15" Foreground="{DynamicResource OnSurfaceBrush}" Margin="4,25,0,12"/>
                    <CheckBox Style="{StaticResource ModernSettingRowStyle}" IsChecked="{Binding PureBlackMode}">
                        <StackPanel>
                            <TextBlock Text="Enable Pure Black Dark Mode" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource OnSurfaceBrush}"/>
                            <TextBlock Text="Applies an absolute blackout layout optimization matrix across your views" FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <CheckBox.Tag>
                            <Path Data="M12 3c0.132 0 0.263 0.007 0.393 0.021a8.4 8.4 0 0 0-0.143 1.579c0 4.639 3.76 8.4 8.4 8.4 0.542 0 1.062-0.051 1.564-0.149A8.4 8.4 0 1 1 12 3z"
                                  Fill="{DynamicResource OnSurfaceVariantBrush}" Width="18" Height="18" Stretch="Uniform"/>
                        </CheckBox.Tag>
                    </CheckBox>

                    <TextBlock Text="Player Background" FontWeight="Bold" FontSize="15" Foreground="{DynamicResource OnSurfaceBrush}" Margin="4,25,0,12"/>
                    <Border CornerRadius="22" BorderThickness="1.5" BorderBrush="{DynamicResource OutlineBrush}" ClipToBounds="True" Margin="0,0,0,25" Height="44" Background="Transparent">
                        <UniformGrid Columns="3">
                            <RadioButton Content="Gradient" Style="{StaticResource SegmentedTabStyle}" GroupName="BgStyleGroup"
                                         IsChecked="{Binding SelectedPlayerBackgroundIndex, Converter={StaticResource IndexToBoolConverter}, ConverterParameter=0}"/>
                            <RadioButton Content="Coloring" Style="{StaticResource SegmentedTabStyle}" GroupName="BgStyleGroup"
                                         IsChecked="{Binding SelectedPlayerBackgroundIndex, Converter={StaticResource IndexToBoolConverter}, ConverterParameter=1}"/>
                            <RadioButton Content="Glow" Style="{StaticResource SegmentedTabStyle}" GroupName="BgStyleGroup"
                                         IsChecked="{Binding SelectedPlayerBackgroundIndex, Converter={StaticResource IndexToBoolConverter}, ConverterParameter=2}"/>
                        </UniformGrid>
                    </Border>

                    <TextBlock Text="Format Configurations" FontWeight="Bold" FontSize="15" Foreground="{DynamicResource OnSurfaceBrush}" Margin="4,15,0,12"/>
                    <Border Background="{DynamicResource SurfaceVariantBrush}" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1" CornerRadius="14" Padding="16,12">
                        <DockPanel>
                            <ComboBox DockPanel.Dock="Right" ItemsSource="{Binding DateFormats}" SelectedItem="{Binding SelectedDateFormat}" Width="160" VerticalAlignment="Center"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Application Date Format" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource OnSurfaceBrush}"/>
                                <TextBlock Text="Updates string display values throughout global window listings" FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                </StackPanel>

                <!-- ═══════════════════════════════════════ -->
                <!-- PALETTE SUBSPACE (visible when navigating color palettes) -->
                <!-- ═══════════════════════════════════════ -->
                <StackPanel Visibility="{Binding IsPaletteSubspaceVisible, Converter={StaticResource BooleanToVisibilityConverter}}">

                    <!-- Back header -->
                    <Border Background="Transparent" Padding="4,4,4,8" Cursor="Hand"
                            MouseLeftButtonUp="PaletteBackButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M15.41,7.41L14,6L8,12L14,18L15.41,16.59L10.83,12L15.41,7.41Z"
                                  Fill="{DynamicResource OnSurfaceBrush}" Width="20" Height="20" Stretch="Uniform"
                                  Margin="0,0,8,0"/>
                            <TextBlock Text="Appearance" FontSize="15" FontWeight="Bold"
                                       Foreground="{DynamicResource OnSurfaceBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Theme Preview Card (mode-accurate: uses live DynamicResource brushes) -->
                    <Border CornerRadius="20" Background="{DynamicResource SurfaceContainerBrush}" Padding="16" Margin="0,0,0,12">
                        <Grid Height="140">
                            <!-- Mini sidebar -->
                            <Border Width="40" CornerRadius="10,0,0,10"
                                    Background="{DynamicResource SurfaceContainerLowBrush}"
                                    HorizontalAlignment="Left" Margin="0,0,0,0"/>
                            <!-- Sidebar accent dot -->
                            <Ellipse Width="20" Height="20" Fill="{DynamicResource PrimaryBrush}"
                                     HorizontalAlignment="Left" Margin="10,12,0,0" VerticalAlignment="Top"/>

                            <!-- Main content area mockup -->
                            <Border CornerRadius="0,10,10,10" Margin="40,0,0,0"
                                    Background="{DynamicResource SurfaceBrush}"/>

                            <!-- Primary card preview -->
                            <Border Width="80" Height="44" CornerRadius="12"
                                    Background="{DynamicResource PrimaryContainerBrush}"
                                    HorizontalAlignment="Left" VerticalAlignment="Top" Margin="52,10,0,0">
                                <StackPanel VerticalAlignment="Center" Margin="10,0,0,0">
                                    <Rectangle Width="36" Height="4" RadiusX="2" Fill="{DynamicResource PrimaryBrush}"/>
                                    <Rectangle Width="24" Height="3" RadiusX="1.5" Fill="{DynamicResource OnSurfaceVariantBrush}" Opacity="0.5" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Secondary + Tertiary accent dots -->
                            <Ellipse Width="28" Height="28" Fill="{DynamicResource SecondaryBrush}" Opacity="0.8"
                                     HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,14,14,0"/>
                            <Ellipse Width="20" Height="20" Fill="{DynamicResource TertiaryBrush}" Opacity="0.8"
                                     HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,14,48,0"/>

                            <!-- Bottom action bar mockup -->
                            <Border CornerRadius="16" Height="28" Width="60"
                                    Background="{DynamicResource PrimaryBrush}"
                                    HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="52,0,0,8">
                                <TextBlock Text="Action" FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource OnPrimaryBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border CornerRadius="16" Height="28" Width="44"
                                    Background="{DynamicResource OutlineBrush}" Opacity="0.3"
                                    HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="120,0,0,8"/>

                            <!-- Reset button -->
                            <Button Content="Reset"
                                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                    Background="{DynamicResource PrimaryBrush}" Foreground="{DynamicResource OnPrimaryBrush}"
                                    BorderThickness="0" Padding="12,6" FontSize="11" FontWeight="SemiBold"
                                    Cursor="Hand"
                                    Click="BtnResetPalette_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="12" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- ═══ Palette Style selector (ArchiveTune feature) ═══ -->
                    <TextBlock Text="Palette Style" FontWeight="Bold" FontSize="15"
                               Foreground="{DynamicResource OnSurfaceBrush}" Margin="4,0,0,8"/>
                    <Border CornerRadius="14" Background="{DynamicResource SurfaceVariantBrush}" Padding="12,10" Margin="0,0,0,12">
                        <StackPanel>
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                          PreviewMouseWheel="HorizontalScrollViewer_PreviewMouseWheel">
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton Content="Tonal Spot" Style="{StaticResource SeedChipButton}" GroupName="PaletteStyleGroup"
                                                 IsChecked="{Binding SelectedPaletteStyleIndex, Converter={StaticResource IndexToBoolConverter}, ConverterParameter=0}"/>
                                    <RadioButton Content="Vibrant" Style="{StaticResource SeedChipButton}" GroupName="PaletteStyleGroup" Margin="6,0,0,0"
                                                 IsChecked="{Binding SelectedPaletteStyleIndex, Converter={StaticResource IndexToBoolConverter}, ConverterParameter=1}"/>
                                    <RadioButton Content="Expressive" Style="{StaticResource SeedChipButton}" GroupName="PaletteStyleGroup" Margin="6,0,0,0"
                                                 IsChecked="{Binding SelectedPaletteStyleIndex, Converter={StaticResource IndexToBoolConverter}, ConverterParameter=2}"/>
                                    <RadioButton Content="Fidelity" Style="{StaticResource SeedChipButton}" GroupName="PaletteStyleGroup" Margin="6,0,0,0"
                                                 IsChecked="{Binding SelectedPaletteStyleIndex, Converter={StaticResource IndexToBoolConverter}, ConverterParameter=3}"/>
                                    <RadioButton Content="Neutral" Style="{StaticResource SeedChipButton}" GroupName="PaletteStyleGroup" Margin="6,0,0,0"
                                                 IsChecked="{Binding SelectedPaletteStyleIndex, Converter={StaticResource IndexToBoolConverter}, ConverterParameter=4}"/>
                                    <RadioButton Content="Monochrome" Style="{StaticResource SeedChipButton}" GroupName="PaletteStyleGroup" Margin="6,0,0,0"
                                                 IsChecked="{Binding SelectedPaletteStyleIndex, Converter={StaticResource IndexToBoolConverter}, ConverterParameter=5}"/>
                                    <RadioButton Content="Rainbow" Style="{StaticResource SeedChipButton}" GroupName="PaletteStyleGroup" Margin="6,0,0,0"
                                                 IsChecked="{Binding SelectedPaletteStyleIndex, Converter={StaticResource IndexToBoolConverter}, ConverterParameter=6}"/>
                                    <RadioButton Content="Fruit Salad" Style="{StaticResource SeedChipButton}" GroupName="PaletteStyleGroup" Margin="6,0,0,0"
                                                 IsChecked="{Binding SelectedPaletteStyleIndex, Converter={StaticResource IndexToBoolConverter}, ConverterParameter=7}"/>
                                </StackPanel>
                            </ScrollViewer>
                            <TextBlock Text="Controls how seed colors are transformed into a full palette. Tonal Spot is the classic M3 style; Fidelity stays true to the source hue; Neutral is auto-selected for low-chroma seeds."
                                       FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                       TextWrapping="Wrap" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- ═══ Exact Palette toggle (ArchiveTune feature) ═══ -->
                    <CheckBox Style="{StaticResource ModernSettingRowStyle}" IsChecked="{Binding ExactPaletteEnabled}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Exact Palette" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource OnSurfaceBrush}"/>
                            <TextBlock Text="Use the seed color literally at its natural tone, without the standard M3 tone-system adjustment" FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <CheckBox.Tag>
                            <Path Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20M12.5,7V12.25L17,14.92L16.25,16.15L11,13V7H12.5Z"
                                  Fill="{DynamicResource OnSurfaceVariantBrush}" Width="18" Height="18" Stretch="Uniform"/>
                        </CheckBox.Tag>
                    </CheckBox>

                    <!-- ═══════════════════════════════════════════════════════ -->
                    <!-- Family group palette cards (IMPROVED: rounded-rect cards -->
                    <!-- with name labels, WrapPanel flow layout)                -->
                    <!-- ═══════════════════════════════════════════════════════ -->
                    <ItemsControl ItemsSource="{Binding FamilyGroups}" Margin="0,0,0,12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Expander Header="{Binding FamilyName}" Style="{StaticResource PaletteExpanderStyle}"
                                          IsExpanded="{Binding IsExpanded}">
                                    <!-- WrapPanel: palettes flow in rows, no horizontal scroll needed -->
                                    <ItemsControl ItemsSource="{Binding Previews}" Margin="0,4,0,0">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <!-- Card: rounded-rect with color swatch + name label -->
                                                <Border Style="{StaticResource PaletteCardStyle}"
                                                        BorderBrush="{Binding BorderBrush}"
                                                        MouseLeftButtonUp="PaletteCard_Click"
                                                        RenderTransformOrigin="0.5,0.5"
                                                        Margin="0,0,8,8"
                                                        ToolTip="{Binding CardName}">
                                                    <Border.RenderTransform>
                                                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                    </Border.RenderTransform>
                                                    <StackPanel Width="72">
                                                        <!-- Color swatch circle -->
                                                        <Grid Width="48" Height="48" Margin="12,8,12,0"
                                                              HorizontalAlignment="Center">
                                                            <Grid.Clip>
                                                                <RectangleGeometry Rect="0,0,48,48" RadiusX="24" RadiusY="24"/>
                                                            </Grid.Clip>
                                                            <!-- Surface background -->
                                                            <Ellipse Fill="{Binding SurfaceBrush}" Width="48" Height="48"/>
                                                            <!-- Primary accent pill -->
                                                            <Border Width="28" Height="14" CornerRadius="7"
                                                                    Background="{Binding PrimaryBrush}"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Top" Margin="0,6,0,0"/>
                                                            <!-- Secondary dot -->
                                                            <Ellipse Fill="{Binding SecondaryBrush}" Width="10" Height="10"
                                                                     HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,6,6"/>
                                                            <!-- Tertiary dot -->
                                                            <Ellipse Fill="{Binding TertiaryBrush}" Width="10" Height="10"
                                                                     HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="6,0,0,6"/>
                                                            <!-- Border ring -->
                                                            <Ellipse Stroke="{Binding BorderBrush}" StrokeThickness="1.5" Fill="Transparent"
                                                                     Width="48" Height="48"/>
                                                            <!-- Selected checkmark overlay -->
                                                            <Border Background="#AA000000"
                                                                    Visibility="{Binding IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                <Path Data="M9,16.17L4.83,12L3.41,13.41L9,19L21,7L19.59,5.59L9,16.17Z"
                                                                      Fill="White" Width="18" Height="18" Stretch="Uniform"/>
                                                            </Border>
                                                        </Grid>
                                                        <!-- Palette name label -->
                                                        <TextBlock Text="{Binding CardName}"
                                                                   FontSize="10" FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   TextWrapping="NoWrap"
                                                                   HorizontalAlignment="Center"
                                                                   Margin="4,4,4,6"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Custom Theme Editor Panel (RGB sliders, ArchiveTune style) -->
                    <Border CornerRadius="20" Background="{DynamicResource SurfaceVariantBrush}" Padding="16"
                            Margin="0,0,0,12"
                            Visibility="{Binding IsCustomThemeEditorOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Custom Theme" FontWeight="Bold" FontSize="15"
                                       Foreground="{DynamicResource OnSurfaceBrush}" Margin="0,0,0,12"/>

                            <!-- Live preview swatch -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <Border Width="48" Height="48" CornerRadius="24" Margin="0,0,10,0"
                                            Background="{Binding CustomPrimaryBrush}">
                                        <Border.Clip>
                                            <RectangleGeometry Rect="0,0,48,48" RadiusX="24" RadiusY="24"/>
                                        </Border.Clip>
                                        <Grid>
                                            <Ellipse Fill="{Binding CustomPrimaryBrush}" Width="48" Height="48"/>
                                            <Ellipse Fill="{Binding CustomSecondaryBrush}" Width="16" Height="16"
                                                     HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,2,2"/>
                                            <Ellipse Fill="{Binding CustomTertiaryBrush}" Width="16" Height="16"
                                                     HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                                            <Ellipse Stroke="{Binding CustomNeutralBrush}" StrokeThickness="2" Fill="Transparent"
                                                     Width="48" Height="48"/>
                                        </Grid>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Seed Colors" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource OnSurfaceBrush}"/>
                                        <TextBlock Text="{Binding SeedRoleLabel, StringFormat='Editing: {0}'}" FontSize="11"
                                                   Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <!-- Seed Role Picker (ArchiveTune style chips) -->
                            <Border CornerRadius="16" Background="{DynamicResource SurfaceContainerLowBrush}" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Seed Role" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,0,0,8"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <RadioButton Grid.Column="0" Content="Primary"
                                                     GroupName="SeedRoleGroup" IsChecked="{Binding IsPrimarySelected, Mode=OneWay}"
                                                     Style="{StaticResource SeedChipButton}"
                                                     Command="{Binding SelectSeedRoleCommand}" CommandParameter="0"/>
                                        <RadioButton Grid.Column="2" Content="Secondary"
                                                     GroupName="SeedRoleGroup" IsChecked="{Binding IsSecondarySelected, Mode=OneWay}"
                                                     Style="{StaticResource SeedChipButton}"
                                                     Command="{Binding SelectSeedRoleCommand}" CommandParameter="1"/>
                                    </Grid>
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <RadioButton Grid.Column="0" Content="Tertiary"
                                                     GroupName="SeedRoleGroup" IsChecked="{Binding IsTertiarySelected, Mode=OneWay}"
                                                     Style="{StaticResource SeedChipButton}"
                                                     Command="{Binding SelectSeedRoleCommand}" CommandParameter="2"/>
                                        <RadioButton Grid.Column="2" Content="Neutral"
                                                     GroupName="SeedRoleGroup" IsChecked="{Binding IsNeutralSelected, Mode=OneWay}"
                                                     Style="{StaticResource SeedChipButton}"
                                                     Command="{Binding SelectSeedRoleCommand}" CommandParameter="3"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- RGB Sliders (ArchiveTune style) -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="18"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="R" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource OnSurfaceVariantBrush}" VerticalAlignment="Center"/>
                                <Slider Grid.Column="1" Minimum="0" Maximum="255" SmallChange="1" LargeChange="10"
                                        Value="{Binding CustomR}" Height="28" Margin="8,0"
                                        Style="{DynamicResource {x:Type Slider}}"/>
                                <TextBlock Grid.Column="2" Text="{Binding CustomRDisplay}"
                                           FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="18"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="G" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource OnSurfaceVariantBrush}" VerticalAlignment="Center"/>
                                <Slider Grid.Column="1" Minimum="0" Maximum="255" SmallChange="1" LargeChange="10"
                                        Value="{Binding CustomG}" Height="28" Margin="8,0"
                                        Style="{DynamicResource {x:Type Slider}}"/>
                                <TextBlock Grid.Column="2" Text="{Binding CustomGDisplay}"
                                           FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="18"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="B" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource OnSurfaceVariantBrush}" VerticalAlignment="Center"/>
                                <Slider Grid.Column="1" Minimum="0" Maximum="255" SmallChange="1" LargeChange="10"
                                        Value="{Binding CustomB}" Height="28" Margin="8,0"
                                        Style="{DynamicResource {x:Type Slider}}"/>
                                <TextBlock Grid.Column="2" Text="{Binding CustomBDisplay}"
                                           FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Grid>

                            <!-- Apply / Cancel buttons -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="Cancel"
                                        Background="{DynamicResource SurfaceContainerHighBrush}"
                                        Foreground="{DynamicResource OnSurfaceBrush}"
                                        BorderThickness="0" Padding="12,8" FontSize="13" FontWeight="SemiBold"
                                        Cursor="Hand"
                                        Command="{Binding CloseCustomThemeCommand}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="14"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Grid.Column="1" Content="Apply Theme"
                                        Background="{DynamicResource PrimaryBrush}"
                                        Foreground="{DynamicResource OnPrimaryBrush}"
                                        BorderThickness="0" Padding="12,8" FontSize="13" FontWeight="SemiBold"
                                        Cursor="Hand"
                                        Command="{Binding ApplyCustomThemeCommand}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="14"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ═══ Custom / Import theme action buttons ═══ -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" CornerRadius="18" Background="{DynamicResource SurfaceVariantBrush}"
                                Padding="14,10" Cursor="Hand"
                                MouseLeftButtonUp="CustomThemeButton_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Path Data="M19.14,12.94C19.18,12.64 19.2,12.33 19.2,12C19.2,11.68 19.18,11.36 19.13,11.06L21.16,9.48C21.34,9.34 21.39,9.07 21.28,8.87L19.36,5.55C19.24,5.33 18.99,5.26 18.77,5.33L16.38,6.29C15.88,5.91 15.35,5.59 14.76,5.35L14.4,2.81C14.36,2.57 14.16,2.4 13.92,2.4H10.08C9.84,2.4 9.65,2.57 9.61,2.81L9.25,5.35C8.66,5.59 8.12,5.92 7.63,6.29L5.24,5.33C5.02,5.25 4.77,5.33 4.65,5.55L2.74,8.87C2.62,9.08 2.66,9.34 2.86,9.48L4.89,11.06C4.84,11.36 4.8,11.69 4.8,12C4.8,12.31 4.82,12.64 4.87,12.94L2.85,14.52C2.67,14.66 2.62,14.93 2.73,15.13L4.65,18.45C4.77,18.67 5.02,18.74 5.24,18.67L7.63,17.71C8.13,18.09 8.66,18.41 9.25,18.65L9.61,21.19C9.65,21.43 9.84,21.6 10.08,21.6H13.92C14.16,21.6 14.36,21.43 14.39,21.19L14.75,18.65C15.34,18.41 15.88,18.09 16.37,17.71L18.76,18.67C18.98,18.75 19.23,18.67 19.35,18.45L21.27,15.13C21.39,14.91 21.34,14.66 21.15,14.52L19.14,12.94ZM12,15.6C10.02,15.6 8.4,13.98 8.4,12C8.4,10.02 10.02,8.4 12,8.4C13.98,8.4 15.6,10.02 15.6,12C15.6,13.98 13.98,15.6 12,15.6Z"
                                      Fill="{DynamicResource OnSurfaceVariantBrush}" Width="16" Height="16" Stretch="Uniform"
                                      Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Custom Theme" FontWeight="SemiBold" FontSize="14"
                                           Foreground="{DynamicResource OnSurfaceBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" CornerRadius="18" Background="{DynamicResource SurfaceVariantBrush}"
                                Padding="14,10" Cursor="Hand"
                                MouseLeftButtonUp="ImportThemeButton_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Path Data="M19,9H15V3H9V9H5L12,16L19,9M5,18V20H19V18H5Z"
                                      Fill="{DynamicResource OnSurfaceVariantBrush}" Width="16" Height="16" Stretch="Uniform"
                                      Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Import Theme" FontWeight="SemiBold" FontSize="14"
                                           Foreground="{DynamicResource OnSurfaceBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
