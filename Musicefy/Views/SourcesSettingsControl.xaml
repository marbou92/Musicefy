<UserControl x:Class="Musicefy.Views.SourcesSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Musicefy.Views"
             xmlns:vm="clr-namespace:Musicefy.ViewModels">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Background="#1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="20,16,20,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Sources" FontSize="22" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Manage your music sources and connections"
                           FontSize="12" Foreground="#AAAAAA" Margin="0,4,0,0"/>
            </StackPanel>

            <Button Grid.Column="1" Content="+ Add Source" Padding="16,8"
                    FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                    Click="AddSourceButton_Click"
                    x:Name="AddSourceButton"/>
        </Grid>

        <!-- Source List -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      Padding="20,0,20,20">
            <Grid>
                <!-- Sources List -->
                <ItemsControl x:Name="SourcesList" Visibility="Visible">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:SourceViewModel}">
                            <views:SourceCard DataContext="{Binding}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty State -->
                <StackPanel x:Name="EmptyState" Visibility="Collapsed"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Margin="0,80,0,0">
                    <TextBlock Text="🎵" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock Text="No sources configured" FontSize="16" FontWeight="SemiBold"
                               Foreground="#AAAAAA" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="Add a music source to start listening"
                               FontSize="12" Foreground="#888888" HorizontalAlignment="Center" Margin="0,0,0,24"/>
                    <Button Content="Add Your First Source" Padding="20,10"
                            FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                            HorizontalAlignment="Center"
                            Click="AddSourceButton_Click"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
