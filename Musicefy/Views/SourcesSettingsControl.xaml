<UserControl x:Class="Musicefy.Views.SourcesSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}"
             Foreground="{DynamicResource ForegroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <TextBlock Text="Streaming Sources" FontSize="22" FontWeight="Bold" Margin="0,0,0,20"/>

            <!-- Info -->
            <TextBlock Text="Manage connections to streaming services like Squidify." 
                       TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,15"/>

            <!-- Source Type -->
            <StackPanel Margin="0,0,0,15">
                <TextBlock Text="Source Type" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox x:Name="SourceTypeCombo" Background="{StaticResource SecondaryBackgroundBrush}" 
                          Foreground="{StaticResource ForegroundBrush}" Padding="10" Height="35">
                    <ComboBoxItem Content="Subsonic (Squidify, etc.)" IsSelected="True"/>
                </ComboBox>
            </StackPanel>

            <!-- Source Name -->
            <StackPanel Margin="0,0,0,15">
                <TextBlock Text="Name" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="NameTextBox" Background="{StaticResource SecondaryBackgroundBrush}" 
                         Foreground="{StaticResource ForegroundBrush}" Padding="10" Height="35" Text="Squidify"/>
            </StackPanel>

            <!-- Server URL -->
            <StackPanel Margin="0,0,0,15">
                <TextBlock Text="Server URL" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="UrlTextBox" Background="{StaticResource SecondaryBackgroundBrush}" 
                         Foreground="{StaticResource ForegroundBrush}" Padding="10" Height="35" Text="https://www.squidify.org"/>
            </StackPanel>

            <!-- Username -->
            <StackPanel Margin="0,0,0,15">
                <TextBlock Text="Username" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="UsernameTextBox" Background="{StaticResource SecondaryBackgroundBrush}" 
                         Foreground="{StaticResource ForegroundBrush}" Padding="10" Height="35"/>
            </StackPanel>

            <!-- Password -->
            <StackPanel Margin="0,0,0,15">
                <TextBlock Text="Password" FontWeight="Bold" Margin="0,0,0,5"/>
                <PasswordBox x:Name="PasswordBox" Background="{StaticResource SecondaryBackgroundBrush}" 
                             Foreground="{StaticResource ForegroundBrush}" Padding="10" Height="35"/>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button x:Name="TestButton" Content="Test" Background="{StaticResource AccentBrush}" 
                        Foreground="{StaticResource BackgroundBrush}" Padding="20,10" Width="100" 
                        Click="TestButton_Click" FontWeight="Bold"/>
                <Button x:Name="AddButton" Content="Add Source" Background="{StaticResource AccentBrush}" 
                        Foreground="{StaticResource BackgroundBrush}" Padding="20,10" Width="120" 
                        Click="AddButton_Click" FontWeight="Bold"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
