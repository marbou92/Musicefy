<UserControl x:Class="Musicefy.Views.SourcesSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource OnSurfaceBrush}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource OnSurfaceBrush}"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource OnSurfaceBrush}"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="Button" BasedOn="{StaticResource TonalButtonStyle}">
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Height" Value="36"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10,0,10,10">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Vertical">

                <TextBlock Text="Streaming Connections" FontSize="22" FontWeight="Bold" Margin="4,0,0,4" Foreground="{DynamicResource OnSurfaceBrush}"/>
                <TextBlock Text="Add and manage remote music sources." Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="4,0,0,20" FontSize="12"/>

                <Border Background="{DynamicResource SurfaceVariantBrush}" CornerRadius="12" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Add New Source" FontWeight="Bold" FontSize="13" Margin="0,0,0,12" Foreground="{DynamicResource OnSurfaceBrush}"/>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Source Type" FontWeight="Bold" Margin="0,0,0,6" FontSize="13" Foreground="{DynamicResource OnSurfaceBrush}"/>
                            <ComboBox x:Name="SourceTypeCombo" DisplayMemberPath="DisplayName" SelectedItem="{Binding SelectedProvider}" SelectionChanged="SourceTypeCombo_SelectionChanged"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Connection Name" FontWeight="Bold" Margin="0,0,0,6" FontSize="13" Foreground="{DynamicResource OnSurfaceBrush}"/>
                            <Border Background="{DynamicResource SurfaceVariantBrush}" BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1" CornerRadius="10" Height="38">
                                <TextBox x:Name="NameTextBox" Text="{Binding SourceName, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>

                        <StackPanel x:Name="DynamicFieldsStack" Margin="0,0,0,12"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                            <TextBlock x:Name="TestStatus" Text="{Binding TestStatusText}" FontSize="12" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <Button x:Name="TestButton" Content="Test Connection" Width="140" Margin="0,0,10,0"/>
                            <Button x:Name="AddButton" Content="Link Service" Width="140"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource SurfaceVariantBrush}" CornerRadius="12" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Connected Sources" FontWeight="Bold" FontSize="13" Margin="0,0,0,12" Foreground="{DynamicResource OnSurfaceBrush}"/>
                        <ItemsControl x:Name="SourcesList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource SurfaceContainerLowBrush}" CornerRadius="10" Padding="12" Margin="0,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18"
                                                    Background="{DynamicResource PrimaryBrush}" Margin="0,0,12,0">
                                                <Path Data="{Binding Type, Converter={StaticResource IconGlyphConverter}}"
                                                      Width="18" Height="18" Stretch="Uniform"
                                                      Fill="{DynamicResource OnPrimaryBrush}"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource OnSurfaceBrush}"/>
                                                <TextBlock Text="{Binding DisplayType}" FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
                                            </StackPanel>

                                            <Button Grid.Column="2" Content="Remove" Click="RemoveSource_Click"
                                                    Tag="{Binding Id}" Foreground="{DynamicResource ErrorBrush}" VerticalAlignment="Center"
                                                    Background="Transparent" FontSize="12"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
