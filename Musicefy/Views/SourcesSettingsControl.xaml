<UserControl x:Class="Musicefy.Views.SourcesSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10,0,10,10">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Vertical">

                <TextBlock Text="Streaming Connections" FontSize="22" FontWeight="Bold" Margin="4,0,0,4" Foreground="{DynamicResource ForegroundBrush}"/>
                <TextBlock Text="Manage remote API indexing connections to servers like Squidify." Foreground="{DynamicResource MutedTextBrush}" Margin="4,0,0,20" FontSize="12"/>

                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Source Profile Architecture" FontWeight="Bold" Margin="4,0,0,6" FontSize="13" Foreground="{DynamicResource ForegroundBrush}"/>
                    <ComboBox x:Name="SourceTypeCombo">
                        <ComboBoxItem Content="Subsonic API (Squidify, Navidrome)" IsSelected="True"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Connection Identity Name" FontWeight="Bold" Margin="4,0,0,6" FontSize="13" Foreground="{DynamicResource ForegroundBrush}"/>
                    <TextBox x:Name="NameTextBox" Text="Squidify"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Target Server Base Endpoint URL" FontWeight="Bold" Margin="4,0,0,6" FontSize="13" Foreground="{DynamicResource ForegroundBrush}"/>
                    <TextBox x:Name="UrlTextBox" Text="https://www.squidify.org"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Identification Username" FontWeight="Bold" Margin="4,0,0,6" FontSize="13" Foreground="{DynamicResource ForegroundBrush}"/>
                    <TextBox x:Name="UsernameTextBox"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,25">
                    <TextBlock Text="Authentication Token Key / Password" FontWeight="Bold" Margin="4,0,0,6" FontSize="13" Foreground="{DynamicResource ForegroundBrush}"/>
                    <PasswordBox x:Name="PasswordBox"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,4,0">
                    <Button x:Name="TestButton" Content="Test Connection" Width="140" Margin="0,0,10,0" Click="TestButton_Click" Height="36"/>
                    <Button x:Name="AddButton" Content="Link Service" Width="140" Click="AddButton_Click" Height="36"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
