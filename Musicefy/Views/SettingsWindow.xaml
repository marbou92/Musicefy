<Window x:Class="Musicefy.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="400" Width="600"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="Musicefy Settings" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Tabs -->
        <TabControl Grid.Row="1">
            <!-- Appearance Tab -->
            <TabItem Header="Appearance">
                <StackPanel Margin="10">
                    <TextBlock Text="Theme" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="ThemeCombo" Width="200" SelectionChanged="ThemeCombo_SelectionChanged">
                        <ComboBoxItem Content="Light" IsSelected="True"/>
                        <ComboBoxItem Content="Dark"/>
                    </ComboBox>
                </StackPanel>
            </TabItem>

            <!-- Streaming Tab -->
            <TabItem Header="Streaming">
                <StackPanel Margin="10">
                    <TextBlock Text="Server URL" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="ServerUrlBox" Width="300"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancel" Width="100" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button Content="Save" Width="100" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
