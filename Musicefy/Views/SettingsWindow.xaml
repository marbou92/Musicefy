<Window x:Class="Musicefy.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Height="650" Width="950"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}"
        Style="{StaticResource EchoCustomWindowStyle}">

    <Window.Resources>
        <Style x:Key="SegmentedTabStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="TabBg" Background="{TemplateBinding Background}" BorderThickness="0,0,1,0" BorderBrush="{DynamicResource BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="TabBg" Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarTabStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="TabBorder" Background="{TemplateBinding Background}" CornerRadius="8" Margin="8,2" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="22,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" CornerRadius="18" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/> 
            <ColumnDefinition Width="*"/>   
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" 
                Background="{DynamicResource BackgroundBrush}" 
                BorderBrush="{DynamicResource BorderBrush}" 
                BorderThickness="0,0,1,0">
            <Grid>
                <StackPanel Margin="10,20,10,10">
                    <TextBlock Text="Settings" FontSize="22" FontWeight="ExtraBold" Margin="15,0,0,25" Foreground="{DynamicResource ForegroundBrush}"/>

                    <RadioButton x:Name="AppearanceButton" Style="{StaticResource SidebarTabStyle}" GroupName="SettingsTabs" IsChecked="True" Click="AppearanceButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M12 2C6.49 2 2 6.49 2 12s4.49 10 10 10c.55 0 1-.45 1-1 0-.28-.11-.53-.29-.71-.18-.18-.29-.43-.29-.71 0-.55.45-1 1-1H16c3.31 0 6-2.69 6-6 0-4.96-4.49-9-10-9zm-5.5 8.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5S8 8.17 8 9s-.67 1.5-1.5 1.5zm3.5-2.5c-.83 0-1.5-.67-1.5-1.5S9.17 5 10 5s1.5.67 1.5 1.5S10.83 8 10 8zm5 0c-.83 0-1.5-.67-1.5-1.5S14.17 5 15 5s1.5.67 1.5 1.5S15.83 8 15 8zm1.5 4.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"
                                  Width="18" Height="18" Stretch="Uniform"
                                  Fill="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"
                                  Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="Appearance" FontWeight="Bold" FontSize="13"/>
                                <TextBlock Text="Theme &amp; palettes" FontSize="11" Foreground="{DynamicResource MutedTextBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="DownloadsButton" Style="{StaticResource SidebarTabStyle}" GroupName="SettingsTabs" Click="DownloadsButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"
                                  Width="18" Height="18" Stretch="Uniform"
                                  Fill="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"
                                  Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="Downloads" FontWeight="Bold" FontSize="13"/>
                                <TextBlock Text="Cache &amp; limits" FontSize="11" Foreground="{DynamicResource MutedTextBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="SourcesButton" Style="{StaticResource SidebarTabStyle}" GroupName="SettingsTabs" Click="SourcesButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M17 7h-4v2h4c1.65 0 3 1.35 3 3s-1.35 3-3 3h-4v2h4c2.76 0 5-2.24 5-5s-2.24-5-5-5zm-6 8H7c-1.65 0-3-1.35-3-3s1.35-3 3-3h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-2zm-3-4h8v2H8v-2z"
                                  Width="18" Height="18" Stretch="Uniform"
                                  Fill="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"
                                  Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="Sources" FontWeight="Bold" FontSize="13"/>
                                <TextBlock Text="Streaming connections" FontSize="11" Foreground="{DynamicResource MutedTextBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="RepositoriesButton" Style="{StaticResource SidebarTabStyle}" GroupName="SettingsTabs" Click="RepositoriesButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M4,6H20V8H4V6M4,11H20V13H4V11M4,16H20V18H4V16Z"
                                  Width="18" Height="18" Stretch="Uniform"
                                  Fill="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"
                                  Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="Repositories" FontWeight="Bold" FontSize="13"/>
                                <TextBlock Text="Extension repos" FontSize="11" Foreground="{DynamicResource MutedTextBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="DiscoverButton" Style="{StaticResource SidebarTabStyle}" GroupName="SettingsTabs" Click="DiscoverButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M12 8c-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4-1.79-4-4-4zm8.94 3c-.46-4.17-3.77-7.48-7.94-7.94V1h-2v2.06C6.83 3.52 3.52 6.83 3.06 11H1v2h2.06c.46 4.17 3.77 7.48 7.94 7.94V23h2v-2.06c4.17-.46 7.48-3.77 7.94-7.94H23v-2h-2.06zM12 19c-3.87 0-7-3.13-7-7s3.13-7 7-7 7 3.13 7 7-3.13 7-7 7z"
                                  Width="18" Height="18" Stretch="Uniform"
                                  Fill="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"
                                  Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="Discover" FontWeight="Bold" FontSize="13"/>
                                <TextBlock Text="Home screen sources" FontSize="11" Foreground="{DynamicResource MutedTextBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="ExtensionsButton" Style="{StaticResource SidebarTabStyle}" GroupName="SettingsTabs" Click="ExtensionsButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M20.5 11H19V7c0-1.1-.9-2-2-2h-4V3.5C13 2.12 11.88 1 10.5 1S8 2.12 8 3.5V5H4c-1.1 0-2 .9-2 2v3.8h1.5c1.49 0 2.7 1.21 2.7 2.7s-1.21 2.7-2.7 2.7H2V20c0 1.1.9 2 2 2h3.8v-1.5c0-1.49 1.21-2.7 2.7-2.7s2.7 1.21 2.7 2.7V22H17c1.1 0 2-.9 2-2v-4h1.5c1.38 0 2.5-1.12 2.5-2.5S21.88 11 20.5 11z"
                                  Width="18" Height="18" Stretch="Uniform"
                                  Fill="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"
                                  Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="Extensions" FontWeight="Bold" FontSize="13"/>
                                <TextBlock Text="Plugin management" FontSize="11" Foreground="{DynamicResource MutedTextBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="40,30,40,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" x:Name="SectionTitle" Text="Appearance Settings" FontSize="24" FontWeight="ExtraBold" Margin="0,0,0,25" Foreground="{DynamicResource ForegroundBrush}"/>

            <ContentControl x:Name="SettingsContent" 
                            Grid.Row="1"
                            VerticalAlignment="Stretch"
                            HorizontalAlignment="Stretch"/>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Cancel" Width="110" Margin="0,0,12,0" Style="{StaticResource ActionButtonStyle}" Click="Cancel_Click"/>
                <Button Content="Save" Width="110" Style="{StaticResource ActionButtonStyle}" Background="{DynamicResource AccentBrush}" Foreground="White" Click="Save_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
