<Window x:Class="Musicefy.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Musicefy.Views"
        Title="Settings"
        Height="600" Width="900"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}">

    <Window.Resources>
        <!-- Sidebar ToggleButton Style with gradient -->
        <Style x:Key="SidebarButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="5"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                            </Trigger>
                            <!-- Pressed -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentPressedBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                            </Trigger>
                            <!-- Active (Checked) -->
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#222222" Offset="0"/>
                                            <GradientStop Color="#333333" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Button Style (Save/Cancel) -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentPressedBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/> <!-- Sidebar -->
            <ColumnDefinition Width="*"/>   <!-- Content -->
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <StackPanel Grid.Column="0" Background="{DynamicResource BackgroundBrush}">
            <TextBlock Text="Settings" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Margin="20"
                       Foreground="{DynamicResource ForegroundBrush}"/>

            <!-- Appearance option -->
            <ToggleButton x:Name="AppearanceButton"
                          Style="{StaticResource SidebarButtonStyle}" 
                          Margin="0,0,0,10"
                          IsChecked="True"
                          Click="AppearanceButton_Click">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🎨" FontSize="16" Margin="0,0,8,0"/>
                    <StackPanel>
                        <TextBlock Text="Appearance" FontWeight="Bold"/>
                        <TextBlock Text="Theme, date &amp; time format" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </ToggleButton>

            <!-- Downloads option -->
            <ToggleButton x:Name="DownloadsButton"
                          Style="{StaticResource SidebarButtonStyle}" 
                          Margin="0,0,0,10"
                          Click="DownloadsButton_Click">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⬇️" FontSize="16" Margin="0,0,8,0"/>
                    <StackPanel>
                        <TextBlock Text="Downloads" FontWeight="Bold"/>
                        <TextBlock Text="Cache, path &amp; limits" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </ToggleButton>

            <!-- Sources option -->
            <ToggleButton x:Name="SourcesButton"
                          Style="{StaticResource SidebarButtonStyle}" 
                          Click="SourcesButton_Click">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔗" FontSize="16" Margin="0,0,8,0"/>
                    <StackPanel>
                        <TextBlock Text="Sources" FontWeight="Bold"/>
                        <TextBlock Text="Streaming connections" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </ToggleButton>
        </StackPanel>

        <!-- Main Content -->
        <Grid Grid.Column="1" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Grid.Row="0" x:Name="SectionTitle"
                       Text="Appearance Settings" 
                       FontSize="22" FontWeight="Bold" Margin="0,0,0,20"/>

            <!-- Dynamic Content Area -->
            <ContentControl Grid.Row="1" x:Name="SettingsContent">
                <views:AppearanceSettingsControl/>
            </ContentControl>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Cancel" Width="100" Margin="0,0,10,0" Style="{StaticResource PrimaryButtonStyle}" Click="Cancel_Click"/>
                <Button Content="Save" Width="100" Style="{StaticResource PrimaryButtonStyle}" Click="Save_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
