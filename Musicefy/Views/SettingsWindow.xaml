<Window x:Class="Musicefy.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Height="600" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Appearance Settings"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>

        <!-- Appearance content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Orientation="Vertical">

                <!-- Theme Tabs -->
                <TabControl SelectedIndex="{Binding SelectedThemeIndex}"
                            SelectionChanged="ThemeTabs_SelectionChanged"
                            Margin="0,0,0,15">
                    <TabItem Header="System"/>
                    <TabItem Header="Light"/>
                    <TabItem Header="Dark"/>
                </TabControl>

                <!-- Theme Previews -->
                <ItemsControl ItemsSource="{Binding ThemePreviews}" Margin="0,0,0,15">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Padding="0" Margin="5"
                                    Background="{Binding AccentBrush}"
                                    Click="PalettePreview_Click">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="White"/>
                                    <Rectangle Height="40" Fill="{Binding AccentBrush}" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Toggles -->
                <CheckBox Content="Pure black dark mode" IsChecked="{Binding PureBlackMode}" Margin="0,0,0,10"/>
                <CheckBox Content="Relative timestamps" IsChecked="{Binding RelativeTimestamps}" Margin="0,0,0,10"/>
                <CheckBox Content="Render images in manga descriptions" IsChecked="{Binding RenderImages}" Margin="0,0,0,10"/>
                <CheckBox Content="Show updates in the nav" IsChecked="{Binding ShowUpdates}" Margin="0,0,0,10"/>

                <!-- Date Format -->
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBlock Text="Date format:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox ItemsSource="{Binding DateFormats}" SelectedItem="{Binding SelectedDateFormat}" Width="200"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Cancel" Width="100" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button Content="Save" Width="100" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
