<Window x:Class="Musicefy.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Height="600" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sidebar -->
            <ColumnDefinition Width="200"/>
            <!-- Content -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <StackPanel Grid.Column="0" Background="{DynamicResource SecondaryBackgroundBrush}">
            <TextBlock Text="Settings" FontSize="20" FontWeight="Bold" Margin="12"/>
            
            <!-- Appearance section -->
            <Button x:Name="AppearanceButton" Content="🎨 Appearance"
                    HorizontalAlignment="Stretch" Margin="6"
                    Background="{DynamicResource AccentBrush}" Foreground="White"
                    Click="AppearanceButton_Click"/>

            <!-- Downloads section -->
            <Button x:Name="DownloadsButton" Content="⬇ Downloads"
                    HorizontalAlignment="Stretch" Margin="6"
                    Background="{DynamicResource SecondaryBackgroundBrush}"
                    Foreground="{DynamicResource ForegroundBrush}"
                    Click="DownloadsButton_Click"/>
        </StackPanel>

        <!-- Content area -->
        <Grid Grid.Column="1" Margin="20">
            <ContentControl x:Name="SettingsContent"/>
        </Grid>
    </Grid>
</Window>
