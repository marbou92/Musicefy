<ComboBox x:Name="ThemeCombo"
          Width="220"
          ItemsSource="{Binding AvailableThemes}"
          SelectedItem="{Binding SelectedTheme, Mode=TwoWay}"
          PreviewMouseMove="ThemeCombo_PreviewMouseMove">
    <ComboBox.ItemTemplate>
        <DataTemplate>
            <StackPanel Orientation="Horizontal" Margin="2">
                <!-- Thumbnail rectangle -->
                <Rectangle Width="20" Height="20" Margin="0,0,6,0">
                    <Rectangle.Fill>
                        <MultiBinding Converter="{StaticResource ThemeThumbnailConverter}">
                            <Binding/>
                        </MultiBinding>
                    </Rectangle.Fill>
                </Rectangle>
                <!-- Theme name -->
                <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
            </StackPanel>
        </DataTemplate>
    </ComboBox.ItemTemplate>
</ComboBox>
