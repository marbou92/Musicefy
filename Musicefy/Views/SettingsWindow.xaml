<Window x:Class="Musicefy.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Musicefy.Converters"
        Title="Settings" Height="400" Width="600"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}">

    <Window.Resources>
        <!-- Register converters -->
        <conv:ThemeThumbnailConverter x:Key="ThemeThumbnailConverter"/>
        <conv:ThemePreviewConverter x:Key="ThemePreviewConverter"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="1">
            <!-- Themes Tab -->
            <TabItem Header="Themes">
                <StackPanel Margin="10">
                    <TextBlock Text="Choose a theme:" FontWeight="Bold" Margin="0,0,0,5"/>
                    
                    <!-- ComboBox with gradient preview -->
                    <ComboBox x:Name="ThemeCombo"
                              Width="220"
                              ItemsSource="{Binding AvailableThemes}"
                              SelectedItem="{Binding SelectedTheme, Mode=TwoWay}"
                              PreviewMouseMove="ThemeCombo_PreviewMouseMove">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <!-- Thumbnail rectangle with animated gradient -->
                                    <Rectangle Width="20" Height="20" Margin="0,0,6,0">
                                        <Rectangle.Fill>
                                            <Binding Converter="{StaticResource ThemePreviewConverter}"/>
                                        </Rectangle.Fill>
                                        <Rectangle.Triggers>
                                            <!-- Animate gradient offset on hover -->
                                            <EventTrigger RoutedEvent="MouseEnter">
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                        <PointAnimation Storyboard.TargetProperty="(Rectangle.Fill).(LinearGradientBrush.StartPoint)"
                                                                        To="1,0" Duration="0:0:1.2"/>
                                                        <PointAnimation Storyboard.TargetProperty="(Rectangle.Fill).(LinearGradientBrush.EndPoint)"
                                                                        To="0,1" Duration="0:0:1.2"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                            <EventTrigger RoutedEvent="MouseLeave">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <PointAnimation Storyboard.TargetProperty="(Rectangle.Fill).(LinearGradientBrush.StartPoint)"
                                                                        To="0,0" Duration="0:0:0.5"/>
                                                        <PointAnimation Storyboard.TargetProperty="(Rectangle.Fill).(LinearGradientBrush.EndPoint)"
                                                                        To="1,1" Duration="0:0:0.5"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Rectangle.Triggers>
                                    </Rectangle>
                                    <!-- Theme name -->
                                    <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="Hover to preview, Save to apply permanently." 
                               FontSize="12" Foreground="Gray" Margin="0,6,0,0"/>
                </StackPanel>
            </TabItem>

            <!-- Streaming Tab -->
            <TabItem Header="Streaming">
                <StackPanel Margin="10">
                    <TextBlock Text="Server URL" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="ServerUrlBox" Width="300"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancel" Width="100" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button Content="Save" Width="100" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
