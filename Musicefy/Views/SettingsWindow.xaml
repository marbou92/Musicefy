<Window x:Class="Musicefy.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Height="600" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="#0E0E0E"
        Foreground="White">

    <Window.Resources>
        <Style x:Key="SidebarTabStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A0A0A0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="TabBorder" Background="{TemplateBinding Background}" CornerRadius="8" Margin="8,2" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#1A1A1A"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#222222"/>
                                <Setter Property="Foreground" Value="#1DB954"/> </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#181818"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" CornerRadius="18" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Value="Background" Value="#252525"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/> <ColumnDefinition Width="*"/>   </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="#050505">
            <StackPanel Margin="10,20,10,10">
                <TextBlock Text="Settings" FontSize="22" FontWeight="ExtraBold" Margin="15,0,0,25" Foreground="White"/>

                <RadioButton x:Name="AppearanceButton"
                             Style="{StaticResource SidebarTabStyle}" 
                             GroupName="SettingsTabs"
                             IsChecked="True"
                             Click="AppearanceButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🎨" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <StackPanel>
                            <TextBlock Text="Appearance" FontWeight="Bold" FontSize="13"/>
                            <TextBlock Text="Theme &amp; palettes" FontSize="11" Foreground="Gray"/>
                        </StackPanel>
                    </StackPanel>
                </RadioButton>

                <RadioButton x:Name="DownloadsButton"
                             Style="{StaticResource SidebarTabStyle}" 
                             GroupName="SettingsTabs"
                             Click="DownloadsButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⬇️" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <StackPanel>
                            <TextBlock Text="Downloads" FontWeight="Bold" FontSize="13"/>
                            <TextBlock Text="Cache &amp; limits" FontSize="11" Foreground="Gray"/>
                        </StackPanel>
                    </StackPanel>
                </RadioButton>

                <RadioButton x:Name="SourcesButton"
                             Style="{StaticResource SidebarTabStyle}" 
                             GroupName="SettingsTabs"
                             Click="SourcesButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔗" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <StackPanel>
                            <TextBlock Text="Sources" FontWeight="Bold" FontSize="13"/>
                            <TextBlock Text="Streaming connections" FontSize="11" Foreground="Gray"/>
                        </StackPanel>
                    </StackPanel>
                </RadioButton>
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1" Margin="40,30,40,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" x:Name="SectionTitle"
                       Text="Appearance Settings" 
                       FontSize="24" FontWeight="ExtraBold" Margin="0,0,0,25"/>

            <ContentControl x:Name="SettingsContent" Grid.Row="1"/>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Cancel" Width="110" Margin="0,0,12,0" Style="{StaticResource ActionButtonStyle}" Click="Cancel_Click"/>
                <Button Content="Save" Width="110" Style="{StaticResource ActionButtonStyle}" Background="#1DB954" Click="Save_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
