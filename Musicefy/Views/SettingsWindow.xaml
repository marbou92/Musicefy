<Window x:Class="Musicefy.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Musicefy.Converters"
        Title="Settings"
        Height="500" Width="700"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}">

    <Window.Resources>
        <!-- Register converters -->
        <conv:ThemeThumbnailConverter x:Key="ThemeThumbnailConverter"/>
        <conv:ThemePreviewConverter x:Key="ThemePreviewConverter"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Application Settings"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>

        <!-- Tabs -->
        <TabControl Grid.Row="1" Margin="0,0,0,10">
            <!-- Themes Tab -->
            <TabItem Header="Appearance">
                <StackPanel Margin="15" Orientation="Vertical" Spacing="12">
                    <TextBlock Text="Choose a theme:" FontWeight="Bold"/>

                    <!-- ComboBox with gradient preview -->
                    <ComboBox x:Name="ThemeCombo"
                              Width="250"
                              ItemsSource="{Binding AvailableThemes}"
                              SelectedItem="{Binding SelectedTheme, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <!-- Thumbnail rectangle with animated gradient -->
                                    <Rectangle Width="24" Height="24" Margin="0,0,8,0">
                                        <Rectangle.Fill>
                                            <Binding Converter="{StaticResource ThemePreviewConverter}"/>
                                        </Rectangle.Fill>
                                        <Rectangle.Triggers>
                                            <!-- Animate gradient offset on hover -->
                                            <EventTrigger RoutedEvent="MouseEnter">
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                        <PointAnimation Storyboard.TargetProperty="(Rectangle.Fill).(LinearGradientBrush.StartPoint)"
                                                                        To="1,0" Duration="0:0:1.2"/>
                                                        <PointAnimation Storyboard.TargetProperty="(Rectangle.Fill).(LinearGradientBrush.EndPoint)"
                                                                        To="0,1" Duration="0:0:1.2"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                            <EventTrigger RoutedEvent="MouseLeave">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <PointAnimation Storyboard.TargetProperty="(Rectangle.Fill).(LinearGradientBrush.StartPoint)"
                                                                        To="0,0" Duration="0:0:0.5"/>
                                                        <PointAnimation Storyboard.TargetProperty="(Rectangle.Fill).(LinearGradientBrush.EndPoint)"
                                                                        To="1,1" Duration="0:0:0.5"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Rectangle.Triggers>
                                    </Rectangle>
                                    <!-- Theme name -->
                                    <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Info -->
                    <TextBlock Text="Hover to preview, Save to apply permanently."
                               FontSize="12" Foreground="Gray"/>
                </StackPanel>
            </TabItem>

            <!-- Streaming Tab -->
            <TabItem Header="Streaming">
                <StackPanel Margin="15" Orientation="Vertical" Spacing="10">
                    <TextBlock Text="Server URL" FontWeight="Bold"/>
                    <TextBox x:Name="ServerUrlBox" Width="350"/>
                </StackPanel>
            </TabItem>

            <!-- Other Settings Tab -->
            <TabItem Header="General">
                <StackPanel Margin="15" Orientation="Vertical" Spacing="10">
                    <CheckBox Content="Enable notifications"/>
                    <CheckBox Content="Start minimized"/>
                    <CheckBox Content="Check for updates automatically"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Cancel" Width="100" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button Content="Save" Width="100" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
