<UserControl x:Class="Musicefy.Views.ExtensionsSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource OnSurfaceBrush}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource OnSurfaceBrush}"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="ItemIconCircle" TargetType="Border">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="Button" BasedOn="{StaticResource TonalButtonStyle}">
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10,0,10,10">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Vertical">

                <!-- Header -->
                <Grid Margin="4,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Extensions" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource OnSurfaceBrush}"/>
                        <TextBlock Text="Manage source extensions and community repositories." Foreground="{DynamicResource OnSurfaceVariantBrush}" FontSize="12" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Command="{Binding RefreshCommand}" VerticalAlignment="Center" Width="100" Margin="0,0,0,4">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Data="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"
                                  Width="14" Height="14" Stretch="Uniform" Fill="White" Margin="0,0,6,0"/>
                            <TextBlock Text="Refresh"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Pre-installed (built-in) providers -->
                <Border Background="{DynamicResource SurfaceVariantBrush}" CornerRadius="12" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Pre-installed" FontWeight="Bold" FontSize="13" Margin="0,0,0,12" Foreground="{DynamicResource OnSurfaceBrush}"/>

                        <ItemsControl ItemsSource="{Binding BuiltInProviders}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource SurfaceContainerHighBrush}" CornerRadius="10" Padding="12" Margin="0,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20"
                                                    Background="{DynamicResource PrimaryBrush}" Margin="0,0,12,0">
                                                <Path Data="{Binding SourceType, Converter={StaticResource IconGlyphConverter}}"
                                                      Width="20" Height="20" Stretch="Uniform"
                                                      Fill="White"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource OnSurfaceBrush}"/>
                                                <TextBlock Text="{Binding Description}" FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>

                                            <Border Grid.Column="2" Background="#27ae60" CornerRadius="6" Padding="10,4" VerticalAlignment="Center">
                                                <TextBlock Text="Installed" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Available Extensions (built-in) -->
                <Border Background="{DynamicResource SurfaceVariantBrush}" CornerRadius="12" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Available Extensions" FontWeight="Bold" FontSize="13" Margin="0,0,0,12" Foreground="{DynamicResource OnSurfaceBrush}"/>

                        <ItemsControl ItemsSource="{Binding AvailableExtensions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource SurfaceContainerHighBrush}" CornerRadius="10" Padding="12" Margin="0,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20"
                                                    Background="{DynamicResource PrimaryBrush}" Margin="0,0,12,0">
                                                <Path Data="{Binding SourceType, Converter={StaticResource IconGlyphConverter}}"
                                                      Width="20" Height="20" Stretch="Uniform"
                                                      Fill="White"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource OnSurfaceBrush}"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,1,0,1">
                                                    <TextBlock Text="{Binding Author, StringFormat='by {0}'}" FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,0,10,0" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Version, StringFormat='v{0}'}" FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Description}" FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>

                                            <Button Grid.Column="2" Content="Install"
                                                    Command="{Binding DataContext.InstallCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" Margin="8,0,0,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Installed Extensions -->
                <Border Background="{DynamicResource SurfaceVariantBrush}" CornerRadius="12" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Installed Extensions" FontWeight="Bold" FontSize="13" Margin="0,0,0,12" Foreground="{DynamicResource OnSurfaceBrush}"/>

                        <ItemsControl ItemsSource="{Binding InstalledExtensions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource SurfaceContainerHighBrush}" CornerRadius="10" Padding="12" Margin="0,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20"
                                                    Background="{DynamicResource PrimaryBrush}" Margin="0,0,12,0">
                                                <Path Data="{Binding SourceType, Converter={StaticResource IconGlyphConverter}}"
                                                      Width="20" Height="20" Stretch="Uniform"
                                                      Fill="White"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource OnSurfaceBrush}"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,1,0,1">
                                                    <TextBlock Text="{Binding Author, StringFormat='by {0}'}" FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,0,10,0" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Version, StringFormat='v{0}'}" FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Description}" FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>

                                            <Button Grid.Column="2" Content="Uninstall"
                                                    Command="{Binding DataContext.UninstallCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" Foreground="#e74c3c"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
