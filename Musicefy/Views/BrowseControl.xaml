<UserControl x:Class="Musicefy.Views.BrowseControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="20,16,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Browse" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource OnSurfaceBrush}"/>
                <TextBlock Text="Moods, genres, charts, and new releases from YouTube Music"
                           FontSize="12" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,4,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Content="🔄 Refresh" Padding="12,6"
                    Command="{Binding RefreshCommand}" Cursor="Hand" VerticalAlignment="Center"/>
        </Grid>

        <!-- Loading -->
        <TextBlock Grid.Row="1" Text="Loading…"
                   FontSize="12" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                   HorizontalAlignment="Center" Margin="0,40,0,0"/>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,0">
            <StackPanel>

                <!-- Mood & Genres -->
                <TextBlock Text="Moods &amp; Genres" FontSize="16" FontWeight="Bold"
                           Foreground="{DynamicResource OnSurfaceBrush}" Margin="0,0,0,10"/>
                <ItemsControl ItemsSource="{Binding MoodGenres}" Margin="0,0,0,20">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource SurfaceVariantBrush}" CornerRadius="20"
                                    Padding="16,10" Margin="0,0,8,8" Cursor="Hand">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Icon}" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource OnSurfaceBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Trending -->
                <TextBlock Text="Trending Songs" FontSize="16" FontWeight="Bold"
                           Foreground="{DynamicResource OnSurfaceBrush}" Margin="0,0,0,10"/>
                <ItemsControl ItemsSource="{Binding Trending}" Margin="0,0,0,20">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource SurfaceVariantBrush}" CornerRadius="8"
                                    Padding="10,8" Margin="0,3" Cursor="Hand">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="🎵" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource OnSurfaceBrush}" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Artist}" FontSize="10"
                                                   Foreground="{DynamicResource OnSurfaceVariantBrush}" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- New Releases -->
                <TextBlock Text="New Releases" FontSize="16" FontWeight="Bold"
                           Foreground="{DynamicResource OnSurfaceBrush}" Margin="0,0,0,10"/>
                <ItemsControl ItemsSource="{Binding NewReleases}" Margin="0,0,0,20">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource SurfaceVariantBrush}" CornerRadius="8"
                                    Padding="10,8" Margin="0,3" Cursor="Hand">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="💿" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Album}" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource OnSurfaceBrush}" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Artist}" FontSize="10"
                                                   Foreground="{DynamicResource OnSurfaceVariantBrush}" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
