<UserControl x:Class="Musicefy.Views.SourceCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Musicefy.ViewModels">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Border BorderBrush="{DynamicResource OutlineBrush}" BorderThickness="1" CornerRadius="12"
            Background="{DynamicResource SurfaceVariantBrush}" Margin="0,0,0,8" Padding="16">
        <StackPanel>
            <!-- Header Row -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Icon and Name -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Health Status Indicator -->
                    <Ellipse Width="10" Height="10" Margin="0,0,8,0"
                             Fill="{Binding HealthStatusColor}"/>

                    <!-- Source Type Icon (vector path via converter) -->
                    <Path Data="{Binding Type, Converter={StaticResource IconGlyphConverter}}"
                          Width="20" Height="20" Stretch="Uniform"
                          Fill="{DynamicResource OnSurfaceBrush}"
                          Margin="0,0,8,0" VerticalAlignment="Center"/>

                    <!-- Source Name -->
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource OnSurfaceBrush}"/>
                        <TextBlock Text="{Binding DisplayName}" FontSize="11"
                                   Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Status -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding HealthStatusText}" FontSize="12"
                               Foreground="{Binding HealthStatusColor}"/>
                </StackPanel>

                <!-- Action Buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Test" Padding="8,4" Margin="4,0"
                            FontSize="11" Cursor="Hand"
                            Click="TestButton_Click"/>
                    <Button Content="&#x25BC;" Padding="6,4" Margin="4,0"
                            FontSize="10" Cursor="Hand"
                            Click="ExpandButton_Click"
                            x:Name="ExpandButton"/>
                    <Button Content="&#x2715;" Padding="6,4" Margin="4,0"
                            FontSize="11" Cursor="Hand" Foreground="{DynamicResource ErrorBrush}"
                            Click="RemoveButton_Click"/>
                </StackPanel>
            </Grid>

            <!-- Error Message -->
            <TextBlock Text="{Binding ErrorMessage}" FontSize="11" Foreground="{DynamicResource ErrorBrush}"
                       TextWrapping="Wrap" Margin="0,0,0,4"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVis}}"/>

            <!-- Last Health Check -->
            <TextBlock FontSize="10" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,0,0,4">
                <Run Text="Last check: "/>
                <Run Text="{Binding LastHealthCheckText, Mode=OneWay}"/>
            </TextBlock>

            <!-- Expanded Configuration Details -->
            <StackPanel Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}"
                        Margin="0,8,0,0">
                <Border BorderBrush="{DynamicResource OutlineVariantBrush}" BorderThickness="0,1,0,0" Padding="0,8,0,0">
                    <StackPanel>
                        <TextBlock Text="Configuration" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,0,0,6"/>
                        <ItemsControl x:Name="ConfigItems">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Key}" FontSize="11"
                                                   Foreground="{DynamicResource OnSurfaceVariantBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Value}" FontSize="11"
                                                   Foreground="{DynamicResource OnSurfaceBrush}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Connection Info -->
                        <StackPanel Margin="0,8,0,0">
                            <TextBlock Text="Connection" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,0,0,4"/>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Source ID" FontSize="11"
                                           Foreground="{DynamicResource OnSurfaceVariantBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding Id}" FontSize="11"
                                           Foreground="{DynamicResource OnSurfaceBrush}" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Type" FontSize="11"
                                           Foreground="{DynamicResource OnSurfaceVariantBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding Type}" FontSize="11"
                                           Foreground="{DynamicResource OnSurfaceBrush}" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Connecting Overlay -->
            <StackPanel Visibility="{Binding IsConnecting, Converter={StaticResource BoolToVis}}"
                        Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4">
                <TextBlock Text="Testing connection..." FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
