<Window x:Class="Musicefy.SplashScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" ResizeMode="NoResize"
        Width="400" Height="400"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False" AllowsTransparency="True"
        Opacity="0"
        Background="Transparent">

    <Border CornerRadius="24" Background="#121212">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="40" ShadowDepth="0" Opacity="0.6"/>
        </Border.Effect>

        <Grid>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Image Source="Assets/musicefy.png" Height="100" Width="100" 
                       Margin="0,0,0,25" RenderOptions.BitmapScalingMode="HighQuality">
                    <Image.Effect>
                        <DropShadowEffect Color="#1DB954" BlurRadius="15" ShadowDepth="0" Opacity="0.3"/>
                    </Image.Effect>
                </Image>

                <TextBlock Text="Musicefy" FontSize="32" FontWeight="Bold" 
                           Foreground="White" HorizontalAlignment="Center"
                           FontFamily="Segoe UI Semibold"/>

                <Grid Width="40" Height="40" Margin="0,40,0,0">
                    <Ellipse x:Name="LoaderRing" Stroke="#1DB954" StrokeThickness="3" 
                             StrokeDashArray="3 1" RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <RotateTransform x:Name="LoaderRotate"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>
                </Grid>
                
                <TextBlock Text="PREPARING LIBRARY" FontSize="10" FontWeight="SemiBold" 
                           Foreground="#B3B3B3" Margin="0,20,0,0"
                           HorizontalAlignment="Center">
                    <TextBlock.RenderTransform>
                        <ScaleTransform ScaleX="1.1"/>
                    </TextBlock.RenderTransform>
                </TextBlock>
            </StackPanel>

            <ProgressBar x:Name="BottomProgress" Height="4" VerticalAlignment="Bottom"
                         Background="Transparent" BorderThickness="0" Foreground="#1DB954"
                         Value="0" Maximum="100" Margin="40,0,40,40"/>
        </Grid>
    </Border>
</Window>
