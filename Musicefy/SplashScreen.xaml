<Window x:Class="Musicefy.SplashScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}"
        Width="400" Height="300"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False" AllowsTransparency="True">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <Image Source="Assets/musicefy.png" Height="96" Width="96" Margin="0,0,0,20"/>
            <TextBlock Text="Musicefy" FontSize="28" FontWeight="Bold"
                       Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center"/>
            <TextBlock Text="Loading your music..." FontSize="14" Foreground="Gray" Margin="0,12,0,0"/>
        </StackPanel>
    </Grid>
</Window>
