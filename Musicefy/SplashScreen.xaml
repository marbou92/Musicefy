<Window x:Class="Musicefy.SplashScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" ResizeMode="NoResize"
        Width="420" Height="420"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False" AllowsTransparency="True"
        Opacity="0"
        Background="Transparent">

    <Border x:Name="MainRootBorder" CornerRadius="28" Background="{DynamicResource SurfaceBrush}" RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="RootScale" ScaleX="0.95" ScaleY="0.95"/>
            </TransformGroup>
        </Border.RenderTransform>
        
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="50" ShadowDepth="0" Opacity="0.6"/>
        </Border.Effect>

        <Grid>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                
                <Grid Width="110" Height="110" Margin="0,0,0,20" RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <ScaleTransform x:Name="LogoScale" ScaleX="1.0" ScaleY="1.0"/>
                    </Grid.RenderTransform>
                    
                    <Image Source="Assets/musicefy.png" RenderOptions.BitmapScalingMode="HighQuality">
                        <Image.Effect>
                            <DropShadowEffect x:Name="LogoGlow" Color="#1DB954" BlurRadius="25" ShadowDepth="0" Opacity="0.25"/>
                        </Image.Effect>
                    </Image>
                </Grid>

                <TextBlock x:Name="TxtBrandTitle" Text="Musicefy" FontSize="36" FontWeight="Bold" 
                           Foreground="{DynamicResource OnSurfaceBrush}" HorizontalAlignment="Center"
                           FontFamily="Segoe UI">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="8" Opacity="0.3" ShadowDepth="2" Color="Black"/>
                    </TextBlock.Effect>
                </TextBlock>

                <TextBlock x:Name="TxtSubMarker" Text="INITIALIZING AUDIO ENGINE" FontSize="10" FontWeight="Bold" 
                           Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,16,0,0" HorizontalAlignment="Center"
                           RenderTransformOrigin="0.5,0.5">
                    <TextBlock.RenderTransform>
                        <ScaleTransform ScaleX="1.05"/>
                    </TextBlock.RenderTransform>
                </TextBlock>
            </StackPanel>

            <Grid VerticalAlignment="Bottom" Margin="48,0,48,44">
                <Border x:Name="ProgressBarTrack" Height="3" Background="{DynamicResource OutlineBrush}" CornerRadius="1.5"/>
                
                <ProgressBar x:Name="BottomProgress" Height="3" 
                             Background="Transparent" BorderThickness="0" Foreground="{DynamicResource PrimaryBrush}"
                             Value="0" Maximum="100"/>
            </Grid>
        </Grid>
    </Border>
</Window>
