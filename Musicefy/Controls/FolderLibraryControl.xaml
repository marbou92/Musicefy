<UserControl x:Class="Musicefy.Controls.FolderLibraryControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Musicefy.Converters"
             Background="Transparent">

    <UserControl.Resources>
        <converters:PathToImageConverter x:Key="PathToImageConverter"/>

        <Style x:Key="EchoActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="19" Padding="{TemplateBinding Padding}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="ButtonScale" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource BorderBrush}"/>
                                <Setter TargetName="Bg" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleX" To="1.03" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleY" To="1.03" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LayoutPillToggleStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="19">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource BorderBrush}"/>
                                <Setter TargetName="Bg" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Button x:Name="BtnFolderBack" Content="←" FontSize="16" FontWeight="Bold" Margin="0,0,12,0" Width="38" Height="38" Style="{StaticResource LayoutPillToggleStyle}" Visibility="Collapsed" Click="BtnFolderBack_Click"/>
                
                <Button x:Name="BtnAddFolder" Style="{StaticResource EchoActionButtonStyle}" Margin="0,0,10,0" Click="BtnAddFolder_Click">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" Fill="{DynamicResource TextBrush}" Width="12" Height="12" Stretch="Uniform" Margin="0,1,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Add Folder Library" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnRefresh" Style="{StaticResource EchoActionButtonStyle}" Margin="0,0,10,0" Click="BtnRefresh_Click">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z" 
                              Fill="{DynamicResource TextBrush}" Width="12" Height="12" Stretch="Uniform" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Refresh" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnClearFolder" Style="{StaticResource EchoActionButtonStyle}" Visibility="Collapsed" Click="BtnClearFolder_Click">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" 
                              Fill="#FF5F5F" Width="12" Height="12" Stretch="Uniform" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Clear Library Link" FontSize="12" FontWeight="Bold" Foreground="#FF5F5F" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <Button x:Name="BtnViewToggle" HorizontalAlignment="Right" Style="{StaticResource LayoutPillToggleStyle}" Click="BtnViewToggle_Click">
                <Path x:Name="ToggleIconPath" Data="M3,5H21V7H3V5M3,11H21V13H3V11M3,17H21V19H3V17Z" 
                      Fill="{DynamicResource TextBrush}" Width="14" Height="14" Stretch="Uniform"/>
            </Button>
        </Grid>

        <Grid Grid.Row="1">
            
            <Grid x:Name="EmptyLibraryStateContainer" Visibility="Visible" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,40">
                <StackPanel HorizontalAlignment="Center">
                    <Border Width="72" Height="72" CornerRadius="36" Background="{DynamicResource SecondaryBackgroundBrush}" HorizontalAlignment="Center" Margin="0,0,0,16">
                        <Path Data="M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z" 
                              Fill="{DynamicResource MutedTextBrush}" Width="26" Height="26" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="No Folder Tracks Indexed Yet" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Tap 'Add Folder Library' above to index your system audio collections seamlessly." FontSize="13" Foreground="{DynamicResource MutedTextBrush}" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <Grid x:Name="ListViewContainer" Visibility="Collapsed" RenderTransformOrigin="0.5, 0.5">
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="ListTranslate" Y="0"/>
                </Grid.RenderTransform>
                <ListView x:Name="FolderSongsListView" 
                          Background="Transparent" BorderThickness="0" 
                          Foreground="{DynamicResource TextBrush}"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          MouseDoubleClick="OnSongDoubleClicked"
                          Padding="0,4">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Margin" Value="0,4"/>
                            <Setter Property="Padding" Value="16,10"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border x:Name="RowBorder" CornerRadius="10" 
                                                Background="{TemplateBinding Background}" 
                                                BorderBrush="Transparent" BorderThickness="1"
                                                Padding="{TemplateBinding Padding}"
                                                SnapsToDevicePixels="True">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="RowBorder" Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
                                                <Setter TargetName="RowBorder" Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="RowBorder" Property="Background" Value="{DynamicResource BorderBrush}"/>
                                                <Setter TargetName="RowBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.View>
                        <GridView>
                            <GridView.ColumnHeaderContainerStyle>
                                <Style TargetType="GridViewColumnHeader">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                    <Setter Property="Padding" Value="16,8"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </GridView.ColumnHeaderContainerStyle>
                            
                            <GridViewColumn Header="TRACK TITLE" Width="420">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <Path Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M10,17L5,12L6.41,10.59L10,14.17L17.59,6.58L19,8L10,17Z" 
                                                  Fill="{DynamicResource AccentBrush}" Width="12" Height="12" Stretch="Uniform" Margin="2,0,12,0" VerticalAlignment="Center" Opacity="0.85"/>
                                            
                                            <Border Grid.Column="1" Background="{DynamicResource SecondaryBackgroundBrush}" Width="32" Height="32" CornerRadius="6" ClipToBounds="True" Margin="0,0,14,0" SnapsToDevicePixels="True" VerticalAlignment="Center">
                                                <Grid>
                                                    <Path x:Name="RowFolderIcon" Data="M2,6A2,2 0 0,1 4,4H10L12,6H20A2,2 0 0,1 22,8V18A2,2 0 0,1 20,20H4A2,2 0 0,1 2,18V6Z" Fill="{DynamicResource AccentBrush}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                                                    <Path x:Name="RowMusicIcon" Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,9A3,3 0 0,1 15,12A3,3 0 0,1 12,15A3,3 0 0,1 9,12A3,3 0 0,1 12,9Z" Fill="{DynamicResource BorderBrush}" Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Visible"/>
                                                    <Image x:Name="RowCoverImage" Source="{Binding CoverPath, Converter={StaticResource PathToImageConverter}}" Stretch="UniformToFill"/>
                                                </Grid>
                                            </Border>
                                            
                                            <TextBlock Grid.Column="2" Text="{Binding Title, TargetNullValue=''}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                        </Grid>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding SourceType}" Value="FolderItem">
                                                <Setter TargetName="RowMusicIcon" Property="Visibility" Value="Collapsed"/>
                                                <Setter TargetName="RowFolderIcon" Property="Visibility" Value="Visible"/>
                                                <Setter TargetName="RowCoverImage" Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            
                            <GridViewColumn Header="ARTIST" Width="220">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock SourceUpdated="True" Text="{Binding Artist, TargetNullValue='Unknown Artist'}" FontSize="13" Foreground="{DynamicResource MutedTextBrush}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Header="LENGTH" Width="90">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Duration, StringFormat=\{0:mm\\:ss\}}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource MutedTextBrush}" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>

            <Grid x:Name="GridViewContainer" Visibility="Visible" RenderTransformOrigin="0.5, 0.5">
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="GridTranslate" Y="0"/>
                </Grid.RenderTransform>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="FolderSongsItemsControl">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" Margin="0,0,-16,0"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Background="Transparent" BorderThickness="0" Margin="0,0,16,22" Cursor="Hand" Click="GridCardItem_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <StackPanel Width="144">
                                                <Border Background="{DynamicResource SecondaryBackgroundBrush}" Height="144" CornerRadius="14" ClipToBounds="True" Margin="0,0,0,12" SnapsToDevicePixels="True">
                                                    <Grid>
                                                        <Grid x:Name="FolderUIContainer" Visibility="Collapsed">
                                                            <Border Background="{DynamicResource BorderBrush}" Opacity="0.1"/>
                                                            <Path Data="M2,6A2,2 0 0,1 4,4H10L12,6H20A2,2 0 0,1 22,8V18A2,2 0 0,1 20,20H4A2,2 0 0,1 2,18V6Z" 
                                                                  Fill="{DynamicResource AccentBrush}" Width="78" Height="78" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.3"/>
                                                            <Path Data="M6,10H8V14H6V10M10,6H12V18H10V6M14,9H16V15H14V9M18,11H20V13H18V11Z" 
                                                                  Fill="{DynamicResource TextBrush}" Width="24" Height="24" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.8"/>
                                                        </Grid>

                                                        <Grid x:Name="AudioFallbackUIContainer" Visibility="Visible">
                                                            <Border Background="{DynamicResource BorderBrush}" Opacity="0.05"/>
                                                            <Path Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,9A3,3 0 0,1 15,12A3,3 0 0,1 12,15A3,3 0 0,1 9,12A3,3 0 0,1 12,9Z" 
                                                                  Fill="{DynamicResource BorderBrush}" Width="36" Height="36" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            <Image Source="{Binding CoverPath, Converter={StaticResource PathToImageConverter}}" Stretch="UniformToFill"/>
                                                        </Grid>
                                                    </Grid>
                                                </Border>
                                                
                                                <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" TextTrimming="CharacterEllipsis" Margin="2,0,0,2"/>
                                                <TextBlock Text="{Binding Artist}" FontSize="11" Foreground="{DynamicResource MutedTextBrush}" TextTrimming="CharacterEllipsis" Margin="2,0,0,0"/>
                                            </StackPanel>
                                            
                                            <ControlTemplate.Triggers>
                                                <DataTrigger Binding="{Binding SourceType}" Value="FolderItem">
                                                    <Setter TargetName="AudioFallbackUIContainer" Property="Visibility" Value="Collapsed"/>
                                                    <Setter TargetName="FolderUIContainer" Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>

        <Grid Grid.Row="0" Grid.RowSpan="2" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Border x:Name="ToastNotificationCard" 
                    Background="#1E1E1E" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Height="44" Padding="18,0" CornerRadius="22" Visibility="Collapsed" IsHitTestVisible="False">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="ToastTranslation" Y="-60"/>
                </Border.RenderTransform>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="25" ShadowDepth="4" Opacity="0.4" Color="Black"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="{DynamicResource AccentBrush}" Margin="0,0,12,0"/>
                    <TextBlock x:Name="TxtToastMessage" Text="Mapping files structure..." FontSize="13" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
