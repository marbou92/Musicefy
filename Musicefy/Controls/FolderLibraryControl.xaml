<UserControl x:Class="Musicefy.Controls.FolderLibraryControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Musicefy.Converters"
             Background="Transparent"
             VerticalAlignment="Stretch"
             HorizontalAlignment="Stretch">

    <UserControl.Resources>
        <converters:PathToImageConverter x:Key="PathToImageConverter"/>

        <Style x:Key="EchoActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="24,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="20" Padding="{TemplateBinding Padding}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="ButtonScale" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Value="{DynamicResource BorderBrush}" Property="Background"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleX" To="1.04" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleY" To="1.04" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.8"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleX" To="0.96" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleY" To="0.96" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LayoutPillToggleStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                CornerRadius="20" RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="ButtonScale" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Value="{DynamicResource BorderBrush}" Property="Background"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleX" To="0.92" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleY" To="0.92" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Toolbar ───────────────────────────────────────────────────── -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">

                <Button x:Name="BtnFolderBack" Margin="0,0,16,0" Width="40" Height="40"
                        Visibility="Collapsed" Click="BtnFolderBack_Click"
                        Style="{StaticResource LayoutPillToggleStyle}">
                    <Path Data="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z"
                          Fill="{DynamicResource TextBrush}" Width="18" Height="18"
                          Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.9"/>
                </Button>

                <Button x:Name="BtnAddFolder" Style="{StaticResource EchoActionButtonStyle}"
                        Margin="0,0,12,0" Click="BtnAddFolder_Click">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z"
                              Fill="{DynamicResource TextBrush}" Width="14" Height="14"
                              Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Add Folder" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnRefresh" Style="{StaticResource EchoActionButtonStyle}"
                        Margin="0,0,12,0" Click="BtnRefresh_Click">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z"
                              Fill="{DynamicResource TextBrush}" Width="14" Height="14"
                              Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Refresh" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnClearFolder" Style="{StaticResource EchoActionButtonStyle}"
                        Visibility="Collapsed" Click="BtnClearFolder_Click">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"
                              Fill="#FF6B6B" Width="14" Height="14"
                              Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Clear Link" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#FF6B6B" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <Button x:Name="BtnViewToggle" HorizontalAlignment="Right"
                    Style="{StaticResource LayoutPillToggleStyle}" Click="BtnViewToggle_Click">
                <Path x:Name="ToggleIconPath"
                      Data="M3,5H21V7H3V5M3,11H21V13H3V11M3,17H21V19H3V17Z"
                      Fill="{DynamicResource TextBrush}" Width="16" Height="16" Stretch="Uniform"/>
            </Button>
        </Grid>

        <!-- ── Content area ──────────────────────────────────────────────── -->
        <Grid Grid.Row="1" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">

            <!-- Empty state -->
            <Grid x:Name="EmptyLibraryStateContainer" Visibility="Visible"
                  VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,40">
                <StackPanel HorizontalAlignment="Center">
                    <Border Width="96" Height="96" CornerRadius="48"
                            Background="{DynamicResource SecondaryBackgroundBrush}"
                            HorizontalAlignment="Center" Margin="0,0,0,20">
                        <Path Data="M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z"
                              Fill="{DynamicResource MutedTextBrush}" Width="32" Height="32"
                              Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5"/>
                    </Border>
                    <TextBlock Text="No Folders Indexed" FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Tap 'Add Folder' to bring your local files into the library."
                               FontSize="14" Foreground="{DynamicResource MutedTextBrush}"
                               Margin="0,8,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- List view -->
            <Grid x:Name="ListViewContainer" Visibility="Collapsed"
                  VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                  RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="ListTranslate" Y="0"/>
                </Grid.RenderTransform>
                <ListView x:Name="FolderSongsListView"
                          Background="Transparent" BorderThickness="0"
                          Foreground="{DynamicResource TextBrush}"
                          VerticalAlignment="Stretch"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.CanContentScroll="True"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          VirtualizingPanel.CacheLengthUnit="Page"
                          VirtualizingPanel.CacheLength="2,3"
                          MouseDoubleClick="OnSongDoubleClicked"
                          Padding="0,4">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Margin" Value="0,4"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border x:Name="RowBorder" CornerRadius="16"
                                                Background="{TemplateBinding Background}"
                                                Padding="16,12" SnapsToDevicePixels="True">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="RowBorder" Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="RowBorder" Property="Background" Value="{DynamicResource BorderBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="40">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                                            Width="40" Height="40" CornerRadius="12" ClipToBounds="True"
                                            Margin="0,0,16,0" SnapsToDevicePixels="True">
                                        <Grid>
                                            <Path x:Name="ListFolderIcon"
                                                  Data="M2,6A2,2 0 0,1 4,4H10L12,6H20A2,2 0 0,1 22,8V18A2,2 0 0,1 20,20H4A2,2 0 0,1 2,18V6Z"
                                                  Fill="{DynamicResource AccentBrush}" Width="20" Height="20"
                                                  Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Visibility="Collapsed"/>
                                            <Path x:Name="ListMusicIcon"
                                                  Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,9A3,3 0 0,1 15,12A3,3 0 0,1 12,15A3,3 0 0,1 9,12A3,3 0 0,1 12,9Z"
                                                  Fill="{DynamicResource BorderBrush}" Width="18" Height="18"
                                                  Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Visibility="Visible"/>
                                            <Image x:Name="ListCoverImage"
                                                   Source="{Binding CoverPath, Converter={StaticResource PathToImageConverter}, ConverterParameter=list}"
                                                   RenderOptions.BitmapScalingMode="HighQuality" Stretch="UniformToFill"/>
                                        </Grid>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="Medium"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock x:Name="ListSubtitleGenre" Text="{Binding Genre}"
                                                   FontSize="11" Foreground="{DynamicResource MutedTextBrush}"
                                                   TextTrimming="CharacterEllipsis" Margin="0,1,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock x:Name="TxtArtistField" Grid.Column="1"
                                           Text="{Binding Artist}" FontSize="14"
                                           Foreground="{DynamicResource MutedTextBrush}"
                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtDurationField" Grid.Column="2"
                                           Text="{Binding Duration, StringFormat='{}{0:mm\\:ss}'}"
                                           FontSize="14" FontWeight="Medium"
                                           Foreground="{DynamicResource MutedTextBrush}"
                                           VerticalAlignment="Center" Margin="0,0,16,0"/>
                            </Grid>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding SourceType}" Value="FolderItem">
                                    <Setter TargetName="ListMusicIcon"     Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="ListCoverImage"    Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="ListFolderIcon"    Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="ListSubtitleGenre" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="TxtArtistField"    Property="Text"       Value="{Binding Artist}"/>
                                    <Setter TargetName="TxtDurationField"  Property="Text"       Value="--:--"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <!-- Grid / card view -->
            <Grid x:Name="GridViewContainer" Visibility="Visible"
                  VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                  RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="GridTranslate" Y="0"/>
                </Grid.RenderTransform>
                <ListBox x:Name="FolderSongsGridBox"
                         Background="Transparent" BorderThickness="0"
                         VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.CanContentScroll="True"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         MouseDoubleClick="OnSongDoubleClicked">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" Margin="0,0,-16,0"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="CardBorder" Background="Transparent"
                                                CornerRadius="24" Padding="12"
                                                RenderTransformOrigin="0.5,0.5" Margin="0,0,16,24">
                                            <Border.RenderTransform>
                                                <ScaleTransform x:Name="CardScale" ScaleX="1" ScaleY="1"/>
                                            </Border.RenderTransform>
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource BorderBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Width="150" Background="Transparent">
                                <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                                        Height="150" CornerRadius="20" ClipToBounds="True"
                                        Margin="0,0,0,14" SnapsToDevicePixels="True">
                                    <Grid>
                                        <Grid x:Name="GridFolderContainer" Visibility="Collapsed">
                                            <Border Background="{DynamicResource BorderBrush}" Opacity="0.1"/>
                                            <Path Data="M6,6H11L13,8H19A1.5,1.5 0 0,1 20.5,9.5V11H4V8A2,2 0 0,1 6,6Z"
                                                  Fill="{DynamicResource AccentBrush}" Width="70" Height="70"
                                                  Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Margin="0,0,8,12" Opacity="0.2"/>
                                            <Path Data="M4,7H10L12,9H20A2,2 0 0,1 22,11V19A2,2 0 0,1 20,21H4A2,2 0 0,1 2,19V9A2,2 0 0,1 4,7Z"
                                                  Fill="{DynamicResource AccentBrush}" Width="86" Height="86"
                                                  Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Opacity="0.4"/>
                                        </Grid>
                                        <Grid x:Name="GridAudioContainer" Visibility="Visible">
                                            <Border Background="{DynamicResource BorderBrush}" Opacity="0.05"/>
                                            <Path Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,9A3,3 0 0,1 15,12A3,3 0 0,1 12,15A3,3 0 0,1 9,12A3,3 0 0,1 12,9Z"
                                                  Fill="{DynamicResource BorderBrush}" Width="40" Height="40"
                                                  Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <Image Source="{Binding CoverPath, Converter={StaticResource PathToImageConverter}, ConverterParameter=grid}"
                                                   RenderOptions.BitmapScalingMode="HighQuality" Stretch="UniformToFill"/>
                                        </Grid>
                                    </Grid>
                                </Border>
                                <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"
                                           TextTrimming="CharacterEllipsis" Margin="4,0,0,2"/>
                                <TextBlock x:Name="GridTxtArtist" Text="{Binding Artist}" FontSize="12"
                                           Foreground="{DynamicResource MutedTextBrush}"
                                           TextTrimming="CharacterEllipsis" Margin="4,0,0,0"/>
                            </StackPanel>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding SourceType}" Value="FolderItem">
                                    <Setter TargetName="GridAudioContainer" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="GridFolderContainer" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="GridTxtArtist"       Property="Text"       Value="{Binding Artist}"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>

        <!-- ── Scan progress toast (bottom-right, MusicBee-style) ──────── -->
        <!--
             Anchored to the bottom-right corner of the control so it never
             obscures the track list, exactly like the MusicBee status bar.
             Slides in from the right; dismisses to the right when done.
        -->
        <Border x:Name="ScanToastCard"
                Grid.Row="0" Grid.RowSpan="2"
                VerticalAlignment="Bottom" HorizontalAlignment="Right"
                Margin="0,0,24,24"
                MinWidth="300" MaxWidth="380"
                Background="{DynamicResource SecondaryBackgroundBrush}"
                BorderThickness="1"
                BorderBrush="{DynamicResource BorderBrush}"
                CornerRadius="20"
                Padding="20,16"
                Visibility="Collapsed"
                IsHitTestVisible="False">
            <Border.RenderTransform>
                <TranslateTransform x:Name="ScanToastTranslate" X="400"/>
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.22" Color="Black"/>
            </Border.Effect>

            <StackPanel>
                <!-- Row 1: pulse dot + headline -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10">
                    <Ellipse x:Name="ScanPulseDot" Width="9" Height="9"
                             Fill="{DynamicResource AccentBrush}"
                             VerticalAlignment="Center" Margin="0,0,12,0">
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Ellipse.Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="1" To="0.25" Duration="0:0:0.9"
                                                         AutoReverse="True"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                    <TextBlock x:Name="TxtScanHeadline"
                               Text="Scanning library…"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Row 2: current filename (scrolling ellipsis) -->
                <TextBlock x:Name="TxtScanCurrentFile"
                           Text=""
                           FontSize="12"
                           Foreground="{DynamicResource MutedTextBrush}"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,0,0,12"/>

                <!-- Row 3: determinate progress bar -->
                <ProgressBar x:Name="ScanProgressBar"
                             Minimum="0" Maximum="100" Value="0"
                             Height="4"
                             Foreground="{DynamicResource AccentBrush}"
                             Background="{DynamicResource BorderBrush}"
                             BorderThickness="0"
                             IsIndeterminate="False"
                             Margin="0,0,0,10"/>

                <!-- Row 4: numeric counter -->
                <TextBlock x:Name="TxtScanCounter"
                           Text="0 / 0 files"
                           FontSize="11"
                           Foreground="{DynamicResource MutedTextBrush}"
                           HorizontalAlignment="Right"/>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
