<UserControl x:Class="Musicefy.Controls.HomeSectionControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Musicefy.Converters"
             xmlns:local="clr-namespace:Musicefy.Controls"
             Background="Transparent">

    <UserControl.Resources>
        <!-- ═══ Track Card Template ══════════════════════════════════════════ -->
        <!-- Square card with cover art, title, artist, and play button overlay on hover -->
        <DataTemplate x:Key="TrackCardTemplate">
            <Border Width="160" Margin="0,0,16,0" Background="Transparent" Cursor="Hand"
                    MouseLeftButtonUp="OnCardClick">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <!-- Cover art with play overlay -->
                    <Border Background="{DynamicResource SurfaceVariantBrush}"
                            Width="160" Height="160" CornerRadius="12"
                            ClipToBounds="True" Margin="0,0,0,10">
                        <Grid>
                            <!-- Placeholder icon -->
                            <Path Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,9A3,3 0 0,1 15,12A3,3 0 0,1 12,15A3,3 0 0,1 9,12A3,3 0 0,1 12,9Z"
                                  Fill="{DynamicResource OutlineBrush}" Width="36" Height="36"
                                  Stretch="Uniform" HorizontalAlignment="Center"
                                  VerticalAlignment="Center" Opacity="0.3"/>
                            <!-- Cover image -->
                            <Image Source="{Binding CoverPath, Converter={StaticResource PathToImageConverter}, ConverterParameter=grid}"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   Stretch="UniformToFill" VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   conv:CoverFadeBehavior.IsEnabled="True"/>
                            <!-- Play button overlay (appears on hover) -->
                            <Border Background="#88000000" CornerRadius="12"
                                    Opacity="0"
                                    Visibility="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                             From="0" To="1" Duration="0:0:0.15"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                             From="1" To="0" Duration="0:0:0.15"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <!-- Circular play button -->
                                    <Border Width="44" Height="44" CornerRadius="22"
                                            Background="{DynamicResource PrimaryBrush}"/>
                                    <Path Data="M8,5.14V19.14L19,12.14L8,5.14Z"
                                          Fill="{DynamicResource OnPrimaryBrush}" Width="20" Height="20"
                                          Stretch="Uniform" HorizontalAlignment="Center"
                                          VerticalAlignment="Center" Margin="2,0,0,0"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                    <!-- Title -->
                    <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource OnSurfaceBrush}"
                               TextTrimming="CharacterEllipsis" Margin="2,0,0,0"/>
                    <!-- Subtitle (Artist) -->
                    <TextBlock Text="{Binding Artist}" FontSize="11"
                               Foreground="{DynamicResource OnSurfaceVariantBrush}"
                               TextTrimming="CharacterEllipsis" Margin="2,2,0,0"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- ═══ Album Card Template ══════════════════════════════════════════ -->
        <!-- Square card with cover art, album name, artist + year -->
        <DataTemplate x:Key="AlbumCardTemplate">
            <Border Width="160" Margin="0,0,16,0" Background="Transparent" Cursor="Hand"
                    MouseLeftButtonUp="OnAlbumCardClick">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <!-- Cover art -->
                    <Border Background="{DynamicResource SurfaceVariantBrush}"
                            Width="160" Height="160" CornerRadius="12"
                            ClipToBounds="True" Margin="0,0,0,10">
                        <Grid>
                            <!-- Placeholder icon (album icon) -->
                            <Path Data="M12,11A1,1 0 0,0 11,12A1,1 0 0,0 12,13A1,1 0 0,0 13,12A1,1 0 0,0 12,11M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,16A4,4 0 0,1 8,12A4,4 0 0,1 12,8A4,4 0 0,1 16,12A4,4 0 0,1 12,16Z"
                                  Fill="{DynamicResource OutlineBrush}" Width="36" Height="36"
                                  Stretch="Uniform" HorizontalAlignment="Center"
                                  VerticalAlignment="Center" Opacity="0.3"/>
                            <!-- Cover image -->
                            <Image Source="{Binding CoverPath, Converter={StaticResource PathToImageConverter}, ConverterParameter=grid}"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   Stretch="UniformToFill" VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   conv:CoverFadeBehavior.IsEnabled="True"/>
                        </Grid>
                    </Border>
                    <!-- Album name -->
                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource OnSurfaceBrush}"
                               TextTrimming="CharacterEllipsis" Margin="2,0,0,0"/>
                    <!-- Subtitle: Artist · Year -->
                    <TextBlock FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                               TextTrimming="CharacterEllipsis" Margin="2,2,0,0">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0}{1}">
                                <Binding Path="Artist"/>
                                <Binding Path="Year" Converter="{StaticResource AlbumYearSuffixConverter}"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- ═══ Artist Card Template ═════════════════════════════════════════ -->
        <!-- Circle avatar with artist name below -->
        <DataTemplate x:Key="ArtistCardTemplate">
            <Border Width="160" Margin="0,0,16,0" Background="Transparent" Cursor="Hand"
                    MouseLeftButtonUp="OnArtistCardClick">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel HorizontalAlignment="Center">
                    <!-- Circle avatar -->
                    <Border Background="{DynamicResource SurfaceVariantBrush}"
                            Width="140" Height="140" CornerRadius="80"
                            ClipToBounds="True" Margin="10,0,10,10"
                            HorizontalAlignment="Center">
                        <Grid>
                            <!-- Placeholder icon (person) -->
                            <Path Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z"
                                  Fill="{DynamicResource OutlineBrush}" Width="40" Height="40"
                                  Stretch="Uniform" HorizontalAlignment="Center"
                                  VerticalAlignment="Center" Opacity="0.3"/>
                            <!-- Cover image -->
                            <Image Source="{Binding CoverPath, Converter={StaticResource PathToImageConverter}, ConverterParameter=grid}"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   Stretch="UniformToFill" VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   conv:CoverFadeBehavior.IsEnabled="True"/>
                        </Grid>
                    </Border>
                    <!-- Artist name (centered) -->
                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource OnSurfaceBrush}"
                               TextTrimming="CharacterEllipsis"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               Width="148" Margin="6,0,6,0"/>
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="0,0,0,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Section Header -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding Title}" FontSize="20" FontWeight="Bold"
                           Foreground="{DynamicResource OnSurfaceBrush}"
                           VerticalAlignment="Center"/>
                <!-- Section type badge for non-local sources -->
                <Border Background="{DynamicResource SurfaceVariantBrush}"
                        CornerRadius="10" Padding="8,2" Margin="12,0,0,0"
                        VerticalAlignment="Center"
                        Visibility="{Binding SourceType, Converter={StaticResource NonLocalVisibilityConverter}}">
                    <TextBlock Text="{Binding SourceType}" FontSize="10"
                               Foreground="{DynamicResource OnSurfaceVariantBrush}"
                               VerticalAlignment="Center"/>
                </Border>
            </StackPanel>

            <!-- See All button — visible when section has 5+ items -->
            <Button Content="See All" HorizontalAlignment="Right"
                    FontSize="12" FontWeight="SemiBold"
                    Foreground="{DynamicResource PrimaryBrush}"
                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                    Visibility="{Binding Items.Count, Converter={StaticResource CountGreaterThanOrEqualConverter}}"
                    Click="SeeAllButton_Click"/>
        </Grid>

        <!-- Loading indicator for this section -->
        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Margin="0,8,0,0">
            <TextBlock Text="Loading..." FontSize="12"
                       Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
        </StackPanel>

        <!-- Horizontal scrolling content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Disabled"
                      HorizontalScrollBarVisibility="Auto"
                      Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisConverter}}">
            <ItemsControl ItemsSource="{Binding Items}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplateSelector>
                    <conv:HomeSectionItemTemplateSelector
                        TrackTemplate="{StaticResource TrackCardTemplate}"
                        AlbumTemplate="{StaticResource AlbumCardTemplate}"
                        ArtistTemplate="{StaticResource ArtistCardTemplate}"/>
                </ItemsControl.ItemTemplateSelector>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
