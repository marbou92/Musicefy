<Window x:Class="Musicefy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Musicefy"
        Height="720" Width="1200"
        WindowStartupLocation="CenterScreen"
        MinHeight="600" MinWidth="900"
        Icon="pack://application:,,,/Assets/musicefy.ico"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}"
        ResizeMode="CanResize"
        SizeToContent="Manual">

    <DockPanel LastChildFill="True">
        <!-- Top Navigation Bar -->
        <!-- ... unchanged ... -->

        <!-- Main Content Area -->
        <Grid DockPanel.Dock="Top" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="{DynamicResource SecondaryBackgroundBrush}" Padding="12" CornerRadius="6">
                <StackPanel>
                    <TextBlock Text="Sources" FontSize="16" FontWeight="Bold"/>
                    <Button x:Name="AddSourceButton" Content="Add Source" Margin="0,8,0,0"
                            Background="{DynamicResource AccentBrush}" Foreground="White"
                            Click="AddSourceButton_Click"/>
                    <ListBox x:Name="SourcesListBox" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" Background="Transparent"/>

            <!-- Library + Queue + Now Playing -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Library -->
                <Border Grid.Row="0" Background="{DynamicResource BackgroundBrush}" Padding="12"
                        CornerRadius="6" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="My Music Library" FontSize="20" FontWeight="Bold"/>
                        <ListBox x:Name="TracksList" Margin="0,12,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Queue View -->
                <Border Grid.Row="1" Background="{DynamicResource BackgroundBrush}" Padding="12"
                        CornerRadius="6" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="Queue" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ListBox x:Name="QueueList" Margin="0,4,0,0" Height="200" MouseDoubleClick="QueueList_DoubleClick"/>
                    </StackPanel>
                </Border>

                <!-- Now Playing Card -->
                <Border Grid.Row="2" Background="{DynamicResource SecondaryBackgroundBrush}" Padding="12" CornerRadius="6" Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="Now Playing" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal">
                            <Image x:Name="AlbumArtImage"
                                   Width="96" Height="96"
                                   Stretch="UniformToFill"
                                   Margin="0,0,12,0"
                                   Source="pack://application:,,,/Assets/default_cover.png"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="NowPlayingTitle" Text="Track Title" FontWeight="Bold"/>
                                <TextBlock x:Name="NowPlayingArtist" Text="Artist" Foreground="Gray" Margin="0,4,0,0"/>
                                <TextBlock x:Name="NowPlayingMeta" Text="Album • Year" Foreground="Gray" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- Bottom Player Bar -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource SecondaryBackgroundBrush}" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Playback Controls -->
                <!-- ... unchanged ... -->

                <!-- Playback Slider -->
                <StackPanel Grid.Column="1" Orientation="Vertical" Margin="12,0">
                    <Slider x:Name="PlaybackSlider" Minimum="0" Maximum="100" Value="0" Height="20"
                            PreviewMouseUp="PlaybackSlider_MouseUp"/>
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" x:Name="ElapsedText" Text="0:00" FontSize="12" Foreground="Gray"/>
                        <TextBlock Grid.Column="2" x:Name="RemainingText" Text="0:00" FontSize="12" Foreground="Gray" HorizontalAlignment="Right"/>
                    </Grid>
                </StackPanel>

                <!-- Volume Control -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Vol" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <Slider x:Name="VolumeSlider"
                            Width="120"
                            Minimum="0"
                            Maximum="100"
                            Value="70"
                            Height="20"
                            ValueChanged="VolumeSlider_ValueChanged"/>
                </StackPanel>
            </Grid>
        </Border>
    </DockPanel>
</Window>
