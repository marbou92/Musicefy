<Window x:Class="Musicefy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Musicefy - Music Streaming Player"
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        MinHeight="480" MinWidth="640">

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="240"/>
      <ColumnDefinition Width="8"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="120"/>
    </Grid.RowDefinitions>

    <!-- Sidebar: Sources + Add button -->
    <Border Grid.Row="0" Grid.Column="0" Background="#FFF2F2F2" Padding="12" BorderBrush="#FFE0E0E0" BorderThickness="0,0,1,0">
      <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" HorizontalAlignment="Stretch">
          <TextBlock Text="Sources" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
          <Button x:Name="AddSourceButton" Content="Add" Width="56" Height="26" Margin="8,0,0,0" HorizontalAlignment="Right" Click="AddSourceButton_Click"/>
        </StackPanel>

        <ListBox x:Name="SourcesListBox" Margin="0,12,0,0" VerticalAlignment="Stretch" />
      </DockPanel>
    </Border>

    <GridSplitter Grid.Row="0" Grid.Column="1" Width="8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent" ShowsPreview="True" ResizeBehavior="PreviousAndNext"/>

    <!-- Main content -->
    <Border Grid.Row="0" Grid.Column="2" Padding="18" Background="White">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="My Music Library" FontSize="24" FontWeight="Bold"/>

        <TextBox x:Name="SearchTextBox" Grid.Row="1" Height="34" Margin="0,12,0,8" Padding="8,4" VerticalContentAlignment="Center" Text="Search..." Foreground="Gray"/>

        <Grid Grid.Row="2">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <Border Grid.Column="0" Background="#FFF9F9F9" Padding="8" CornerRadius="4" BorderBrush="#FFECECEC" BorderThickness="1">
            <StackPanel>
              <TextBlock Text="Tracks" FontWeight="SemiBold" Margin="0,0,0,8"/>
              <ListBox x:Name="TracksList" MinHeight="200"/>
            </StackPanel>
          </Border>

          <GridSplitter Grid.Column="1" Width="12" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent" ShowsPreview="True" ResizeBehavior="PreviousAndNext"/>

          <Border Grid.Column="2" Background="#FFFFFFFF" Padding="12" CornerRadius="4" BorderBrush="#FFECECEC" BorderThickness="1">
            <StackPanel>
              <TextBlock Text="Now Playing" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
              <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Rectangle Width="96" Height="96" Fill="#FFDDDDDD" RadiusX="4" RadiusY="4"/>
                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                  <TextBlock x:Name="NowPlayingTitle" Text="Selected Track Title" FontWeight="Bold"/>
                  <TextBlock x:Name="NowPlayingArtist" Text="Selected Artist" Foreground="Gray" Margin="0,4,0,0"/>
                </StackPanel>
              </StackPanel>
              <TextBlock x:Name="NowPlayingMeta" Text="Album • Year" Foreground="Gray" FontSize="12"/>
            </StackPanel>
          </Border>
        </Grid>
      </Grid>
    </Border>

    <ProgressBar Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Height="4" Value="35" Margin="0" Foreground="#FF3B82F6" Background="#FFEFEFEF"/>

    <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Padding="12" Background="#FFF2F2F2" BorderThickness="1,0,0,0" BorderBrush="#FFE0E0E0">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
          <Button x:Name="PreviousButton" Content="⏮" Width="40" Height="36" Margin="4" Click="PreviousButton_Click"/>
          <Button x:Name="PlayButton" Content="⏯" Width="40" Height="36" Margin="4" Click="PlayButton_Click"/>
          <Button x:Name="NextButton" Content="⏭" Width="40" Height="36" Margin="4" Click="NextButton_Click"/>
        </StackPanel>

        <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center" Margin="12,0">
          <Slider x:Name="PlaybackSlider" Minimum="0" Maximum="100" Value="0" Height="20"/>
          <Grid Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="ElapsedText" Text="0:00" FontSize="12" Foreground="Gray"/>
            <TextBlock Grid.Column="2" x:Name="RemainingText" Text="0:00" FontSize="12" Foreground="Gray" HorizontalAlignment="Right"/>
          </Grid>
        </StackPanel>

        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
          <TextBlock Text="Vol" VerticalAlignment="Center" Margin="0,0,6,0"/>
          <Slider x:Name="VolumeSlider" Width="120" Minimum="0" Maximum="100" Value="70" Height="20"/>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
