<Window x:Class="Musicefy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Musicefy - Music Streaming Player"
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        MinHeight="480" MinWidth="640">

  <!-- Top-level layout: two columns (sidebar + main) and three rows (content, progress, player) -->
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="200"/> <!-- Sidebar fixed width -->
      <ColumnDefinition Width="8"/>   <!-- Splitter -->
      <ColumnDefinition Width="*"/>   <!-- Main content -->
    </Grid.ColumnDefinitions>

    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>      <!-- Main content -->
      <RowDefinition Height="Auto"/>   <!-- Thin progress bar row -->
      <RowDefinition Height="120"/>    <!-- Player controls -->
    </Grid.RowDefinitions>

    <!-- Sidebar (use Border to support Padding) -->
    <Border Grid.Row="0" Grid.Column="0" Background="#FFF2F2F2" Padding="12" BorderBrush="#FFE0E0E0" BorderThickness="0,0,1,0">
      <StackPanel>
        <TextBlock Text="Musicefy" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>
        <Button Content="Home" Margin="0,0,0,6" HorizontalAlignment="Stretch"/>
        <Button Content="Library" Margin="0,0,0,6" HorizontalAlignment="Stretch"/>
        <Button Content="Playlists" Margin="0,0,0,6" HorizontalAlignment="Stretch"/>
        <Button Content="Settings" Margin="0,12,0,0" HorizontalAlignment="Stretch"/>
      </StackPanel>
    </Border>

    <!-- Vertical splitter between sidebar and main -->
    <GridSplitter Grid.Row="0" Grid.Column="1" Width="8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent" ShowsPreview="True" ResizeBehavior="PreviousAndNext"/>

    <!-- Main content area -->
    <Border Grid.Row="0" Grid.Column="2" Padding="18" Background="White">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Text="My Music Library" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Search box -->
        <TextBox x:Name="SearchTextBox"
                 Grid.Row="1"
                 Height="34"
                 Margin="0,12,0,8"
                 Padding="8,4"
                 VerticalContentAlignment="Center"
                 Text="Search..."
                 Foreground="Gray"/>

        <!-- Content: list of tracks and details -->
        <Grid Grid.Row="2">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <!-- Tracks list -->
          <Border Grid.Column="0" Background="#FFF9F9F9" Padding="8" CornerRadius="4" BorderBrush="#FFECECEC" BorderThickness="1">
            <StackPanel>
              <TextBlock Text="Tracks" FontWeight="SemiBold" Margin="0,0,0,8"/>
              <ListBox x:Name="TracksList" MinHeight="200">
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <Border Padding="8" Margin="0,0,0,6" Background="Transparent">
                      <StackPanel Orientation="Vertical">
                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Artist}" FontSize="12" Foreground="Gray"/>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>

                <!-- Example static items (replace with binding in code) -->
                <ListBoxItem>
                  <StackPanel>
                    <TextBlock Text="Song Title 1" FontWeight="SemiBold"/>
                    <TextBlock Text="Artist 1" FontSize="12" Foreground="Gray"/>
                  </StackPanel>
                </ListBoxItem>
                <ListBoxItem>
                  <StackPanel>
                    <TextBlock Text="Song Title 2" FontWeight="SemiBold"/>
                    <TextBlock Text="Artist 2" FontSize="12" Foreground="Gray"/>
                  </StackPanel>
                </ListBoxItem>
              </ListBox>
            </StackPanel>
          </Border>

          <!-- Spacer / splitter column -->
          <GridSplitter Grid.Column="1" Width="12" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent" ShowsPreview="True" ResizeBehavior="PreviousAndNext"/>

          <!-- Details / now playing -->
          <Border Grid.Column="2" Background="#FFFFFFFF" Padding="12" CornerRadius="4" BorderBrush="#FFECECEC" BorderThickness="1">
            <StackPanel>
              <TextBlock Text="Now Playing" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
              <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Rectangle Width="96" Height="96" Fill="#FFDDDDDD" RadiusX="4" RadiusY="4"/>
                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                  <TextBlock Text="Selected Track Title" FontWeight="Bold"/>
                  <TextBlock Text="Selected Artist" Foreground="Gray" Margin="0,4,0,0"/>
                  <TextBlock Text="Album • Year" Foreground="Gray" FontSize="12" Margin="0,6,0,0"/>
                </StackPanel>
              </StackPanel>

              <TextBlock Text="Additional details, lyrics or metadata can appear here." Foreground="Gray" FontSize="12"/>
            </StackPanel>
          </Border>
        </Grid>
      </Grid>
    </Border>

    <!-- Thin progress bar row (spans both main columns) -->
    <ProgressBar Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Height="4" Value="35" Margin="0" Foreground="#FF3B82F6" Background="#FFEFEFEF"/>

    <!-- Player controls area -->
    <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Padding="12" Background="#FFF2F2F2" BorderThickness="1,0,0,0" BorderBrush="#FFE0E0E0">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Left: basic controls -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
          <Button Content="⏮" Width="40" Height="36" Margin="4"/>
          <Button Content="⏯" Width="40" Height="36" Margin="4"/>
          <Button Content="⏭" Width="40" Height="36" Margin="4"/>
        </StackPanel>

        <!-- Center: progress and time -->
        <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center" Margin="12,0">
          <Slider x:Name="PlaybackSlider" Minimum="0" Maximum="100" Value="70" Height="20"/>
          <Grid Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="1:12" FontSize="12" Foreground="Gray"/>
            <TextBlock Grid.Column="2" Text="3:45" FontSize="12" Foreground="Gray" HorizontalAlignment="Right"/>
          </Grid>
        </StackPanel>

        <!-- Right: volume / extra -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
          <TextBlock Text="Vol" VerticalAlignment="Center" Margin="0,0,6,0"/>
          <Slider Width="120" Minimum="0" Maximum="100" Value="70" Height="20"/>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
