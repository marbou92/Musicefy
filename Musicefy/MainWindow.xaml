<Window x:Class="Musicefy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Musicefy - Music Streaming Player"
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="100"/>
        </Grid.RowDefinitions>

        <!-- Sidebar -->
        <StackPanel Grid.Row="0" Background="LightGray" Width="200" Padding="10">
            <TextBlock Text="Sidebar" FontSize="16" FontWeight="Bold"/>
        </StackPanel>

        <!-- Music List Area -->
        <Border Grid.Row="0" Grid.Column="1" Padding="20" Background="White">
            <StackPanel>
                <TextBlock Text="My Music Library" FontSize="24" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBox x:Name="SearchTextBox" Padding="5" Height="30" Text="Search..."/>
                <ListBox Margin="0,10,0,0">
                    <ListBoxItem Padding="5">Song Title - Artist</ListBoxItem>
                </ListBox>
            </StackPanel>
        </Border>

        <!-- Progress Bar -->
        <ProgressBar Grid.Row="1" Height="3" Value="35"/>

        <!-- Player Controls -->
        <Border Grid.Row="2" Padding="10" Background="LightGray">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="⏮" Margin="5"/>
                <Button Content="▶" Margin="5"/>
                <Button Content="⏭" Margin="5"/>
                <Slider Width="100" Minimum="0" Maximum="100" Value="70" Margin="10,0,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
