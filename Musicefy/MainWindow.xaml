<Window x:Class="Musicefy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Musicefy"
        Height="720" Width="1200"
        WindowStartupLocation="CenterScreen"
        MinHeight="600" MinWidth="900"
        Icon="pack://application:,,,/Assets/musicefy.ico"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}"
        ResizeMode="CanResize"
        SizeToContent="Manual">

    <DockPanel LastChildFill="True">
        <!-- Top Navigation Bar -->
        <!-- ... your top bar code unchanged ... -->

        <!-- Main Content Area -->
        <!-- ... your sidebar, library, queue, now playing unchanged ... -->

        <!-- Bottom Player Bar -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource SecondaryBackgroundBrush}" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Playback Controls -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button x:Name="PreviousButton" Content="⏮" Width="48" Height="40" Margin="4"
                            Background="{DynamicResource AccentBrush}" Foreground="White"
                            FontSize="18" FontWeight="Bold" Click="PreviousButton_Click"/>
                    <Button x:Name="PlayButton" Content="▶" Width="64" Height="40" Margin="4"
                            Background="{DynamicResource AccentBrush}" Foreground="White"
                            FontSize="18" FontWeight="Bold" Click="PlayButton_Click"/>
                    <Button x:Name="PauseButton" Content="⏸" Width="64" Height="40" Margin="4"
                            Background="{DynamicResource AccentBrush}" Foreground="White"
                            FontSize="18" FontWeight="Bold" Click="PauseButton_Click"/>
                    <Button x:Name="NextButton" Content="⏭" Width="48" Height="40" Margin="4"
                            Background="{DynamicResource AccentBrush}" Foreground="White"
                            FontSize="18" FontWeight="Bold" Click="NextButton_Click"/>

                    <!-- Shuffle & Repeat -->
                    <Button x:Name="ShuffleButton" Content="🔀" Width="48" Height="40" Margin="4"
                            Background="{DynamicResource SecondaryBackgroundBrush}" Foreground="{DynamicResource ForegroundBrush}"
                            FontSize="18" FontWeight="Bold" Click="ShuffleButton_Click"/>
                    <Button x:Name="RepeatButton" Content="🔁" Width="48" Height="40" Margin="4"
                            Background="{DynamicResource SecondaryBackgroundBrush}" Foreground="{DynamicResource ForegroundBrush}"
                            FontSize="18" FontWeight="Bold" Click="RepeatButton_Click"/>
                </StackPanel>

                <!-- Playback Slider -->
                <StackPanel Grid.Column="1" Orientation="Vertical" Margin="12,0">
                    <Slider x:Name="PlaybackSlider" Minimum="0" Maximum="100" Value="0" Height="20"
                            PreviewMouseUp="PlaybackSlider_MouseUp"/>
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" x:Name="ElapsedText" Text="0:00" FontSize="12" Foreground="Gray"/>
                        <TextBlock Grid.Column="2" x:Name="RemainingText" Text="0:00" FontSize="12" Foreground="Gray" HorizontalAlignment="Right"/>
                    </Grid>
                </StackPanel>

                <!-- Volume Control -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Vol" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <Slider x:Name="VolumeSlider"
                            Width="120"
                            Minimum="0"
                            Maximum="100"
                            Value="70"
                            Height="20"
                            ValueChanged="VolumeSlider_ValueChanged"/>
                </StackPanel>
            </Grid>
        </Border>
    </DockPanel>
</Window>
