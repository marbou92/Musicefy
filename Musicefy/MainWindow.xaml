<Window x:Class="Musicefy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Musicefy - Music Streaming Player" Height="600" Width="900"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource ForegroundBrush}"
        WindowStartupLocation="CenterScreen"
        Icon="/Musicefy;component/Resources/music_icon.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="100"/>
        </Grid.RowDefinitions>
        
        <!-- Main Content Area -->
        <Grid Grid.Row="0" Background="{StaticResource BackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Sidebar -->
            <StackPanel Grid.Column="0" Background="{StaticResource SecondaryBackgroundBrush}" Padding="10">
                <TextBlock Text="SOURCES" FontSize="14" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,10"/>
                <Button x:Name="AddSourceButton" Content="+ Add Streaming Source" Background="{StaticResource AccentBrush}" Foreground="{StaticResource BackgroundBrush}" Padding="10" Margin="0,0,0,10" FontWeight="Bold" Click="AddSourceButton_Click"/>
                <ListBox x:Name="SourcesListBox" Background="{StaticResource BackgroundBrush}" Foreground="{StaticResource ForegroundBrush}" BorderBrush="{StaticResource BorderBrush}" Margin="0,0,0,15"/>
                
                <TextBlock Text="PLAYLISTS" FontSize="14" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,15"/>
                <Button Content="+ New Playlist" Background="{StaticResource AccentBrush}" Foreground="{StaticResource BackgroundBrush}" Padding="10" Margin="0,0,0,10" FontWeight="Bold"/>
                <Button Content="My Favorite Songs" Background="{StaticResource BorderBrush}" Foreground="{StaticResource ForegroundBrush}" Padding="10" Margin="0,0,0,5"/>
                <Button Content="Recent" Background="{StaticResource BorderBrush}" Foreground="{StaticResource ForegroundBrush}" Padding="10" Margin="0,0,0,5"/>
                
                <TextBlock Text="LIBRARY" FontSize="14" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,20,0,15"/>
                <Button Content="📁 Add Local Folder" Background="{StaticResource AccentBrush}" Foreground="{StaticResource BackgroundBrush}" Padding="10" Margin="0,0,0,10" FontWeight="Bold"/>
            </StackPanel>
            
            <!-- Music List Area -->
            <Grid Grid.Column="1" Padding="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Search Bar -->
                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="My Music Library" FontSize="24" FontWeight="Bold" Foreground="{StaticResource ForegroundBrush}" Margin="0,0,0,10"/>
                    <TextBox x:Name="SearchTextBox" Background="{StaticResource SecondaryBackgroundBrush}" Foreground="{StaticResource ForegroundBrush}" Padding="10" Height="35" FontSize="14" Foreground="#888888"/>
                </StackPanel>
                
                <!-- Songs List -->
                <ListBox x:Name="SongsListBox" Grid.Row="1" Background="{StaticResource BackgroundBrush}" Foreground="{StaticResource ForegroundBrush}" BorderBrush="{StaticResource BorderBrush}">
                    <ListBoxItem Background="{StaticResource SecondaryBackgroundBrush}" Padding="15,10" Margin="0,5">
                        <StackPanel>
                            <TextBlock Text="Song Title" FontSize="14" FontWeight="Bold"/>
                            <TextBlock Text="Artist Name" FontSize="11" Foreground="#AAAAAA"/>
                        </StackPanel>
                    </ListBoxItem>
                </ListBox>
            </Grid>
        </Grid>
        
        <!-- Progress Bar -->
        <ProgressBar Grid.Row="1" Height="3" Foreground="{StaticResource AccentBrush}" Background="{StaticResource SecondaryBackgroundBrush}" Value="35"/>
        
        <!-- Player Controls -->
        <Grid Grid.Row="2" Background="{StaticResource SecondaryBackgroundBrush}" Padding="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="150"/>
            </Grid.ColumnDefinitions>
            
            <!-- Current Song Info -->
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Now Playing" FontSize="12" Foreground="#888888"/>
                <TextBlock x:Name="CurrentSongTitle" Text="Song Title" FontSize="14" FontWeight="Bold" Foreground="{StaticResource ForegroundBrush}"/>
                <TextBlock x:Name="CurrentSongArtist" Text="Artist Name" FontSize="11" Foreground="#AAAAAA"/>
            </StackPanel>
            
            <!-- Control Buttons -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                <Button x:Name="PreviousButton" Content="⏮" Width="40" Height="40" Background="{StaticResource BorderBrush}" Foreground="{StaticResource ForegroundBrush}" FontSize="18" Cursor="Hand" Click="PreviousButton_Click"/>
                <Button x:Name="PlayButton" Content="▶" Width="50" Height="50" Background="{StaticResource AccentBrush}" Foreground="{StaticResource BackgroundBrush}" FontSize="20" Cursor="Hand" FontWeight="Bold" Click="PlayButton_Click"/>
                <Button x:Name="NextButton" Content="⏭" Width="40" Height="40" Background="{StaticResource BorderBrush}" Foreground="{StaticResource ForegroundBrush}" FontSize="18" Cursor="Hand" Click="NextButton_Click"/>
            </StackPanel>
            
            <!-- Volume Control -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                <TextBlock Text="🔊" FontSize="16" VerticalAlignment="Center"/>
                <Slider x:Name="VolumeSlider" Width="100" VerticalAlignment="Center" Minimum="0" Maximum="100" Value="70" Background="{StaticResource BorderBrush}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
