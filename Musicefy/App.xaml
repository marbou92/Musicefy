<Application x:Class="Musicefy.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Musicefy.Converters"
             StartupUri="SplashScreen.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Default mode -->
                <ResourceDictionary Source="Themes/Modes/System.xaml"/>
                <!-- Default palette -->
                <ResourceDictionary Source="Themes/Palettes/Default.xaml"/>
                <!-- Base animations + styles -->
                <ResourceDictionary Source="Themes/Base.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Global converters -->
            <conv:ThemeThumbnailConverter x:Key="ThemeThumbnailConverter"/>
            <conv:ThemePreviewConverter x:Key="ThemePreviewConverter"/>
            <conv:BoolToBrushConverter x:Key="BoolToBrushConverter"/>
            <conv:PathToImageConverter x:Key="PathToImageConverter"/>
            <conv:LyricsToLinesConverter x:Key="LyricsToLinesConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
