<Application x:Class="Musicefy.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Musicefy.Converters"
             StartupUri="SplashScreen.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Modes/System.xaml"/>
                <ResourceDictionary Source="Themes/Base.xaml"/>
                <ResourceDictionary Source="Themes/SharedSkeletons.xaml"/>
                <ResourceDictionary Source="Themes/ScrollbarTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisConverter"/>
            <conv:NonLocalVisibilityConverter x:Key="NonLocalVisibilityConverter"/>
            <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>

            <conv:ThemePreviewConverter x:Key="ThemePreviewConverter"/>
            <conv:BoolToBrushConverter x:Key="BoolToBrushConverter"/>
            <conv:PathToImageConverter x:Key="PathToImageConverter"/>
            <conv:AsyncCoverConverter x:Key="AsyncCoverConverter"/>
            <conv:LyricsToLinesConverter x:Key="LyricsToLinesConverter"/>
            <conv:IndexToBoolConverter x:Key="IndexToBoolConverter"/>
            <conv:IconGlyphConverter x:Key="IconGlyphConverter"/>

            <!-- Phase 2: Search converters -->
            <conv:NonZeroToVisibilityConverter x:Key="NonZeroToVisibilityConverter"/>
            <conv:ZeroToVisibilityConverter x:Key="ZeroToVisibilityConverter"/>
            <conv:SearchModeIconConverter x:Key="SearchModeIconConverter"/>
            <conv:ItemTypeToCornerRadiusConverter x:Key="ItemTypeToCornerRadiusConverter"/>

            <!-- Home section converters -->
            <conv:CountGreaterThanOrEqualConverter x:Key="CountGreaterThanOrEqualConverter"/>
            <conv:AlbumYearSuffixConverter x:Key="AlbumYearSuffixConverter"/>

            <!-- Session 3: Template selector for differentiated home section cards -->
            <conv:HomeSectionItemTemplateSelector x:Key="HomeSectionItemTemplateSelector"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
