<Application x:Class="Musicefy.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Musicefy.Converters"
             StartupUri="SplashScreen.xaml"
             Icon="pack://application:,,,/Assets/musicefy.ico">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Dark.xaml"/>
                <ResourceDictionary Source="Themes/Base.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Global converters -->
            <conv:ThemeThumbnailConverter x:Key="ThemeThumbnailConverter"/>
            <conv:ThemePreviewConverter x:Key="ThemePreviewConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
