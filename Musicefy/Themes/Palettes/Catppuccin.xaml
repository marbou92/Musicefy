<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <LinearGradientBrush x:Key="AccentBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F5C2E7" Offset="0"/>
        <GradientStop Color="#DDB6F2" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#E8A2D0"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#C08ACF"/>
</ResourceDictionary>
