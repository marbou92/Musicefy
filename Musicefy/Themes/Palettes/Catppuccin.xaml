<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Material Design 3 - Catppuccin Palette -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#F5C2E7"/>
    <SolidColorBrush x:Key="OnPrimaryBrush" Color="#1A1A2E"/>
    <SolidColorBrush x:Key="PrimaryContainerBrush" Color="#DDB6F2"/>
    <SolidColorBrush x:Key="OnPrimaryContainerBrush" Color="#2D1B3E"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="#DDB6F2"/>
    <SolidColorBrush x:Key="OnSecondaryBrush" Color="#1A1A2E"/>
    <SolidColorBrush x:Key="SecondaryContainerBrush" Color="#C08ACF"/>
    <SolidColorBrush x:Key="OnSecondaryContainerBrush" Color="#F5E6FF"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="#89DCEB"/>
    <SolidColorBrush x:Key="OnTertiaryBrush" Color="#1A1A2E"/>
    <SolidColorBrush x:Key="TertiaryContainerBrush" Color="#A6E3E9"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#F28FAD"/>
    <SolidColorBrush x:Key="OnErrorBrush" Color="#1A1A2E"/>
    <SolidColorBrush x:Key="ErrorContainerBrush" Color="#93000A"/>
    <SolidColorBrush x:Key="OnErrorContainerBrush" Color="#FFDAD6"/>

    <!-- Legacy aliases -->
    <SolidColorBrush x:Key="AccentBrush" Color="#F5C2E7"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#DDB6F2"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#C08ACF"/>
    <SolidColorBrush x:Key="AccentGlowBrush" Color="#F5C2E7"/>
</ResourceDictionary>
