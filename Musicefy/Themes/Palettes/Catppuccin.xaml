<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Normal -->
    <Color x:Key="AccentStartColor">#F5C2E7</Color>
    <Color x:Key="AccentEndColor">#DDB6F2</Color>

    <!-- Hover -->
    <Color x:Key="AccentHoverStartColor">#D6B8F7</Color>
    <Color x:Key="AccentHoverEndColor">#B57EDC</Color>

    <!-- Pressed -->
    <Color x:Key="AccentPressedStartColor">#9A6FD0</Color>
    <Color x:Key="AccentPressedEndColor">#7E56B8</Color>

    <!-- Glow -->
    <Color x:Key="AccentGlowColor">#B57EDC</Color>
</ResourceDictionary>
