<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Material Design 3 - Default Dark Palette -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#3C8CE7"/>
    <SolidColorBrush x:Key="OnPrimaryBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="PrimaryContainerBrush" Color="#5AA2F0"/>
    <SolidColorBrush x:Key="OnPrimaryContainerBrush" Color="#0D1B2E"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="#5AA2F0"/>
    <SolidColorBrush x:Key="OnSecondaryBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SecondaryContainerBrush" Color="#2A5FB5"/>
    <SolidColorBrush x:Key="OnSecondaryContainerBrush" Color="#E3F2FD"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="#B57EDC"/>
    <SolidColorBrush x:Key="OnTertiaryBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TertiaryContainerBrush" Color="#C89DF2"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#FF5252"/>
    <SolidColorBrush x:Key="OnErrorBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ErrorContainerBrush" Color="#93000A"/>
    <SolidColorBrush x:Key="OnErrorContainerBrush" Color="#FFDAD6"/>

    <!-- Legacy aliases -->
    <SolidColorBrush x:Key="AccentBrush" Color="#3C8CE7"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#5AA2F0"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#1E6BD6"/>
    <SolidColorBrush x:Key="AccentGlowBrush" Color="#3C8CE7"/>
</ResourceDictionary>
