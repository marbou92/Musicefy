<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Echo Default Dark Palette -->
    <LinearGradientBrush x:Key="AccentBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#3C8CE7" Offset="0"/>
        <GradientStop Color="#1E6BD6" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentHoverBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#5AA2F0" Offset="0"/>
        <GradientStop Color="#2E7BE0" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentPressedBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#2A5FB5" Offset="0"/>
        <GradientStop Color="#1B4A91" Offset="1"/>
    </LinearGradientBrush>

    <SolidColorBrush x:Key="AccentGlowBrush" Color="#3C8CE7"/>
</ResourceDictionary>
