<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Normal -->
    <LinearGradientBrush x:Key="AccentBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFFFFF" Offset="0"/>
        <GradientStop Color="#DDDDDD" Offset="1"/>
    </LinearGradientBrush>

    <!-- Hover -->
    <LinearGradientBrush x:Key="AccentHoverBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F5F5F5" Offset="0"/>
        <GradientStop Color="#CCCCCC" Offset="1"/>
    </LinearGradientBrush>

    <!-- Pressed -->
    <LinearGradientBrush x:Key="AccentPressedBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#BBBBBB" Offset="0"/>
        <GradientStop Color="#999999" Offset="1"/>
    </LinearGradientBrush>

    <!-- Glow -->
    <SolidColorBrush x:Key="AccentGlowBrush" Color="#FFFFFF"/>
</ResourceDictionary>
