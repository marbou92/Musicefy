<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">

    <!-- Normal -->
    <Color x:Key="AccentStartColor">#FFA500</Color> <!-- Orange -->
    <Color x:Key="AccentEndColor">#FF8C00</Color>   <!-- Dark Orange -->

    <!-- Hover -->
    <Color x:Key="AccentHoverStartColor">#FFB84D</Color> <!-- Lighter Orange -->
    <Color x:Key="AccentHoverEndColor">#E67300</Color>   <!-- Rich Orange -->

    <!-- Pressed -->
    <Color x:Key="AccentPressedStartColor">#CC6600</Color> <!-- Deep Orange -->
    <Color x:Key="AccentPressedEndColor">#993D00</Color>   <!-- Brownish Orange -->

    <!-- Glow -->
    <Color x:Key="AccentGlowColor">#FFA500</Color> <!-- Orange glow -->
</ResourceDictionary>
