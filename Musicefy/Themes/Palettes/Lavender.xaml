<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Material Design 3 - Lavender Palette -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#B57EDC"/>
    <SolidColorBrush x:Key="OnPrimaryBrush" Color="#1A1A2E"/>
    <SolidColorBrush x:Key="PrimaryContainerBrush" Color="#C89DF2"/>
    <SolidColorBrush x:Key="OnPrimaryContainerBrush" Color="#2D1B3E"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="#C89DF2"/>
    <SolidColorBrush x:Key="OnSecondaryBrush" Color="#1A1A2E"/>
    <SolidColorBrush x:Key="SecondaryContainerBrush" Color="#9A6FD0"/>
    <SolidColorBrush x:Key="OnSecondaryContainerBrush" Color="#F5E6FF"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="#7E57C2"/>
    <SolidColorBrush x:Key="OnTertiaryBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TertiaryContainerBrush" Color="#D1C4E9"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#FF5252"/>
    <SolidColorBrush x:Key="OnErrorBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ErrorContainerBrush" Color="#93000A"/>
    <SolidColorBrush x:Key="OnErrorContainerBrush" Color="#FFDAD6"/>

    <!-- Legacy aliases -->
    <SolidColorBrush x:Key="AccentBrush" Color="#B57EDC"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#C89DF2"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#9A6FD0"/>
    <SolidColorBrush x:Key="AccentGlowBrush" Color="#B57EDC"/>
</ResourceDictionary>
