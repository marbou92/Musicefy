<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Echo Lavender Palette -->
    <LinearGradientBrush x:Key="AccentBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#B57EDC" Offset="0"/>
        <GradientStop Color="#C89DF2" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentHoverBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#D6B8F7" Offset="0"/>
        <GradientStop Color="#B57EDC" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentPressedBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#9A6FD0" Offset="0"/>
        <GradientStop Color="#7E56B8" Offset="1"/>
    </LinearGradientBrush>

    <SolidColorBrush x:Key="AccentGlowBrush" Color="#B57EDC"/>
</ResourceDictionary>
