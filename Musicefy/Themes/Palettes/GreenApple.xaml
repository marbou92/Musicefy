<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Material Design 3 - Green Apple Palette -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#4CAF50"/>
    <SolidColorBrush x:Key="OnPrimaryBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="PrimaryContainerBrush" Color="#81C784"/>
    <SolidColorBrush x:Key="OnPrimaryContainerBrush" Color="#0B3D0B"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="#66BB6A"/>
    <SolidColorBrush x:Key="OnSecondaryBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SecondaryContainerBrush" Color="#2E7D32"/>
    <SolidColorBrush x:Key="OnSecondaryContainerBrush" Color="#E8F5E9"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="#1B5E20"/>
    <SolidColorBrush x:Key="OnTertiaryBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TertiaryContainerBrush" Color="#A5D6A7"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#FF5252"/>
    <SolidColorBrush x:Key="OnErrorBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ErrorContainerBrush" Color="#93000A"/>
    <SolidColorBrush x:Key="OnErrorContainerBrush" Color="#FFDAD6"/>

    <!-- Legacy aliases -->
    <SolidColorBrush x:Key="AccentBrush" Color="#4CAF50"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#81C784"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#2E7D32"/>
</ResourceDictionary>
