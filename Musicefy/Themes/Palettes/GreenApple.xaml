<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Normal -->
    <LinearGradientBrush x:Key="AccentBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#4CAF50" Offset="0"/>
        <GradientStop Color="#81C784" Offset="1"/>
    </LinearGradientBrush>

    <!-- Hover -->
    <LinearGradientBrush x:Key="AccentHoverBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#66BB6A" Offset="0"/>
        <GradientStop Color="#388E3C" Offset="1"/>
    </LinearGradientBrush>

    <!-- Pressed -->
    <LinearGradientBrush x:Key="AccentPressedBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#2E7D32" Offset="0"/>
        <GradientStop Color="#1B5E20" Offset="1"/>
    </LinearGradientBrush>

    <!-- Glow -->
    <SolidColorBrush x:Key="AccentGlowBrush" Color="#4CAF50"/>
</ResourceDictionary>
