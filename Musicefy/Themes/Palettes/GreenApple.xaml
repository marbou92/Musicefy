<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <LinearGradientBrush x:Key="AccentBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#4CAF50" Offset="0"/>
        <GradientStop Color="#81C784" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#66BB6A"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#2E7D32"/>
</ResourceDictionary>
