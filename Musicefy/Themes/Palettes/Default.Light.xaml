<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Material Design 3 - Default Light Palette -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#1565C0"/>
    <SolidColorBrush x:Key="OnPrimaryBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="PrimaryContainerBrush" Color="#42A5F5"/>
    <SolidColorBrush x:Key="OnPrimaryContainerBrush" Color="#E3F2FD"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="#42A5F5"/>
    <SolidColorBrush x:Key="OnSecondaryBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SecondaryContainerBrush" Color="#BBDEFB"/>
    <SolidColorBrush x:Key="OnSecondaryContainerBrush" Color="#0D47A1"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="#9C27B0"/>
    <SolidColorBrush x:Key="OnTertiaryBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TertiaryContainerBrush" Color="#E1BEE7"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#D32F2F"/>
    <SolidColorBrush x:Key="OnErrorBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ErrorContainerBrush" Color="#F9DEDC"/>
    <SolidColorBrush x:Key="OnErrorContainerBrush" Color="#410002"/>

    <!-- Legacy aliases -->
    <SolidColorBrush x:Key="AccentBrush" Color="#1565C0"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#42A5F5"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#0D47A1"/>
    <SolidColorBrush x:Key="AccentGlowBrush" Color="#1565C0"/>
</ResourceDictionary>
