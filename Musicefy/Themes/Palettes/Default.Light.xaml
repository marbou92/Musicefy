<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Normal -->
    <LinearGradientBrush x:Key="AccentBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#000000" Offset="0"/>
        <GradientStop Color="#333333" Offset="1"/>
    </LinearGradientBrush>

    <!-- Hover -->
    <LinearGradientBrush x:Key="AccentHoverBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#444444" Offset="0"/>
        <GradientStop Color="#666666" Offset="1"/>
    </LinearGradientBrush>

    <!-- Pressed -->
    <LinearGradientBrush x:Key="AccentPressedBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#222222" Offset="0"/>
        <GradientStop Color="#111111" Offset="1"/>
    </LinearGradientBrush>

    <!-- Glow -->
    <SolidColorBrush x:Key="AccentGlowBrush" Color="#000000"/>
</ResourceDictionary>
