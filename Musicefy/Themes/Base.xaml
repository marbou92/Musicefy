<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DropShadowEffect x:Key="EchoShadow" BlurRadius="25" ShadowDepth="0" Opacity="0.4" Color="Black"/>

    <Style TargetType="{x:Type ScrollViewer}">
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
        <Setter Property="CanContentScroll" Value="False"/>
    </Style>

    <Style TargetType="{x:Type ScrollBar}">
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
    </Style>

    <Style x:Key="EchoCustomWindowStyle" TargetType="{x:Type Window}">
        <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        <Setter Property="WindowChrome.WindowChrome">
            <Setter.Value>
                <WindowChrome CaptionHeight="40" 
                              CornerRadius="0" 
                              GlassFrameThickness="0" 
                              ResizeBorderThickness="7"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Window}">
                    <Border Background="{TemplateBinding Background}" 
                            BorderBrush="{DynamicResource BorderBrush}" 
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Background="{DynamicResource SecondaryBackgroundBrush}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="14,0,0,0" IsHitTestVisible="False">
                                    <TextBlock Text="🎵" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{TemplateBinding Title}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,6,0" WindowChrome.IsHitTestVisibleInChrome="True">
                                    <Button Name="BtnShellMinimize" ToolTip="Minimize" Width="36" Height="28" Background="Transparent" BorderThickness="0" Margin="0,0,2,0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="BtnBg" Background="Transparent" CornerRadius="4">
                                                    <Path Data="M4,12H20V14H4V12Z" Fill="{DynamicResource MutedTextBrush}" Width="12" Height="12" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="BtnBg" Property="Background" Value="{DynamicResource BorderBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <Button Name="BtnShellMaximize" ToolTip="Maximize" Width="36" Height="28" Background="Transparent" BorderThickness="0" Margin="0,0,2,0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="BtnBg" Background="Transparent" CornerRadius="4">
                                                    <Path x:Name="MaxIcon" Data="M4,4H20V20H4V4M6,8V18H18V8H6Z" Fill="{DynamicResource MutedTextBrush}" Width="11" Height="11" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="BtnBg" Property="Background" Value="{DynamicResource BorderBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <Button Name="BtnShellClose" ToolTip="Close" Width="36" Height="28" Background="Transparent" BorderThickness="0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="BtnBg" Background="Transparent" CornerRadius="4">
                                                    <Path x:Name="CloseIcon" Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z" Fill="{DynamicResource MutedTextBrush}" Width="12" Height="12" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="BtnBg" Property="Background" Value="#FF4B4B"/>
                                                        <Setter TargetName="CloseIcon" Property="Fill" Value="White"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="1" Background="{TemplateBinding Background}" Padding="0,0,6,0">
                                <ContentPresenter Content="{TemplateBinding Content}" ContentTemplate="{TemplateBinding ContentTemplate}" Margin="{TemplateBinding Padding}"/>
                            </Grid>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SegmentedTabStyle" TargetType="RadioButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Grid>
                        <Border x:Name="TabBg" Background="{TemplateBinding Background}" CornerRadius="20" Margin="1">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock x:Name="CheckMark" Text="✓ " Visibility="Collapsed" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold"/>
                                <ContentPresenter x:Name="ContentArea" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="TabBg" Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                            <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ModernSettingRowStyle" TargetType="CheckBox">
        <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        <Setter Property="Padding" Value="16,14"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Border Background="{TemplateBinding Background}" 
                            BorderBrush="{TemplateBinding BorderBrush}" 
                            BorderThickness="1" 
                            CornerRadius="14" 
                            Padding="{TemplateBinding Padding}">
                        <DockPanel>
                            <Grid DockPanel.Dock="Right" Width="44" Height="24" VerticalAlignment="Center" Margin="10,0,0,0">
                                <Border x:Name="SwitchTrack" Background="#252525" CornerRadius="12" BorderThickness="1.5" BorderBrush="{DynamicResource BorderBrush}"/>
                                <Ellipse x:Name="SwitchKnob" Width="16" Height="16" Fill="#707070" HorizontalAlignment="Left" Margin="4,0,0,0"/>
                                <TextBlock x:Name="CrossIcon" Text="×" Foreground="#101010" FontSize="14" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="8,-2,0,0"/>
                            </Grid>
    
                            <ContentControl x:Name="IconPresenter" DockPanel.Dock="Left" Content="{TemplateBinding Tag}" VerticalAlignment="Center" Margin="0,0,16,0"/>
    
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock TextElement.FontWeight="Bold" TextElement.FontSize="14" TextElement.Foreground="{TemplateBinding Foreground}">
                                    <ContentPresenter x:Name="TitlePresenter" Content="{TemplateBinding Content}" ContentTemplate="{TemplateBinding ContentTemplate}"/>
                                </TextBlock>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="SwitchTrack" Property="Background" Value="{DynamicResource AccentBrush}"/>
                            <Setter TargetName="SwitchTrack" Property="BorderThickness" Value="0"/>
                            <Setter TargetName="SwitchKnob" Property="HorizontalAlignment" Value="Right"/>
                            <Setter TargetName="SwitchKnob" Property="Margin" Value="0,0,4,0"/>
                            <Setter TargetName="SwitchKnob" Property="Fill" Value="White"/>
                            <Setter TargetName="CrossIcon" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="20,10"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="25" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Slider">
        <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid x:Name="SliderRoot">
                        <Border x:Name="TrackBackground" 
                                Background="{TemplateBinding Background}" 
                                Height="4" 
                                CornerRadius="2" 
                                VerticalAlignment="Center"/>
                        <Track x:Name="PART_Track">
                            <Track.Thumb>
                                <Thumb Width="14" Height="14" Focusable="False">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Ellipse Fill="{DynamicResource ForegroundBrush}" Width="14" Height="14"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Orientation" Value="Vertical">
                            <Setter TargetName="TrackBackground" Property="Width" Value="4"/>
                            <Setter TargetName="TrackBackground" Property="Height" Value="Auto"/>
                            <Setter TargetName="TrackBackground" Property="HorizontalAlignment" Value="Center"/>
                            <Setter TargetName="TrackBackground" Property="VerticalAlignment" Value="Stretch"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
