<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Shared Accent Colors -->
    <Color x:Key="AccentStartColor">#B57EDC</Color>
    <Color x:Key="AccentEndColor">#C89DF2</Color>

    <!-- Global AccentBrush for non-button controls -->
    <LinearGradientBrush x:Key="AccentBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource AccentStartColor}" Offset="0.0"/>
        <GradientStop Color="{StaticResource AccentEndColor}" Offset="1.0"/>
    </LinearGradientBrush>

    <!-- Buttons -->
    <Style TargetType="Button">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop x:Name="AccentStart" Color="{StaticResource AccentStartColor}" Offset="0.0"/>
                                <GradientStop x:Name="AccentEnd" Color="{StaticResource AccentEndColor}" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"
                                          RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Hover animation -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="AccentStart"
                                                        Storyboard.TargetProperty="Color"
                                                        To="#D6B8F7" Duration="0:0:0.3"/>
                                        <ColorAnimation Storyboard.TargetName="AccentEnd"
                                                        Storyboard.TargetProperty="Color"
                                                        To="#B57EDC" Duration="0:0:0.3"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                        </Trigger>

                        <!-- Pressed animation -->
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="AccentStart"
                                                        Storyboard.TargetProperty="Color"
                                                        To="#9A6FD0" Duration="0:0:0.2"/>
                                        <ColorAnimation Storyboard.TargetName="AccentEnd"
                                                        Storyboard.TargetProperty="Color"
                                                        To="#7E56B8" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                        </Trigger>

                        <!-- Focus glow -->
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="border" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#B57EDC" BlurRadius="15" ShadowDepth="0"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
