<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Material Design 3 - Dark Pure Mode Surface Colors -->
    <SolidColorBrush x:Key="SurfaceBrush" Color="#000000"/>
    <SolidColorBrush x:Key="SurfaceVariantBrush" Color="#0D0D0D"/>
    <SolidColorBrush x:Key="SurfaceContainerLowBrush" Color="#0D0D0D"/>
    <SolidColorBrush x:Key="SurfaceContainerHighBrush" Color="#141414"/>
    <SolidColorBrush x:Key="OnSurfaceBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="OnSurfaceVariantBrush" Color="#808080"/>
    <SolidColorBrush x:Key="OutlineBrush" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="OutlineVariantBrush" Color="#252525"/>
    <SolidColorBrush x:Key="HoverBrush" Color="#252525"/>

    <!-- Legacy aliases -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#000000"/>
    <SolidColorBrush x:Key="SecondaryBackgroundBrush" Color="#0D0D0D"/>
    <SolidColorBrush x:Key="ForegroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="MutedTextBrush" Color="#808080"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#1A1A1A"/>
</ResourceDictionary>
