<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Material Design 3 - Dark Pure Mode (AMOLED Black Surfaces + Full Brush Set) -->
    <!-- Surface tones are forced to near-black by DynamicScheme.GetArgb().
         This XAML provides the complete set of brush fallbacks for design-time
         and initial-load, matching Dark.xaml but with pure-black surfaces. -->

    <!-- ── Surface / Neutral (Pure Black) ── -->
    <SolidColorBrush x:Key="SurfaceBrush" Color="#000000"/>
    <SolidColorBrush x:Key="OnSurfaceBrush" Color="#E6E0E9"/>
    <SolidColorBrush x:Key="SurfaceVariantBrush" Color="#49454F"/>
    <SolidColorBrush x:Key="OnSurfaceVariantBrush" Color="#CAC4D0"/>
    <SolidColorBrush x:Key="SurfaceContainerLowestBrush" Color="#000000"/>
    <SolidColorBrush x:Key="SurfaceContainerLowBrush" Color="#050505"/>
    <SolidColorBrush x:Key="SurfaceContainerBrush" Color="#0A0A0A"/>
    <SolidColorBrush x:Key="SurfaceContainerHighBrush" Color="#0F0F0F"/>
    <SolidColorBrush x:Key="SurfaceContainerHighestBrush" Color="#141414"/>
    <SolidColorBrush x:Key="OutlineBrush" Color="#938F99"/>
    <SolidColorBrush x:Key="OutlineVariantBrush" Color="#49454F"/>
    <SolidColorBrush x:Key="HoverBrush" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="InverseSurfaceBrush" Color="#E6E0E9"/>
    <SolidColorBrush x:Key="InverseOnSurfaceBrush" Color="#313033"/>
    <SolidColorBrush x:Key="InversePrimaryBrush" Color="#6750A4"/>

    <!-- ── Accent brushes (overridden at runtime by ThemeManager) ── -->
    <SolidColorBrush x:Key="AccentBrush" Color="#D0BCFF"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#4F378B"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#EADDFF"/>
    <SolidColorBrush x:Key="AccentGlowBrush" Color="#D0BCFF"/>

    <!-- ── Primary (overridden at runtime) ── -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#D0BCFF"/>
    <SolidColorBrush x:Key="OnPrimaryBrush" Color="#381E72"/>
    <SolidColorBrush x:Key="PrimaryContainerBrush" Color="#4F378B"/>
    <SolidColorBrush x:Key="OnPrimaryContainerBrush" Color="#EADDFF"/>

    <!-- ── Secondary (overridden at runtime) ── -->
    <SolidColorBrush x:Key="SecondaryBrush" Color="#CCC2DC"/>
    <SolidColorBrush x:Key="OnSecondaryBrush" Color="#332D41"/>
    <SolidColorBrush x:Key="SecondaryContainerBrush" Color="#4A4458"/>
    <SolidColorBrush x:Key="OnSecondaryContainerBrush" Color="#E8DEF8"/>

    <!-- ── Tertiary (overridden at runtime) ── -->
    <SolidColorBrush x:Key="TertiaryBrush" Color="#EFB8C8"/>
    <SolidColorBrush x:Key="OnTertiaryBrush" Color="#492532"/>
    <SolidColorBrush x:Key="TertiaryContainerBrush" Color="#633B48"/>
    <SolidColorBrush x:Key="OnTertiaryContainerBrush" Color="#FFD8E4"/>

    <!-- ── Error (overridden at runtime) ── -->
    <SolidColorBrush x:Key="ErrorBrush" Color="#F2B8B5"/>
    <SolidColorBrush x:Key="OnErrorBrush" Color="#601410"/>
    <SolidColorBrush x:Key="ErrorContainerBrush" Color="#8C1D18"/>
    <SolidColorBrush x:Key="OnErrorContainerBrush" Color="#F9DEDC"/>

    <!-- ── Legacy aliases ── -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#000000"/>
    <SolidColorBrush x:Key="SecondaryBackgroundBrush" Color="#050505"/>
    <SolidColorBrush x:Key="ForegroundBrush" Color="#E6E0E9"/>
    <SolidColorBrush x:Key="TextBrush" Color="#E6E0E9"/>
    <SolidColorBrush x:Key="MutedTextBrush" Color="#CAC4D0"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#938F99"/>
    <SolidColorBrush x:Key="DynamicPrimaryBrush" Color="#D0BCFF"/>

    <!-- ── Skeleton / shimmer colors ── -->
    <Color x:Key="SkeletonBaseColor">#0D0D0D</Color>
    <Color x:Key="SkeletonHighColor">#1A1A1A</Color>
</ResourceDictionary>
