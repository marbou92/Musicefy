<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Echo Light Mode -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SecondaryBackgroundBrush" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="ForegroundBrush" Color="#000000"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#DDDDDD"/>

    <!-- Accent Colors -->
    <Color x:Key="AccentStartColor">#FF3C8CE7</Color>
    <Color x:Key="AccentEndColor">#FF1E6BD6</Color>
    <SolidColorBrush x:Key="AccentGlowColor" Color="#3C8CE7"/>
</ResourceDictionary>
