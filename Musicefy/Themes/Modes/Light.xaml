<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Material Design 3 - Light Mode Surface Colors -->
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SurfaceVariantBrush" Color="#F3F3F3"/>
    <SolidColorBrush x:Key="SurfaceContainerLowBrush" Color="#F3F3F3"/>
    <SolidColorBrush x:Key="SurfaceContainerHighBrush" Color="#EEEEEE"/>
    <SolidColorBrush x:Key="OnSurfaceBrush" Color="#111111"/>
    <SolidColorBrush x:Key="OnSurfaceVariantBrush" Color="#666666"/>
    <SolidColorBrush x:Key="OutlineBrush" Color="#E5E5E5"/>
    <SolidColorBrush x:Key="OutlineVariantBrush" Color="#D0D0D0"/>
    <SolidColorBrush x:Key="HoverBrush" Color="#D0D0D0"/>

    <!-- Legacy aliases -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SecondaryBackgroundBrush" Color="#F3F3F3"/>
    <SolidColorBrush x:Key="ForegroundBrush" Color="#111111"/>
    <SolidColorBrush x:Key="TextBrush" Color="#111111"/>
    <SolidColorBrush x:Key="MutedTextBrush" Color="#666666"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#E5E5E5"/>
</ResourceDictionary>
