<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Echo Dark Mode -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="SecondaryBackgroundBrush" Color="#2A2A2A"/>
    <SolidColorBrush x:Key="ForegroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#444444"/>

    <!-- Accent Colors -->
    <Color x:Key="AccentStartColor">#FF3C8CE7</Color>
    <Color x:Key="AccentEndColor">#FF1E6BD6</Color>
    <SolidColorBrush x:Key="AccentGlowColor" Color="#3C8CE7"/>
</ResourceDictionary>
