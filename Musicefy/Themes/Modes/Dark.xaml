<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Material Design 3 - Dark Mode Surface Colors -->
    <SolidColorBrush x:Key="SurfaceBrush" Color="#181818"/>
    <SolidColorBrush x:Key="SurfaceVariantBrush" Color="#242424"/>
    <SolidColorBrush x:Key="SurfaceContainerLowBrush" Color="#242424"/>
    <SolidColorBrush x:Key="SurfaceContainerHighBrush" Color="#2A2A2A"/>
    <SolidColorBrush x:Key="OnSurfaceBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="OnSurfaceVariantBrush" Color="#9E9E9E"/>
    <SolidColorBrush x:Key="OutlineBrush" Color="#2F2F2F"/>
    <SolidColorBrush x:Key="OutlineVariantBrush" Color="#3A3A3A"/>
    <SolidColorBrush x:Key="HoverBrush" Color="#3A3A3A"/>

    <!-- Legacy aliases -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#181818"/>
    <SolidColorBrush x:Key="SecondaryBackgroundBrush" Color="#242424"/>
    <SolidColorBrush x:Key="ForegroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="MutedTextBrush" Color="#9E9E9E"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#2F2F2F"/>
</ResourceDictionary>
