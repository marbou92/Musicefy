<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Material Design 3 - Dark Mode Surface Colors -->
    <SolidColorBrush x:Key="SurfaceBrush" Color="#141218"/>
    <SolidColorBrush x:Key="OnSurfaceBrush" Color="#E6E0E9"/>
    <SolidColorBrush x:Key="SurfaceVariantBrush" Color="#49454F"/>
    <SolidColorBrush x:Key="OnSurfaceVariantBrush" Color="#CAC4D0"/>
    <SolidColorBrush x:Key="SurfaceContainerLowestBrush" Color="#0F0D13"/>
    <SolidColorBrush x:Key="SurfaceContainerLowBrush" Color="#1D1B20"/>
    <SolidColorBrush x:Key="SurfaceContainerBrush" Color="#211F26"/>
    <SolidColorBrush x:Key="SurfaceContainerHighBrush" Color="#2B2930"/>
    <SolidColorBrush x:Key="SurfaceContainerHighestBrush" Color="#36343B"/>
    <SolidColorBrush x:Key="OutlineBrush" Color="#938F99"/>
    <SolidColorBrush x:Key="OutlineVariantBrush" Color="#49454F"/>
    <SolidColorBrush x:Key="HoverBrush" Color="#49454F"/>
    <SolidColorBrush x:Key="InverseSurfaceBrush" Color="#E6E0E9"/>
    <SolidColorBrush x:Key="InverseOnSurfaceBrush" Color="#313033"/>
    <SolidColorBrush x:Key="InversePrimaryBrush" Color="#6750A4"/>

    <!-- Accent brushes (overridden at runtime by ThemeManager) -->
    <SolidColorBrush x:Key="AccentBrush" Color="#FFB4AB"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#930006"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#FFDAD4"/>
    <SolidColorBrush x:Key="AccentGlowBrush" Color="#FFB4AB"/>

    <!-- Primary (overridden at runtime — default matches coral-red) -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#FFB4AB"/>
    <SolidColorBrush x:Key="OnPrimaryBrush" Color="#680003"/>
    <SolidColorBrush x:Key="PrimaryContainerBrush" Color="#930006"/>
    <SolidColorBrush x:Key="OnPrimaryContainerBrush" Color="#FFDAD4"/>

    <!-- Secondary (overridden at runtime) -->
    <SolidColorBrush x:Key="SecondaryBrush" Color="#CCC2DC"/>
    <SolidColorBrush x:Key="OnSecondaryBrush" Color="#332D41"/>
    <SolidColorBrush x:Key="SecondaryContainerBrush" Color="#4A4458"/>
    <SolidColorBrush x:Key="OnSecondaryContainerBrush" Color="#E8DEF8"/>

    <!-- Tertiary (overridden at runtime) -->
    <SolidColorBrush x:Key="TertiaryBrush" Color="#EFB8C8"/>
    <SolidColorBrush x:Key="OnTertiaryBrush" Color="#492532"/>
    <SolidColorBrush x:Key="TertiaryContainerBrush" Color="#633B48"/>
    <SolidColorBrush x:Key="OnTertiaryContainerBrush" Color="#FFD8E4"/>

    <!-- Error (overridden at runtime) -->
    <SolidColorBrush x:Key="ErrorBrush" Color="#F2B8B5"/>
    <SolidColorBrush x:Key="OnErrorBrush" Color="#601410"/>
    <SolidColorBrush x:Key="ErrorContainerBrush" Color="#8C1D18"/>
    <SolidColorBrush x:Key="OnErrorContainerBrush" Color="#F9DEDC"/>

    <!-- Legacy aliases -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#141218"/>
    <SolidColorBrush x:Key="SecondaryBackgroundBrush" Color="#1D1B20"/>
    <SolidColorBrush x:Key="ForegroundBrush" Color="#E6E0E9"/>
    <SolidColorBrush x:Key="TextBrush" Color="#E6E0E9"/>
    <SolidColorBrush x:Key="MutedTextBrush" Color="#CAC4D0"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#938F99"/>
    <SolidColorBrush x:Key="DynamicPrimaryBrush" Color="#FFB4AB"/>

    <!-- Skeleton / shimmer colors -->
    <Color x:Key="SkeletonBaseColor">#1D1B20</Color>
    <Color x:Key="SkeletonHighColor">#2B2930</Color>

    <!-- Gradient brushes (overridden at runtime by ThemeManager) -->
    <LinearGradientBrush x:Key="HomeGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFB4AB" Offset="0.0"/>
        <GradientStop Color="#FFB4AB" Offset="0.15"/>
        <GradientStop Color="#141218" Offset="1.0"/>
    </LinearGradientBrush>
    <Color x:Key="HomeSurfaceColor">#141218</Color>
    <Color x:Key="HomePrimaryColor">#FFB4AB</Color>
    <LinearGradientBrush x:Key="PlayerGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFB4AB" Offset="0.0"/>
        <GradientStop Color="#930006" Offset="0.6"/>
        <GradientStop Color="#141218" Offset="1.0"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="PlayerBackgroundSolid" Color="Transparent"/>
    <Color x:Key="PlayerSurfaceColor">#141218</Color>
    <Color x:Key="PlayerPrimaryColor">#FFB4AB</Color>
</ResourceDictionary>
