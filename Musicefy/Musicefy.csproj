<Project Sdk="Microsoft.NET.Sdk.WindowsDesktop">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net472</TargetFramework>
    <UseWPF>true</UseWPF>

    <!-- Prevent duplicate AssemblyInfo -->
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>

    <!-- App metadata -->
    <RootNamespace>Musicefy</RootNamespace>
    <AssemblyName>Musicefy</AssemblyName>
    <ApplicationIcon>Assets\musicefy.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <!-- Reference your Core project -->
    <ProjectReference Include="..\Musicefy.Core\Musicefy.Core.csproj" />
  </ItemGroup>

</Project>
